# Dependencies
node_modules/

# Build output
designer/dist/
designer-mcp/dist/

# Designer generated outputs
output/

# Playwright MCP artifacts
.playwright-mcp/
screenshots/
*.png
# 仕様書に紐づく UI スクリーンショットは追跡する
!docs/ui-screenshots/*.png

# Claude Code local settings (skills/commands はチーム共有のため追跡対象)
.claude/settings.local.json

# 一時出力 (例: /review-pr /review-issue が書き出すレビュー結果は tmp/review-cache/ 配下)
tmp/
.tmp/

# Codex CLI のプロジェクト固有設定 (ユーザー個人の sandbox 設定等、共有しない)
.codex/

# Playwright / vitest 等のテスト実行結果
test-results/

# Editor / OS
.DS_Store
Thumbs.db
*.suo
.vscode/settings.json

# Logs
*.log
npm-debug.log*

# Local env
.env
.env.local

# Runtime project data (generated by designer)
data/

# Playwright test artifacts
designer/test-results/
designer/playwright-report/
designer/blob-report/
