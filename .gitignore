# Dependencies
node_modules/

# Build output
designer/dist/
designer-mcp/dist/

# Designer generated outputs
output/

# Playwright MCP artifacts
.playwright-mcp/
screenshots/
*.png
# 仕様書に紐づく UI スクリーンショットは追跡する
!docs/ui-screenshots/*.png

# Claude Code local settings (skills/commands はチーム共有のため追跡対象)
.claude/settings.local.json
# Claude Code agent worktrees — 本来は C:/tmp/ 等プロジェクト外に置くべきだが
# 誤配置時の VS Code git panel 汚染を防止 (memory feedback_worktree_placement_outside_project.md)
.claude/worktrees/
# Claude Code runtime artifacts (ScheduleWakeup の lock ファイル等)
.claude/scheduled_tasks.lock

# 一時出力 (例: /review-pr /review-issue が書き出すレビュー結果は tmp/review-cache/ 配下)
tmp/
.tmp/

# Codex CLI のプロジェクト固有設定 (ユーザー個人の sandbox 設定等、共有しない)
.codex/

# Playwright / vitest 等のテスト実行結果
test-results/

# Editor / OS
.DS_Store
Thumbs.db
*.suo
.vscode/settings.json

# Logs
*.log
npm-debug.log*
logs/

# Local env
.env
.env.local

# Runtime project data (generated by designer)
data/
!data/
!data/extensions/
!data/extensions/**

# User / AI workspace area (gitignored, default for new workspace)
/workspaces/
!/workspaces/README.md
!/workspaces/.gitkeep
# #806 Puck dogfood サンプル (workspaces/ 管理、git 追跡対象)
!/workspaces/dogfood-puck-tailwind-2026-05-05/
!/workspaces/dogfood-puck-tailwind-2026-05-05/**
!/workspaces/dogfood-puck-bootstrap-2026-05-05/
!/workspaces/dogfood-puck-bootstrap-2026-05-05/**

# 編集中 draft ファイル (個人の作業中間状態、git 管理対象外)
data/.drafts/

# Playwright test artifacts
designer/test-results/
designer/playwright-report/
designer/blob-report/
