---
import { navigation, type NavGroup } from '../data/navigation';

interface Props {
  area: 'spec' | 'user-guide' | 'conventions' | 'setup';
  current?: string;
}

const { area, current } = Astro.props;
const groups: NavGroup[] = navigation[area] ?? [];
---

<nav class="sticky top-20 space-y-3 text-sm">
  {groups.map((group) => (
    <div>
      <div class="font-bold text-xs uppercase tracking-wider text-slate-500 dark:text-slate-400 mt-3 mb-1.5">
        {group.title}
      </div>
      <ul class="space-y-0.5">
        {group.items.map((item) => (
          <li>
            <a
              href={`/${area}/${item.id}/`}
              class:list={['sidebar-link', { active: current === item.id }]}
            >
              {item.title}
            </a>
          </li>
        ))}
      </ul>
    </div>
  ))}
</nav>
