---
import type { NavGroup } from '../data/navigation';

interface Props {
  area: string;
  groups: NavGroup[];
}

const { area, groups } = Astro.props;
---

<div class="not-prose grid grid-cols-1 md:grid-cols-2 gap-5 my-6">
  {groups.map((group) => (
    <section class="border border-slate-200 dark:border-slate-700 rounded-lg p-4 bg-slate-50/50 dark:bg-slate-900/50">
      <h2 class="text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400 mt-0 mb-3">
        {group.title}
      </h2>
      <ul class="space-y-0.5 list-none p-0 m-0">
        {group.items.map((item) => (
          <li class="m-0">
            <a
              href={`/${area}/${item.id}/`}
              class="block text-sm text-blue-700 dark:text-blue-300 hover:bg-blue-50 dark:hover:bg-blue-950 rounded px-2 py-0.5 no-underline"
            >
              {item.title}
            </a>
          </li>
        ))}
      </ul>
    </section>
  ))}
</div>
