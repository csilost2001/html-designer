{
  "$schema": "../../../schemas/v3/screen.v3.schema.json",
  "id": "c2254dd6-ab5d-4428-931f-d27c71e89951",
  "name": "配送指示",
  "description": "注文の配送指示を登録する (S-4)。注文詳細 (読み取り専用) にキャリア・配送希望日・時間帯を入力し指示を確定する。",
  "kind": "form",
  "path": "/orders/:id/dispatch",
  "auth": "required",
  "groupId": "a7285b88-9e12-4d2c-94c6-ef6bd788685d",
  "maturity": "committed",
  "createdAt": "2026-05-02T00:00:00.000Z",
  "updatedAt": "2026-05-02T00:00:00.000Z",
  "items": [
    {
      "id": "orderId",
      "label": "対象注文 ID",
      "type": "integer",
      "direction": "output",
      "description": "S-4 配送指示対象の注文 ID (URL :id パラメータから取得、表示専用)。",
      "valueFrom": {
        "kind": "expression",
        "expression": "@route.id"
      }
    },
    {
      "id": "carrierId",
      "label": "配送会社",
      "type": "string",
      "direction": "input",
      "required": true,
      "options": [
        { "value": "yamato", "label": "ヤマト運輸" },
        { "value": "sagawa", "label": "佐川急便" },
        { "value": "japanpost", "label": "日本郵便" }
      ],
      "errorMessages": {
        "required": "配送会社を選択してください。"
      },
      "description": "S-4 配送指示フォームの配送会社選択。"
    },
    {
      "id": "preferredDate",
      "label": "希望配送日",
      "type": "date",
      "direction": "input",
      "required": false,
      "description": "S-4 配送指示の希望配送日 (任意)。"
    },
    {
      "id": "timeSlot",
      "label": "希望時間帯",
      "type": "string",
      "direction": "input",
      "required": false,
      "options": [
        { "value": "morning", "label": "午前中" },
        { "value": "afternoon", "label": "14:00〜18:00" },
        { "value": "evening", "label": "18:00〜21:00" },
        { "value": "any", "label": "指定なし" }
      ],
      "description": "S-4 配送指示の希望時間帯選択 (任意)。"
    },
    {
      "id": "trackingNumber",
      "label": "追跡番号",
      "type": "string",
      "direction": "output",
      "description": "S-4 配送指示登録後に発行された追跡番号 (表示専用)。",
      "valueFrom": {
        "kind": "flowVariable",
        "processFlowId": "d63c703c-26ed-4704-8b76-329c6bfae9c9",
        "variableName": "trackingNumber"
      }
    },
    {
      "id": "dispatchOrderButton",
      "label": "配送指示登録",
      "type": { "kind": "extension", "extensionRef": "retail:button" },
      "direction": "output",
      "readonly": true,
      "events": [
        {
          "id": "submit",
          "label": "配送指示登録",
          "handlerFlowId": "d63c703c-26ed-4704-8b76-329c6bfae9c9",
          "argumentMapping": {
            "orderId": "@screen.orderId",
            "carrierId": "@screen.carrierId",
            "preferredDate": "@screen.preferredDate",
            "timeSlot": "@screen.timeSlot"
          }
        }
      ],
      "description": "S-4 配送指示登録ボタン。クリック時に配送指示フロー (d63c703c) を起動する。"
    }
  ],
  "design": {
    "designFileRef": "c2254dd6-ab5d-4428-931f-d27c71e89951.design.json"
  }
}
