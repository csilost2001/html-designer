{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/csilost2001/harmony/main/schemas/v3/harmony.v3.schema.json",
  "title": "Harmony Workspace Marker (v3)",
  "description": "ワークスペースルートを識別する marker ファイル (harmony.json) の定義。ワークスペースフォルダの root に単独で配置する。設計データは dataDir で指定したサブディレクトリ配下に格納される。",
  "type": "object",
  "required": ["schemaVersion", "meta", "dataDir"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },

    "schemaVersion": {
      "type": "string",
      "enum": ["v3"],
      "description": "本ワークスペースが使う schema バージョン。loader は本値で schemas/v3/ を選択する。"
    },

    "dataDir": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!\\.{1,2}(/|$))(?![A-Za-z]:)(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*/$).+$",
      "description": "設計データを格納するサブディレクトリのパス (ワークスペースルートからの相対パス)。例: 'harmony' / 'docs/harmony'。推奨慣習は 'harmony'。絶対パス・path traversal (..セグメント)・空文字・'.' 単独・末尾スラッシュは禁止。"
    },

    "meta": {
      "description": "ワークスペース identity と運用設定。",
      "allOf": [
        { "$ref": "common.v3.schema.json#/$defs/EntityMeta" }
      ],
      "type": "object",
      "properties": {
        "mode": { "$ref": "common.v3.schema.json#/$defs/Mode", "description": "プロジェクト全体の上流/下流モード。" }
      },
      "unevaluatedProperties": false
    },

    "extensionsApplied": {
      "type": "array",
      "items": { "$ref": "common.v3.schema.json#/$defs/ExtensionApplied" },
      "description": "本プロジェクトが適用する拡張 namespace 一覧 (version 制約付き object)。例: [{ namespace: 'retail', version: '>=2.0.0' }]。loader は <dataDir>/extensions/<ns>.v3.json (または <dataDir>/extensions/<ns>/*.v3.json 分割) を読み、version 制約と突合の上で core schema と合成する。"
    },

    "entities": {
      "description": "プロジェクトが保持する各 entity への参照一覧。各 entity の本体は別ファイル (<dataDir>/screens/<id>.json 等) に格納される。本セクションは entity の存在と表示用メタ (一覧 UI で使う) を集約する。",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "screens": { "type": "array", "items": { "$ref": "#/$defs/ScreenEntry" } },
        "tables":  { "type": "array", "items": { "$ref": "#/$defs/TableEntry" } },
        "processFlows": { "type": "array", "items": { "$ref": "#/$defs/ProcessFlowEntry" } },
        "views": { "type": "array", "items": { "$ref": "#/$defs/ViewEntry" } },
        "viewDefinitions": { "type": "array", "items": { "$ref": "#/$defs/ViewDefinitionEntry" } },
        "sequences": { "type": "array", "items": { "$ref": "#/$defs/SequenceEntry" } },
        "screenGroups": { "type": "array", "items": { "$ref": "#/$defs/ScreenGroupEntry" } },
        "screenTransitions": { "type": "array", "items": { "$ref": "#/$defs/ScreenTransitionEntry" } }
      }
    },

    "authoring": {
      "$ref": "common.v3.schema.json#/$defs/Authoring",
      "description": "プロジェクト全体の authoring 情報 (markers / decisions / glossary)。entity 横断で共有される ADR や用語集はここに集約。"
    },

    "techStack": {
      "type": "object",
      "additionalProperties": false,
      "description": "プロジェクトの技術スタック定義。AI コード生成時のターゲット環境とデザイナー動作設定を統合する。",
      "properties": {
        "designer": {
          "type": "object",
          "additionalProperties": false,
          "description": "デザイナー動作設定 (AI コード生成時のフロントエンドテンプレート選択に使用)。",
          "properties": {
            "editorKind": {
              "type": "string",
              "enum": ["grapesjs", "puck"],
              "default": "grapesjs",
              "description": "AI コード生成時のターゲット指定。プロジェクト全画面の default エディタ種別。画面側 (screen.design.editorKind) で override 可能。'grapesjs' = HTML 直接編集。'puck' = React コンポーネントツリー編集 (React 専用)。省略時は 'grapesjs' 相当。"
            },
            "cssFramework": {
              "type": "string",
              "enum": ["bootstrap", "tailwind"],
              "default": "bootstrap",
              "description": "AI コード生成時のターゲット指定。プロジェクト全画面の default CSS フレームワーク。画面側 (screen.design.cssFramework) で override 可能。省略時は 'bootstrap' 相当。"
            }
          }
        },
        "backend": {
          "type": "object",
          "additionalProperties": false,
          "description": "バックエンド技術スタック (AI コード生成時のターゲット指定)。",
          "properties": {
            "language": {
              "type": "string",
              "enum": ["java", "typescript", "python", "go", "kotlin"],
              "default": "java",
              "description": "AI コード生成時のターゲット指定。バックエンド実装言語。"
            },
            "framework": {
              "type": "string",
              "enum": ["spring-boot", "nestjs", "express", "fastapi", "gin"],
              "default": "spring-boot",
              "description": "AI コード生成時のターゲット指定。バックエンドフレームワーク。言語と組合せ制約あり (techStackConstraints.ts 参照)。"
            }
          }
        },
        "database": {
          "type": "object",
          "additionalProperties": false,
          "description": "データベース技術スタック (AI コード生成時のターゲット指定)。",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["postgresql", "mysql", "sqlite", "oracle", "sqlserver"],
              "default": "postgresql",
              "description": "AI コード生成時のターゲット指定。データベース種別。"
            },
            "version": {
              "type": "string",
              "description": "AI コード生成時のターゲット指定。データベースバージョン文字列 (例: '16', '8.0')。省略可。"
            }
          }
        },
        "frontend": {
          "type": "object",
          "additionalProperties": false,
          "description": "フロントエンド技術スタック (AI コード生成時のターゲット指定)。",
          "properties": {
            "library": {
              "type": "string",
              "enum": ["react", "vue", "thymeleaf", "blade", "none"],
              "default": "thymeleaf",
              "description": "AI コード生成時のターゲット指定。フロントエンドライブラリ / テンプレートエンジン。"
            },
            "framework": {
              "type": "string",
              "enum": ["next", "nuxt", "vite", "none"],
              "description": "AI コード生成時のターゲット指定。フロントエンドフレームワーク。library との組合せ制約あり (techStackConstraints.ts 参照)。省略可。"
            }
          }
        },
        "auth": {
          "type": "object",
          "additionalProperties": false,
          "description": "認証方式 (AI コード生成時のターゲット指定)。",
          "properties": {
            "method": {
              "type": "string",
              "enum": ["jwt", "session", "oauth2", "saml", "none"],
              "default": "session",
              "description": "AI コード生成時のターゲット指定。認証方式。"
            }
          }
        },
        "deployment": {
          "type": "object",
          "additionalProperties": false,
          "description": "デプロイターゲット (AI コード生成時のターゲット指定)。",
          "properties": {
            "target": {
              "type": "string",
              "enum": ["docker", "vm", "lambda", "cloud-run", "kubernetes"],
              "default": "docker",
              "description": "AI コード生成時のターゲット指定。デプロイターゲット環境。"
            }
          }
        }
      }
    }
  },
  "$defs": {

    "EntryBase": {
      "description": "entities.* 配列要素の共通プロパティ。一覧 UI が表示する最小メタ。",
      "type": "object",
      "required": ["id", "no", "name", "updatedAt"],
      "properties": {
        "id": { "$ref": "common.v3.schema.json#/$defs/Uuid" },
        "no": { "type": "integer", "minimum": 1, "description": "物理順 (1..N)。一覧の並び替え永続化に使用。" },
        "name": { "$ref": "common.v3.schema.json#/$defs/DisplayName" },
        "updatedAt": { "$ref": "common.v3.schema.json#/$defs/Timestamp" },
        "maturity": { "$ref": "common.v3.schema.json#/$defs/Maturity" }
      }
    },

    "ScreenEntry": {
      "allOf": [{ "$ref": "#/$defs/EntryBase" }],
      "type": "object",
      "properties": {
        "kind": { "type": "string", "description": "ScreenKind 文字列 (login/dashboard/list/detail/form 等、または 'retail:storefront' 等の拡張参照)。" },
        "path": { "type": "string", "description": "URL ルーティングパス。" },
        "groupId": { "$ref": "common.v3.schema.json#/$defs/Uuid" },
        "hasDesign": { "type": "boolean" }
      },
      "unevaluatedProperties": false
    },

    "TableEntry": {
      "allOf": [{ "$ref": "#/$defs/EntryBase" }],
      "type": "object",
      "properties": {
        "physicalName": { "$ref": "common.v3.schema.json#/$defs/PhysicalName" },
        "category": { "type": "string", "description": "テーブルカテゴリ (例: 'マスタ', 'トランザクション', '中間テーブル', 'ログ' 等)。" },
        "columnCount": { "type": "integer", "minimum": 0 }
      },
      "unevaluatedProperties": false
    },

    "ProcessFlowEntry": {
      "allOf": [{ "$ref": "#/$defs/EntryBase" }],
      "type": "object",
      "properties": {
        "kind": { "type": "string", "description": "ProcessFlowKind (screen/batch/scheduled/system/common/other、または 'retail:posTransaction' 等の拡張参照)。" },
        "screenId": { "$ref": "common.v3.schema.json#/$defs/Uuid", "description": "screen kind の場合の関連画面 ID。" },
        "actionCount": { "type": "integer", "minimum": 0 },
        "notesCount": { "type": "integer", "minimum": 0 }
      },
      "unevaluatedProperties": false
    },

    "ViewEntry": {
      "allOf": [{ "$ref": "#/$defs/EntryBase" }],
      "type": "object",
      "properties": {
        "physicalName": { "$ref": "common.v3.schema.json#/$defs/PhysicalName" }
      },
      "unevaluatedProperties": false
    },

    "ViewDefinitionEntry": {
      "description": "ViewDefinition (画面 一覧 UI viewer) entry。schemas/v3/view-definition.v3.schema.json と対応。",
      "allOf": [{ "$ref": "#/$defs/EntryBase" }],
      "type": "object",
      "properties": {
        "kind": { "type": "string", "description": "ViewDefinitionKind (list / detail / kanban / calendar、または 'retail:storefront' 等の拡張参照)。" },
        "sourceTableId": { "$ref": "common.v3.schema.json#/$defs/Uuid", "description": "ベースとなる source table の Uuid (一覧 UI 表示用)。" },
        "columnCount": { "type": "integer", "minimum": 0 }
      },
      "unevaluatedProperties": false
    },

    "SequenceEntry": {
      "allOf": [{ "$ref": "#/$defs/EntryBase" }],
      "type": "object",
      "properties": {
        "physicalName": { "$ref": "common.v3.schema.json#/$defs/PhysicalName" },
        "conventionRef": { "type": "string", "description": "@conv.numbering.<key> 形式の参照。" }
      },
      "unevaluatedProperties": false
    },

    "ScreenGroupEntry": {
      "type": "object",
      "required": ["id", "name"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "common.v3.schema.json#/$defs/Uuid" },
        "name": { "$ref": "common.v3.schema.json#/$defs/DisplayName" },
        "color": { "type": "string", "description": "UI 表示色 (#RRGGBB)。" }
      }
    },

    "ScreenTransitionEntry": {
      "description": "画面間の遷移定義。source / target は ScreenEntry.id を指す。UI 座標は screen-flow-positions に分離。",
      "type": "object",
      "required": ["id", "sourceScreenId", "targetScreenId", "trigger"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "common.v3.schema.json#/$defs/LocalId" },
        "sourceScreenId": { "$ref": "common.v3.schema.json#/$defs/Uuid" },
        "targetScreenId": { "$ref": "common.v3.schema.json#/$defs/Uuid" },
        "label": { "$ref": "common.v3.schema.json#/$defs/DisplayName" },
        "trigger": {
          "type": "string",
          "enum": ["click", "submit", "select", "cancel", "auto", "back", "other"],
          "description": "遷移トリガー種別。"
        },
        "kind": {
          "type": "string",
          "enum": ["navigation", "flow-driven"],
          "default": "navigation",
          "description": "遷移種別。'navigation' = 純 UI 遷移 (戻るボタン / リンク / シンプルナビ)、ScreenTransitionStep 不要。'flow-driven' = 処理を伴う遷移、対応する ScreenTransitionStep が必要 (#744)。省略時は 'navigation' とみなす。"
        }
      }
    }
  }
}
