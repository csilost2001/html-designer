{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/csilost2001/html-designer/main/schemas/extensions-db-operations.schema.json",
  "title": "ProcessFlow DbOperation Extensions",
  "type": "object",
  "required": ["namespace", "dbOperations"],
  "additionalProperties": false,
  "properties": {
    "namespace": {
      "type": "string",
      "pattern": "^[a-z0-9_-]*$"
    },
    "dbOperations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["value", "label"],
        "additionalProperties": false,
        "properties": {
          "value": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
