{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/csilost2001/html-designer/main/schemas/v2/view.v2.schema.json",
  "title": "View — ビュー定義 v2",
  "description": "DB ビュー定義の一覧ファイル (将来: data/views/*.json)。SELECT 文・出力列・依存テーブルを宣言的に管理する。",
  "$ref": "#/$defs/ViewsFile",
  "$defs": {
    "ViewOutputColumn": {
      "description": "ビューが出力する 1 列の定義。SELECT 文の出力列に対応する。",
      "type": "object",
      "required": ["name", "kind"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "$ref": "common.v2.schema.json#/$defs/DbColumnName",
          "description": "出力列の名前 (snake_case)。SQL SELECT 文の列エイリアスと一致させる。"
        },
        "kind": {
          "type": "string",
          "description": "出力列の DB データ型 (例: VARCHAR, INTEGER, TIMESTAMP)。DB 慣習により UPPER 文字列で記述する。"
        },
        "description": {
          "$ref": "common.v2.schema.json#/$defs/Description",
          "description": "出力列の業務説明。"
        }
      }
    },
    "ViewDefinition": {
      "description": "ビュー 1 件の完全定義。SELECT 文・出力列・依存テーブル・メタデータを保持する。",
      "type": "object",
      "required": ["id", "selectStatement", "outputColumns", "createdAt", "updatedAt"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "common.v2.schema.json#/$defs/Uuid",
          "description": "ビューの一意識別子 (UUID v4)。"
        },
        "selectStatement": {
          "type": "string",
          "minLength": 1,
          "description": "ビューを定義する SELECT 文。完全な SQL 文字列で記述する。"
        },
        "outputColumns": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/ViewOutputColumn" },
          "description": "ビューの出力列定義。SELECT 文の列と対応させる。"
        },
        "dependencies": {
          "type": "array",
          "items": {
            "$ref": "common.v2.schema.json#/$defs/DbTableName"
          },
          "description": "このビューが参照するテーブル・ビューの物理名リスト。依存関係管理・DDL 生成順序制御に使用する。"
        },
        "description": {
          "$ref": "common.v2.schema.json#/$defs/Description",
          "description": "ビューの業務説明。目的・用途・参照シーンを記述する。"
        },
        "createdAt": {
          "$ref": "common.v2.schema.json#/$defs/Timestamp",
          "description": "作成日時 (ISO 8601 UTC)。"
        },
        "updatedAt": {
          "$ref": "common.v2.schema.json#/$defs/Timestamp",
          "description": "最終更新日時 (ISO 8601 UTC)。"
        }
      }
    },
    "ViewMeta": {
      "description": "ビューのメタ情報 (一覧表示用)。完全データは ViewsFile.views を参照。",
      "type": "object",
      "required": ["id", "no", "updatedAt"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "common.v2.schema.json#/$defs/Uuid",
          "description": "ビューの一意識別子 (UUID v4)。ViewDefinition.id と一致する。"
        },
        "no": {
          "type": "integer",
          "minimum": 1,
          "description": "物理順 (1..N 連番)。一覧表示の No 列として使用。"
        },
        "description": {
          "$ref": "common.v2.schema.json#/$defs/Description",
          "description": "ビューの用途説明 (サマリ)。"
        },
        "updatedAt": {
          "$ref": "common.v2.schema.json#/$defs/Timestamp",
          "description": "最終更新日時 (ISO 8601 UTC)。"
        }
      }
    },
    "ViewsFile": {
      "description": "ビュー定義の一覧ファイルのルートオブジェクト (将来: data/views/*.json)。",
      "type": "object",
      "required": ["version", "updatedAt", "views"],
      "additionalProperties": false,
      "properties": {
        "$schema": {
          "type": "string",
          "description": "JSON Schema URL (IDE 関連付け用)。"
        },
        "version": {
          "$ref": "common.v2.schema.json#/$defs/SemVer",
          "description": "ビュー定義ファイルのバージョン (SemVer)。"
        },
        "updatedAt": {
          "$ref": "common.v2.schema.json#/$defs/Timestamp",
          "description": "最終更新日時 (ISO 8601 UTC)。"
        },
        "views": {
          "type": "array",
          "items": { "$ref": "#/$defs/ViewDefinition" },
          "description": "ビュー定義のリスト。id でユニーク。"
        }
      }
    }
  }
}
