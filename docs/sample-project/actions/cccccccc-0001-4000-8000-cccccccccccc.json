{
  "id": "cccccccc-0001-4000-8000-cccccccccccc",
  "name": "ログイン画面",
  "type": "screen",
  "screenId": "aaaaaaaa-0001-4000-8000-aaaaaaaaaaaa",
  "description": "ログイン画面の処理フロー定義",
  "mode": "upstream",
  "maturity": "provisional",
  "actions": [
    {
      "id": "act-login-001",
      "name": "ログインボタン",
      "trigger": "click",
      "maturity": "provisional",
      "httpRoute": {
        "method": "POST",
        "path": "/api/auth/login",
        "auth": "none"
      },
      "responses": [
        {
          "id": "200-success",
          "status": 200,
          "bodySchema": {
            "schema": {
              "type": "object",
              "required": ["sessionId", "userId"],
              "properties": {
                "sessionId": { "type": "string" },
                "userId": { "type": "integer" },
                "permissions": { "type": "array", "items": { "type": "string" } }
              }
            }
          },
          "description": "ログイン成功"
        },
        {
          "id": "400-validation",
          "status": 400,
          "bodySchema": {
            "typeRef": "ApiError"
          },
          "description": "入力不正"
        },
        {
          "id": "401-unauthorized",
          "status": 401,
          "bodySchema": {
            "typeRef": "ApiError"
          },
          "description": "認証失敗"
        }
      ],
      "inputs": [
        {
          "name": "userId",
          "label": "ユーザーID",
          "type": "string",
          "required": true
        },
        {
          "name": "password",
          "label": "パスワード",
          "type": "string",
          "required": true
        }
      ],
      "outputs": [
        {
          "name": "sessionId",
          "label": "セッションID",
          "type": "string"
        },
        {
          "name": "permissions",
          "label": "権限情報",
          "type": {
            "kind": "custom",
            "label": "string[]"
          }
        }
      ],
      "steps": [
        {
          "id": "step-login-001",
          "type": "validation",
          "maturity": "committed",
          "description": "入力値チェック",
          "conditions": "ユーザーID・パスワードの必須チェック",
          "rules": [
            {
              "field": "userId",
              "type": "required",
              "message": "@conv.msg.required"
            },
            {
              "field": "password",
              "type": "required",
              "message": "@conv.msg.required"
            }
          ],
          "inlineBranch": {
            "ok": "次のステップへ続行",
            "ng": "400 VALIDATION で return",
            "ngResponseRef": "400-validation"
          }
        },
        {
          "id": "step-login-002",
          "type": "commonProcess",
          "maturity": "provisional",
          "description": "認証チェック",
          "refId": "cccccccc-0003-4000-8000-cccccccccccc",
          "refName": "認証チェック",
          "outputBinding": "authResult",
          "argumentMapping": {
            "userId": "@userId",
            "password": "@password"
          },
          "notes": [
            {
              "id": "n-login-001",
              "type": "assumption",
              "body": "@authResult.success で成功判定、@authResult.sessionId で session 取得",
              "createdAt": "2026-04-14T00:00:00.000Z"
            }
          ]
        },
        {
          "id": "step-login-003",
          "type": "dbAccess",
          "maturity": "committed",
          "description": "ユーザー情報取得",
          "tableName": "users",
          "tableId": "bbbbbbbb-0001-4000-8000-bbbbbbbbbbbb",
          "operation": "SELECT",
          "sql": "SELECT id, login_id, display_name, role FROM users WHERE id = @authResult.userId AND is_active = true LIMIT 1",
          "outputBinding": "user"
        },
        {
          "id": "step-login-004",
          "type": "screenTransition",
          "maturity": "committed",
          "description": "ダッシュボードへ遷移",
          "targetScreenId": "aaaaaaaa-0002-4000-8000-aaaaaaaaaaaa",
          "targetScreenName": "ダッシュボード"
        }
      ]
    },
    {
      "id": "act-login-002",
      "name": "パスワードリセットリンク",
      "trigger": "click",
      "maturity": "draft",
      "steps": [
        {
          "id": "step-login-005",
          "type": "screenTransition",
          "maturity": "draft",
          "description": "パスワードリセット画面へ遷移",
          "targetScreenName": "パスワードリセット画面",
          "notes": [
            {
              "id": "n-login-002",
              "type": "prerequisite",
              "body": "パスワードリセット画面は未設計",
              "createdAt": "2026-04-14T00:00:00.000Z"
            }
          ]
        }
      ]
    }
  ],
  "createdAt": "2026-04-14T00:00:00.000Z",
  "updatedAt": "2026-04-20T12:00:00.000Z"
}
