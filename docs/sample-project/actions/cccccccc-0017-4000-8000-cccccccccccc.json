{
  "id": "cccccccc-0017-4000-8000-cccccccccccc",
  "name": "注文登録画面 (詳細設計版 / 新スキーマ完全活用)",
  "type": "screen",
  "screenId": "aaaaaaaa-0009-4000-8000-aaaaaaaaaaaa",
  "description": "顧客が商品を注文する一連の処理 (顧客選択 → 明細入力 → 事前在庫確認 → 決済 authorize → TX[注文+明細+在庫引当] → Saga 補償判定 → 決済 capture → 確認メール → 完了画面)。\n\n0015 をベースに、#159〜#171 で追加された構造化フィールド (httpRoute / responses / outcomes / timeoutMs / fireAndForget / retryPolicy / txBoundary / compensatesFor / externalChain / affectedRowsCheck / ValidationRule[] / outputBinding.operation / dbAccess.sql) をフル活用した版。description 依存を最小化。\n\n【前提スキーマ (#151 (A) 機能化予定、本フロー外で確定済)】\n- items テーブル: id / item_code (C-NNNN) / name / unit_price (DECIMAL 12,0 税抜) / is_deleted / timestamps\n- inventory テーブル: item_id (PK, FK items) / stock / reserved / updated_at\n- orders テーブル: 既存 + payment_id (VARCHAR 100 NULL) / order_number は DB DEFAULT 'ORD-YYYY-NNNN'\n- DB TX: req.db.tx(async (tx) => {...}) 提供\n- 決済: Stripe Japan 2 段階 (authorize → capture)\n- 参照規約: docs/conventions/validation-rules.md / product-scope.md (ambient)",
  "mode": "downstream",
  "maturity": "committed",
  "actions": [
    {
      "id": "act-orderreg-001",
      "name": "顧客選択時",
      "trigger": "change",
      "maturity": "committed",
      "httpRoute": { "method": "GET", "path": "/api/customers/:customerId/summary", "auth": "required" },
      "responses": [
        { "status": 200, "bodySchema": "CustomerSummary", "description": "正常" },
        { "status": 404, "bodySchema": "ApiError", "description": "顧客が存在しない / 論理削除済", "when": "SELECT 結果 null" }
      ],
      "inputs": [
        { "name": "customerId", "label": "顧客ID", "type": "number", "required": true, "description": "URL パスパラメータ" }
      ],
      "outputs": [
        { "name": "customerDisplay", "label": "顧客表示情報", "type": { "kind": "tableRow", "tableId": "bbbbbbbb-0002-4000-8000-bbbbbbbbbbbb" } }
      ],
      "steps": [
        {
          "id": "step-or1-001",
          "type": "dbAccess",
          "maturity": "committed",
          "description": "顧客情報取得",
          "tableName": "customers",
          "tableId": "bbbbbbbb-0002-4000-8000-bbbbbbbbbbbb",
          "operation": "SELECT",
          "sql": "SELECT id, name, name_kana, phone, email, address FROM customers WHERE id = @customerId AND is_deleted = false LIMIT 1",
          "outputBinding": "customerDisplay"
        },
        {
          "id": "step-or1-002",
          "type": "other",
          "maturity": "committed",
          "description": "HTTP 200 @customerDisplay を JSON 返却。NULL の場合は上位で 404。"
        }
      ]
    },
    {
      "id": "act-orderreg-002",
      "name": "注文確定ボタン",
      "trigger": "submit",
      "maturity": "committed",
      "httpRoute": { "method": "POST", "path": "/api/orders", "auth": "required" },
      "responses": [
        { "status": 201, "bodySchema": "{orderId, orderNumber}", "description": "登録成功" },
        { "status": 400, "bodySchema": "ApiError", "description": "バリデーション違反", "when": "rules[] 違反あり" },
        { "status": 404, "bodySchema": "ApiError", "description": "顧客/商品が存在しない" },
        { "status": 402, "bodySchema": "ApiError", "description": "決済拒否", "when": "@paymentAuth.status == 'failed'" },
        { "status": 409, "bodySchema": "ApiError", "description": "在庫不足", "when": "事前 or 並行引当検出" }
      ],
      "inputs": [
        { "name": "customerId", "label": "顧客ID", "type": "number", "required": true },
        { "name": "items", "label": "明細一覧", "type": { "kind": "custom", "label": "Array<{itemId, quantity}>" }, "required": true },
        { "name": "paymentMethod", "label": "支払方法", "type": "string", "required": true },
        { "name": "orderNotes", "label": "備考", "type": "string", "required": false }
      ],
      "outputs": [
        { "name": "orderId", "label": "注文ID", "type": "number" },
        { "name": "orderNumber", "label": "注文番号", "type": "string", "description": "ORD-YYYY-NNNN" }
      ],
      "steps": [
        {
          "id": "step-or2-001",
          "type": "validation",
          "maturity": "committed",
          "description": "入力バリデーション (構造化 rules[])",
          "conditions": "customerId / items / paymentMethod の必須・型・範囲チェック",
          "rules": [
            { "field": "customerId", "type": "required", "message": "@conv.msg.required" },
            { "field": "items", "type": "custom", "condition": "@items.length >= 1", "message": "明細は 1 件以上必要です" },
            { "field": "items", "type": "custom", "condition": "@items.every(i => i.quantity >= 1 && i.quantity <= 9999)", "message": "@conv.msg.outOfRange" },
            { "field": "paymentMethod", "type": "enum", "values": ["credit_card", "bank_transfer", "cash_on_delivery"], "message": "@conv.msg.invalidFormat" }
          ],
          "inlineBranch": { "ok": "次へ", "ng": "HTTP 400 VALIDATION 返却" }
        },
        {
          "id": "step-or2-002",
          "type": "dbAccess",
          "maturity": "committed",
          "description": "顧客存在確認 + メール取得 (後段で使用)",
          "tableName": "customers",
          "tableId": "bbbbbbbb-0002-4000-8000-bbbbbbbbbbbb",
          "operation": "SELECT",
          "sql": "SELECT id, name, email FROM customers WHERE id = @customerId AND is_deleted = false LIMIT 1",
          "outputBinding": "customer"
        },
        {
          "id": "step-or2-003",
          "type": "loop",
          "maturity": "committed",
          "description": "明細ごとに商品 + 在庫を JOIN SELECT し、累積データ構築",
          "loopKind": "collection",
          "collectionSource": "@items",
          "collectionItemName": "item",
          "steps": [
            {
              "id": "step-or2-003-1",
              "type": "dbAccess",
              "maturity": "committed",
              "description": "商品 + 在庫 JOIN",
              "tableName": "items",
              "operation": "SELECT",
              "sql": "SELECT i.id, i.name, i.unit_price, COALESCE(v.stock, 0) AS stock FROM items i LEFT JOIN inventory v ON v.item_id = i.id WHERE i.id = @item.itemId AND i.is_deleted = false LIMIT 1",
              "outputBinding": "itemDetail"
            },
            {
              "id": "step-or2-003-2",
              "type": "other",
              "maturity": "committed",
              "description": "@item.quantity > @itemDetail.stock なら shortageList に push",
              "outputBinding": { "name": "shortageList", "operation": "push" }
            },
            {
              "id": "step-or2-003-3",
              "type": "other",
              "maturity": "committed",
              "description": "@itemDetail.unit_price * @item.quantity を subtotal に accumulate",
              "outputBinding": { "name": "subtotal", "operation": "accumulate" }
            },
            {
              "id": "step-or2-003-4",
              "type": "other",
              "maturity": "committed",
              "description": "enrichedItems に {itemId, name, quantity, unit_price, subtotal} を push",
              "outputBinding": { "name": "enrichedItems", "operation": "push" }
            }
          ]
        },
        {
          "id": "step-or2-004",
          "type": "branch",
          "maturity": "committed",
          "description": "事前在庫不足分岐",
          "branches": [
            {
              "id": "br-shortage",
              "code": "A",
              "label": "在庫不足あり",
              "condition": "@shortageList != null && @shortageList.length > 0",
              "steps": [
                {
                  "id": "step-or2-004-a-1",
                  "type": "other",
                  "maturity": "committed",
                  "description": "HTTP 409 STOCK_SHORTAGE { detail: @shortageList } で return"
                }
              ]
            }
          ],
          "elseBranch": {
            "id": "br-noshortage",
            "code": "ELSE",
            "label": "続行",
            "condition": "",
            "steps": [
              {
                "id": "step-or2-005",
                "type": "other",
                "maturity": "committed",
                "description": "税額/合計計算 (外税 10% 切り捨て): taxAmount = Math.floor(@subtotal * 0.10), totalAmount = @subtotal + taxAmount",
                "outputBinding": "amounts"
              },
              {
                "id": "step-or2-006",
                "type": "externalSystem",
                "maturity": "committed",
                "description": "決済 authorize (@paymentMethod='credit_card' 時のみ、それ以外は skip)",
                "systemName": "Stripe Japan",
                "protocol": "HTTPS POST /v1/payment_intents (capture_method=manual)",
                "outputBinding": "paymentAuth",
                "externalChain": { "chainId": "stripe-pi-order", "phase": "authorize" },
                "timeoutMs": 10000,
                "outcomes": {
                  "success": { "action": "continue" },
                  "failure": { "action": "abort", "description": "HTTP 402 PAYMENT_FAILED で return", "jumpTo": "end-of-action" },
                  "timeout": { "action": "abort", "description": "failure と同じ扱い", "jumpTo": "end-of-action" }
                },
                "argumentMapping": {
                  "amount": "@amounts.totalAmount",
                  "currency": "jpy",
                  "payment_method_types[]": "card",
                  "capture_method": "manual",
                  "metadata[customer_id]": "@customerId"
                }
              },
              {
                "id": "step-or2-007",
                "type": "dbAccess",
                "maturity": "committed",
                "description": "注文ヘッダ INSERT",
                "tableName": "orders",
                "tableId": "bbbbbbbb-0003-4000-8000-bbbbbbbbbbbb",
                "operation": "INSERT",
                "sql": "INSERT INTO orders (customer_id, order_date, subtotal, tax_amount, total_amount, payment_method, payment_id, status, notes) VALUES (@customerId, CURRENT_TIMESTAMP, @amounts.subtotal, @amounts.taxAmount, @amounts.totalAmount, @paymentMethod, @paymentAuth?.id, 'processing', @orderNotes) RETURNING id, order_number",
                "outputBinding": "registeredOrder",
                "txBoundary": { "role": "begin", "txId": "tx-order-main" }
              },
              {
                "id": "step-or2-008",
                "type": "loop",
                "maturity": "committed",
                "description": "明細を一括 INSERT",
                "loopKind": "collection",
                "collectionSource": "@enrichedItems",
                "collectionItemName": "eitem",
                "txBoundary": { "role": "member", "txId": "tx-order-main" },
                "steps": [
                  {
                    "id": "step-or2-008-1",
                    "type": "dbAccess",
                    "maturity": "committed",
                    "description": "order_items INSERT",
                    "tableName": "order_items",
                    "tableId": "bbbbbbbb-0004-4000-8000-bbbbbbbbbbbb",
                    "operation": "INSERT",
                    "sql": "INSERT INTO order_items (order_id, item_name, quantity, unit_price, subtotal) VALUES (@registeredOrder.id, @eitem.name, @eitem.quantity, @eitem.unit_price, @eitem.subtotal)"
                  }
                ]
              },
              {
                "id": "step-or2-009",
                "type": "loop",
                "maturity": "committed",
                "description": "在庫引当 (条件付き UPDATE)",
                "loopKind": "collection",
                "collectionSource": "@enrichedItems",
                "collectionItemName": "eitem",
                "txBoundary": { "role": "end", "txId": "tx-order-main" },
                "steps": [
                  {
                    "id": "step-or2-009-1",
                    "type": "dbAccess",
                    "maturity": "committed",
                    "description": "stock 減算 + reserved 加算",
                    "tableName": "inventory",
                    "operation": "UPDATE",
                    "sql": "UPDATE inventory SET stock = stock - @eitem.quantity, reserved = reserved + @eitem.quantity, updated_at = CURRENT_TIMESTAMP WHERE item_id = @eitem.itemId AND stock >= @eitem.quantity",
                    "affectedRowsCheck": {
                      "operator": ">",
                      "expected": 0,
                      "onViolation": "throw",
                      "errorCode": "STOCK_SHORTAGE",
                      "description": "並行引当による在庫切れ発覚 → TX ROLLBACK"
                    }
                  }
                ]
              },
              {
                "id": "step-or2-010",
                "type": "branch",
                "maturity": "committed",
                "description": "TX 結果分岐 (StockShortageError catch で Saga 補償)",
                "branches": [
                  {
                    "id": "br-tx-fail",
                    "code": "A",
                    "label": "TX rollback",
                    "condition": "TX catch で StockShortageError",
                    "steps": [
                      {
                        "id": "step-or2-010-a-1",
                        "type": "externalSystem",
                        "maturity": "committed",
                        "description": "Saga 補償: Stripe PaymentIntent cancel",
                        "systemName": "Stripe Japan",
                        "protocol": "HTTPS POST /v1/payment_intents/@paymentAuth.id/cancel",
                        "externalChain": { "chainId": "stripe-pi-order", "phase": "cancel" },
                        "compensatesFor": "step-or2-006",
                        "timeoutMs": 10000,
                        "outcomes": {
                          "success": { "action": "continue" },
                          "failure": { "action": "continue", "description": "Sentry error + 運用通知、レスポンス優先" },
                          "timeout": { "action": "continue", "description": "failure と同じ" }
                        }
                      },
                      {
                        "id": "step-or2-010-a-2",
                        "type": "other",
                        "maturity": "committed",
                        "description": "HTTP 409 STOCK_SHORTAGE { detail: {itemId, name, required} } で return"
                      }
                    ]
                  }
                ],
                "elseBranch": {
                  "id": "br-tx-ok",
                  "code": "ELSE",
                  "label": "TX commit、続行",
                  "condition": "",
                  "steps": [
                    {
                      "id": "step-or2-011",
                      "type": "externalSystem",
                      "maturity": "committed",
                      "description": "決済 capture",
                      "systemName": "Stripe Japan",
                      "protocol": "HTTPS POST /v1/payment_intents/@paymentAuth.id/capture",
                      "externalChain": { "chainId": "stripe-pi-order", "phase": "capture" },
                      "timeoutMs": 10000,
                      "outcomes": {
                        "success": { "action": "continue" },
                        "failure": { "action": "continue", "description": "orders.status='payment_failed' UPDATE + Sentry + 運用通知。同期レスポンスは 201 維持" },
                        "timeout": { "action": "continue", "description": "failure と同じ" }
                      }
                    },
                    {
                      "id": "step-or2-012",
                      "type": "externalSystem",
                      "maturity": "committed",
                      "description": "注文確認メール送信 (fire-and-forget)",
                      "systemName": "SendGrid",
                      "protocol": "HTTPS POST /v3/mail/send",
                      "fireAndForget": true,
                      "timeoutMs": 10000,
                      "outcomes": {
                        "success": { "action": "continue", "description": "info ログ" },
                        "failure": { "action": "continue", "description": "Sentry error、レスポンス変更なし" },
                        "timeout": { "action": "continue", "description": "failure と同じ" }
                      },
                      "argumentMapping": {
                        "to": "@customer.email",
                        "template_id": "order-confirmation",
                        "dynamic_template_data.customerName": "@customer.name",
                        "dynamic_template_data.orderNumber": "@registeredOrder.order_number",
                        "dynamic_template_data.items": "@enrichedItems",
                        "dynamic_template_data.totalAmount": "@amounts.totalAmount"
                      }
                    },
                    {
                      "id": "step-or2-013",
                      "type": "other",
                      "maturity": "committed",
                      "description": "HTTP 201 { orderId: @registeredOrder.id, orderNumber: @registeredOrder.order_number } で return。FE は navigate('/complete', { state }) で遷移。"
                    }
                  ]
                }
              }
            ]
          }
        }
      ]
    }
  ],
  "createdAt": "2026-04-20T17:00:00.000Z",
  "updatedAt": "2026-04-20T17:00:00.000Z"
}
