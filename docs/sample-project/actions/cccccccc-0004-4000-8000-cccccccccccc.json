{
  "id": "cccccccc-0004-4000-8000-cccccccccccc",
  "name": "月次売上集計バッチ",
  "type": "batch",
  "description": "月次の売上データを集計するバッチ処理",
  "mode": "upstream",
  "maturity": "draft",
  "actions": [
    {
      "id": "act-batch-001",
      "name": "集計実行",
      "trigger": "timer",
      "maturity": "draft",
      "inputs": [
        { "name": "targetMonth", "label": "対象月", "type": "string", "required": true, "description": "YYYY-MM 形式" }
      ],
      "outputs": [
        { "name": "totalAmount", "label": "集計総額", "type": "number" },
        { "name": "processedCount", "label": "処理件数", "type": "number" }
      ],
      "steps": [
        {
          "id": "step-batch-001",
          "type": "dbAccess",
          "maturity": "provisional",
          "description": "注文データ取得",
          "tableName": "orders",
          "tableId": "bbbbbbbb-0003-4000-8000-bbbbbbbbbbbb",
          "operation": "SELECT",
          "sql": "SELECT id, customer_id, total_amount FROM orders WHERE to_char(order_date, 'YYYY-MM') = @targetMonth AND status = 'completed'",
          "outputBinding": "orders"
        },
        {
          "id": "step-batch-002",
          "type": "compute",
          "maturity": "provisional",
          "description": "売上集計処理",
          "expression": "@orders.reduce((s, o) => s + o.total_amount, 0)",
          "outputBinding": "totalAmount",
          "notes": [
            { "id": "n-batch-001", "type": "deferred", "body": "顧客別・商品別集計の詳細は将来検討。現状は単純合計のみ。", "createdAt": "2026-04-14T00:00:00.000Z" }
          ]
        },
        {
          "id": "step-batch-003",
          "type": "dbAccess",
          "maturity": "draft",
          "description": "集計結果登録",
          "tableName": "orders",
          "tableId": "bbbbbbbb-0003-4000-8000-bbbbbbbbbbbb",
          "operation": "UPDATE",
          "sql": "UPDATE orders SET monthly_aggregated = true WHERE to_char(order_date, 'YYYY-MM') = @targetMonth AND status = 'completed'",
          "notes": [
            { "id": "n-batch-002", "type": "question", "body": "monthly_aggregated カラムの存在を要確認 (テーブル定義に未追加の可能性)", "createdAt": "2026-04-14T00:00:00.000Z" }
          ]
        },
        {
          "id": "step-batch-004",
          "type": "commonProcess",
          "maturity": "draft",
          "description": "処理完了ログ出力",
          "refId": "",
          "refName": "ログ出力",
          "argumentMapping": {
            "processedCount": "@orders.length",
            "totalAmount": "@totalAmount"
          },
          "notes": [
            { "id": "n-batch-003", "type": "prerequisite", "body": "ログ出力共通処理は別途設計予定 (refId 空)", "createdAt": "2026-04-14T00:00:00.000Z" }
          ]
        }
      ]
    }
  ],
  "createdAt": "2026-04-14T00:00:00.000Z",
  "updatedAt": "2026-04-20T12:00:00.000Z"
}
