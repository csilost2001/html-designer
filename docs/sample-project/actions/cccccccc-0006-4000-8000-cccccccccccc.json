{
  "id": "cccccccc-0006-4000-8000-cccccccccccc",
  "name": "注文一覧画面",
  "type": "screen",
  "screenId": "aaaaaaaa-0008-4000-8000-aaaaaaaaaaaa",
  "description": "注文検索と一覧表示。検索結果の件数に応じて表示を分岐する（0件はメッセージ / 1件は詳細へ自動遷移 / 複数件は一覧表示）。",
  "actions": [
    {
      "id": "act-orderlist-001",
      "name": "検索ボタン",
      "trigger": "click",
      "description": "検索条件で orders を検索し、件数に応じて表示または自動遷移する。",
      "inputs": "顧客名（部分一致）\n期間開始日\n期間終了日\nステータス",
      "outputs": "検索結果一覧\n結果件数\n結果メッセージ",
      "steps": [
        {
          "id": "step-orderlist-001",
          "type": "validation",
          "description": "検索条件チェック",
          "conditions": "期間開始日 ≤ 期間終了日 / 期間未指定時は直近3ヶ月を既定",
          "inlineBranch": {
            "ok": "検索処理を実行",
            "ng": "エラーメッセージを検索条件エリア上部に表示"
          }
        },
        {
          "id": "step-orderlist-002",
          "type": "dbAccess",
          "description": "注文検索（顧客名 JOIN）",
          "tableName": "orders",
          "tableId": "bbbbbbbb-0003-4000-8000-bbbbbbbbbbbb",
          "operation": "SELECT",
          "fields": "注文ID、注文日、顧客名（customers JOIN）、合計金額、ステータス",
          "note": "想定: 結果を『検索結果』として保持し、後続の分岐と表示更新で参照。customers との JOIN は顧客IDで紐付け。ページング仕様は将来検討。"
        },
        {
          "id": "step-orderlist-003",
          "type": "branch",
          "description": "件数による動作分岐",
          "branches": [
            {
              "id": "branch-orderlist-a",
              "code": "A",
              "label": "0件",
              "condition": "検索結果.件数 == 0",
              "steps": [
                {
                  "id": "step-orderlist-003-a-1",
                  "type": "displayUpdate",
                  "description": "『該当データがありません』を一覧エリアに表示",
                  "target": "一覧テーブルのゼロ件表示領域"
                }
              ]
            },
            {
              "id": "branch-orderlist-b",
              "code": "B",
              "label": "1件",
              "condition": "検索結果.件数 == 1",
              "steps": [
                {
                  "id": "step-orderlist-003-b-1",
                  "type": "screenTransition",
                  "description": "注文詳細画面へ自動遷移（想定：未設計）",
                  "targetScreenName": "注文詳細",
                  "note": "想定: 1件ヒット時は確認不要で詳細へ。注文詳細画面は本サンプル時点で未設計のため、ID解決と遷移パラメータの設計は将来検討。"
                }
              ]
            },
            {
              "id": "branch-orderlist-c",
              "code": "C",
              "label": "複数件",
              "condition": "検索結果.件数 >= 2",
              "steps": [
                {
                  "id": "step-orderlist-003-c-1",
                  "type": "displayUpdate",
                  "description": "検索結果を一覧テーブルに表示",
                  "target": "注文一覧テーブル"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "act-orderlist-002",
      "name": "行クリック",
      "trigger": "select",
      "description": "一覧の行をクリックした時、注文詳細へ遷移する。",
      "inputs": "選択された注文ID",
      "outputs": "",
      "steps": [
        {
          "id": "step-orderlist-004",
          "type": "screenTransition",
          "description": "注文詳細画面へ遷移（想定：未設計）",
          "targetScreenName": "注文詳細",
          "note": "想定: 注文IDをパラメータとして引き渡す。注文詳細画面は本サンプル時点で未設計。"
        }
      ]
    }
  ],
  "createdAt": "2026-04-20T12:00:00.000Z",
  "updatedAt": "2026-04-20T12:00:00.000Z"
}
