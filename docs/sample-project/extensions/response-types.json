{
  "namespace": "",
  "responseTypes": {
    "ApiError": {
      "description": "product-scope §7 共通エラーレスポンス",
      "schema": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "fieldErrors": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "detail": {}
        }
      }
    },
    "InventorySearchResponse": {
      "description": "店舗在庫照会結果レスポンス",
      "schema": {
        "type": "object",
        "required": ["items"],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "productCode": { "type": "string" },
                "productName": { "type": "string" },
                "storeCode": { "type": "string" },
                "availableQuantity": { "type": "integer" },
                "reservedQuantity": { "type": "integer" }
              }
            }
          },
          "totalCount": { "type": "integer" }
        }
      }
    },
    "CartAddResponse": {
      "description": "カート追加成功レスポンス",
      "schema": {
        "type": "object",
        "required": ["cartId", "status"],
        "properties": {
          "cartId": { "type": "string" },
          "status": { "type": "string" },
          "itemCount": { "type": "integer" },
          "totalAmount": { "type": "number" }
        }
      }
    },
    "OrderConfirmResponse": {
      "description": "注文確定成功レスポンス",
      "schema": {
        "type": "object",
        "required": ["orderId", "orderNumber", "status"],
        "properties": {
          "orderId": { "type": "string" },
          "orderNumber": { "type": "string" },
          "status": { "type": "string" },
          "totalAmount": { "type": "number" },
          "taxAmount": { "type": "number" }
        }
      }
    },
    "ShipmentDispatchResponse": {
      "description": "配送指示登録成功レスポンス",
      "schema": {
        "type": "object",
        "required": ["shipmentId", "trackingNumber", "status"],
        "properties": {
          "shipmentId": { "type": "string" },
          "trackingNumber": { "type": "string" },
          "status": { "type": "string" },
          "estimatedDeliveryDate": { "type": "string" }
        }
      }
    }
  }
}
