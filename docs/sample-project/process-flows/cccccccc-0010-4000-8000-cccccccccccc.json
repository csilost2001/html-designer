{
  "id": "cccccccc-0010-4000-8000-cccccccccccc",
  "name": "決済処理",
  "type": "screen",
  "screenId": "aaaaaaaa-0010-4000-8000-aaaaaaaaaaaa",
  "description": "#427 P3-2 実証サンプル: StructuredCriterion (jsonpath / simple / regex) を使う外部 API 呼び出しと Arazzo 互換 successCriteria を示す。Stripe 決済 API との連携フロー。",
  "maturity": "draft",

  "externalSystemCatalog": {
    "stripe": {
      "name": "Stripe Payment API",
      "baseUrl": "https://api.stripe.com",
      "openApiSpec": "https://raw.githubusercontent.com/stripe/openapi/master/openapi/spec3.json",
      "auth": { "kind": "bearer", "tokenRef": "SECRET:payment/stripe-secret-key" },
      "timeoutMs": 15000,
      "retryPolicy": { "maxAttempts": 2, "backoff": "fixed", "initialDelayMs": 500 }
    }
  },

  "errorCatalog": {
    "PAYMENT_FAILED": {
      "httpStatus": 402,
      "defaultMessage": "決済処理に失敗しました",
      "description": "Stripe が拒否した決済"
    },
    "STRIPE_TIMEOUT": {
      "httpStatus": 504,
      "defaultMessage": "決済サービスがタイムアウトしました。時間をおいて再試行してください",
      "description": "タイムアウト — retriable"
    }
  },

  "actions": [
    {
      "id": "act-pay-001",
      "name": "決済実行",
      "trigger": "submit",
      "description": "注文確定後に Stripe で決済を実行する",
      "inputs": [
        { "name": "orderId",        "type": "number",  "required": true,  "label": "注文ID" },
        { "name": "amount",         "type": "number",  "required": true,  "label": "決済金額 (円単位)" },
        { "name": "currency",       "type": "string",  "required": false, "label": "通貨コード" },
        { "name": "customerId",     "type": "string",  "required": true,  "label": "Stripe 顧客 ID" },
        { "name": "paymentMethodId","type": "string",  "required": true,  "label": "Stripe 支払い方法 ID" }
      ],
      "steps": [
        {
          "id": "step-create-payment-intent",
          "type": "externalSystem",
          "description": "Stripe に PaymentIntent を作成する",
          "systemRef": "stripe",
          "systemName": "Stripe",
          "operationId": "PostPaymentIntents",
          "outputBinding": "paymentIntent",
          "httpCall": {
            "method": "POST",
            "path": "/v1/payment_intents",
            "body": "{\"amount\": \"@amount\", \"currency\": \"@currency\", \"customer\": \"@customerId\"}"
          },
          "successCriteria": [
            {
              "type": "simple",
              "expression": "@statusCode == 200",
              "context": "@statusCode"
            },
            {
              "type": "jsonpath",
              "expression": "$.status",
              "context": "@responseBody"
            },
            {
              "type": "regex",
              "expression": "^pi_",
              "context": "@responseBody.id"
            }
          ],
          "outcomes": {
            "success": { "action": "continue" },
            "failure": { "action": "abort", "description": "Stripe API エラー" },
            "timeout": { "action": "abort", "description": "タイムアウト — リトライ上限到達" }
          }
        },
        {
          "id": "step-confirm-payment",
          "type": "externalSystem",
          "description": "PaymentIntent を確定 (confirm) する",
          "systemRef": "stripe",
          "systemName": "Stripe",
          "operationId": "PostPaymentIntentsIntentConfirm",
          "outputBinding": "confirmResult",
          "httpCall": {
            "method": "POST",
            "path": "/v1/payment_intents/@paymentIntent.id/confirm",
            "body": "{\"payment_method\": \"@paymentMethodId\"}"
          },
          "successCriteria": [
            {
              "type": "simple",
              "expression": "@statusCode == 200",
              "context": "@statusCode"
            },
            {
              "type": "jsonpath",
              "expression": "$.status == 'succeeded'",
              "context": "@responseBody"
            }
          ],
          "outcomes": {
            "success": { "action": "continue" },
            "failure": { "action": "abort", "description": "決済確定失敗" },
            "timeout": { "action": "abort" }
          }
        },
        {
          "id": "step-save-result",
          "type": "dbAccess",
          "description": "決済結果を orders テーブルに保存する",
          "tableName": "orders",
          "operation": "UPDATE",
          "sql": "UPDATE orders SET payment_id=@paymentIntent.id, status='completed' WHERE id=@orderId"
        },
        {
          "id": "step-return",
          "type": "return",
          "description": "決済完了レスポンスを返す",
          "bodyExpression": "{\"success\": true, \"paymentIntentId\": \"@paymentIntent.id\", \"status\": \"completed\"}"
        }
      ]
    }
  ],

  "createdAt": "2026-04-25T00:00:00.000Z",
  "updatedAt": "2026-04-25T00:00:00.000Z"
}
