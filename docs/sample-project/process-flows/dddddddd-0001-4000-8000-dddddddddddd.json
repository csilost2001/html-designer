{
  "id": "dddddddd-0001-4000-8000-dddddddddddd",
  "name": "注文受付/約定/確認通知 (証券)",
  "type": "screen",
  "screenId": "aaaaaaaa-0001-4000-8000-dddddddddddd",
  "description": "証券注文の受付、取引所への回送、約定通知受信、顧客への確認通知までを扱うドッグフードサンプル。取引所 OpenAPI と FIX 接続を抽象化し、冪等な約定登録と非同期通知を明示する。",
  "apiVersion": "v2",
  "mode": "downstream",
  "maturity": "committed",
  "eventsCatalog": {
    "order.received": {
      "description": "注文受付 API が入力検証を通過し、業務注文として受け付けられた時点で発行されるイベント。",
      "payload": {
        "type": "object",
        "required": [
          "orderId",
          "accountId",
          "securityCode",
          "side",
          "quantity"
        ],
        "properties": {
          "orderId": {
            "type": "string"
          },
          "accountId": {
            "type": "string"
          },
          "securityCode": {
            "type": "string"
          },
          "side": {
            "type": "string",
            "enum": [
              "BUY",
              "SELL"
            ]
          },
          "quantity": {
            "type": "number"
          }
        },
        "additionalProperties": false
      }
    },
    "order.routed": {
      "description": "注文が取引所へ送信され、取引所注文 ID とともに回送済みになった時点で発行されるイベント。",
      "payload": {
        "type": "object",
        "required": [
          "orderId",
          "exchangeOrderId",
          "exchangeCode",
          "status"
        ],
        "properties": {
          "orderId": {
            "type": "string"
          },
          "exchangeOrderId": {
            "type": "string"
          },
          "exchangeCode": {
            "type": "string",
            "enum": [
              "TSE",
              "OSE"
            ]
          },
          "status": {
            "type": "string",
            "const": "ROUTED"
          }
        },
        "additionalProperties": false
      }
    },
    "trade.executed": {
      "description": "取引所から約定通知を受信し、約定行と注文の約定数量が更新された時点で発行されるイベント。",
      "payload": {
        "type": "object",
        "required": [
          "orderId",
          "tradeId",
          "executedQty",
          "executedPrice",
          "status"
        ],
        "properties": {
          "orderId": {
            "type": "string"
          },
          "tradeId": {
            "type": "string"
          },
          "executedQty": {
            "type": "number"
          },
          "executedPrice": {
            "type": "number"
          },
          "status": {
            "type": "string",
            "enum": [
              "FILLED",
              "PARTIALLY_FILLED"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "trade.notified": {
      "description": "約定通知を通知ゲートウェイへ依頼した後に発行されるイベント。通知失敗は注文約定処理をロールバックしない。",
      "payload": {
        "type": "object",
        "required": [
          "orderId",
          "tradeId",
          "notificationRequested"
        ],
        "properties": {
          "orderId": {
            "type": "string"
          },
          "tradeId": {
            "type": "string"
          },
          "notificationRequested": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    },
    "securities.market_open_warmed": {
      "description": "市場開場時に当日の取引可能銘柄マスタをキャッシュへ事前ロードした時点で発行されるイベント。",
      "payload": {
        "type": "object",
        "required": [
          "marketDate",
          "cachedSecurityCount"
        ],
        "properties": {
          "marketDate": {
            "type": "string"
          },
          "cachedSecurityCount": {
            "type": "number"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "glossary": {
    "注文": {
      "definition": "顧客が証券会社に対して銘柄、売買区分、数量、価格条件を指定して売買を依頼する業務単位。",
      "aliases": [
        "オーダー",
        "Order"
      ],
      "domainRef": "orders"
    },
    "約定": {
      "definition": "取引所で注文が成立し、約定数量・約定価格・約定時刻が確定した状態。",
      "aliases": [
        "Trade",
        "Execution"
      ],
      "domainRef": "trades"
    },
    "銘柄コード": {
      "definition": "上場商品を識別するコード。取引所ルーティングと取引可否判定に利用する。",
      "aliases": [
        "SecurityCode",
        "証券コード"
      ],
      "domainRef": "securities.security_code"
    },
    "ロット": {
      "definition": "市場で売買できる最小取引単位。数量はロット単位の倍数である必要がある。",
      "aliases": [
        "売買単位",
        "Lot"
      ],
      "domainRef": "securities.lot_size"
    },
    "取引所": {
      "definition": "注文を回送し約定通知を受け取る市場システム。TSE と OSE を外部システムとして扱う。",
      "aliases": [
        "Exchange",
        "市場"
      ],
      "domainRef": "exchanges"
    },
    "与信枠": {
      "definition": "口座ごとに許容される注文可能金額の上限。必要証拠金と比較して注文可否を判定する。",
      "aliases": [
        "Credit Limit",
        "信用枠"
      ],
      "domainRef": "credit_limits"
    },
    "証拠金": {
      "definition": "注文に必要な担保額。数量、価格、レバレッジ率から算出する。",
      "aliases": [
        "Margin",
        "必要証拠金"
      ],
      "domainRef": "orders.required_margin"
    },
    "FIXプロトコル": {
      "definition": "金融取引メッセージ交換の標準プロトコル。本サンプルでは NewOrderSingle の抽象化として扱う。",
      "aliases": [
        "FIX",
        "Financial Information eXchange"
      ],
      "domainRef": "exchange_sessions.fix"
    }
  },
  "decisions": [
    {
      "id": "ADR-001",
      "title": "約定登録は UPSERT_IDEMPOTENT で冪等処理する",
      "status": "accepted",
      "context": "取引所コールバックはネットワーク再送や運用再送により同一 tradeId が複数回到達する可能性がある。",
      "decision": "trades.trade_id に一意制約を置き、既存 tradeId の場合は no-op とする UPSERT_IDEMPOTENT 方針で処理する。",
      "consequences": "重複通知による約定行の二重作成を防げる。注文の executed_qty 更新は新規約定として登録された場合のみ加算する実装が必要になる。",
      "date": "2026-04-26"
    },
    {
      "id": "ADR-002",
      "title": "約定確認通知は fireAndForget で送信する",
      "status": "accepted",
      "context": "通知ゲートウェイの一時障害で約定登録を失敗扱いにすると、顧客残高と取引所実績の整合性が崩れる。",
      "decision": "notificationGateway 呼び出しは fireAndForget: true とし、failure/timeout は continue にする。",
      "consequences": "通知未達は別運用の再送対象になる。約定登録処理の可用性と整合性を優先できる。",
      "date": "2026-04-26"
    },
    {
      "id": "ADR-003",
      "title": "取引所 OpenAPI と FIX 接続を外部システムカタログで抽象化する",
      "status": "accepted",
      "context": "TSE/OSE で API 仕様や FIX 接続情報が異なるが、注文回送ステップは同一業務概念として扱いたい。",
      "decision": "tseExchange と oseExchange を externalSystemCatalog に分け、OpenAPI 参照、FIX トークン、タイムアウトをカタログ化する。 FIX ClOrdID 由来の idempotencyKey をクライアントが付与する場合に優先利用し、未指定時は requestId をフォールバックする。",
      "consequences": "ルーティング結果から systemRef を切り替えるだけで注文回送の業務フローを共通化できる。 クライアント指定の FIX ClOrdID と注文回送の冪等キーを対応付けられる。",
      "date": "2026-04-26"
    }
  ],
  "ambientVariables": [
    {
      "name": "requestId",
      "type": "string",
      "required": true,
      "description": "リクエスト単位の追跡 ID。取引所送信の冪等キーにも利用する。"
    },
    {
      "name": "sessionUserId",
      "type": "string",
      "required": true,
      "description": "注文を入力したログインユーザー ID。"
    },
    {
      "name": "idempotencyKey",
      "type": "string",
      "required": false,
      "description": "クライアントまたはミドルウェアが付与する冪等キー。"
    },
    {
      "name": "marketDate",
      "type": "date",
      "required": true,
      "description": "市場営業日。取引カレンダー照会に利用する。"
    }
  ],
  "errorCatalog": {
    "VALIDATION": {
      "httpStatus": 400,
      "defaultMessage": "入力値が不正です",
      "responseRef": "400-validation"
    },
    "SECURITY_NOT_TRADABLE": {
      "httpStatus": 422,
      "defaultMessage": "指定銘柄は取引できません",
      "responseRef": "422-security-not-tradable"
    },
    "MARKET_CLOSED": {
      "httpStatus": 422,
      "defaultMessage": "市場時間外です",
      "responseRef": "422-market-closed"
    },
    "CREDIT_LIMIT_EXCEEDED": {
      "httpStatus": 422,
      "defaultMessage": "与信枠を超過しています",
      "responseRef": "422-credit-limit-exceeded"
    },
    "EXCHANGE_REJECTED": {
      "httpStatus": 502,
      "defaultMessage": "取引所が注文を拒否しました",
      "responseRef": "502-exchange-rejected"
    },
    "EXCHANGE_TIMEOUT": {
      "httpStatus": 504,
      "defaultMessage": "取引所応答がタイムアウトしました",
      "responseRef": "504-exchange-timeout"
    },
    "ORDER_NOT_FOUND": {
      "httpStatus": 404,
      "defaultMessage": "注文が見つかりません",
      "responseRef": "404-order-not-found"
    },
    "CACHE_WARMUP_FAILED": {
      "httpStatus": 503,
      "defaultMessage": "銘柄マスタのキャッシュ事前ロードに失敗しました",
      "responseRef": "503-cache-warmup-failed"
    },
    "ORDER_CANCELLED": {
      "httpStatus": 400,
      "defaultMessage": "対象注文はキャンセル済みです",
      "responseRef": "400-order-cancelled"
    }
  },
