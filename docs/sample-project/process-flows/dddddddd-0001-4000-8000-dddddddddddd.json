        "input": { "accountId": "ACC-001", "securityCode": "7203", "side": "BUY", "quantity": 100, "price": 3000, "orderType": "LIMIT" }
      },
      "then": [
        { "kind": "outcome", "expected": "202-accepted" },
        { "kind": "output", "path": "$.status", "equals": "ROUTED" },
        { "kind": "externalCall", "externalRef": "tseExchange", "method": "POST", "bodyMatch": { "securityCode": "7203", "side": "BUY" } }
      ],
      "tags": ["happy", "buy", "tse"]
    },
    {
      "id": "validation-error-negative-quantity",
      "name": "quantity=0 は 400 になる",
      "description": "数量 0 の注文は入力検証で拒否され、取引所へ送信されない。",
      "given": [
        { "kind": "sessionContext", "context": { "sessionUserId": "user-101", "requestId": "req-459-validation", "marketDate": "2026-04-26" } }
      ],
      "when": {
        "actionId": "act-001",
        "input": { "accountId": "ACC-001", "securityCode": "7203", "side": "BUY", "quantity": 0, "price": 3000, "orderType": "LIMIT" }
      },
      "then": [
        { "kind": "outcome", "expected": "400-validation" },
        { "kind": "errorMessage", "msgKey": "数量は 1 以上で入力してください" }
      ],
      "tags": ["error", "validation"]
    },
    {
      "id": "idempotent-trade-callback",
      "name": "同一 tradeId の約定通知は 1 行のみ登録される",
      "description": "同じ tradeId のコールバックを 2 回受けても、trades は 1 行のみになり注文数量は二重加算されない。",
      "given": [
        { "kind": "clock", "now": "2026-04-26T00:35:00.000Z" },
        { "kind": "sessionContext", "context": { "sessionUserId": "exchange-system", "requestId": "req-459-trade", "marketDate": "2026-04-26" } },
        { "kind": "dbState", "table": "orders", "rows": [{ "id": "ORD-459-001", "quantity": 100, "executed_qty": 0, "status": "ROUTED" }] },
        { "kind": "dbState", "table": "trades", "rows": [] },
        { "kind": "externalStub", "externalRef": "notificationGateway", "responseMock": { "status": 202, "body": { "accepted": true } } }
      ],
      "when": {
        "actionId": "act-002",
        "input": { "orderId": "ORD-459-001", "tradeId": "TRD-459-001", "executedQty": 100, "executedPrice": 3000, "executedAt": "2026-04-26T00:35:00.000Z" }
      },
      "then": [
        { "kind": "outcome", "expected": "200-ok" },
