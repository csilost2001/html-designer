  "functionsCatalog": {
    "calcRequiredMargin": {
      "signature": "calcRequiredMargin(quantity: number, price: number, leverageRate: number): number",
      "returnType": "number",
      "description": "数量、価格、レバレッジ率から必要証拠金を算出する。",
      "examples": [
        "@fn.calcRequiredMargin(@inputs.quantity, @inputs.price, @account.leverage_rate)"
      ]
    },
    "selectExchangeRoute": {
      "signature": "selectExchangeRoute(securityCode: string, marketCode: string): string",
      "returnType": "string",
      "description": "銘柄コードと市場コードから回送先取引所 TSE/OSE を決定する。",
      "examples": [
        "@fn.selectExchangeRoute(@inputs.securityCode, @security.market_code) // => \"TSE\""
      ]
    }
  },
  "actions": [
    {
      "id": "act-001",
      "name": "注文受付",
      "trigger": "submit",
      "description": "画面から受け付けた証券注文を検証し、取引所へ NewOrderSingle として回送する。",
      "maturity": "committed",
      "httpRoute": {
        "method": "POST",
        "path": "/api/orders",
        "auth": "required"
      },
      "inputs": [
        {
          "name": "accountId",
          "label": "口座 ID",
          "type": "string",
          "required": true,
          "domainRef": "AccountId"
        },
        {
          "name": "securityCode",
          "label": "銘柄コード",
          "type": "string",
          "required": true,
          "domainRef": "SecurityCode"
        },
        {
          "name": "side",
          "label": "売買区分",
          "type": "string",
          "required": true
        },
        {
          "name": "quantity",
          "label": "数量",
          "type": "number",
          "required": true,
          "domainRef": "Quantity"
        },
        {
          "name": "price",
          "label": "価格",
          "type": "number",
          "required": false,
          "domainRef": "Price"
        },
        {
          "name": "orderType",
          "label": "注文種別",
          "type": "string",
          "required": true
        }
      ],
      "outputs": [
        {
          "name": "orderId",
          "label": "注文 ID",
          "type": "string",
          "domainRef": "OrderId"
        },
        {
          "name": "status",
          "label": "注文ステータス",
          "type": "string"
        }
      ],
      "responses": [
        {
          "id": "202-accepted",
          "status": 202,
          "bodySchema": {
            "typeRef": "OrderAcceptedResponse"
          },
          "when": "注文が取引所へ回送された"
        },
        {
          "id": "400-validation",
          "status": 400,
          "bodySchema": {
            "typeRef": "ApiError"
          },
          "when": "入力値が不正"
        },
        {
          "id": "422-security-not-tradable",
          "status": 422,
          "bodySchema": {
            "typeRef": "ApiError"
          },
          "when": "銘柄が取引不可"
        },
        {
          "id": "422-market-closed",
          "status": 422,
          "bodySchema": {
            "typeRef": "ApiError"
          },
          "when": "市場時間外"
        },
        {
          "id": "422-credit-limit-exceeded",
          "status": 422,
          "bodySchema": {
            "typeRef": "ApiError"
          },
          "when": "与信枠超過"
        },
        {
          "id": "502-exchange-rejected",
          "status": 502,
          "bodySchema": {
            "typeRef": "ApiError"
          },
          "when": "取引所拒否または送信失敗"
        },
        {
          "id": "504-exchange-timeout",
          "status": 504,
          "bodySchema": {
            "typeRef": "ApiError"
          }
        },
        {
          "id": "404-order-not-found",
          "status": 404,
          "bodySchema": {
            "typeRef": "ApiError"
          }
        },
        {
          "id": "503-cache-warmup-failed",
          "status": 503,
          "bodySchema": {
            "typeRef": "ApiError"
          }
        },
        {
          "id": "400-order-cancelled",
          "status": 400,
          "bodySchema": {
            "typeRef": "ApiError"
          }
        }
      ],
      "steps": [
        {
          "id": "step-01",
          "type": "validation",
          "description": "必須チェック。price は LIMIT 注文時のみ必須。",
          "maturity": "committed",
          "conditions": "accountId/securityCode/side/quantity/orderType は必須。quantity > 0。orderType == 'LIMIT' の場合 price は必須。",
          "rules": [
            {
              "field": "accountId",
              "type": "required",
              "message": "口座 ID は必須です"
            },
            {
              "field": "securityCode",
              "type": "required",
              "message": "銘柄コードは必須です"
            },
            {
              "field": "side",
              "type": "enum",
              "values": [
                "BUY",
                "SELL"
              ],
              "message": "売買区分が不正です"
            },
            {
              "field": "quantity",
              "type": "range",
              "min": 1,
              "message": "数量は 1 以上で入力してください"
            },
            {
              "field": "price",
              "type": "required",
              "condition": "@inputs.orderType == 'LIMIT'",
              "message": "指値注文では価格が必須です"
            }
          ],
          "fieldErrorsVar": "fieldErrors",
          "inlineBranch": {
            "ok": "次のステップへ進む",
            "ng": "400 入力値エラーを返す",
            "ngResponseRef": "400-validation",
            "ngBodyExpression": "{ code: 'VALIDATION', message: '入力値が不正です', fieldErrors: @fieldErrors }"
          }
        },
        {
          "id": "step-02",
          "type": "dbAccess",
          "description": "securities マスタから取引可否と市場コードを取得する。",
          "maturity": "committed",
          "tableName": "securities",
          "operation": "SELECT",
          "sql": "SELECT security_code, market_code, lot_size, is_tradable FROM securities WHERE security_code = @inputs.securityCode",
          "outputBinding": "security",
          "lineage": {
            "reads": [
              "securities"
            ]
          },
          "cache": {
            "ttlSeconds": 60,
            "key": "security-@inputs.securityCode",
            "invalidateOn": [
              "security.updated"
            ]
          }
        },
        {
          "id": "step-03",
          "type": "branch",
          "description": "取引不可銘柄を 422 で返す。",
          "maturity": "committed",
          "branches": [
            {
              "id": "br-03-a",
              "code": "A",
              "label": "取引不可",
              "condition": "@security == null || @security.is_tradable == false",
              "steps": [
                {
                  "id": "step-03-a-01",
                  "type": "return",
                  "description": "422 取引不可",
                  "responseRef": "422-security-not-tradable",
                  "bodyExpression": "{ code: 'SECURITY_NOT_TRADABLE', message: '指定銘柄は取引できません' }"
                }
              ]
            }
          ],
          "elseBranch": {
            "id": "br-03-else",
            "code": "B",
            "label": "取引可能",
            "steps": []
          }
        },
        {
          "id": "step-04",
          "type": "dbAccess",
          "description": "trading_calendar から市場営業状態を取得する。",
          "maturity": "committed",
          "tableName": "trading_calendar",
          "operation": "SELECT",
          "sql": "SELECT market_code, market_date, is_open, open_at, close_at FROM trading_calendar WHERE market_code = @security.market_code AND market_date = @marketDate",
          "outputBinding": "tradingCalendar",
          "lineage": {
            "reads": [
              "trading_calendar"
            ]
          },
          "cache": {
            "ttlSeconds": 300,
            "key": "calendar-@security.market_code-@marketDate",
            "invalidateOn": [
              "trading_calendar.updated"
            ]
          }
        },
        {
          "id": "step-05",
          "type": "branch",
          "description": "市場時間外なら 422 を返す。",
          "maturity": "committed",
          "branches": [
            {
              "id": "br-05-a",
              "code": "A",
              "label": "市場時間外",
              "condition": "@tradingCalendar == null || @tradingCalendar.is_open == false",
              "steps": [
                {
                  "id": "step-05-a-01",
                  "type": "return",
                  "description": "422 市場時間外",
                  "responseRef": "422-market-closed",
                  "bodyExpression": "{ code: 'MARKET_CLOSED', message: '市場時間外です' }"
                }
              ]
            }
          ],
          "elseBranch": {
            "id": "br-05-else",
            "code": "B",
            "label": "市場時間内",
            "steps": []
          }
        },
        {
          "id": "step-06",
          "type": "dbAccess",
          "description": "accounts と credit_limits を取得する。",
          "maturity": "committed",
          "tableName": "accounts",
          "operation": "SELECT",
          "sql": "SELECT a.id, a.leverage_rate, c.available_amount FROM accounts a JOIN credit_limits c ON c.account_id = a.id WHERE a.id = @inputs.accountId",
          "outputBinding": "account",
          "lineage": {
            "reads": [
              "accounts",
              "credit_limits"
            ]
          }
        },
        {
          "id": "step-07",
          "type": "compute",
          "description": "@fn.calcRequiredMargin で必要証拠金を算出する。",
          "maturity": "committed",
          "expression": "@fn.calcRequiredMargin(@inputs.quantity, @inputs.price, @account.leverage_rate)",
          "outputBinding": "requiredMargin"
        },
        {
          "id": "step-08",
          "type": "branch",
          "description": "与信枠超過なら 422 を返す。",
          "maturity": "committed",
          "branches": [
            {
              "id": "br-08-a",
              "code": "A",
              "label": "与信枠超過",
              "condition": "@requiredMargin > @account.available_amount",
              "steps": [
                {
                  "id": "step-08-a-01",
                  "type": "return",
                  "description": "422 与信枠超過",
                  "responseRef": "422-credit-limit-exceeded",
                  "bodyExpression": "{ code: 'CREDIT_LIMIT_EXCEEDED', message: '与信枠を超過しています' }"
                }
              ]
            }
          ],
          "elseBranch": {
            "id": "br-08-else",
            "code": "B",
            "label": "与信枠内",
            "steps": []
          }
        },
        {
          "id": "step-09",
          "type": "compute",
          "description": "@fn.selectExchangeRoute(@inputs.securityCode, @security.market_code) で TSE または OSE を決定する。",
          "maturity": "committed",
          "expression": "@fn.selectExchangeRoute(@inputs.securityCode, @security.market_code)",
          "outputBinding": "exchangeRoute"
        },
        {
          "id": "step-10",
          "type": "transactionScope",
          "description": "orders INSERT のみを 1 トランザクションで実行する。外部取引所連携と ROUTED 更新は TX 外で行う。",
          "maturity": "committed",
          "isolationLevel": "READ_COMMITTED",
          "propagation": "REQUIRED",
          "steps": [
            {
              "id": "step-10",
              "type": "dbAccess",
              "description": "orders に PENDING 注文を登録する。",
              "maturity": "committed",
              "tableName": "orders",
              "operation": "INSERT",
              "sql": "INSERT INTO orders (account_id, security_code, side, quantity, price, order_type, status, required_margin, created_by, created_at) VALUES (@inputs.accountId, @inputs.securityCode, @inputs.side, @inputs.quantity, @inputs.price, @inputs.orderType, 'PENDING', @requiredMargin, @sessionUserId, NOW()) RETURNING id",
              "outputBinding": "newOrder",
              "lineage": {
                "writes": [
                  "orders"
                ]
              }
            }
          ]
        },
        {
          "id": "step-10b",
          "type": "eventPublish",
          "description": "order.received イベントを発行する。",
          "maturity": "committed",
          "topic": "order.received",
          "eventRef": "order.received",
          "payload": "{ orderId: @newOrder.id, accountId: @inputs.accountId, securityCode: @inputs.securityCode, side: @inputs.side, quantity: @inputs.quantity }"
        },
        {
          "id": "step-11",
          "type": "externalSystem",
          "description": "取引所へ NewOrderSingle を送信する。systemRef は @exchangeRoute が TSE なら tseExchange、OSE なら oseExchange を選ぶ。",
          "maturity": "committed",
          "systemName": "Exchange Order Gateway",
          "systemRef": "@exchangeRoute == 'TSE' ? 'tseExchange' : 'oseExchange'",
          "operationId": "NewOrderSingle",
          "httpCall": {
            "method": "POST",
            "path": "/orders/new-order-single",
            "body": "{ orderId: @newOrder.id, accountId: @inputs.accountId, securityCode: @inputs.securityCode, side: @inputs.side, quantity: @inputs.quantity, price: @inputs.price, orderType: @inputs.orderType }"
          },
          "idempotencyKey": "@inputs.idempotencyKey ?? @requestId",
          "outputBinding": "exchangeResult",
          "outcomes": {
            "success": {
              "action": "continue"
            },
            "failure": {
              "action": "continue"
            },
            "timeout": {
              "action": "abort",
              "sameAs": "failure"
            }
          },
          "operationRef": "/openapi/securities/exchanges#NewOrderSingle"
        },
        {
          "id": "step-12",
          "type": "branch",
          "description": "取引所送信 failure の場合は orders を REJECTED に補償更新し、502 を返す。",
          "maturity": "committed",
          "branches": [
            {
              "id": "br-12-a",
              "code": "A",
              "label": "送信失敗",
              "condition": "@exchangeResult.success == false",
              "steps": [
                {
                  "id": "step-12-comp",
                  "type": "dbAccess",
                  "description": "補償処理: orders を REJECTED に更新する。",
                  "maturity": "committed",
                  "tableName": "orders",
                  "operation": "UPDATE",
                  "sql": "UPDATE orders SET status = 'REJECTED', reject_reason = 'EXCHANGE_REJECTED', updated_at = NOW() WHERE id = @newOrder.id",
                  "lineage": {
                    "writes": [
                      "orders"
                    ]
                  }
                },
                {
                  "id": "step-12-a-02",
                  "type": "return",
                  "description": "502 取引所拒否",
                  "responseRef": "502-exchange-rejected",
                  "bodyExpression": "{ code: 'EXCHANGE_REJECTED', message: '取引所が注文を拒否しました' }"
                }
              ]
            }
          ],
          "elseBranch": {
            "id": "br-12-else",
            "code": "B",
            "label": "送信成功",
            "steps": []
          }
        },
        {
          "id": "step-13",
          "type": "dbAccess",
          "description": "orders を ROUTED に更新し、取引所 OrderID を保存する。",
          "maturity": "committed",
          "tableName": "orders",
          "operation": "UPDATE",
          "sql": "UPDATE orders SET status = 'ROUTED', exchange_code = @exchangeRoute, exchange_order_id = @exchangeResult.exchangeOrderId, updated_at = NOW() WHERE id = @newOrder.id",
          "lineage": {
            "writes": [
              "orders"
            ]
          }
        },
        {
          "id": "step-14",
          "type": "eventPublish",
          "description": "order.routed イベントを発行する。",
          "maturity": "committed",
          "topic": "order.routed",
          "eventRef": "order.routed",
          "payload": "{ orderId: @newOrder.id, exchangeOrderId: @exchangeResult.exchangeOrderId, exchangeCode: @exchangeRoute, status: 'ROUTED' }"
        },
        {
          "id": "step-15",
          "type": "return",
          "description": "202 Accepted を返す。",
          "maturity": "committed",
          "responseRef": "202-accepted",
          "bodyExpression": "{ orderId: @newOrder.id, status: 'ROUTED' }"
        }
      ]
    },
    {
      "id": "act-002",
      "name": "約定通知受信",
      "trigger": "other",
      "description": "external trigger: 取引所から ExecutionReport を受信し、約定を冪等登録して注文ステータスを更新する。",
      "maturity": "committed",
      "httpRoute": {
        "method": "POST",
        "path": "/internal/exchange-callback/execution-report",
        "auth": "required"
      },
      "inputs": [
        {
          "name": "orderId",
          "label": "注文 ID",
          "type": "string",
          "required": true,
          "domainRef": "OrderId"
        },
        {
          "name": "tradeId",
          "label": "約定 ID",
          "type": "string",
          "required": true,
          "domainRef": "TradeId"
        },
        {
          "name": "executedQty",
          "label": "約定数量",
          "type": "number",
          "required": true,
          "domainRef": "Quantity"
        },
        {
          "name": "executedPrice",
          "label": "約定価格",
          "type": "number",
          "required": true,
          "domainRef": "Price"
        },
        {
          "name": "executedAt",
          "label": "約定時刻",
          "type": "string",
          "required": true
        }
      ],
      "outputs": [
        {
          "name": "status",
          "label": "注文ステータス",
          "type": "string"
        }
      ],
      "responses": [
        {
          "id": "200-ok",
          "status": 200,
          "bodySchema": {
            "typeRef": "ExecutionReportResponse"
          },
          "when": "約定通知を処理した"
        },
        {
          "id": "404-order-not-found",
          "status": 404,
          "bodySchema": {
            "typeRef": "ApiError"
          },
          "when": "注文が存在しない"
        },
        {
          "id": "400-order-cancelled",
          "status": 400,
          "bodySchema": {
            "typeRef": "ApiError"
          },
          "when": "対象注文が CANCELLED 状態"
        },
        {
          "id": "400-validation",
          "status": 400,
          "bodySchema": {
            "typeRef": "ApiError"
          }
        },
        {
          "id": "422-security-not-tradable",
          "status": 422,
          "bodySchema": {
            "typeRef": "ApiError"
          }
        },
        {
          "id": "422-market-closed",
          "status": 422,
          "bodySchema": {
            "typeRef": "ApiError"
          }
        },
        {
          "id": "422-credit-limit-exceeded",
          "status": 422,
          "bodySchema": {
            "typeRef": "ApiError"
          }
        },
        {
          "id": "502-exchange-rejected",
          "status": 502,
          "bodySchema": {
            "typeRef": "ApiError"
          }
        },
        {
          "id": "504-exchange-timeout",
          "status": 504,
          "bodySchema": {
            "typeRef": "ApiError"
          }
        },
        {
          "id": "503-cache-warmup-failed",
          "status": 503,
          "bodySchema": {
            "typeRef": "ApiError"
          }
        }
      ],
      "steps": [
        {
          "id": "step-01",
          "type": "validation",
          "description": "全フィールド必須、executedQty > 0 を検証する。",
          "maturity": "committed",
          "conditions": "orderId/tradeId/executedQty/executedPrice/executedAt は必須。executedQty > 0。",
          "rules": [
            {
              "field": "orderId",
              "type": "required",
              "message": "注文 ID は必須です"
            },
            {
              "field": "tradeId",
              "type": "required",
              "message": "約定 ID は必須です"
            },
            {
              "field": "executedQty",
              "type": "range",
              "min": 1,
              "message": "約定数量は 1 以上です"
            },
            {
              "field": "executedPrice",
              "type": "required",
              "message": "約定価格は必須です"
            },
            {
              "field": "executedAt",
              "type": "required",
              "message": "約定時刻は必須です"
            }
          ]
        },
        {
          "id": "step-02",
          "type": "dbAccess",
          "description": "orders を取得する。",
          "maturity": "committed",
          "tableName": "orders",
          "operation": "SELECT",
          "sql": "SELECT id, quantity, executed_qty, status FROM orders WHERE id = @inputs.orderId",
          "outputBinding": "order",
          "lineage": {
            "reads": [
              "orders"
            ]
          }
        },
        {
          "id": "step-03",
          "type": "branch",
          "description": "注文が存在しない、または CANCELLED 状態の場合はエラーを返す。",
          "maturity": "committed",
          "branches": [
            {
              "id": "br-03-a",
              "code": "A",
              "label": "注文なし",
              "condition": "@order == null",
              "steps": [
                {
                  "id": "step-03-a-01",
                  "type": "return",
                  "description": "404 注文なし",
                  "responseRef": "404-order-not-found",
                  "bodyExpression": "{ code: 'ORDER_NOT_FOUND', message: '注文が見つかりません' }"
                }
              ]
            },
            {
              "id": "br-03-b",
              "code": "B",
              "label": "キャンセル済み注文",
              "condition": "@order != null && @order.status == 'CANCELLED'",
              "steps": [
                {
                  "id": "step-03-b-01",
                  "type": "return",
                  "description": "400 キャンセル済み注文",
                  "responseRef": "400-order-cancelled",
                  "bodyExpression": "{ code: 'ORDER_CANCELLED', message: '対象注文はキャンセル済みです' }"
                }
              ]
            }
          ],
          "elseBranch": {
            "id": "br-03-else",
            "code": "C",
            "label": "取引中の注文",
            "steps": []
          }
        },
        {
          "id": "step-04",
          "type": "dbAccess",
          "description": "UPSERT_IDEMPOTENT: trades を tradeId 一意で冪等登録し、既存なら no-op にする。",
          "maturity": "committed",
          "tableName": "trades",
          "operation": "UPSERT_IDEMPOTENT",
          "sql": "INSERT INTO trades (trade_id, order_id, executed_qty, executed_price, executed_at, created_at) VALUES (@inputs.tradeId, @inputs.orderId, @inputs.executedQty, @inputs.executedPrice, @inputs.executedAt, NOW()) ON CONFLICT (trade_id) DO NOTHING RETURNING trade_id",
          "outputBinding": "upsertedTrade",
          "lineage": {
            "writes": [
              "trades"
            ]
          }
        },
        {
          "id": "step-05",
          "type": "dbAccess",
          "description": "orders.executed_qty を加算し、全量なら FILLED、部分なら PARTIALLY_FILLED に更新する。",
          "maturity": "committed",
          "tableName": "orders",
          "operation": "UPDATE",
          "sql": "UPDATE orders SET executed_qty = executed_qty + @inputs.executedQty, status = CASE WHEN executed_qty + @inputs.executedQty >= quantity THEN 'FILLED' ELSE 'PARTIALLY_FILLED' END, updated_at = NOW() WHERE id = @inputs.orderId AND @upsertedTrade.trade_id IS NOT NULL RETURNING status",
          "outputBinding": "updatedOrder",
          "lineage": {
            "writes": [
              "orders"
            ]
          },
          "runIf": "@upsertedTrade.trade_id != null"
        },
        {
          "id": "step-06",
          "type": "eventPublish",
          "description": "trade.executed イベントを発行する。",
          "maturity": "committed",
          "topic": "trade.executed",
          "eventRef": "trade.executed",
          "payload": "{ orderId: @inputs.orderId, tradeId: @inputs.tradeId, executedQty: @inputs.executedQty, executedPrice: @inputs.executedPrice, status: @updatedOrder.status }",
          "runIf": "@upsertedTrade.trade_id != null"
        },
        {
          "id": "step-07",
          "type": "externalSystem",
          "description": "notificationGateway に約定通知を依頼する。fireAndForget なので失敗しても処理を継続する。",
          "maturity": "committed",
          "systemName": "Trade Notification Gateway",
          "systemRef": "notificationGateway",
          "httpCall": {
            "method": "POST",
            "path": "/notifications/trades",
            "body": "{ orderId: @inputs.orderId, tradeId: @inputs.tradeId, executedQty: @inputs.executedQty, executedPrice: @inputs.executedPrice, status: @updatedOrder.status }"
          },
          "fireAndForget": true,
          "outcomes": {
            "success": {
              "action": "continue"
            },
            "failure": {
              "action": "continue"
            },
            "timeout": {
              "action": "continue",
              "sameAs": "failure"
            }
          },
          "runIf": "@upsertedTrade.trade_id != null",
          "operationId": "SendNotification",
          "operationRef": "/openapi/notification-gateway#SendNotification"
        },
        {
          "id": "step-08",
          "type": "eventPublish",
          "description": "trade.notified イベントを発行する。",
          "maturity": "committed",
          "topic": "trade.notified",
          "eventRef": "trade.notified",
          "payload": "{ orderId: @inputs.orderId, tradeId: @inputs.tradeId, notificationRequested: true }",
          "runIf": "@upsertedTrade.trade_id != null"
        },
        {
          "id": "step-09",
          "type": "return",
          "description": "200 OK を返す。",
          "maturity": "committed",
          "responseRef": "200-ok",
          "bodyExpression": "{ status: @updatedOrder.status }",
          "runIf": "@upsertedTrade.trade_id != null"
        },
        {
          "id": "step-09b",
          "type": "return",
          "description": "冪等 no-op の場合は処理済みとして 200 OK を返す。",
          "maturity": "committed",
          "runIf": "@upsertedTrade.trade_id == null",
          "responseRef": "200-ok",
          "bodyExpression": "{ status: 'ALREADY_PROCESSED' }"
        }
      ]
    },
    {
      "id": "act-003",
      "name": "市場開場時の銘柄マスタ事前ウォームアップ",
      "trigger": "marketOpen",
      "description": "市場開場時に当日の取引可能銘柄マスタを事前にキャッシュへロードしておく。注文受付の cache miss を抑制するための事前準備処理。",
      "maturity": "committed",
      "httpRoute": {
        "method": "POST",
        "path": "/internal/scheduled/market-open-warmup",
        "auth": "required"
      },
      "inputs": [],
      "outputs": [
        {
          "name": "cachedSecurityCount",
          "label": "キャッシュ済み銘柄数",
          "type": "number"
        }
      ],
      "responses": [
        {
          "id": "200-ok",
          "status": 200,
          "bodySchema": {
            "schema": {
              "type": "object",
              "required": [
                "cachedSecurityCount"
              ],
              "properties": {
                "cachedSecurityCount": {
                  "type": "number"
                }
              },
              "additionalProperties": false
            }
          },
          "when": "銘柄マスタの事前ウォームアップが完了した"
        },
        {
          "id": "503-cache-warmup-failed",
          "status": 503,
          "bodySchema": {
            "typeRef": "ApiError"
          },
          "when": "銘柄マスタの事前ウォームアップに失敗した"
        },
        {
          "id": "400-validation",
          "status": 400,
          "bodySchema": {
            "typeRef": "ApiError"
          }
        },
        {
          "id": "422-security-not-tradable",
          "status": 422,
          "bodySchema": {
            "typeRef": "ApiError"
          }
        },
        {
          "id": "422-market-closed",
          "status": 422,
          "bodySchema": {
            "typeRef": "ApiError"
          }
        },
        {
          "id": "422-credit-limit-exceeded",
          "status": 422,
          "bodySchema": {
            "typeRef": "ApiError"
          }
        },
        {
          "id": "502-exchange-rejected",
          "status": 502,
          "bodySchema": {
            "typeRef": "ApiError"
          }
        },
        {
          "id": "504-exchange-timeout",
          "status": 504,
          "bodySchema": {
            "typeRef": "ApiError"
          }
        },
        {
          "id": "404-order-not-found",
          "status": 404,
          "bodySchema": {
            "typeRef": "ApiError"
          }
        },
        {
          "id": "400-order-cancelled",
          "status": 400,
          "bodySchema": {
            "typeRef": "ApiError"
          }
        }
      ],
      "steps": [
        {
          "id": "step-01",
          "type": "dbAccess",
          "description": "当日取引可能銘柄一覧を取得する。",
          "maturity": "committed",
          "tableName": "securities",
          "operation": "SELECT",
          "sql": "SELECT code FROM securities WHERE is_tradable = true",
          "outputBinding": "tradableSecurities",
          "lineage": {
            "reads": [
              "securities"
            ]
          }
        },
        {
          "id": "step-02",
          "type": "loop",
          "description": "各銘柄に対してキャッシュキーを生成し、銘柄詳細をキャッシュへロードする。",
          "maturity": "committed",
          "loopKind": "collection",
          "collectionSource": "@tradableSecurities",
          "collectionItemName": "item",
          "steps": [
            {
              "id": "step-02-01",
              "type": "compute",
              "description": "銘柄キャッシュキーを生成する。",
              "maturity": "committed",
              "expression": "'security-' + @item.code",
              "outputBinding": "cacheKey"
            },
            {
              "id": "step-02-02",
              "type": "dbAccess",
              "description": "securities 詳細を取得し、銘柄キャッシュへ書き込む。",
              "maturity": "committed",
              "tableName": "securities",
              "operation": "SELECT",
              "sql": "SELECT * FROM securities WHERE code = @item.code",
              "outputBinding": "securityDetail",
              "lineage": {
                "reads": [
                  "securities"
                ]
              },
              "cache": {
                "ttlSeconds": 86400,
                "key": "@cacheKey",
                "invalidateOn": [
                  "security.updated"
                ]
              }
            }
          ],
          "outputBinding": "cacheCount"
        },
        {
          "id": "step-03",
          "type": "eventPublish",
          "description": "securities.market_open_warmed イベントを発行する。",
          "maturity": "committed",
          "topic": "securities.market_open_warmed",
          "eventRef": "securities.market_open_warmed",
          "payload": "{ marketDate: @marketDate, cachedSecurityCount: @cacheCount }"
        },
        {
          "id": "step-04",
          "type": "return",
          "description": "200 OK を返す。",
          "maturity": "committed",
          "responseRef": "200-ok",
          "bodyExpression": "{ cachedSecurityCount: @cacheCount }"
        }
      ],
      "requiredPermissions": [
        "system"
      ]
    }
  ],
  "testScenarios": [
    {
      "id": "happy-path-buy-order-tse",
      "name": "BUY 注文が TSE に回送され約定完了する",
      "description": "取引可能銘柄の BUY 注文を受け付け、TSE へ回送した後、約定通知で FILLED になる正常系。",
      "given": [
        {
          "kind": "clock",
          "now": "2026-04-26T00:30:00.000Z"
        },
        {
          "kind": "sessionContext",
          "context": {
            "sessionUserId": "user-100",
            "requestId": "req-459-happy",
            "marketDate": "2026-04-26"
          }
        },
        {
          "kind": "dbState",
          "table": "securities",
          "rows": [
