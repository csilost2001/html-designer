    },
    "AccountId": {
      "type": "string",
      "uiHint": "text",
      "description": "証券口座 ID。"
    },
    "TradeId": {
      "type": "string",
      "uiHint": "text",
      "description": "取引所が通知する約定 ID。"
    },
    "SecurityCode": {
      "type": "string",
      "uiHint": "text",
