{
  "id": "gggggggg-0004-4000-8000-gggggggggggg",
  "name": "配送指示 (小売)",
  "type": "system",
  "screenId": "aaaaaaaa-0004-4000-8000-gggggggggggg",
  "description": "注文確定イベント (order.confirmed) を受けて配送指示レコードを生成し、物流会社 API に配送依頼を送信する。retail:ShipmentDispatchStep を使用した小売業サンプル。",
  "apiVersion": "v2",
  "mode": "downstream",
  "maturity": "committed",
  "eventsCatalog": {
    "shipment.created": {
      "description": "配送指示レコードが生成され、物流会社への連携が完了した時点で発行されるイベント。",
      "payload": {
        "type": "object",
        "required": ["shipmentId", "orderId", "trackingNumber", "carrierCode"],
        "properties": {
          "shipmentId": { "type": "string" },
          "orderId": { "type": "string" },
          "trackingNumber": { "type": "string" },
          "carrierCode": { "type": "string" },
          "estimatedDeliveryDate": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "shipment.dispatch_failed": {
      "description": "物流会社 API への配送依頼が失敗した時点で発行されるイベント。配送指示レコードは PENDING のまま残る。",
      "payload": {
        "type": "object",
        "required": ["orderId", "errorCode"],
        "properties": {
          "orderId": { "type": "string" },
          "errorCode": { "type": "string" },
          "retryCount": { "type": "number" }
        },
        "additionalProperties": false
      }
    },
    "shipment.carrier_notified": {
      "description": "物流会社 API への配送依頼送信を試行した後に発行されるイベント (成否問わず)。",
      "payload": {
        "type": "object",
        "required": ["shipmentId", "orderId", "carrierCode", "success"],
        "properties": {
          "shipmentId": { "type": "string" },
          "orderId": { "type": "string" },
          "carrierCode": { "type": "string" },
          "success": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "retail.max_delivery_attempts_exceeded": {
      "description": "配送試行上限 (@conv.limit.maxDeliveryAttempts=3) に達した配送指示が存在する場合に発行されるイベント。",
      "payload": {
        "type": "object",
        "required": ["shipmentId", "orderId", "attemptCount"],
        "properties": {
          "shipmentId": { "type": "string" },
          "orderId": { "type": "string" },
          "attemptCount": { "type": "number" }
        },
        "additionalProperties": false
      }
    }
  },
  "glossary": {
    "配送指示": {
      "definition": "注文確定後に生成される配送依頼レコード。物流会社への連携情報 (追跡番号・業者コード) を管理する。",
      "aliases": ["Shipment", "配送依頼"],
      "domainRef": "shipments"
    },
    "物流会社": {
      "definition": "配送依頼を受け付け、商品を顧客に届ける外部業者。carrierCode (YAMATO / SAGAWA / JP_POST 等) で識別する。",
      "aliases": ["Carrier", "配送業者"],
      "domainRef": "shipments.carrier_code"
    },
    "追跡番号": {
      "definition": "物流会社が発行する配送追跡番号。物流会社 API のレスポンスから取得する。",
      "aliases": ["TrackingNumber", "配送番号"],
      "domainRef": "shipments.tracking_number"
    },
    "配送試行上限": {
      "definition": "配送依頼の試行上限回数。@conv.limit.maxDeliveryAttempts=3。超過した場合は FAILED ステータスに更新しサポートに通知する。",
      "aliases": ["MaxDeliveryAttempts"],
      "domainRef": "retail.maxDeliveryAttempts"
    },
    "配送ステータス": {
      "definition": "shipments.status の値。PENDING / DISPATCHED / IN_TRANSIT / DELIVERED / FAILED のいずれか。existingShipment.id は shipments.id (PK, UUID v4) で、order_id に対して 1:1 制約 (UNIQUE INDEX)。",
      "aliases": ["ShipmentStatus"],
      "domainRef": "shipments.status"
    },
    "注文-配送対応": {
      "definition": "1 注文に対して 1 配送指示レコードを生成する 1:1 対応 (本サンプルの制約)。複数口配送は将来拡張。",
      "aliases": ["Order-Shipment Mapping"],
      "domainRef": "shipments.order_id"
    },
    "配送予定日": {
      "definition": "物流会社 API が返す配送予定日。shipments.estimated_delivery_date に保存する。",
      "aliases": ["EstimatedDeliveryDate"],
      "domainRef": "shipments.estimated_delivery_date"
    },
    "配送指示補償": {
      "definition": "物流会社 API 失敗時に shipments.status を PENDING のまま維持し、delivery_attempt_count をインクリメントする補償処理。TX 外で行う。",
      "aliases": ["ShipmentCompensation"],
      "domainRef": "shipments.delivery_attempt_count"
    }
  },
  "decisions": [
    {
      "id": "ADR-001",
      "title": "配送指示レコード INSERT は外部 API 呼び出し前に行う",
      "status": "accepted",
      "context": "物流会社 API は TX 外で呼び出す。API 失敗時に配送指示が記録されない状態を防ぐため、INSERT を先に行う。",
      "decision": "shipments INSERT (status: PENDING) を先に行い、その後に物流会社 API を呼び出す。API 失敗時は status を PENDING のまま維持し、delivery_attempt_count をインクリメントする。",
      "consequences": "API 失敗時も配送指示レコードが残るため、再試行処理を実装しやすい。",
      "date": "2026-04-26"
    },
    {
      "id": "ADR-002",
      "title": "物流会社 API は TX 外、配送試行上限は @conv.limit.maxDeliveryAttempts",
      "status": "accepted",
      "context": "物流会社 API は外部システムのため TX 内に含められない。試行回数の上限管理が必要。",
      "decision": "外部 API は TX 外で呼び出す。失敗時は delivery_attempt_count を +1 し、@conv.limit.maxDeliveryAttempts (3) 超過時は FAILED ステータスに更新してアラートイベントを発行する。",
      "consequences": "最大 3 回試行後に FAILED になる。4 回目以降は manual 対応が必要。",
      "date": "2026-04-26"
    },
    {
      "id": "ADR-004",
      "title": "step-12/13 (DB 更新 2 件) は TX なしでべき等リトライを保証する",
      "status": "accepted",
      "context": "step-12 (shipments DISPATCHED 更新) と step-13 (orders SHIPPED 更新) を TransactionScope に入れるかどうか。",
      "decision": "両ステップは独立した UPDATE であり、いずれかが失敗しても再試行でべき等に収束する。TX は使用しない。step-12 の shipmentId をべき等キーとして利用し、再試行時に同じ値で UPDATE することで副作用が発生しない。",
      "consequences": "step-12 成功後 step-13 失敗のパターンでは orders が CONFIRMED のまま残るが、再試行時に step-12 はノーオペレーション (同値 UPDATE)、step-13 は冪等に SHIPPED に更新される。",
      "date": "2026-04-26"
    },
    {
      "id": "ADR-003",
      "title": "retail:ShipmentDispatchStep で配送指示操作を明示化する",
      "status": "accepted",
      "context": "配送指示は retail namespace 固有の操作。",
      "decision": "type: 'retail:ShipmentDispatchStep' を使用して retail 拡張定義を実利用する。",
      "consequences": "retail namespace の ShipmentDispatchStep が拡張定義に登録されている必要がある。",
      "date": "2026-04-26"
    }
  ],
  "ambientVariables": [
    {
      "name": "requestId",
      "type": "string",
      "required": true,
      "description": "リクエスト単位の追跡 ID。"
    },
    {
      "name": "sessionUserId",
      "type": "string",
      "required": false,
      "description": "起動元ユーザー (システム自動実行時は null)。"
    }
  ],
  "errorCatalog": {
    "VALIDATION": {
      "httpStatus": 400,
      "defaultMessage": "入力値が不正です",
      "responseRef": "400-validation"
    },
    "ORDER_NOT_FOUND": {
      "httpStatus": 404,
      "defaultMessage": "注文が見つかりません",
      "responseRef": "404-order-not-found"
    },
    "ORDER_NOT_CONFIRMED": {
      "httpStatus": 422,
      "defaultMessage": "注文が確定状態ではありません",
      "responseRef": "422-order-not-confirmed"
    },
    "SHIPMENT_ALREADY_EXISTS": {
      "httpStatus": 409,
      "defaultMessage": "配送指示が既に存在します",
      "responseRef": "409-shipment-exists"
    },
    "CARRIER_API_FAILED": {
      "httpStatus": 502,
      "defaultMessage": "物流会社 API への接続に失敗しました",
      "responseRef": "502-carrier-api-failed"
    },
    "MAX_ATTEMPTS_EXCEEDED": {
      "httpStatus": 422,
      "defaultMessage": "配送試行上限に達しました",
      "responseRef": "422-max-attempts-exceeded"
    }
  },
  "externalSystemCatalog": {
    "carrierApiYamato": {
      "name": "ヤマト運輸 API",
      "baseUrl": "https://carrier-api.yamato.example.internal",
      "auth": {
        "kind": "apiKey",
        "tokenRef": "@secret.yamatoApiKey",
        "headerName": "X-API-Key"
      },
      "timeoutMs": 5000,
      "description": "ヤマト運輸の配送依頼 API。追跡番号・配送予定日を返す。",
      "responseSchema": {
        "type": "object",
        "required": ["success", "trackingNumber", "estimatedDeliveryDate"],
        "properties": {
          "success": { "type": "boolean", "description": "配送依頼の成否" },
          "trackingNumber": { "type": "string", "description": "ヤマト運輸が発行する追跡番号" },
          "estimatedDeliveryDate": { "type": "string", "description": "配送予定日 (ISO 8601 date 形式)" }
        }
      }
    },
    "carrierApiSagawa": {
      "name": "佐川急便 API",
      "baseUrl": "https://carrier-api.sagawa.example.internal",
      "auth": {
        "kind": "apiKey",
        "tokenRef": "@secret.sagawaApiKey",
        "headerName": "X-API-Key"
      },
      "timeoutMs": 5000,
      "description": "佐川急便の配送依頼 API。追跡番号・配送予定日を返す。",
      "responseSchema": {
        "type": "object",
        "required": ["success", "trackingNumber", "estimatedDeliveryDate"],
        "properties": {
          "success": { "type": "boolean", "description": "配送依頼の成否" },
          "trackingNumber": { "type": "string", "description": "佐川急便が発行する追跡番号" },
          "estimatedDeliveryDate": { "type": "string", "description": "配送予定日 (ISO 8601 date 形式)" }
        }
      }
    }
  },
  "secretsCatalog": {
    "yamatoApiKey": {
      "source": "env",
      "name": "YAMATO_CARRIER_API_KEY",
      "rotationDays": 90,
      "description": "ヤマト運輸 API キー"
    },
    "sagawaApiKey": {
      "source": "env",
      "name": "SAGAWA_CARRIER_API_KEY",
      "rotationDays": 90,
      "description": "佐川急便 API キー"
    }
  },
  "domainsCatalog": {
    "ShipmentId": {
      "type": "string",
      "uiHint": "text",
      "description": "配送指示 ID。UUID v4。"
    },
    "OrderId": {
      "type": "string",
      "uiHint": "text",
      "description": "注文 ID。orders.id。"
    },
    "CarrierCode": {
      "type": "string",
      "uiHint": "select",
      "description": "物流業者コード。YAMATO / SAGAWA / JP_POST のいずれか。"
    }
  },
  "functionsCatalog": {
    "selectCarrier": {
      "signature": "selectCarrier(shippingAddress: string): string",
      "returnType": "string",
      "description": "配送先住所から最適な物流業者コードを選択する。デフォルトは YAMATO。",
      "examples": [
        "@fn.selectCarrier(@order.shipping_address)"
      ]
    },
    "generateShipmentId": {
      "signature": "generateShipmentId(): string",
      "returnType": "string",
      "description": "配送指示 ID として UUID v4 を生成する。",
      "examples": [
        "@fn.generateShipmentId()"
      ]
    }
  },
  "actions": [
    {
      "id": "act-001",
      "name": "配送指示生成",
      "trigger": "other",
      "description": "external trigger: order.confirmed イベントを受け、orderId を受け取って shipments レコードを生成し、物流会社 API に配送依頼を送信する。retail:ShipmentDispatchStep を使用。",
      "maturity": "committed",
      "httpRoute": {
        "method": "POST",
        "path": "/internal/retail/shipments/dispatch",
        "auth": "required"
      },
      "inputs": [
        {
          "name": "orderId",
          "label": "注文ID",
          "type": "string",
          "required": true,
          "domainRef": "OrderId"
        },
        {
          "name": "carrierCode",
          "label": "配送業者コード",
          "type": "string",
          "required": false,
          "domainRef": "CarrierCode"
        }
      ],
      "outputs": [
        {
          "name": "shipmentId",
          "label": "配送指示ID",
          "type": "string",
          "domainRef": "ShipmentId"
        },
        {
          "name": "trackingNumber",
          "label": "追跡番号",
          "type": "string"
        },
        {
          "name": "status",
          "label": "配送ステータス",
          "type": "string"
        }
      ],
      "responses": [
        {
          "id": "201-created",
          "status": 201,
          "bodySchema": { "typeRef": "ShipmentDispatchResponse" },
          "when": "配送指示が生成され物流会社への連携が完了した"
        },
        {
          "id": "400-validation",
          "status": 400,
          "bodySchema": { "typeRef": "ApiError" },
          "when": "入力値が不正"
        },
        {
          "id": "404-order-not-found",
          "status": 404,
          "bodySchema": { "typeRef": "ApiError" },
          "when": "注文が存在しない"
        },
        {
          "id": "422-order-not-confirmed",
          "status": 422,
          "bodySchema": { "typeRef": "ApiError" },
          "when": "注文が CONFIRMED ステータスではない"
        },
        {
          "id": "409-shipment-exists",
          "status": 409,
          "bodySchema": { "typeRef": "ApiError" },
          "when": "配送指示が既に存在する"
        },
        {
          "id": "502-carrier-api-failed",
          "status": 502,
          "bodySchema": { "typeRef": "ApiError" },
          "when": "物流会社 API 呼び出しが失敗"
        },
        {
          "id": "422-max-attempts-exceeded",
          "status": 422,
          "bodySchema": { "typeRef": "ApiError" },
          "when": "配送試行上限超過"
        }
      ],
      "steps": [
        {
          "id": "step-01",
          "type": "validation",
          "description": "orderId は必須。",
          "maturity": "committed",
          "conditions": "orderId は必須。",
          "rules": [
            {
              "field": "orderId",
              "type": "required",
              "message": "注文 ID は必須です"
            }
          ],
          "fieldErrorsVar": "fieldErrors",
          "inlineBranch": {
            "ok": "次のステップへ進む",
            "ng": "400 入力値エラーを返す",
            "ngResponseRef": "400-validation",
            "ngBodyExpression": "{ code: 'VALIDATION', message: '入力値が不正です', fieldErrors: @fieldErrors }"
          }
        },
        {
          "id": "step-02",
          "type": "dbAccess",
          "description": "注文の存在・ステータス・配送先住所を取得する。",
          "maturity": "committed",
          "tableName": "orders",
          "operation": "SELECT",
          "sql": "SELECT id, status, shipping_address, customer_id FROM orders WHERE id = @inputs.orderId",
          "outputBinding": "order",
          "lineage": { "reads": ["orders"] }
        },
        {
          "id": "step-03",
          "type": "branch",
          "description": "注文なし / CONFIRMED 以外の場合はエラーを返す。",
          "maturity": "committed",
          "branches": [
            {
              "id": "br-03-a",
              "code": "A",
              "label": "注文なし",
              "condition": "@order == null",
              "steps": [
                {
                  "id": "step-03-a-01",
                  "type": "return",
                  "description": "404 注文なし",
                  "responseRef": "404-order-not-found",
                  "bodyExpression": "{ code: 'ORDER_NOT_FOUND', message: '注文が見つかりません' }"
                }
              ]
            },
            {
              "id": "br-03-b",
              "code": "B",
              "label": "注文未確定",
              "condition": "@order != null && @order.status != 'CONFIRMED'",
              "steps": [
                {
                  "id": "step-03-b-01",
                  "type": "return",
                  "description": "422 注文未確定",
                  "responseRef": "422-order-not-confirmed",
                  "bodyExpression": "{ code: 'ORDER_NOT_CONFIRMED', message: '注文が確定状態ではありません' }"
                }
              ]
            }
          ],
          "elseBranch": {
            "id": "br-03-else",
            "code": "C",
            "label": "注文確定済",
            "steps": []
          }
        },
        {
          "id": "step-04",
          "type": "dbAccess",
          "description": "既に配送指示が存在するか確認する。",
          "maturity": "committed",
          "tableName": "shipments",
          "operation": "SELECT",
          "sql": "SELECT id, delivery_attempt_count, status FROM shipments WHERE order_id = @inputs.orderId",
          "outputBinding": "existingShipment",
          "lineage": { "reads": ["shipments"] }
        },
        {
          "id": "step-05",
          "type": "branch",
          "description": "配送指示が既に存在する場合: DISPATCHED 以上ならば 409、試行回数上限超過なら 422、そうでなければ試行を継続する。",
          "maturity": "committed",
          "branches": [
            {
              "id": "br-05-a",
              "code": "A",
              "label": "配送完了済",
              "condition": "@existingShipment != null && (@existingShipment.status == 'DISPATCHED' || @existingShipment.status == 'IN_TRANSIT' || @existingShipment.status == 'DELIVERED')",
              "steps": [
                {
                  "id": "step-05-a-01",
                  "type": "return",
                  "description": "409 配送指示既存",
                  "responseRef": "409-shipment-exists",
                  "bodyExpression": "{ code: 'SHIPMENT_ALREADY_EXISTS', message: '配送指示が既に存在します' }"
                }
              ]
            },
            {
              "id": "br-05-b",
              "code": "B",
              "label": "試行上限超過",
              "condition": "@existingShipment != null && @existingShipment.delivery_attempt_count > @conv.limit.maxDeliveryAttempts",
              "steps": [
                {
                  "id": "step-05-b-00",
                  "type": "dbAccess",
                  "description": "配送指示を FAILED ステータスに更新する。試行上限超過を永続化する。",
                  "maturity": "committed",
                  "tableName": "shipments",
                  "operation": "UPDATE",
                  "sql": "UPDATE shipments SET status = 'FAILED', updated_at = NOW() WHERE id = @existingShipment.id",
                  "lineage": { "writes": ["shipments"] }
                },
                {
                  "id": "step-05-b-01",
                  "type": "eventPublish",
                  "description": "retail.max_delivery_attempts_exceeded イベントを発行する。",
                  "maturity": "committed",
                  "topic": "retail.max_delivery_attempts_exceeded",
                  "eventRef": "retail.max_delivery_attempts_exceeded",
                  "payload": "{ shipmentId: @existingShipment.id, orderId: @inputs.orderId, attemptCount: @existingShipment.delivery_attempt_count }"
                },
                {
                  "id": "step-05-b-02",
                  "type": "return",
                  "description": "422 試行上限超過",
                  "responseRef": "422-max-attempts-exceeded",
                  "bodyExpression": "{ code: 'MAX_ATTEMPTS_EXCEEDED', message: '配送試行上限に達しました' }"
                }
              ]
            }
          ],
          "elseBranch": {
            "id": "br-05-else",
            "code": "C",
            "label": "新規または再試行可能",
            "steps": []
          }
        },
        {
          "id": "step-06",
          "type": "compute",
          "description": "配送指示 ID を採番する。既存 shipment があれば再利用、なければ新規生成。",
          "maturity": "committed",
          "expression": "@existingShipment?.id != null ? @existingShipment.id : @fn.generateShipmentId()",
          "outputBinding": "shipmentId"
        },
        {
          "id": "step-07",
          "type": "compute",
          "description": "物流会社コードを選択する。inputs.carrierCode が指定されれば優先、なければ配送先住所から自動選択。",
          "maturity": "committed",
          "expression": "@inputs.carrierCode != null ? @inputs.carrierCode : @fn.selectCarrier(@order.shipping_address)",
          "outputBinding": "selectedCarrier"
        },
        {
          "id": "step-08",
          "type": "dbAccess",
          "description": "配送指示レコードを PENDING で INSERT する (既存の場合は delivery_attempt_count を +1)。",
          "maturity": "committed",
          "tableName": "shipments",
          "operation": "INSERT",
          "sql": "INSERT INTO shipments (id, order_id, carrier_code, status, delivery_attempt_count, created_at, updated_at) VALUES (@shipmentId, @inputs.orderId, @selectedCarrier, 'PENDING', 1, NOW(), NOW()) ON CONFLICT (id) DO UPDATE SET carrier_code = @selectedCarrier, delivery_attempt_count = shipments.delivery_attempt_count + 1, status = 'PENDING', updated_at = NOW() RETURNING id, delivery_attempt_count",
          "outputBinding": "upsertedShipment",
          "lineage": { "writes": ["shipments"] }
        },
        {
          "id": "step-10",
          "type": "externalSystem",
          "description": "物流会社 API に配送依頼を送信する。carrierCode に応じて carrierApiYamato または carrierApiSagawa を使用する。",
          "maturity": "committed",
          "systemName": "物流会社 API",
          "systemRef": "@selectedCarrier == 'YAMATO' ? 'carrierApiYamato' : 'carrierApiSagawa'",
          "operationId": "CreateShipment",
          "httpCall": {
            "method": "POST",
            "path": "/shipments",
            "body": "{ shipmentId: @shipmentId, orderId: @inputs.orderId, shippingAddress: @order.shipping_address }"
          },
          "idempotencyKey": "@shipmentId",
          "outputBinding": "carrierResult",
          "outcomes": {
            "success": { "action": "continue" },
            "failure": { "action": "continue" },
            "timeout": { "action": "continue", "sameAs": "failure" }
          }
        },
        {
          "id": "step-11",
          "type": "branch",
          "description": "物流会社 API 失敗時は delivery_attempt_count を確認して max 超過なら FAILED に更新、そうでなければ PENDING 継続。",
          "maturity": "committed",
          "branches": [
            {
              "id": "br-11-a",
              "code": "A",
              "label": "API 失敗",
              "condition": "@carrierResult == null || @carrierResult.success != true",
              "steps": [
                {
                  "id": "step-11-a-01",
                  "type": "eventPublish",
                  "description": "shipment.dispatch_failed イベントを発行する。",
                  "maturity": "committed",
                  "topic": "shipment.dispatch_failed",
                  "eventRef": "shipment.dispatch_failed",
                  "payload": "{ orderId: @inputs.orderId, errorCode: 'CARRIER_API_FAILED', retryCount: @upsertedShipment.delivery_attempt_count }",
                  "compensatesFor": "step-08"
                },
                {
                  "id": "step-11-a-01b",
                  "type": "eventPublish",
                  "description": "shipment.carrier_notified イベントを success: false で発行する (catalog 整合)。",
                  "maturity": "committed",
                  "topic": "shipment.carrier_notified",
                  "eventRef": "shipment.carrier_notified",
                  "payload": "{ shipmentId: @shipmentId, orderId: @inputs.orderId, carrierCode: @selectedCarrier, success: false }"
                },
                {
                  "id": "step-11-a-02",
                  "type": "return",
                  "description": "502 物流会社 API 失敗",
                  "responseRef": "502-carrier-api-failed",
                  "bodyExpression": "{ code: 'CARRIER_API_FAILED', message: '物流会社 API への接続に失敗しました' }"
                }
              ]
            }
          ],
          "elseBranch": {
            "id": "br-11-else",
            "code": "B",
            "label": "API 成功",
            "steps": []
          }
        },
        {
          "id": "step-12",
          "type": "dbAccess",
          "description": "shipments を DISPATCHED に更新し、追跡番号・配送予定日を保存する。",
          "maturity": "committed",
          "tableName": "shipments",
          "operation": "UPDATE",
          "sql": "UPDATE shipments SET status = 'DISPATCHED', tracking_number = @carrierResult.trackingNumber, estimated_delivery_date = @carrierResult.estimatedDeliveryDate, updated_at = NOW() WHERE id = @shipmentId",
          "lineage": { "writes": ["shipments"] }
        },
        {
          "id": "step-13",
          "type": "dbAccess",
          "description": "orders を SHIPPED に更新する。",
          "maturity": "committed",
          "tableName": "orders",
          "operation": "UPDATE",
          "sql": "UPDATE orders SET status = 'SHIPPED', updated_at = NOW() WHERE id = @inputs.orderId",
          "lineage": { "writes": ["orders"] }
        },
        {
          "id": "step-14",
          "type": "eventPublish",
          "description": "shipment.carrier_notified イベントを発行する。",
          "maturity": "committed",
          "topic": "shipment.carrier_notified",
          "eventRef": "shipment.carrier_notified",
          "payload": "{ shipmentId: @shipmentId, orderId: @inputs.orderId, carrierCode: @selectedCarrier, success: true }"
        },
        {
          "id": "step-15",
          "type": "eventPublish",
          "description": "shipment.created イベントを発行する。",
          "maturity": "committed",
          "topic": "shipment.created",
          "eventRef": "shipment.created",
          "payload": "{ shipmentId: @shipmentId, orderId: @inputs.orderId, trackingNumber: @carrierResult.trackingNumber, carrierCode: @selectedCarrier, estimatedDeliveryDate: @carrierResult.estimatedDeliveryDate }"
        },
        {
          "id": "step-16",
          "type": "return",
          "description": "201 Created を返す。",
          "maturity": "committed",
          "responseRef": "201-created",
          "bodyExpression": "{ shipmentId: @shipmentId, trackingNumber: @carrierResult.trackingNumber, status: 'DISPATCHED', estimatedDeliveryDate: @carrierResult.estimatedDeliveryDate }"
        }
      ]
    }
  ],
  "testScenarios": [
