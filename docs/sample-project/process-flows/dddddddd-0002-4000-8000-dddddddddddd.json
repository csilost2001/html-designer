        { "kind": "dbState", "table": "positions", "rows": [{ "position_id": "POS-001", "account_id": "ACC-001", "security_code": "7203", "quantity": 100, "average_cost": 3000 }] },
        { "kind": "dbState", "table": "pnl_snapshots", "rows": [] },
