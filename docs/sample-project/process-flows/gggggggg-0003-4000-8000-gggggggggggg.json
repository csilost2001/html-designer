{
  "id": "gggggggg-0003-4000-8000-gggggggggggg",
  "name": "注文確定 (小売)",
  "type": "screen",
  "screenId": "aaaaaaaa-0003-4000-8000-gggggggggggg",
  "description": "カートを注文に確定する。TransactionScope 内で orders INSERT / order_items INSERT / 在庫引当 (inventory UPDATE) を原子的に処理する。retail:OrderConfirmStep / retail:InventoryReserveStep を使用。",
  "apiVersion": "v2",
  "mode": "upstream",
  "maturity": "committed",
  "eventsCatalog": {
    "order.confirmed": {
      "description": "注文が確定し、在庫引当が完了した時点で発行されるイベント。後続の配送指示フローを起動するトリガーとなる。",
      "payload": {
        "type": "object",
        "required": ["orderId", "orderNumber", "customerId", "totalAmount"],
        "properties": {
          "orderId": { "type": "string" },
          "orderNumber": { "type": "string" },
          "customerId": { "type": "number" },
          "totalAmount": { "type": "number" },
          "taxAmount": { "type": "number" }
        },
        "additionalProperties": false
      }
    },
    "order.confirm_failed": {
      "description": "注文確定処理が失敗 (在庫不足 / バリデーションエラー等) した場合に発行されるイベント。",
      "payload": {
        "type": "object",
        "required": ["cartId", "customerId", "errorCode"],
        "properties": {
          "cartId": { "type": "string" },
          "customerId": { "type": "number" },
          "errorCode": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "order.inventory_reserved": {
      "description": "注文確定 TX 内で全商品の在庫引当が完了した時点で発行されるイベント。",
      "payload": {
        "type": "object",
        "required": ["orderId", "reservedItems"],
        "properties": {
          "orderId": { "type": "string" },
          "reservedItems": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "productCode": { "type": "string" },
                "quantity": { "type": "number" }
              }
            }
          }
        },
        "additionalProperties": false
      }
    },
    "retail.order_tax_calculated": {
      "description": "税額計算完了時に発行されるイベント。消費税率 @conv.tax.standard.rate を適用した計算結果を含む。",
      "payload": {
        "type": "object",
        "required": ["orderId", "subtotal", "taxAmount", "totalAmount"],
        "properties": {
          "orderId": { "type": "string" },
          "subtotal": { "type": "number" },
          "taxAmount": { "type": "number" },
          "totalAmount": { "type": "number" }
        },
        "additionalProperties": false
      }
    }
  },
  "glossary": {
    "注文確定": {
      "definition": "カートの内容を注文として確定する操作。在庫引当・注文マスタ登録・注文明細登録を原子的に処理する。",
      "aliases": ["OrderConfirm", "チェックアウト"],
      "domainRef": "orders"
    },
    "在庫引当": {
      "definition": "注文確定時に inventory.available_quantity を注文数量分減算する操作。TX 内で行うことで原子性を保証する。",
      "aliases": ["InventoryReservation", "引当処理"],
      "domainRef": "inventory.available_quantity"
    },
    "消費税計算": {
      "definition": "小計 × @conv.tax.standard.rate (10%) で税額を算出し、1 円未満を @conv.tax.standard.roundingMode (切り捨て) する。",
      "aliases": ["TaxCalculation", "税計算"],
      "domainRef": "tax.standard"
    },
    "注文番号": {
      "definition": "確定注文を識別する業務番号。@conv.numbering.orderNumber 準拠 RO-YYYY-NNNN 形式。",
      "aliases": ["OrderNumber"],
      "domainRef": "orders.order_number"
    },
    "トランザクション境界": {
      "definition": "orders INSERT / order_items INSERT / inventory UPDATE の 3 操作を 1 TX に束ねる。TX 外で行う外部連携はなく、全操作が DB 内で完結する。",
      "aliases": ["TransactionBoundary"],
      "domainRef": "tx.singleOperation"
    },
    "カートチェックアウト": {
      "definition": "ACTIVE カートを CHECKED_OUT ステータスに変更し、注文として確定する処理。TX 外で行う。",
      "aliases": ["CartCheckout"],
      "domainRef": "carts.status"
    },
    "注文明細スナップショット": {
      "definition": "注文確定時点の商品名・単価を order_items に保存する。商品マスタの変更後も注文時の情報を保持できる。",
      "aliases": ["OrderItemSnapshot"],
      "domainRef": "order_items"
    },
    "在庫引当失敗補償": {
      "definition": "TX 内で在庫引当が affectedRows = 0 の場合、TX をロールバックして INSUFFICIENT_INVENTORY エラーを返す。",
      "aliases": ["InventoryReserveFailed"],
      "domainRef": "inventory"
    }
  },
  "decisions": [
    {
      "id": "ADR-001",
      "title": "注文確定は 3 テーブルを 1 TX に束ねる",
      "status": "accepted",
      "context": "orders INSERT / order_items INSERT / inventory UPDATE は原子的に成功または失敗する必要がある。",
      "decision": "transactionScope に 3 操作を含め、いずれかが失敗した場合はロールバックする。TX 外の外部連携は含めない。",
      "consequences": "TX が長くなる可能性があるが、在庫引当の整合性を保証できる。外部連携は TX コミット後に行う。",
      "date": "2026-04-26"
    },
    {
      "id": "ADR-002",
      "title": "在庫引当は UPDATE WHERE available_quantity >= quantity で行う",
      "status": "accepted",
      "context": "在庫不足の場合に TX をロールバックする方法として、UPDATE の WHERE 句に在庫チェックを含める方法を採用する。",
      "decision": "UPDATE inventory SET available_quantity = available_quantity - @quantity WHERE product_code = ... AND available_quantity >= @quantity。affectedRows = 0 の場合、affectedRowsCheck で TX をロールバックして INSUFFICIENT_INVENTORY を返す。",
      "consequences": "在庫確認と引当が 1 SQL で原子的に行われる。SELECT + UPDATE の 2 段階チェックより性能が良い。",
      "date": "2026-04-26"
    },
    {
      "id": "ADR-004",
      "title": "branch の elseBranch は fallthrough で後続ステップに継続する",
      "status": "accepted",
      "context": "branch ステップで条件が全 branches に一致しない場合の動作を明示する必要がある。",
      "decision": "elseBranch に steps: [] の場合、後続のステップ (同一 action 内の次の step) に自動的に制御が移る (fallthrough)。return ステップがない限り処理は継続される。",
      "consequences": "elseBranch が空の場合に意図しない fallthrough が発生するリスクを排除するため、各 branch の意図を description で明示する。",
      "date": "2026-04-26"
    },
    {
      "id": "ADR-003",
      "title": "消費税計算は compute step で行い、税率は @conv.tax.standard.rate を参照する",
      "status": "accepted",
      "context": "消費税率の変更に対して処理フローの変更なしに対応できる仕組みが必要。",
      "decision": "税額計算は compute step で @conv.tax.standard.rate を参照して行う。税率変更時は conventions-catalog.json のみ変更する。",
      "consequences": "税率変更時のコード修正が不要になる。ただし @conv.tax.standard.rate の参照は catalog に定義が必要。",
      "date": "2026-04-26"
    }
  ],
  "ambientVariables": [
    {
      "name": "requestId",
      "type": "string",
      "required": true,
      "description": "リクエスト単位の追跡 ID。"
    },
    {
      "name": "sessionUserId",
      "type": "string",
      "required": true,
      "description": "ログインユーザー ID。"
    }
  ],
  "errorCatalog": {
    "VALIDATION": {
      "httpStatus": 400,
      "defaultMessage": "入力値が不正です",
      "responseRef": "400-validation"
    },
    "CART_NOT_FOUND": {
      "httpStatus": 404,
      "defaultMessage": "カートが見つかりません",
      "responseRef": "404-cart-not-found"
    },
    "CART_EMPTY": {
      "httpStatus": 422,
      "defaultMessage": "カートに商品がありません",
      "responseRef": "422-cart-empty"
    },
    "CART_EXPIRED": {
      "httpStatus": 422,
      "defaultMessage": "カートの有効期限が切れています",
      "responseRef": "422-cart-expired"
    },
    "CUSTOMER_NOT_FOUND": {
      "httpStatus": 404,
      "defaultMessage": "顧客情報が見つかりません",
      "responseRef": "404-customer-not-found"
    },
    "INSUFFICIENT_INVENTORY": {
      "httpStatus": 422,
      "defaultMessage": "在庫が不足しています",
      "responseRef": "422-insufficient-inventory"
    },
    "ORDER_CONFIRM_FAILED": {
      "httpStatus": 500,
      "defaultMessage": "注文確定処理に失敗しました",
      "responseRef": "500-order-confirm-failed"
    }
  },
  "externalSystemCatalog": {},
  "secretsCatalog": {},
  "domainsCatalog": {
    "OrderId": {
      "type": "string",
      "uiHint": "text",
      "description": "注文 ID。UUID v4 形式。アプリ層で採番。"
    },
    "CustomerId": {
      "type": "number",
      "uiHint": "number",
      "description": "顧客 ID。customers.id。"
    },
    "Amount": {
      "type": "number",
      "uiHint": "number",
      "constraints": [
        {
          "field": "amount",
          "type": "range",
          "min": 0,
          "message": "金額は 0 以上で入力してください"
        }
      ],
      "description": "金額 (JPY)。DECIMAL(12,0) 保存。"
    }
  },
  "functionsCatalog": {
    "generateUUID": {
      "signature": "generateUUID(): string",
      "returnType": "string",
      "description": "UUID v4 を生成する。注文 ID 採番に使用する。",
      "examples": [
        "@fn.generateUUID()"
      ]
    },
    "calcTax": {
      "signature": "calcTax(subtotal: number, rate: number): number",
      "returnType": "number",
      "description": "小計 × 税率で税額を算出し、1 円未満を切り捨てる。@conv.tax.standard.rate を rate として渡す。",
      "examples": [
        "@fn.calcTax(@subtotal, @conv.tax.standard.rate)"
      ]
    },
    "calcSubtotal": {
      "signature": "calcSubtotal(items: CartItem[]): number",
      "returnType": "number",
      "description": "カート明細の unit_price × quantity の合計を算出する。",
      "examples": [
        "@fn.calcSubtotal(@cartItems)"
      ]
    }
  },
  "actions": [
    {
      "id": "act-001",
      "name": "注文確定",
      "trigger": "submit",
      "description": "cartId と customerId を受け付け、カート明細を注文に確定する。TransactionScope 内で orders / order_items / inventory を処理する。",
      "maturity": "committed",
      "httpRoute": {
        "method": "POST",
        "path": "/api/retail/orders/confirm",
        "auth": "required"
      },
      "inputs": [
        {
          "name": "cartId",
          "label": "カートID",
          "type": "string",
          "required": true
        },
        {
          "name": "customerId",
          "label": "顧客ID",
          "type": "number",
          "required": true,
          "domainRef": "CustomerId"
        },
        {
          "name": "shippingAddress",
          "label": "配送先住所",
          "type": "string",
          "required": false
        }
      ],
      "outputs": [
        {
          "name": "orderId",
          "label": "注文ID",
          "type": "string",
          "domainRef": "OrderId"
        },
        {
          "name": "orderNumber",
          "label": "注文番号",
          "type": "string"
        },
        {
          "name": "status",
          "label": "注文ステータス",
          "type": "string"
        }
      ],
      "responses": [
        {
          "id": "201-created",
          "status": 201,
          "bodySchema": { "typeRef": "OrderConfirmResponse" },
          "when": "注文が確定した"
        },
        {
          "id": "400-validation",
          "status": 400,
          "bodySchema": { "typeRef": "ApiError" },
          "when": "入力値が不正"
        },
        {
          "id": "404-cart-not-found",
          "status": 404,
          "bodySchema": { "typeRef": "ApiError" },
          "when": "カートが存在しない"
        },
        {
          "id": "422-cart-empty",
          "status": 422,
          "bodySchema": { "typeRef": "ApiError" },
          "when": "カートが空"
        },
        {
          "id": "422-cart-expired",
          "status": 422,
          "bodySchema": { "typeRef": "ApiError" },
          "when": "カートが期限切れ"
        },
        {
          "id": "404-customer-not-found",
          "status": 404,
          "bodySchema": { "typeRef": "ApiError" },
          "when": "顧客が存在しない"
        },
        {
          "id": "422-insufficient-inventory",
          "status": 422,
          "bodySchema": { "typeRef": "ApiError" },
          "when": "在庫が不足"
        },
        {
          "id": "500-order-confirm-failed",
          "status": 500,
          "bodySchema": { "typeRef": "ApiError" },
          "when": "注文確定処理の内部エラー"
        }
      ],
      "steps": [
        {
          "id": "step-01",
          "type": "validation",
          "description": "cartId・customerId は必須。",
          "maturity": "committed",
          "conditions": "cartId は必須。customerId は 1 以上の整数。",
          "rules": [
            {
              "field": "cartId",
              "type": "required",
              "message": "カート ID は必須です"
            },
            {
              "field": "customerId",
              "type": "range",
              "min": 1,
              "message": "顧客 ID は 1 以上の整数です"
            }
          ],
          "fieldErrorsVar": "fieldErrors",
          "inlineBranch": {
            "ok": "次のステップへ進む",
            "ng": "400 入力値エラーを返す",
            "ngResponseRef": "400-validation",
            "ngBodyExpression": "{ code: 'VALIDATION', message: '入力値が不正です', fieldErrors: @fieldErrors }"
          }
        },
        {
          "id": "step-02",
          "type": "dbAccess",
          "description": "カートの存在・ステータス・有効期限を確認する。",
          "maturity": "committed",
          "tableName": "carts",
          "operation": "SELECT",
          "sql": "SELECT id, status, expires_at FROM carts WHERE id = @inputs.cartId",
          "outputBinding": "cart",
          "lineage": { "reads": ["carts"] }
        },
        {
          "id": "step-03",
          "type": "branch",
          "description": "カートなし / 期限切れ / CHECKED_OUT の場合はエラーを返す。",
          "maturity": "committed",
          "branches": [
            {
              "id": "br-03-a",
              "code": "A",
              "label": "カートなし",
              "condition": "@cart == null",
              "steps": [
                {
                  "id": "step-03-a-01",
                  "type": "return",
                  "description": "404 カートなし",
                  "responseRef": "404-cart-not-found",
                  "bodyExpression": "{ code: 'CART_NOT_FOUND', message: 'カートが見つかりません' }"
                }
              ]
            },
            {
              "id": "br-03-b",
              "code": "B",
              "label": "カート無効",
              "condition": "@cart != null && (@cart.status != 'ACTIVE' || @cart.expires_at < NOW())",
              "steps": [
                {
                  "id": "step-03-b-01",
                  "type": "return",
                  "description": "422 カート期限切れ",
                  "responseRef": "422-cart-expired",
                  "bodyExpression": "{ code: 'CART_EXPIRED', message: 'カートの有効期限が切れています' }"
                }
              ]
            }
          ],
          "elseBranch": {
            "id": "br-03-else",
            "code": "C",
            "label": "カート有効",
            "steps": []
          }
        },
        {
          "id": "step-04",
          "type": "dbAccess",
          "description": "カート明細を取得する。",
          "maturity": "committed",
          "tableName": "cart_items",
          "operation": "SELECT",
          "sql": "SELECT ci.cart_id, ci.product_code, ci.quantity, ci.unit_price, p.name AS product_name FROM cart_items ci JOIN products p ON p.product_code = ci.product_code WHERE ci.cart_id = @inputs.cartId",
          "outputBinding": "cartItems",
          "lineage": { "reads": ["cart_items", "products"] }
        },
        {
          "id": "step-05",
          "type": "branch",
          "description": "カートが空の場合は 422 を返す。",
          "maturity": "committed",
          "branches": [
            {
              "id": "br-05-a",
              "code": "A",
              "label": "カート空",
              "condition": "@cartItems == null || @cartItems.length == 0",
              "steps": [
                {
                  "id": "step-05-a-01",
                  "type": "return",
                  "description": "422 カート空",
                  "responseRef": "422-cart-empty",
                  "bodyExpression": "{ code: 'CART_EMPTY', message: 'カートに商品がありません' }"
                }
              ]
            }
          ],
          "elseBranch": {
            "id": "br-05-else",
            "code": "B",
            "label": "カートに商品あり",
            "steps": []
          }
        },
        {
          "id": "step-06",
          "type": "dbAccess",
          "description": "顧客の存在確認。",
          "maturity": "committed",
          "tableName": "customers",
          "operation": "SELECT",
          "sql": "SELECT id FROM customers WHERE id = @inputs.customerId AND is_deleted = false",
          "outputBinding": "customer",
          "lineage": { "reads": ["customers"] }
        },
        {
          "id": "step-07",
          "type": "branch",
          "description": "顧客が存在しない場合は 404 を返す。",
          "maturity": "committed",
          "branches": [
            {
              "id": "br-07-a",
              "code": "A",
              "label": "顧客なし",
              "condition": "@customer == null",
              "steps": [
                {
                  "id": "step-07-a-01",
                  "type": "return",
                  "description": "404 顧客なし",
                  "responseRef": "404-customer-not-found",
                  "bodyExpression": "{ code: 'CUSTOMER_NOT_FOUND', message: '顧客情報が見つかりません' }"
                }
              ]
            }
          ],
          "elseBranch": {
            "id": "br-07-else",
            "code": "B",
            "label": "顧客あり",
            "steps": []
          }
        },
        {
          "id": "step-08",
          "type": "compute",
          "description": "カート明細から小計 (税抜) を算出する。",
          "maturity": "committed",
          "expression": "@fn.calcSubtotal(@cartItems)",
          "outputBinding": "subtotal"
        },
        {
          "id": "step-09",
          "type": "compute",
          "description": "消費税額を算出する。@conv.tax.standard.rate (0.10) を使用して 1 円未満切り捨て。",
          "maturity": "committed",
          "expression": "@fn.calcTax(@subtotal, @conv.tax.standard.rate)",
          "outputBinding": "taxAmount"
        },
        {
          "id": "step-10",
          "type": "compute",
          "description": "合計金額 (税込) を算出する。",
          "maturity": "committed",
          "expression": "@subtotal + @taxAmount",
          "outputBinding": "totalAmount"
        },
        {
          "id": "step-11",
          "type": "compute",
          "description": "注文 ID を採番する (UUID v4)。@fn.generateUUID を使用する。",
          "maturity": "committed",
          "expression": "@fn.generateUUID()",
          "outputBinding": "newOrderId"
        },
        {
          "id": "step-13",
          "type": "transactionScope",
          "description": "orders INSERT / order_items INSERT / inventory availability DECREMENT を 1 TX で原子的に実行する。",
          "maturity": "committed",
          "isolationLevel": "READ_COMMITTED",
          "propagation": "REQUIRED",
          "rollbackOn": ["INSUFFICIENT_INVENTORY"],
          "steps": [
            {
              "id": "step-13-01",
              "type": "dbAccess",
              "description": "orders テーブルに CONFIRMED 注文を INSERT する。",
              "maturity": "committed",
              "tableName": "orders",
              "operation": "INSERT",
              "sql": "INSERT INTO orders (id, order_number, customer_id, cart_id, status, subtotal, tax_amount, total_amount, shipping_address, created_at, updated_at) VALUES (@newOrderId, CONCAT('RO-', TO_CHAR(NOW(), 'YYYY'), '-', LPAD(NEXTVAL('seq_order_number')::text, 4, '0')), @inputs.customerId, @inputs.cartId, 'CONFIRMED', @subtotal, @taxAmount, @totalAmount, @inputs.shippingAddress, NOW(), NOW()) RETURNING id, order_number",
              "outputBinding": "newOrder",
              "lineage": { "writes": ["orders"] }
            },
            {
              "id": "step-13-02",
              "type": "dbAccess",
              "description": "order_items にカート明細からコピーして INSERT する。",
              "maturity": "committed",
              "tableName": "order_items",
              "operation": "INSERT",
              "sql": "INSERT INTO order_items (order_id, product_code, product_name, quantity, unit_price, subtotal, created_at) SELECT @newOrderId, ci.product_code, p.name, ci.quantity, ci.unit_price, ci.quantity * ci.unit_price, NOW() FROM cart_items ci JOIN products p ON p.product_code = ci.product_code WHERE ci.cart_id = @inputs.cartId",
              "lineage": { "writes": ["order_items"] }
            },
            {
              "id": "step-13-03",
              "type": "retail:InventoryReserveStep",
              "description": "在庫引当 (retail 拡張)。前処理フックとして在庫引当の retail セマンティクスを明示する。実際の引当 UPDATE は step-13-04 で行う。",
              "maturity": "committed"
            },
            {
              "id": "step-13-04",
              "type": "dbAccess",
              "description": "inventory.available_quantity を注文数量分デクリメントする。WHERE 句で在庫不足チェックを兼ねる。",
              "maturity": "committed",
              "tableName": "inventory",
              "operation": "UPDATE",
              "sql": "UPDATE inventory SET available_quantity = available_quantity - sub.qty, updated_at = NOW() FROM (SELECT ci.product_code, ci.quantity AS qty FROM cart_items ci WHERE ci.cart_id = @inputs.cartId) sub WHERE inventory.product_code = sub.product_code AND inventory.available_quantity >= sub.qty",
              "outputBinding": "inventoryUpdate",
              "affectedRowsCheck": {
                "operator": ">",
                "expected": 0,
                "onViolation": "throw",
                "errorCode": "INSUFFICIENT_INVENTORY"
              },
              "lineage": { "writes": ["inventory"] }
            }
          ]
        },
        {
          "id": "step-13b",
          "type": "branch",
          "description": "TX 失敗 (在庫不足 rollback 等) を検出する。newOrder.id が null の場合は TX が失敗している。",
          "maturity": "committed",
          "branches": [
            {
              "id": "br-13b-a",
              "code": "A",
              "label": "TX 失敗",
              "condition": "@newOrder == null || @newOrder.id == null",
              "steps": [
                {
                  "id": "step-13b-a-01",
                  "type": "eventPublish",
                  "description": "order.confirm_failed イベントを発行する。",
                  "maturity": "committed",
                  "topic": "order.confirm_failed",
                  "eventRef": "order.confirm_failed",
                  "payload": "{ cartId: @inputs.cartId, customerId: @inputs.customerId, errorCode: 'INSUFFICIENT_INVENTORY' }"
                },
                {
                  "id": "step-13b-a-02",
                  "type": "return",
                  "description": "422 在庫不足で TX ロールバック",
                  "responseRef": "422-insufficient-inventory",
                  "bodyExpression": "{ code: 'INSUFFICIENT_INVENTORY', message: '在庫が不足しています' }"
                }
              ]
            }
          ],
          "elseBranch": {
            "id": "br-13b-else",
            "code": "B",
            "label": "TX 成功",
            "description": "TX コミット済み。以降のステップを続行する。",
            "steps": []
          }
        },
        {
          "id": "step-13c",
          "type": "dbAccess",
          "description": "TX コミット後に orders テーブルから確定済み注文を再 SELECT する。TX inner outputBinding (@newOrder) のネスト参照を避け、TX 外の確定値を取得する (#460 の修正パターン踏襲)。",
          "maturity": "committed",
          "tableName": "orders",
          "operation": "SELECT",
          "sql": "SELECT id, order_number, total_amount FROM orders WHERE id = @newOrderId",
          "outputBinding": "persistedOrder",
          "lineage": { "reads": ["orders"] }
        },
        {
          "id": "step-14",
          "type": "dbAccess",
          "description": "carts のステータスを CHECKED_OUT に更新する (TX 外)。",
          "maturity": "committed",
          "tableName": "carts",
          "operation": "UPDATE",
          "sql": "UPDATE carts SET status = 'CHECKED_OUT', updated_at = NOW() WHERE id = @inputs.cartId",
          "lineage": { "writes": ["carts"] },
          "runIf": "@persistedOrder != null"
        },
        {
          "id": "step-15",
          "type": "eventPublish",
          "description": "retail.order_tax_calculated イベントを発行する。",
          "maturity": "committed",
          "topic": "retail.order_tax_calculated",
          "eventRef": "retail.order_tax_calculated",
          "payload": "{ orderId: @persistedOrder.id, subtotal: @subtotal, taxAmount: @taxAmount, totalAmount: @totalAmount }",
          "runIf": "@persistedOrder != null"
        },
        {
          "id": "step-16",
          "type": "eventPublish",
          "description": "order.inventory_reserved イベントを発行する。reservedItems は TX 後 SELECT の @inventoryUpdate を参照する。",
          "maturity": "committed",
          "topic": "order.inventory_reserved",
          "eventRef": "order.inventory_reserved",
          "payload": "{ orderId: @persistedOrder.id, reservedItems: @inventoryUpdate }",
          "runIf": "@persistedOrder != null"
        },
        {
          "id": "step-17",
          "type": "eventPublish",
          "description": "order.confirmed イベントを発行する。後続の配送指示フロー (gggggggg-0004) を起動する。",
          "maturity": "committed",
          "topic": "order.confirmed",
          "eventRef": "order.confirmed",
          "payload": "{ orderId: @persistedOrder.id, orderNumber: @persistedOrder.order_number, customerId: @inputs.customerId, totalAmount: @totalAmount, taxAmount: @taxAmount }",
          "runIf": "@persistedOrder != null"
        },
        {
          "id": "step-18",
          "type": "return",
          "description": "201 Created を返す。",
          "maturity": "committed",
          "responseRef": "201-created",
          "bodyExpression": "{ orderId: @persistedOrder.id, orderNumber: @persistedOrder.order_number, status: 'CONFIRMED', totalAmount: @totalAmount, taxAmount: @taxAmount }",
          "runIf": "@persistedOrder != null"
        }
      ]
    }
  ],
  "testScenarios": [
    {
