{
  "$schema": "../../../../schemas/v3/extensions.v3.schema.json",
  "namespace": "welfare-benefit",
  "version": "1.0.0",
  "requiresCoreSchema": ">=3.0.0",
  "description": "社会保険行政の給付業務 v3 dogfood 用拡張。本人確認、給付申請受付、多段審査、支払通知、銀行送金、受給者台帳に関する型・ステップ・レスポンス・規約カテゴリを定義する。",
  "fieldTypes": [
    { "kind": "applicantId", "label": "申請者ID", "baseType": "string", "description": "AP + 10 桁の申請者識別子。" },
    { "kind": "applicationCode", "label": "申請番号", "baseType": "string", "description": "BN + YYYYMMDD + 連番8桁の給付申請番号。" },
    { "kind": "beneficiaryCode", "label": "受給者ID", "baseType": "string", "description": "BF + 10 桁の受給者台帳識別子。" },
    { "kind": "bankAccountRef", "label": "銀行口座参照", "baseType": "string", "description": "ハッシュ化された銀行口座参照値 (PII を直接保持しない設計)。" }
  ],
  "actionTriggers": [
    { "value": "applicationSubmitted", "label": "給付申請提出", "description": "申請者が給付申請を提出した時に起動する。" },
    { "value": "paymentApproved", "label": "支払承認", "description": "最終承認後に支払指示が発行された時に起動する。" }
  ],
  "stepKinds": {
    "BenefitLimitCheckStep": {
      "label": "給付限度額チェック",
      "icon": "Calculator",
      "description": "対象給付種別の上限額・期間内累計を確認する。",
      "schema": {
        "type": "object",
        "required": ["benefitType", "requestedAmount", "applicantRef"],
        "properties": {
          "benefitType": { "type": "string" },
          "requestedAmount": { "type": "number" },
          "applicantRef": { "type": "string" },
          "evaluationWindowDays": { "type": "integer" }
        },
        "additionalProperties": false
      }
    },
    "DuplicateApplicationCheckStep": {
      "label": "重複申請チェック",
      "icon": "FileSearch",
      "description": "同一申請者が一定期間内に同一給付種別を重複申請していないか確認する。",
      "schema": {
        "type": "object",
        "required": ["applicantRef", "benefitType"],
        "properties": {
          "applicantRef": { "type": "string" },
          "benefitType": { "type": "string" },
          "lookbackDays": { "type": "integer" }
        },
        "additionalProperties": false
      }
    }
  },
  "responseTypes": {
    "ApplicationReceptionResponse": {
      "description": "給付申請受付 API の成功レスポンス。",
      "schema": {
        "type": "object",
        "required": ["applicationCode", "status"],
        "properties": {
          "applicationCode": { "type": "string" },
          "applicantId": { "type": "string" },
          "benefitType": { "type": "string" },
          "requestedAmount": { "type": "number" },
          "status": { "type": "string" },
          "submittedAt": { "type": "string" }
        }
      }
    },
    "PaymentNotificationResponse": {
      "description": "支払通知 API の成功レスポンス。",
      "schema": {
        "type": "object",
        "required": ["paymentId", "applicationCode", "status"],
        "properties": {
          "paymentId": { "type": "string" },
          "applicationCode": { "type": "string" },
          "amount": { "type": "number" },
          "currency": { "type": "string" },
          "transactionReference": { "type": "string" },
          "status": { "type": "string" },
          "paidAt": { "type": "string" }
        }
      }
    },
    "ApiError": {
      "description": "給付業務 API 共通エラー。",
      "schema": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "requestId": { "type": "string" },
          "fieldErrors": { "type": "array", "items": { "type": "object" } }
        }
      }
    }
  },
  "conventionCategories": [
    {
      "categoryName": "benefitLimit",
      "label": "給付限度額",
      "description": "給付種別ごとの一回上限・年間累計上限・遡及期間など。",
      "entrySchema": {
        "type": "object",
        "required": ["amount", "currency", "windowDays"],
        "properties": {
          "amount": { "type": "number" },
          "currency": { "type": "string" },
          "windowDays": { "type": "integer" },
          "description": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    {
      "categoryName": "reviewerRole",
      "label": "審査者ロール",
      "description": "受付担当、一次審査担当、上長承認者、最終決裁者などの業務ロール。",
      "entrySchema": {
        "type": "object",
        "required": ["code", "description"],
        "properties": {
          "code": { "type": "string" },
          "description": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    {
      "categoryName": "benefitPolicy",
      "label": "給付ポリシー",
      "description": "本人確認方法、重複申請判定窓、PII 取扱、口座参照ハッシュ方式などの運用規約。",
      "entrySchema": {
        "type": "object",
        "required": ["value", "description"],
        "properties": {
          "value": { "type": "string" },
          "description": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  ]
}
