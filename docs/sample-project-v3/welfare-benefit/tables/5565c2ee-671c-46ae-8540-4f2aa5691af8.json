{
  "$schema": "../../../../schemas/v3/table.v3.schema.json",
  "id": "5565c2ee-671c-46ae-8540-4f2aa5691af8",
  "name": "審査記録",
  "description": "給付申請の各段階 (一次審査 / 上長承認 / 最終決裁) の審査結果を保持する履歴テーブル。1 申請に対し複数行が存在する。",
  "version": "1.0.0",
  "maturity": "committed",
  "createdAt": "2026-04-30T00:00:00.000Z",
  "updatedAt": "2026-04-30T00:00:00.000Z",
  "physicalName": "reviews",
  "category": "トランザクション",
  "comment": "監査要件のため上書きせず履歴で残す (decision='requested_supplement' で再審査を経た場合も別行)。",
  "columns": [
    { "id": "col-rev01", "no": 1, "physicalName": "id", "name": "審査内部ID", "dataType": "BIGINT", "notNull": true, "primaryKey": true, "autoIncrement": true },
    { "id": "col-rev02", "no": 2, "physicalName": "application_id", "name": "申請内部ID", "dataType": "BIGINT", "notNull": true },
    { "id": "col-rev03", "no": 3, "physicalName": "stage", "name": "段階", "dataType": "VARCHAR", "length": 30, "notNull": true, "comment": "first_review / manager_approval / final_decision" },
    { "id": "col-rev04", "no": 4, "physicalName": "reviewer_user_id", "name": "審査者ユーザーID", "dataType": "VARCHAR", "length": 80, "notNull": true },
    { "id": "col-rev05", "no": 5, "physicalName": "reviewer_role", "name": "審査者ロール", "dataType": "VARCHAR", "length": 32, "notNull": true, "comment": "@conv.reviewerRole 規約のキーを保持。" },
    { "id": "col-rev06", "no": 6, "physicalName": "decision", "name": "判定", "dataType": "VARCHAR", "length": 30, "comment": "approved / rejected / requested_supplement / null (未判定)" },
    { "id": "col-rev07", "no": 7, "physicalName": "approved_amount", "name": "承認額", "dataType": "DECIMAL", "length": 14, "scale": 0, "comment": "stage 別に減額判断したい場合に使用。" },
    { "id": "col-rev08", "no": 8, "physicalName": "comment", "name": "コメント", "dataType": "TEXT" },
    { "id": "col-rev09", "no": 9, "physicalName": "decided_at", "name": "判定日時", "dataType": "TIMESTAMP" },
    { "id": "col-rev10", "no": 10, "physicalName": "created_at", "name": "作成日時", "dataType": "TIMESTAMP", "notNull": true, "defaultValue": "CURRENT_TIMESTAMP" }
  ],
  "indexes": [
    { "id": "idx-rev01", "physicalName": "idx_reviews_application_stage", "columns": [{ "columnId": "col-rev02" }, { "columnId": "col-rev03" }, { "columnId": "col-rev09", "order": "desc" }] },
    { "id": "idx-rev02", "physicalName": "idx_reviews_pending", "columns": [{ "columnId": "col-rev03" }, { "columnId": "col-rev09" }], "where": "decision IS NULL", "description": "未判定の審査キューを高速検索 (Partial Index)。" }
  ],
  "constraints": [
    { "id": "fk-rev01", "kind": "foreignKey", "physicalName": "fk_reviews_application", "columnIds": ["col-rev02"], "referencedTableId": "b57571d6-dc31-4dad-aad9-a2315267ea90", "referencedColumnIds": ["col-app01"], "onDelete": "cascade", "onUpdate": "cascade" },
    { "id": "chk-rev01", "kind": "check", "physicalName": "chk_reviews_stage", "expression": "stage IN ('first_review', 'manager_approval', 'final_decision')" },
    { "id": "chk-rev02", "kind": "check", "physicalName": "chk_reviews_decision", "expression": "decision IS NULL OR decision IN ('approved', 'rejected', 'requested_supplement')" },
    { "id": "chk-rev03", "kind": "check", "physicalName": "chk_reviews_decided_consistency", "expression": "(decision IS NULL AND decided_at IS NULL) OR (decision IS NOT NULL AND decided_at IS NOT NULL)" }
  ]
}
