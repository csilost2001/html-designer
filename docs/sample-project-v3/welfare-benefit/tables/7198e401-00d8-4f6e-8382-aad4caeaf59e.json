{
  "$schema": "../../../../schemas/v3/table.v3.schema.json",
  "id": "7198e401-00d8-4f6e-8382-aad4caeaf59e",
  "name": "支払処理",
  "description": "承認済給付申請に対する銀行送金処理の履歴。冪等キーで二重送金を防ぎ、銀行 API 応答 (transaction_reference) を保持する。",
  "version": "1.0.0",
  "maturity": "committed",
  "createdAt": "2026-04-30T00:00:00.000Z",
  "updatedAt": "2026-04-30T00:00:00.000Z",
  "physicalName": "payments",
  "category": "トランザクション",
  "comment": "transfer_status は pending → in_progress → completed/failed の遷移。idempotency_key は同一申請への二重支払い防止に使用。",
  "columns": [
    { "id": "col-pay01", "no": 1, "physicalName": "id", "name": "支払内部ID", "dataType": "BIGINT", "notNull": true, "primaryKey": true, "autoIncrement": true },
    { "id": "col-pay02", "no": 2, "physicalName": "application_id", "name": "申請内部ID", "dataType": "BIGINT", "notNull": true },
    { "id": "col-pay03", "no": 3, "physicalName": "beneficiary_id", "name": "受給者内部ID", "dataType": "BIGINT", "notNull": true },
    { "id": "col-pay04", "no": 4, "physicalName": "amount", "name": "支払額", "dataType": "DECIMAL", "length": 14, "scale": 0, "notNull": true },
    { "id": "col-pay05", "no": 5, "physicalName": "currency", "name": "通貨", "dataType": "VARCHAR", "length": 8, "notNull": true, "defaultValue": "'JPY'" },
    { "id": "col-pay06", "no": 6, "physicalName": "payment_method", "name": "支払方法", "dataType": "VARCHAR", "length": 32, "notNull": true, "defaultValue": "'bank_transfer'" },
    { "id": "col-pay07", "no": 7, "physicalName": "bank_account_ref", "name": "銀行口座参照", "dataType": "VARCHAR", "length": 64, "notNull": true, "comment": "ハッシュ化された銀行口座参照 (raw 口座番号は別 vault)。" },
    { "id": "col-pay08", "no": 8, "physicalName": "idempotency_key", "name": "冪等キー", "dataType": "VARCHAR", "length": 64, "notNull": true, "unique": true, "comment": "application_code + 送金試行回数等から決定論的に生成。" },
    { "id": "col-pay09", "no": 9, "physicalName": "transfer_status", "name": "送金状態", "dataType": "VARCHAR", "length": 30, "notNull": true, "defaultValue": "'pending'" },
    { "id": "col-pay10", "no": 10, "physicalName": "transfer_initiated_at", "name": "送金開始日時", "dataType": "TIMESTAMP" },
    { "id": "col-pay11", "no": 11, "physicalName": "transfer_completed_at", "name": "送金完了日時", "dataType": "TIMESTAMP" },
    { "id": "col-pay12", "no": 12, "physicalName": "transaction_reference", "name": "銀行送金参照番号", "dataType": "VARCHAR", "length": 64, "comment": "銀行 API が返す送金参照。" },
    { "id": "col-pay13", "no": 13, "physicalName": "failure_reason", "name": "失敗理由", "dataType": "TEXT" },
    { "id": "col-pay14", "no": 14, "physicalName": "created_at", "name": "作成日時", "dataType": "TIMESTAMP", "notNull": true, "defaultValue": "CURRENT_TIMESTAMP" },
    { "id": "col-pay15", "no": 15, "physicalName": "updated_at", "name": "更新日時", "dataType": "TIMESTAMP", "notNull": true, "defaultValue": "CURRENT_TIMESTAMP" }
  ],
  "indexes": [
    { "id": "idx-pay01", "physicalName": "idx_payments_idempotency", "columns": [{ "columnId": "col-pay08" }], "unique": true },
    { "id": "idx-pay02", "physicalName": "idx_payments_application", "columns": [{ "columnId": "col-pay02" }, { "columnId": "col-pay09" }] },
    { "id": "idx-pay03", "physicalName": "idx_payments_in_progress", "columns": [{ "columnId": "col-pay10" }], "where": "transfer_status = 'in_progress'", "description": "送金中の支払をリコンサイルジョブで一括検索 (Partial Index)。" }
  ],
  "constraints": [
    { "id": "fk-pay01", "kind": "foreignKey", "physicalName": "fk_payments_application", "columnIds": ["col-pay02"], "referencedTableId": "b57571d6-dc31-4dad-aad9-a2315267ea90", "referencedColumnIds": ["col-app01"], "onDelete": "restrict", "onUpdate": "cascade" },
    { "id": "fk-pay02", "kind": "foreignKey", "physicalName": "fk_payments_beneficiary", "columnIds": ["col-pay03"], "referencedTableId": "dde87bc9-e122-4466-9b1c-e8c5b2f98408", "referencedColumnIds": ["col-bnf01"], "onDelete": "restrict", "onUpdate": "cascade" },
    { "id": "chk-pay01", "kind": "check", "physicalName": "chk_payments_status", "expression": "transfer_status IN ('pending', 'in_progress', 'completed', 'failed', 'reversed')" },
    { "id": "chk-pay02", "kind": "check", "physicalName": "chk_payments_amount_positive", "expression": "amount > 0" },
    { "id": "chk-pay03", "kind": "check", "physicalName": "chk_payments_completed_consistency", "expression": "(transfer_status = 'completed' AND transfer_completed_at IS NOT NULL AND transaction_reference IS NOT NULL) OR transfer_status <> 'completed'" }
  ]
}
