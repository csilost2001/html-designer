{
  "$schema": "../../../../schemas/v3/table.v3.schema.json",
  "id": "dde87bc9-e122-4466-9b1c-e8c5b2f98408",
  "name": "受給者台帳",
  "description": "過去に給付を受けた受給者の累計情報。年間累計上限・受給資格停止状態を保持し、新規申請の限度額計算と資格判定に利用する。",
  "version": "1.0.0",
  "maturity": "committed",
  "createdAt": "2026-04-30T00:00:00.000Z",
  "updatedAt": "2026-04-30T00:00:00.000Z",
  "physicalName": "beneficiaries",
  "category": "マスタ",
  "comment": "申請者と 1:1 を想定 (1 申請者 1 台帳)。total_paid_amount は会計年度ごとに集計バッチでリセット。",
  "columns": [
    { "id": "col-bnf01", "no": 1, "physicalName": "id", "name": "受給者内部ID", "dataType": "BIGINT", "notNull": true, "primaryKey": true, "autoIncrement": true },
    { "id": "col-bnf02", "no": 2, "physicalName": "beneficiary_code", "name": "受給者ID", "dataType": "VARCHAR", "length": 16, "notNull": true, "unique": true, "comment": "BF + 10 桁。" },
    { "id": "col-bnf03", "no": 3, "physicalName": "applicant_id", "name": "申請者内部ID", "dataType": "BIGINT", "notNull": true, "unique": true, "comment": "申請者と 1:1。" },
    { "id": "col-bnf04", "no": 4, "physicalName": "fiscal_year", "name": "会計年度", "dataType": "INTEGER", "notNull": true, "comment": "西暦の会計年度開始年。" },
    { "id": "col-bnf05", "no": 5, "physicalName": "total_paid_amount", "name": "年間累計支払額", "dataType": "DECIMAL", "length": 14, "scale": 0, "notNull": true, "defaultValue": "0" },
    { "id": "col-bnf06", "no": 6, "physicalName": "last_paid_at", "name": "最終支払日時", "dataType": "TIMESTAMP" },
    { "id": "col-bnf07", "no": 7, "physicalName": "eligibility_status", "name": "受給資格状態", "dataType": "VARCHAR", "length": 30, "notNull": true, "defaultValue": "'eligible'" },
    { "id": "col-bnf08", "no": 8, "physicalName": "disqualification_reason", "name": "資格停止理由", "dataType": "TEXT" },
    { "id": "col-bnf09", "no": 9, "physicalName": "created_at", "name": "作成日時", "dataType": "TIMESTAMP", "notNull": true, "defaultValue": "CURRENT_TIMESTAMP" },
    { "id": "col-bnf10", "no": 10, "physicalName": "updated_at", "name": "更新日時", "dataType": "TIMESTAMP", "notNull": true, "defaultValue": "CURRENT_TIMESTAMP" }
  ],
  "indexes": [
    { "id": "idx-bnf01", "physicalName": "idx_beneficiaries_code", "columns": [{ "columnId": "col-bnf02" }], "unique": true },
    { "id": "idx-bnf02", "physicalName": "idx_beneficiaries_applicant", "columns": [{ "columnId": "col-bnf03" }], "unique": true }
  ],
  "constraints": [
    { "id": "fk-bnf01", "kind": "foreignKey", "physicalName": "fk_beneficiaries_applicant", "columnIds": ["col-bnf03"], "referencedTableId": "c3bff56f-e4d2-4597-8819-93ecf7fc0acd", "referencedColumnIds": ["col-apl01"], "onDelete": "restrict", "onUpdate": "cascade" },
    { "id": "chk-bnf01", "kind": "check", "physicalName": "chk_beneficiaries_eligibility", "expression": "eligibility_status IN ('eligible', 'disqualified', 'suspended')" },
    { "id": "chk-bnf02", "kind": "check", "physicalName": "chk_beneficiaries_total_nonneg", "expression": "total_paid_amount >= 0" },
    { "id": "chk-bnf03", "kind": "check", "physicalName": "chk_beneficiaries_disqual_consistency", "expression": "(eligibility_status = 'disqualified' AND disqualification_reason IS NOT NULL) OR eligibility_status <> 'disqualified'" }
  ]
}
