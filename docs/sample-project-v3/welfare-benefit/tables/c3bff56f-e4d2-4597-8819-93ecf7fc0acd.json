{
  "$schema": "../../../../schemas/v3/table.v3.schema.json",
  "id": "c3bff56f-e4d2-4597-8819-93ecf7fc0acd",
  "name": "申請者",
  "description": "給付申請を行う住民の本体マスタ。本人確認状態 (identity_verified) を中心に保持し、PII は最小範囲のみ持つ。住所詳細は別マスタ (本サンプルでは省略)。",
  "version": "1.0.0",
  "maturity": "committed",
  "createdAt": "2026-04-30T00:00:00.000Z",
  "updatedAt": "2026-04-30T00:00:00.000Z",
  "physicalName": "applicants",
  "category": "マスタ",
  "comment": "申請者マスタ。本人確認は住民基本台帳ネットワーク等で確認した結果を identity_verified に持つ。PII 保持期間は @conv.benefitPolicy.piiRetention 規約に従う。",
  "columns": [
    { "id": "col-apl01", "no": 1, "physicalName": "id", "name": "申請者内部ID", "dataType": "BIGINT", "notNull": true, "primaryKey": true, "autoIncrement": true },
    { "id": "col-apl02", "no": 2, "physicalName": "applicant_code", "name": "申請者ID", "dataType": "VARCHAR", "length": 16, "notNull": true, "unique": true, "comment": "AP + 10 桁。" },
    { "id": "col-apl03", "no": 3, "physicalName": "full_name", "name": "氏名", "dataType": "VARCHAR", "length": 200, "notNull": true },
    { "id": "col-apl04", "no": 4, "physicalName": "date_of_birth", "name": "生年月日", "dataType": "DATE", "notNull": true },
    { "id": "col-apl05", "no": 5, "physicalName": "address_hash", "name": "住所ハッシュ", "dataType": "VARCHAR", "length": 64, "notNull": true, "comment": "住所そのものは保持せず SHA-256 ハッシュのみ。住所変更検出に利用。" },
    { "id": "col-apl06", "no": 6, "physicalName": "phone", "name": "電話番号", "dataType": "VARCHAR", "length": 32 },
    { "id": "col-apl07", "no": 7, "physicalName": "email", "name": "メールアドレス", "dataType": "VARCHAR", "length": 255 },
    { "id": "col-apl08", "no": 8, "physicalName": "identity_verified", "name": "本人確認済", "dataType": "BOOLEAN", "notNull": true, "defaultValue": "false" },
    { "id": "col-apl09", "no": 9, "physicalName": "identity_verified_at", "name": "本人確認日時", "dataType": "TIMESTAMP" },
    { "id": "col-apl10", "no": 10, "physicalName": "identity_verification_method", "name": "本人確認方法", "dataType": "VARCHAR", "length": 32, "comment": "juki_net / mynumber_card / manual_clerk 等。" },
    { "id": "col-apl11", "no": 11, "physicalName": "created_at", "name": "作成日時", "dataType": "TIMESTAMP", "notNull": true, "defaultValue": "CURRENT_TIMESTAMP" },
    { "id": "col-apl12", "no": 12, "physicalName": "updated_at", "name": "更新日時", "dataType": "TIMESTAMP", "notNull": true, "defaultValue": "CURRENT_TIMESTAMP" }
  ],
  "indexes": [
    { "id": "idx-apl01", "physicalName": "idx_applicants_code", "columns": [{ "columnId": "col-apl02" }], "unique": true },
    { "id": "idx-apl02", "physicalName": "idx_applicants_identity_verified", "columns": [{ "columnId": "col-apl08" }, { "columnId": "col-apl09", "order": "desc" }] }
  ],
  "constraints": [
    { "id": "chk-apl01", "kind": "check", "physicalName": "chk_applicants_code_format", "expression": "applicant_code ~ '^AP[0-9]{10}$'" },
    { "id": "chk-apl02", "kind": "check", "physicalName": "chk_applicants_verified_consistency", "expression": "(identity_verified = false AND identity_verified_at IS NULL) OR (identity_verified = true AND identity_verified_at IS NOT NULL)" }
  ]
}
