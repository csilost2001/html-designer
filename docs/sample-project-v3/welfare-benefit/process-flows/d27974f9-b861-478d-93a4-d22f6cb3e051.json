{
  "$schema": "../../../../schemas/v3/process-flow.v3.schema.json",
  "meta": {
    "id": "d27974f9-b861-478d-93a4-d22f6cb3e051",
    "name": "支払通知",
    "description": "最終決裁済みの給付申請に対して出納長による支払前最終決裁を経て、銀行送金を実行し、支払 / 申請 / 受給者台帳を一貫した状態に更新して受給者へ通知する。冪等キーで二重送金を防ぐ。",
    "version": "1.0.0",
    "maturity": "committed",
    "createdAt": "2026-04-30T00:00:00.000Z",
    "updatedAt": "2026-04-30T00:00:00.000Z",
    "kind": "system",
    "apiVersion": "v1",
    "mode": "upstream",
    "primaryInvoker": {
      "kind": "screen-item-event",
      "screenId": "1cfb3eef-baa4-4666-8ef3-f74fe2954f85",
      "itemId": "submitBtn",
      "eventId": "click"
    }
  },
  "context": {
    "catalogs": {
      "errors": {
        "VALIDATION": { "httpStatus": 400, "defaultMessage": "入力値が不正です", "responseId": "400-validation" },
        "APPLICATION_NOT_FOUND": { "httpStatus": 404, "defaultMessage": "申請が見つかりません", "responseId": "404-application-not-found" },
        "APPLICATION_NOT_APPROVED": { "httpStatus": 409, "defaultMessage": "最終決裁が完了していない申請は支払いできません", "responseId": "409-application-not-approved" },
        "TREASURER_REJECTED": { "httpStatus": 422, "defaultMessage": "出納長最終決裁で支払いが差し戻されました", "responseId": "422-treasurer-rejected" },
        "BANK_TRANSFER_FAILED": { "httpStatus": 502, "defaultMessage": "銀行送金 API の呼び出しに失敗しました", "responseId": "502-bank-transfer-failed" },
        "DUPLICATE_BENEFICIARY_CODE": { "httpStatus": 500, "defaultMessage": "受給者コード 採番衝突 (内部エラー)", "responseId": "500-internal-error" },
        "DUPLICATE_IDEMPOTENCY_KEY": { "httpStatus": 500, "defaultMessage": "冪等キー 採番衝突 (内部エラー)", "responseId": "500-internal-error" },
        "NOTIFICATION_FAILED": { "httpStatus": 502, "defaultMessage": "支払通知メールの送信に失敗しました", "responseId": "502-notification-failed" }
      },
      "externalSystems": {
        "bankSystem": { "name": "銀行送金 API", "baseUrl": "https://bank-gw.example.local", "auth": { "kind": "oauth2", "tokenRef": "@secret.bankAccessToken" }, "timeoutMs": 8000, "retryPolicy": { "maxAttempts": 3, "backoff": "exponential", "initialDelayMs": 500 }, "description": "全銀協議定書経由の送金 API。冪等キー必須。サーキットブレーカー (failureThreshold=5 / timeout=30s) は呼び出し step 側で設定する。" },
        "notificationSystem": { "name": "住民通知システム", "baseUrl": "https://notify.example.local", "auth": { "kind": "bearer", "tokenRef": "@secret.notificationApiToken" }, "timeoutMs": 3000, "retryPolicy": { "maxAttempts": 2, "backoff": "exponential", "initialDelayMs": 200 }, "description": "受給者にメール / 郵送通知を送る連携システム。" }
      },
      "secrets": {
        "bankAccessToken": { "source": "vault", "name": "welfare/bank/access-token", "description": "銀行送金 API の OAuth2 アクセストークン。", "rotationDays": 30 },
        "notificationApiToken": { "source": "vault", "name": "welfare/notification/api-token", "description": "住民通知 API の bearer token。", "rotationDays": 90 }
      },
      "domains": {
        "ApplicationCode": { "type": "string", "constraints": [{ "field": "value", "type": "regex", "pattern": "^BN[0-9]{8}[0-9]{8}$", "severity": "error" }], "description": "給付申請番号 (BN + YYYYMMDD + 連番8桁)。" },
        "PaymentId": { "type": "string", "constraints": [{ "field": "value", "type": "regex", "pattern": "^PAY[0-9]{12}$", "severity": "error" }], "description": "支払 ID。" },
        "MoneyAmount": { "type": "number", "constraints": [{ "field": "value", "type": "range", "min": 1, "severity": "error" }], "description": "正の整数円単位の金額。" },
        "BankAccountRef": { "type": "string", "constraints": [{ "field": "value", "type": "regex", "pattern": "^BA[0-9a-f]{40,64}$", "severity": "error" }], "description": "ハッシュ化された銀行口座参照値 (PII を直接保持しない)。" }
      },
      "functions": {
        "buildIdempotencyKey": { "signature": "buildIdempotencyKey(applicationCode: string, attempt: integer): string", "returnType": "string", "description": "申請番号と試行回数から冪等キーを決定論的に生成する。", "examples": ["buildIdempotencyKey('BN20260430000001', 1)"] },
        "generatePaymentCode": { "signature": "generatePaymentCode(now: datetime): string", "returnType": "string", "description": "PAY + YYYYMMDD + 連番4桁の支払 ID を採番する。", "examples": ["generatePaymentCode(@now)"] },
        "currentFiscalYear": { "signature": "currentFiscalYear(now: datetime): integer", "returnType": "integer", "description": "現在の会計年度開始年を返す (4 月始まり)。", "examples": ["currentFiscalYear(@now)"] }
      },
      "events": {
        "welfare.payment_initiated": { "description": "支払通知フローが起動した時に発行する。", "payload": { "type": "object", "required": ["applicationCode", "initiatedBy"], "properties": { "applicationCode": { "type": "string" }, "initiatedBy": { "type": "string" } } } },
        "welfare.payment_treasurer_approved": { "description": "出納長による支払前最終決裁が承認された時に発行する。会計監査トレイル用。", "payload": { "type": "object", "required": ["applicationCode", "treasurerUserId"], "properties": { "applicationCode": { "type": "string" }, "treasurerUserId": { "type": "string" } } } },
        "welfare.payment_completed": { "description": "銀行送金完了 + 受給者台帳更新が成功した時に発行する。", "payload": { "type": "object", "required": ["applicationCode", "paymentCode", "amount", "transactionReference"], "properties": { "applicationCode": { "type": "string" }, "paymentCode": { "type": "string" }, "amount": { "type": "number" }, "transactionReference": { "type": "string" } } } },
        "welfare.payment_failed": { "description": "銀行送金失敗または出納長差戻しで支払いが完了しなかった時に発行する。", "payload": { "type": "object", "required": ["applicationCode", "reason"], "properties": { "applicationCode": { "type": "string" }, "paymentCode": { "type": "string" }, "reason": { "type": "string" } } } },
        "welfare.notification_failed": { "description": "支払通知メール送信失敗時に発行する。リコンサイル用。", "payload": { "type": "object", "required": ["applicationCode", "reason"], "properties": { "applicationCode": { "type": "string" }, "reason": { "type": "string" } } } }
      }
    },
    "ambientVariables": [
      { "name": "requestId", "type": "string", "required": true },
      { "name": "sessionUserId", "type": "string", "required": true },
      { "name": "sessionRole", "type": "string", "required": true },
      { "name": "now", "type": "datetime", "required": true }
    ]
  },
  "actions": [
    {
      "id": "act-001",
      "name": "支払通知の実行",
      "trigger": "welfare-benefit:paymentApproved",
      "description": "最終決裁済み申請に対して出納長最終決裁、銀行送金、台帳更新、受給者通知を行う。",
      "maturity": "committed",
      "httpRoute": { "method": "POST", "path": "/api/welfare/payments", "auth": "required" },
      "requiredPermissions": ["@conv.permission.payment.execute"],
      "inputs": [
        { "name": "applicationCode", "label": "申請番号", "type": { "kind": "domain", "domainKey": "ApplicationCode" }, "required": true },
        { "name": "bankAccountRef", "label": "銀行口座参照", "type": { "kind": "domain", "domainKey": "BankAccountRef" }, "required": true },
        { "name": "paymentMethod", "label": "支払方法", "type": "string", "required": true },
        { "name": "remitterReference", "label": "送金人参照", "type": "string", "required": true }
      ],
      "outputs": [
        { "name": "paymentCode", "label": "支払ID", "type": "string" },
        { "name": "transactionReference", "label": "送金参照番号", "type": "string" },
        { "name": "status", "label": "状態", "type": "string" }
      ],
      "responses": [
        { "id": "200-ok", "status": 200, "bodySchema": { "typeRef": "welfare-benefit:PaymentNotificationResponse" }, "when": "支払成功" },
        { "id": "400-validation", "status": 400, "bodySchema": { "typeRef": "welfare-benefit:ApiError" } },
        { "id": "404-application-not-found", "status": 404, "bodySchema": { "typeRef": "welfare-benefit:ApiError" } },
        { "id": "409-application-not-approved", "status": 409, "bodySchema": { "typeRef": "welfare-benefit:ApiError" } },
        { "id": "422-treasurer-rejected", "status": 422, "bodySchema": { "typeRef": "welfare-benefit:ApiError" } },
        { "id": "502-bank-transfer-failed", "status": 502, "bodySchema": { "typeRef": "welfare-benefit:ApiError" } },
        { "id": "502-notification-failed", "status": 502, "bodySchema": { "typeRef": "welfare-benefit:ApiError" } }
      ],
      "steps": [
        { "id": "step-01", "kind": "eventPublish", "description": "支払処理開始イベントを発行する。", "topic": "welfare.payment_initiated", "payload": "{ applicationCode: @inputs.applicationCode, initiatedBy: @sessionUserId }" },
        { "id": "step-02", "kind": "validation", "description": "申請番号、銀行口座参照、支払方法を検証する。", "rules": [
          { "field": "applicationCode", "type": "regex", "pattern": "^BN[0-9]{8}[0-9]{8}$", "severity": "error", "message": "申請番号の形式が不正です" },
          { "field": "bankAccountRef", "type": "regex", "pattern": "^BA[0-9a-f]{40,64}$", "severity": "error", "message": "銀行口座参照の形式が不正です" },
          { "field": "paymentMethod", "type": "enum", "values": ["bank_transfer", "check"], "severity": "error", "message": "支払方法が不正です" },
          { "field": "remitterReference", "type": "minLength", "length": 1, "severity": "error", "message": "送金人参照は必須です" }
        ], "fieldErrorsVar": "fieldErrors", "inlineBranch": { "ok": [], "ng": [], "ngResponseId": "400-validation", "ngBodyExpression": "{ code: 'VALIDATION', message: '入力値が不正です', requestId: @requestId, fieldErrors: @fieldErrors }" } },
        { "id": "step-03", "kind": "dbAccess", "description": "申請を申請番号で取得する。最終決裁額 (approved_amount) と申請者を持つ。", "tableId": "b57571d6-dc31-4dad-aad9-a2315267ea90", "operation": "SELECT", "sql": "SELECT id, application_code, applicant_id, benefit_type, requested_amount, approved_amount, status, decided_at FROM applications WHERE application_code = @inputs.applicationCode", "outputBinding": { "name": "application" }, "lineage": { "reads": [{ "tableId": "b57571d6-dc31-4dad-aad9-a2315267ea90", "purpose": "lookup" }] } },
        { "id": "step-04", "kind": "branch", "description": "申請が存在しない場合は 404 を返す。", "branches": [{ "id": "br-04-a", "code": "A", "label": "申請なし", "condition": { "kind": "expression", "expression": "@application == null" }, "steps": [
          { "id": "step-04-a-01", "kind": "return", "description": "申請なし", "responseId": "404-application-not-found", "bodyExpression": "{ code: 'APPLICATION_NOT_FOUND', message: '申請が見つかりません', requestId: @requestId }" }
        ] }], "elseBranch": { "id": "br-04-else", "code": "B", "label": "申請あり", "steps": [] } },
        { "id": "step-05", "kind": "branch", "description": "最終決裁が approved 以外の状態は支払不可。", "branches": [{ "id": "br-05-a", "code": "A", "label": "未決裁", "condition": { "kind": "expression", "expression": "@application.status != 'approved' || @application.approved_amount == null" }, "steps": [
          { "id": "step-05-a-01", "kind": "return", "description": "未決裁", "responseId": "409-application-not-approved", "bodyExpression": "{ code: 'APPLICATION_NOT_APPROVED', message: '最終決裁が完了していない申請は支払いできません', requestId: @requestId }" }
        ] }], "elseBranch": { "id": "br-05-else", "code": "B", "label": "決裁済", "steps": [] } },
        { "id": "step-06", "kind": "dbAccess", "description": "申請者を取得する (出力用)。", "tableId": "c3bff56f-e4d2-4597-8819-93ecf7fc0acd", "operation": "SELECT", "sql": "SELECT id, applicant_code, full_name FROM applicants WHERE id = @application.applicant_id", "outputBinding": { "name": "applicant" }, "lineage": { "reads": [{ "tableId": "c3bff56f-e4d2-4597-8819-93ecf7fc0acd", "purpose": "lookup" }] } },
        { "id": "step-07", "kind": "dbAccess", "description": "受給者台帳から既存行を取得する (新規受給者は null)。", "tableId": "dde87bc9-e122-4466-9b1c-e8c5b2f98408", "operation": "SELECT", "sql": "SELECT id, beneficiary_code, total_paid_amount, fiscal_year FROM beneficiaries WHERE applicant_id = @applicant.id", "outputBinding": { "name": "existingBeneficiary" }, "lineage": { "reads": [{ "tableId": "dde87bc9-e122-4466-9b1c-e8c5b2f98408", "purpose": "ledger-lookup" }] } },
        { "id": "step-08", "kind": "compute", "description": "冪等キーを申請番号と attempt=1 で生成する。再試行時は attempt を +1 する別フロー想定。", "expression": "fn.buildIdempotencyKey(@application.application_code, 1)", "outputBinding": { "name": "idempotencyKey" } },
        { "id": "step-stage-treasurer", "kind": "workflow", "description": "出納長による支払前最終決裁。書類審査の最終承認後、実際の銀行送金実行前に出納長が支払額と口座を確認する単段ワークフロー。", "maturity": "committed", "pattern": "review", "approvers": [{ "role": "@conv.reviewerRole.treasurer", "label": "出納長", "order": 1 }], "onApproved": [
          { "id": "step-stage-treasurer-app-01", "kind": "audit", "description": "出納長承認を監査ログに記録する。", "action": "welfare.payment.treasurer_approved", "resource": { "type": "application", "id": "@application.application_code" }, "result": "success", "sensitive": true },
          { "id": "step-stage-treasurer-app-02", "kind": "eventPublish", "description": "出納長承認イベントを発行する (会計監査トレイル用、step-01 の payment_initiated とは別目的)。", "topic": "welfare.payment_treasurer_approved", "payload": "{ applicationCode: @application.application_code, treasurerUserId: @sessionUserId }" }
        ], "onRejected": [
          { "id": "step-stage-treasurer-rej-01", "kind": "eventPublish", "description": "支払差戻しイベントを発行する。", "topic": "welfare.payment_failed", "payload": "{ applicationCode: @application.application_code, reason: 'treasurer rejected' }" },
          { "id": "step-stage-treasurer-rej-02", "kind": "audit", "description": "出納長差戻しを監査ログに記録する。", "action": "welfare.payment.treasurer_rejected", "resource": { "type": "application", "id": "@application.application_code" }, "result": "failure", "sensitive": true },
          { "id": "step-stage-treasurer-rej-03", "kind": "return", "description": "出納長差戻し", "responseId": "422-treasurer-rejected", "bodyExpression": "{ code: 'TREASURER_REJECTED', message: '出納長最終決裁で支払いが差し戻されました', requestId: @requestId }" }
        ] },
        { "id": "step-08b-create-beneficiary", "kind": "branch", "description": "初回受給者の場合は支払前に受給者台帳を作成する (payments.beneficiary_id NOT NULL 制約のため)。送金失敗で初回 beneficiary 行が残るが eligibility_status=eligible / total_paid_amount=0 なので運用上無害、リコンサイル後に総支払額が更新される。", "branches": [{ "id": "br-08b-a", "code": "A", "label": "初回受給者", "condition": { "kind": "expression", "expression": "@existingBeneficiary == null" }, "steps": [
          { "id": "step-08b-a-01", "kind": "dbAccess", "description": "受給者台帳に新規行を作成する (total_paid_amount=0 で初期化、支払成功後の step-15 で加算)。", "tableId": "dde87bc9-e122-4466-9b1c-e8c5b2f98408", "operation": "INSERT", "sql": "INSERT INTO beneficiaries (beneficiary_code, applicant_id, fiscal_year, total_paid_amount, eligibility_status) VALUES ('BF' || LPAD(CAST(@applicant.id AS TEXT), 10, '0'), @applicant.id, fn.currentFiscalYear(@now), 0, 'eligible') RETURNING id, beneficiary_code, total_paid_amount, fiscal_year", "outputBinding": { "name": "createdBeneficiary" }, "affectedRowsCheck": { "operator": "=", "expected": 1, "onViolation": "throw", "errorCode": "DUPLICATE_BENEFICIARY_CODE", "description": "beneficiary_code 採番衝突 (defense-in-depth、numbering convention により実質発生しない想定)" }, "lineage": { "writes": [{ "tableId": "dde87bc9-e122-4466-9b1c-e8c5b2f98408", "purpose": "ledger-create" }] } }
        ] }], "elseBranch": { "id": "br-08b-else", "code": "B", "label": "既存受給者", "steps": [] } },
        { "id": "step-09", "kind": "dbAccess", "description": "支払処理を pending で作成する (idempotency_key で二重作成を防ぐ)。beneficiary_id は既存受給者なら existingBeneficiary、初回なら step-08b で作成した createdBeneficiary を使用 (両者は同一 applicant に対し排他)。", "tableId": "7198e401-00d8-4f6e-8382-aad4caeaf59e", "operation": "INSERT", "sql": "INSERT INTO payments (application_id, beneficiary_id, amount, currency, payment_method, bank_account_ref, idempotency_key, transfer_status) VALUES (@application.id, COALESCE(@existingBeneficiary.id, @createdBeneficiary.id), @application.approved_amount, 'JPY', @inputs.paymentMethod, @inputs.bankAccountRef, @idempotencyKey, 'pending') RETURNING id, amount, currency, transfer_status", "outputBinding": { "name": "createdPayment" }, "affectedRowsCheck": { "operator": "=", "expected": 1, "onViolation": "throw", "errorCode": "DUPLICATE_IDEMPOTENCY_KEY", "description": "idempotency_key 採番衝突 (defense-in-depth、numbering convention により実質発生しない想定)" }, "lineage": { "writes": [{ "tableId": "7198e401-00d8-4f6e-8382-aad4caeaf59e", "purpose": "create" }] } },
        { "id": "step-10", "kind": "dbAccess", "description": "支払処理を in_progress に更新する。送金開始日時を記録。", "tableId": "7198e401-00d8-4f6e-8382-aad4caeaf59e", "operation": "UPDATE", "sql": "UPDATE payments SET transfer_status = 'in_progress', transfer_initiated_at = @now, updated_at = @now WHERE id = @createdPayment.id", "affectedRowsCheck": { "operator": "=", "expected": 1, "onViolation": "throw", "errorCode": "BANK_TRANSFER_FAILED" }, "lineage": { "writes": [{ "tableId": "7198e401-00d8-4f6e-8382-aad4caeaf59e", "purpose": "in-progress-update" }] } },
        { "id": "step-11", "kind": "externalSystem", "description": "銀行送金 API へ送金を依頼する。冪等キーで二重送金を防止。", "systemRef": "bankSystem", "httpCall": { "method": "POST", "path": "/v1/transfers", "body": "{ idempotencyKey: @idempotencyKey, amount: @createdPayment.amount, currency: @createdPayment.currency, bankAccountRef: @inputs.bankAccountRef, remitterReference: @inputs.remitterReference }" }, "outputBinding": { "name": "bankResult" }, "idempotencyKey": "@idempotencyKey", "outcomes": { "success": { "action": "continue" }, "failure": { "action": "continue", "sideEffects": [
          { "id": "step-11-fail-event", "kind": "eventPublish", "description": "銀行送金失敗イベントを発行する。", "topic": "welfare.payment_failed", "payload": "{ applicationCode: @application.application_code, paymentCode: @createdPayment.id, reason: 'bank api failure' }" }
        ] }, "timeout": { "action": "continue", "sideEffects": [
          { "id": "step-11-timeout-event", "kind": "eventPublish", "description": "銀行送金タイムアウトイベントを発行する。", "topic": "welfare.payment_failed", "payload": "{ applicationCode: @application.application_code, paymentCode: @createdPayment.id, reason: 'bank api timeout' }" }
        ] } } },
        { "id": "step-12", "kind": "branch", "description": "銀行送金が成功状態でない場合は支払を失敗にして 502 を返す。", "branches": [{ "id": "br-12-a", "code": "A", "label": "送金失敗", "condition": { "kind": "expression", "expression": "@bankResult == null || @bankResult.status != 'completed'" }, "steps": [
          { "id": "step-12-a-01", "kind": "dbAccess", "description": "支払を failed にして失敗理由を記録する。", "tableId": "7198e401-00d8-4f6e-8382-aad4caeaf59e", "operation": "UPDATE", "sql": "UPDATE payments SET transfer_status = 'failed', failure_reason = COALESCE(@bankResult.message, 'bank api failure'), updated_at = @now WHERE id = @createdPayment.id", "lineage": { "writes": [{ "tableId": "7198e401-00d8-4f6e-8382-aad4caeaf59e", "purpose": "fail-update" }] } },
          { "id": "step-12-a-02", "kind": "audit", "description": "送金失敗を監査ログに記録する。", "action": "welfare.payment.transfer_failed", "resource": { "type": "application", "id": "@application.application_code" }, "result": "failure", "sensitive": true },
          { "id": "step-12-a-03", "kind": "return", "description": "銀行送金失敗", "responseId": "502-bank-transfer-failed", "bodyExpression": "{ code: 'BANK_TRANSFER_FAILED', message: '銀行送金 API の呼び出しに失敗しました', requestId: @requestId }" }
        ] }], "elseBranch": { "id": "br-12-else", "code": "B", "label": "送金成功", "steps": [] } },
        { "id": "step-13", "kind": "dbAccess", "description": "支払を completed にして送金参照番号を記録する。", "tableId": "7198e401-00d8-4f6e-8382-aad4caeaf59e", "operation": "UPDATE", "sql": "UPDATE payments SET transfer_status = 'completed', transfer_completed_at = @now, transaction_reference = @bankResult.transactionReference, updated_at = @now WHERE id = @createdPayment.id", "affectedRowsCheck": { "operator": "=", "expected": 1, "onViolation": "throw", "errorCode": "BANK_TRANSFER_FAILED" }, "lineage": { "writes": [{ "tableId": "7198e401-00d8-4f6e-8382-aad4caeaf59e", "purpose": "complete-update" }] } },
        { "id": "step-14", "kind": "dbAccess", "description": "申請のステータスを paid に更新し決裁額を反映する。", "tableId": "b57571d6-dc31-4dad-aad9-a2315267ea90", "operation": "UPDATE", "sql": "UPDATE applications SET status = 'paid', paid_at = @now, updated_at = @now WHERE id = @application.id", "affectedRowsCheck": { "operator": "=", "expected": 1, "onViolation": "throw", "errorCode": "BANK_TRANSFER_FAILED" }, "lineage": { "writes": [{ "tableId": "b57571d6-dc31-4dad-aad9-a2315267ea90", "purpose": "paid-update" }] } },
        { "id": "step-15", "kind": "dbAccess", "description": "受給者台帳の累計支払額に加算する (初回受給者は step-08b で total_paid_amount=0 行が作成済みなので、ここでは UPDATE 一本で統合)。", "tableId": "dde87bc9-e122-4466-9b1c-e8c5b2f98408", "operation": "UPDATE", "sql": "UPDATE beneficiaries SET total_paid_amount = total_paid_amount + @createdPayment.amount, last_paid_at = @now, updated_at = @now WHERE id = COALESCE(@existingBeneficiary.id, @createdBeneficiary.id)", "affectedRowsCheck": { "operator": "=", "expected": 1, "onViolation": "throw", "errorCode": "BANK_TRANSFER_FAILED" }, "lineage": { "writes": [{ "tableId": "dde87bc9-e122-4466-9b1c-e8c5b2f98408", "purpose": "ledger-update" }] } },
        { "id": "step-16", "kind": "audit", "description": "支払完了を監査ログへ記録する。", "action": "welfare.payment.complete", "resource": { "type": "application", "id": "@application.application_code" }, "result": "success", "sensitive": true },
        { "id": "step-17", "kind": "eventPublish", "description": "支払完了イベントを発行する。", "topic": "welfare.payment_completed", "payload": "{ applicationCode: @application.application_code, paymentCode: @createdPayment.id, amount: @createdPayment.amount, transactionReference: @bankResult.transactionReference }" },
        { "id": "step-18", "kind": "externalSystem", "description": "受給者へ支払通知メールを送る。失敗時は支払自体は成立、リコンサイルジョブで再送する。", "systemRef": "notificationSystem", "httpCall": { "method": "POST", "path": "/v1/notifications", "body": "{ kind: 'welfare.payment.completed', applicantCode: @applicant.applicant_code, applicationCode: @application.application_code, amount: @createdPayment.amount, transactionReference: @bankResult.transactionReference }" }, "outputBinding": { "name": "notificationResult" }, "outcomes": { "success": { "action": "continue" }, "failure": { "action": "continue", "sideEffects": [
          { "id": "step-18-fail-event", "kind": "eventPublish", "description": "通知失敗イベント発行 (リコンサイル用)。", "topic": "welfare.notification_failed", "payload": "{ applicationCode: @application.application_code, reason: 'notification provider failure' }" }
        ] }, "timeout": { "action": "continue", "sideEffects": [
          { "id": "step-18-timeout-event", "kind": "eventPublish", "description": "通知タイムアウトイベント発行。", "topic": "welfare.notification_failed", "payload": "{ applicationCode: @application.application_code, reason: 'notification timeout' }" }
        ] } } },
        { "id": "step-19", "kind": "return", "description": "支払結果を返す。", "responseId": "200-ok", "bodyExpression": "{ paymentId: @createdPayment.id, applicationCode: @application.application_code, amount: @createdPayment.amount, currency: @createdPayment.currency, transactionReference: @bankResult.transactionReference, status: 'paid', paidAt: @now }" }
      ]
    }
  ],
  "authoring": {
    "decisions": [
      { "id": "ADR-001", "title": "支払前最終決裁を WorkflowStep で表現する", "status": "accepted", "context": "書類審査での最終決裁 (final_decision) に加え、実際の銀行送金実行前にも会計責任者 (出納長) の最終確認が必要。書類最終決裁と支払承認の責任分界を明確にする。", "decision": "支払通知フロー内に review パターンの 1 段 WorkflowStep を入れ、出納長承認後にのみ銀行送金を実行する。差戻し時は 422 を返し、申請ステータスは approved のまま据え置く (再試行可)。", "consequences": "支払までのリードタイムが 1 段増えるが、二重承認原則と監査要件を満たせる。再試行は別 API 呼び出しで実行する。", "date": "2026-04-30" },
      { "id": "ADR-002", "title": "銀行送金は冪等キー必須・送金前 in_progress 記録", "status": "accepted", "context": "銀行送金 API はネットワーク障害やタイムアウトで応答が不確定になりうる。リトライで二重送金が発生するリスクが高い。", "decision": "送金前に payments.idempotency_key UNIQUE で行を作成し、status='in_progress' で送金実行。リトライ時は同じキーを送り、銀行側で重複検知させる。", "consequences": "DB に in_progress 中の行が残るリスクがあり、リコンサイルジョブで完了確認 / 再試行 / キャンセル判定が必要。", "date": "2026-04-30" },
      { "id": "ADR-003", "title": "受給者台帳は支払前に作成 / 支払完了後に累計加算", "status": "accepted", "context": "受給者台帳は累計支払額の信頼源だが、payments.beneficiary_id は NOT NULL であるため初回受給者の場合に payments INSERT が制約違反になる。送金後に台帳を作る順序ではこの制約を満たせない。", "decision": "step-08b で初回受給者なら beneficiaries を total_paid_amount=0 で先行 INSERT し、step-15 で送金完了後に同行を UPDATE して累計を加算する。送金失敗時は初回行が残るが eligibility_status=eligible / total_paid_amount=0 なので運用上無害、再支払いで自然に統合される。affectedRowsCheck で 1 行更新を保証する (throw on violation)。", "consequences": "支払前に beneficiary 行を作るため初回時の参照整合は保証されるが、送金失敗で 0 円の台帳行が残るレアケースが発生する (リコンサイル監視対象)。送金成功後に DB 更新が一部失敗した場合の不整合は支払完了イベントから整合性監視ジョブを動かす運用で吸収する。", "date": "2026-04-30" },
      { "id": "ADR-004", "title": "通知失敗は支払成立を覆さない", "status": "accepted", "context": "支払通知メール送信は補助情報伝達であり、銀行送金が完了している以上支払自体を取り消すべきではない。", "decision": "notificationSystem 失敗時は continue + welfare.notification_failed イベントを発行し、レスポンスは 200 で支払成立を返す。リコンサイルジョブで通知再送する。", "consequences": "通知未達のケースが運用で発生しうるため、リコンサイル監視と再送 SLA を別途定義する必要がある。", "date": "2026-04-30" }
    ],
    "glossary": {
      "支払通知": { "definition": "決裁済み給付申請に対して銀行送金を実行し、受給者に通知メールを送る一連の処理。", "aliases": ["Payment Notification"] },
      "出納長": { "definition": "自治体の会計責任者。歳出予算の執行と支払いの最終承認権限を持つ。", "aliases": ["Treasurer"] },
      "冪等キー": { "definition": "同一操作の二重実行を防ぐため、API 呼び出しに付加する一意キー。同じキーでの再呼び出しは銀行側で重複検知される。", "aliases": ["Idempotency Key"] },
      "全銀協議定書": { "definition": "全国銀行協会が定める銀行間送金プロトコル。日本国内での銀行送金 API の業界標準。", "aliases": ["Zengin Protocol"] },
      "リコンサイル": { "definition": "送金中 / 通知未達などの不確定状態を後続バッチで確認・修正する処理。", "aliases": ["Reconciliation"] },
      "受給者台帳": { "definition": "過去に給付を受けた住民の累計金額・受給資格状態を保持する台帳。", "aliases": ["Beneficiary Ledger"] },
      "送金参照番号": { "definition": "銀行送金 API が返す送金トランザクションの一意識別子。受給者問い合わせ時の照合に使う。", "aliases": ["Transaction Reference"] },
      "会計年度": { "definition": "日本の自治体は 4 月始まりの年度で予算を管理する。受給者台帳の累計はこの単位でリセットする。", "aliases": ["Fiscal Year"] }
    },
    "testScenarios": [
      { "id": "happy-path-payment", "name": "決裁済み申請への支払成功 (出納長承認 + 銀行送金成功想定)", "description": "step-stage-treasurer は approved に分岐させ、bankSystem は completed を返す前提のシナリオ。", "given": [{ "kind": "sessionContext", "context": { "requestId": "req-pay-001", "sessionUserId": "treasurer-001", "sessionRole": "treasurer" } }, { "kind": "dbState", "tableId": "b57571d6-dc31-4dad-aad9-a2315267ea90", "rows": [{ "id": 1, "application_code": "BN2026043000000001", "applicant_id": 1, "benefit_type": "child_allowance", "requested_amount": 50000, "approved_amount": 50000, "status": "approved", "decided_at": "2026-04-29T10:00:00.000Z" }] }, { "kind": "dbState", "tableId": "c3bff56f-e4d2-4597-8819-93ecf7fc0acd", "rows": [{ "id": 1, "applicant_code": "AP0000000001", "full_name": "山田太郎", "identity_verified": true }] }, { "kind": "dbState", "tableId": "dde87bc9-e122-4466-9b1c-e8c5b2f98408", "rows": [{ "id": 1, "applicant_id": 1, "beneficiary_code": "BF0000000001", "fiscal_year": 2026, "total_paid_amount": 100000, "eligibility_status": "eligible" }] }, { "kind": "externalStub", "externalRef": "bankSystem", "responseMock": { "status": "completed", "transactionReference": "TXN-2026-0001" } }, { "kind": "externalStub", "externalRef": "notificationSystem", "responseMock": { "status": "delivered" } }], "when": { "actionId": "act-001", "input": { "applicationCode": "BN2026043000000001", "bankAccountRef": "BA0123456789abcdef0123456789abcdef0123456789", "paymentMethod": "bank_transfer", "remitterReference": "REM-2026-0001" } }, "then": [{ "kind": "outcome", "expected": "200-ok" }, { "kind": "dbRow", "tableId": "7198e401-00d8-4f6e-8382-aad4caeaf59e", "match": { "transfer_status": "completed" }, "count": 1 }, { "kind": "dbRow", "tableId": "b57571d6-dc31-4dad-aad9-a2315267ea90", "match": { "status": "paid" }, "count": 1 }, { "kind": "auditLog", "action": "welfare.payment.complete", "result": "success" }], "tags": ["happy"] },
      { "id": "edge-application-not-approved", "name": "未決裁の申請への支払試行は 409", "given": [{ "kind": "sessionContext", "context": { "requestId": "req-pay-002", "sessionUserId": "treasurer-001" } }, { "kind": "dbState", "tableId": "b57571d6-dc31-4dad-aad9-a2315267ea90", "rows": [{ "id": 2, "application_code": "BN2026043000000002", "applicant_id": 1, "benefit_type": "child_allowance", "requested_amount": 50000, "approved_amount": null, "status": "under_first_review" }] }], "when": { "actionId": "act-001", "input": { "applicationCode": "BN2026043000000002", "bankAccountRef": "BA0123456789abcdef0123456789abcdef0123456789", "paymentMethod": "bank_transfer", "remitterReference": "REM-2026-0002" } }, "then": [{ "kind": "outcome", "expected": "409-application-not-approved" }], "tags": ["edge", "status"] },
      { "id": "edge-bank-transfer-failed", "name": "銀行送金が失敗した場合は 502 と payments.failed (出納長承認後 / 銀行 NG)", "description": "step-stage-treasurer は approved 前提、bankSystem は status='failed' を返す前提のシナリオ。", "given": [{ "kind": "sessionContext", "context": { "requestId": "req-pay-003", "sessionUserId": "treasurer-001" } }, { "kind": "dbState", "tableId": "b57571d6-dc31-4dad-aad9-a2315267ea90", "rows": [{ "id": 3, "application_code": "BN2026043000000003", "applicant_id": 1, "approved_amount": 30000, "status": "approved" }] }, { "kind": "dbState", "tableId": "c3bff56f-e4d2-4597-8819-93ecf7fc0acd", "rows": [{ "id": 1, "applicant_code": "AP0000000001", "identity_verified": true }] }, { "kind": "externalStub", "externalRef": "bankSystem", "responseMock": { "status": "failed", "message": "insufficient funds at remitter account" } }], "when": { "actionId": "act-001", "input": { "applicationCode": "BN2026043000000003", "bankAccountRef": "BA0123456789abcdef0123456789abcdef0123456789", "paymentMethod": "bank_transfer", "remitterReference": "REM-2026-0003" } }, "then": [{ "kind": "outcome", "expected": "502-bank-transfer-failed" }, { "kind": "dbRow", "tableId": "7198e401-00d8-4f6e-8382-aad4caeaf59e", "match": { "transfer_status": "failed" }, "count": 1 }], "tags": ["edge", "bank"] },
      { "id": "edge-treasurer-rejected", "name": "出納長最終決裁で差戻し → 422 + payments 未作成", "description": "step-stage-treasurer の出納長 reviewer が rejected を返す前提のシナリオ (予算枠超過などを想定)。", "given": [{ "kind": "sessionContext", "context": { "requestId": "req-pay-004", "sessionUserId": "treasurer-001" } }, { "kind": "dbState", "tableId": "b57571d6-dc31-4dad-aad9-a2315267ea90", "rows": [{ "id": 4, "application_code": "BN2026043000000004", "applicant_id": 1, "approved_amount": 100000, "status": "approved" }] }, { "kind": "dbState", "tableId": "c3bff56f-e4d2-4597-8819-93ecf7fc0acd", "rows": [{ "id": 1, "applicant_code": "AP0000000001", "identity_verified": true }] }], "when": { "actionId": "act-001", "input": { "applicationCode": "BN2026043000000004", "bankAccountRef": "BA0123456789abcdef0123456789abcdef0123456789", "paymentMethod": "bank_transfer", "remitterReference": "REM-2026-0004" } }, "then": [{ "kind": "outcome", "expected": "422-treasurer-rejected" }, { "kind": "dbRow", "tableId": "7198e401-00d8-4f6e-8382-aad4caeaf59e", "match": {}, "count": 0 }], "tags": ["edge", "workflow"] },
      { "id": "happy-path-first-time-beneficiary", "name": "初回受給者の支払成功 — beneficiaries 行が新規作成され total_paid_amount が金額分進む", "description": "受給者台帳に行が無い初回申請者への支払。step-08b で beneficiaries を total_paid_amount=0 で作成し、step-15 で UPDATE して支払額を加算する経路を検証する (M1 防止のためのレビュー追加)。", "given": [{ "kind": "sessionContext", "context": { "requestId": "req-pay-005", "sessionUserId": "treasurer-001", "sessionRole": "treasurer" } }, { "kind": "dbState", "tableId": "b57571d6-dc31-4dad-aad9-a2315267ea90", "rows": [{ "id": 5, "application_code": "BN2026043000000005", "applicant_id": 5, "benefit_type": "livelihood_support", "requested_amount": 80000, "approved_amount": 80000, "status": "approved", "decided_at": "2026-04-29T10:00:00.000Z" }] }, { "kind": "dbState", "tableId": "c3bff56f-e4d2-4597-8819-93ecf7fc0acd", "rows": [{ "id": 5, "applicant_code": "AP0000000005", "full_name": "鈴木一郎", "identity_verified": true, "identity_verified_at": "2026-04-15T00:00:00.000Z" }] }, { "kind": "externalStub", "externalRef": "bankSystem", "responseMock": { "status": "completed", "transactionReference": "TXN-2026-0005" } }, { "kind": "externalStub", "externalRef": "notificationSystem", "responseMock": { "status": "delivered" } }], "when": { "actionId": "act-001", "input": { "applicationCode": "BN2026043000000005", "bankAccountRef": "BA0123456789abcdef0123456789abcdef0123456789", "paymentMethod": "bank_transfer", "remitterReference": "REM-2026-0005" } }, "then": [{ "kind": "outcome", "expected": "200-ok" }, { "kind": "dbRow", "tableId": "dde87bc9-e122-4466-9b1c-e8c5b2f98408", "match": { "applicant_id": 5, "total_paid_amount": 80000 }, "count": 1 }, { "kind": "dbRow", "tableId": "7198e401-00d8-4f6e-8382-aad4caeaf59e", "match": { "transfer_status": "completed" }, "count": 1 }, { "kind": "dbRow", "tableId": "b57571d6-dc31-4dad-aad9-a2315267ea90", "match": { "status": "paid" }, "count": 1 }], "tags": ["happy", "first-time-beneficiary"] }
    ]
