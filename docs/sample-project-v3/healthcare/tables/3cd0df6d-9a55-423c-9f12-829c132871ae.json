{
  "$schema": "../../../../schemas/v3/table.v3.schema.json",
  "id": "3cd0df6d-9a55-423c-9f12-829c132871ae",
  "name": "医療提供者",
  "description": "医師、薬剤師、看護師、受付担当者の資格状態と業務ロールを保持する。",
  "version": "1.0.0",
  "maturity": "committed",
  "createdAt": "2026-04-30T00:00:00.000Z",
  "updatedAt": "2026-04-30T00:00:00.000Z",
  "physicalName": "providers",
  "category": "マスタ",
  "columns": [
    { "id": "col-prv01", "no": 1, "physicalName": "id", "name": "提供者内部ID", "dataType": "BIGINT", "notNull": true, "primaryKey": true, "autoIncrement": true },
    { "id": "col-prv02", "no": 2, "physicalName": "provider_code", "name": "提供者ID", "dataType": "VARCHAR", "length": 20, "notNull": true, "unique": true },
    { "id": "col-prv03", "no": 3, "physicalName": "full_name", "name": "氏名", "dataType": "VARCHAR", "length": 120, "notNull": true },
    { "id": "col-prv04", "no": 4, "physicalName": "role", "name": "ロール", "dataType": "VARCHAR", "length": 30, "notNull": true },
    { "id": "col-prv05", "no": 5, "physicalName": "credential_number", "name": "資格番号", "dataType": "VARCHAR", "length": 64 },
    { "id": "col-prv06", "no": 6, "physicalName": "credential_status", "name": "資格状態", "dataType": "VARCHAR", "length": 30, "notNull": true, "defaultValue": "'active'" },
    { "id": "col-prv07", "no": 7, "physicalName": "specialty", "name": "専門科", "dataType": "VARCHAR", "length": 80 },
    { "id": "col-prv08", "no": 8, "physicalName": "pharmacy_license_state", "name": "薬剤師免許州", "dataType": "VARCHAR", "length": 40 },
    { "id": "col-prv09", "no": 9, "physicalName": "created_at", "name": "作成日時", "dataType": "TIMESTAMP", "notNull": true, "defaultValue": "CURRENT_TIMESTAMP" },
    { "id": "col-prv10", "no": 10, "physicalName": "updated_at", "name": "更新日時", "dataType": "TIMESTAMP", "notNull": true, "defaultValue": "CURRENT_TIMESTAMP" }
  ],
  "indexes": [
    { "id": "idx-prv01", "physicalName": "idx_providers_provider_code", "columns": [{ "columnId": "col-prv02" }], "unique": true },
    { "id": "idx-prv02", "physicalName": "idx_providers_role_status", "columns": [{ "columnId": "col-prv04" }, { "columnId": "col-prv06" }] }
  ],
  "constraints": [
    { "id": "chk-prv01", "kind": "check", "physicalName": "chk_providers_role", "expression": "role IN ('physician', 'pharmacist', 'nurse', 'receptionist')" },
    { "id": "chk-prv02", "kind": "check", "physicalName": "chk_providers_credential_status", "expression": "credential_status IN ('active', 'suspended', 'expired')" }
  ]
}
