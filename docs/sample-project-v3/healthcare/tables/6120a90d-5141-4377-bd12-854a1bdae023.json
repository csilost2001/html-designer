    { "id": "fk-apt02", "kind": "foreignKey", "physicalName": "fk_appointments_provider", "columnIds": ["col-apt04"], "referencedTableId": "3cd0df6d-9a55-423c-9f12-829c132871ae", "referencedColumnIds": ["col-prv01"], "onDelete": "restrict", "onUpdate": "cascade" },
