{
  "$schema": "../../../../schemas/v3/process-flow.v3.schema.json",
  "meta": {
    "id": "a54d7fe5-a575-4ac8-967d-e72ec27db401",
    "name": "処方箋発行",
    "description": "診察記録に基づいて処方案を作成し、医師署名、重複処方チェック、薬剤師鑑査、薬局システム送信までを行う。",
    "version": "1.0.0",
    "maturity": "committed",
    "createdAt": "2026-04-30T00:00:00.000Z",
    "updatedAt": "2026-04-30T00:00:00.000Z",
    "kind": "system",
    "apiVersion": "v1",
    "mode": "upstream",
    "primaryInvoker": {
      "kind": "screen-item-event",
      "screenId": "2b3d8199-e338-4c61-b0c3-3df36cd41532",
      "itemId": "submitBtn",
      "eventId": "click"
    }
  },
  "context": {
    "catalogs": {
      "errors": {
        "VALIDATION": { "httpStatus": 400, "defaultMessage": "入力値が不正です", "responseId": "400-validation" },
        "MEDICAL_RECORD_NOT_FOUND": { "httpStatus": 404, "defaultMessage": "患者記録が見つかりません", "responseId": "404-medical-record-not-found" },
        "PHI_ACCESS_DENIED": { "httpStatus": 403, "defaultMessage": "PHI へのアクセスが許可されていません", "responseId": "403-phi-access-denied" },
        "PRESCRIBER_INVALID": { "httpStatus": 422, "defaultMessage": "処方医の資格が有効ではありません", "responseId": "422-prescriber-invalid" },
        "DUPLICATE_PRESCRIPTION": { "httpStatus": 409, "defaultMessage": "重複処方の疑いがあります", "responseId": "409-duplicate-prescription" },
        "PHARMACIST_REJECTED": { "httpStatus": 422, "defaultMessage": "薬剤師鑑査で差し戻されました", "responseId": "422-pharmacist-rejected" },
        "PHARMACY_SEND_FAILED": { "httpStatus": 502, "defaultMessage": "薬局システムへの送信に失敗しました", "responseId": "502-pharmacy-send-failed" },
        "PRESCRIPTION_UPDATE_CONFLICT": { "httpStatus": 500, "defaultMessage": "処方箋ステータス更新で楽観ロック競合または対象不在", "responseId": "500-prescription-update-conflict" }
      },
      "externalSystems": {
        "emrSystem": { "name": "電子カルテシステム", "baseUrl": "https://emr.example.local", "auth": { "kind": "bearer", "tokenRef": "@secret.emrApiToken" }, "timeoutMs": 3000, "description": "患者記録と処方履歴を参照する院内 EMR。" },
        "pharmacyNetwork": { "name": "薬局連携システム", "baseUrl": "https://pharmacy.example.local", "auth": { "kind": "oauth2", "tokenRef": "@secret.pharmacyOAuthToken" }, "timeoutMs": 5000, "retryPolicy": { "maxAttempts": 3, "backoff": "exponential", "initialDelayMs": 300 }, "description": "電子処方箋を保険薬局へ送信するネットワーク。" },
        "drugInteractionService": { "name": "薬剤安全性チェックサービス", "baseUrl": "https://drug-safety.example.local", "auth": { "kind": "apiKey", "tokenRef": "@secret.drugSafetyApiKey", "headerName": "X-API-Key" }, "timeoutMs": 3000, "description": "相互作用、禁忌、重複処方を判定する。" }
      },
      "secrets": {
        "emrApiToken": { "source": "vault", "name": "healthcare/emr/api-token", "description": "電子カルテ API の bearer token。", "rotationDays": 90 },
        "pharmacyOAuthToken": { "source": "vault", "name": "healthcare/pharmacy/oauth-token", "description": "薬局連携 OAuth token。", "rotationDays": 60 },
        "drugSafetyApiKey": { "source": "vault", "name": "healthcare/drug-safety/api-key", "description": "薬剤安全性チェック API key。", "rotationDays": 180 }
      },
      "domains": {
        "PrescriptionId": { "type": "string", "constraints": [{ "field": "value", "type": "regex", "pattern": "^RX[0-9]{8}[0-9]{6}$", "severity": "error" }], "description": "電子処方箋 ID。" },
        "PatientId": { "type": "string", "constraints": [{ "field": "value", "type": "regex", "pattern": "^PAT[0-9]{10}$", "severity": "error" }], "description": "医療機関内患者 ID。" },
        "MedicationCode": { "type": "string", "constraints": [{ "field": "value", "type": "minLength", "length": 1, "severity": "error" }], "description": "院内または標準薬剤コード。" },
        "DaysSupply": { "type": "integer", "constraints": [{ "field": "value", "type": "range", "min": 1, "max": 90, "severity": "error" }], "description": "処方日数。" },
        "MoneyAmount": { "type": "number", "constraints": [{ "field": "value", "type": "range", "min": 0, "severity": "error" }], "description": "薬剤費などの非負金額。" }
      },
      "functions": {
        "generatePrescriptionCode": { "signature": "generatePrescriptionCode(now: datetime): string", "returnType": "string", "description": "RX + 日付 + 連番の処方箋 ID を採番する。", "examples": ["generatePrescriptionCode(@now)"] },
        "calculateRetentionDate": { "signature": "calculateRetentionDate(encounterAt: datetime, years: integer): date", "returnType": "date", "description": "カルテ法定保存期限を算出する。", "examples": ["calculateRetentionDate(@record.encounter_at, 5)"] },
        "normalizeMedicationCode": { "signature": "normalizeMedicationCode(code: string): string", "returnType": "string", "description": "薬剤コード表記を標準化する。", "examples": ["normalizeMedicationCode('rx-001')"] },
        "isDuplicateActivePrescription": { "signature": "isDuplicateActivePrescription(existingCount: integer): boolean", "returnType": "boolean", "description": "同一患者、同一薬剤の有効処方が存在するか判定する。", "examples": ["isDuplicateActivePrescription(1)"] }
      },
      "events": {
        "healthcare.prescription_drafted": { "description": "処方案が作成された時に発行する。", "payload": { "type": "object", "required": ["prescriptionCode", "patientCode"], "properties": { "prescriptionCode": { "type": "string" }, "patientCode": { "type": "string" } } } },
        "healthcare.prescriber_signed": { "description": "処方医が処方案に署名した時に発行する。", "payload": { "type": "object", "required": ["prescriptionCode", "prescriberCode"], "properties": { "prescriptionCode": { "type": "string" }, "prescriberCode": { "type": "string" } } } },
        "healthcare.pharmacist_verified": { "description": "薬剤師鑑査が完了した時に発行する。", "payload": { "type": "object", "required": ["prescriptionCode", "pharmacistCode"], "properties": { "prescriptionCode": { "type": "string" }, "pharmacistCode": { "type": "string" } } } },
        "healthcare.prescription_blocked": { "description": "重複処方や鑑査差し戻しで処方が停止された時に発行する。", "payload": { "type": "object", "required": ["prescriptionCode", "reason"], "properties": { "prescriptionCode": { "type": "string" }, "reason": { "type": "string" } } } },
        "healthcare.prescription_sent": { "description": "薬局システムへ処方箋を送信した時に発行する。", "payload": { "type": "object", "required": ["prescriptionCode", "routingStatus"], "properties": { "prescriptionCode": { "type": "string" }, "routingStatus": { "type": "string" } } } }
      }
    },
    "ambientVariables": [
      { "name": "requestId", "type": "string", "required": true },
      { "name": "sessionUserId", "type": "string", "required": true },
      { "name": "sessionRole", "type": "string", "required": true },
      { "name": "now", "type": "datetime", "required": true }
    ]
  },
  "actions": [
    {
      "id": "act-001",
      "name": "処方箋を発行",
      "trigger": "healthcare:prescriptionRequested",
      "description": "診察記録、医師資格、薬剤安全性、薬剤師鑑査を確認して電子処方箋を発行する。",
      "maturity": "committed",
      "httpRoute": { "method": "POST", "path": "/api/healthcare/prescriptions", "auth": "required" },
      "requiredPermissions": ["@conv.permission.prescription.issue"],
      "inputs": [
        { "name": "medicalRecordCode", "label": "患者記録ID", "type": "string", "required": true },
        { "name": "prescriberCode", "label": "処方医ID", "type": "string", "required": true },
        { "name": "medicationCode", "label": "薬剤コード", "type": { "kind": "domain", "domainKey": "MedicationCode" }, "required": true },
        { "name": "medicationName", "label": "薬剤名", "type": "string", "required": true },
        { "name": "dosageInstruction", "label": "用法用量", "type": "string", "required": true },
        { "name": "daysSupply", "label": "処方日数", "type": { "kind": "domain", "domainKey": "DaysSupply" }, "required": true }
      ],
      "outputs": [
        { "name": "prescriptionId", "label": "処方箋ID", "type": { "kind": "domain", "domainKey": "PrescriptionId" } },
        { "name": "status", "label": "状態", "type": "string" },
        { "name": "pharmacyRoutingStatus", "label": "薬局送信状態", "type": "string" }
      ],
      "responses": [
        { "id": "201-created", "status": 201, "bodySchema": { "typeRef": "healthcare:PrescriptionResponse" }, "when": "処方箋発行成功" },
        { "id": "400-validation", "status": 400, "bodySchema": { "typeRef": "healthcare:ApiError" } },
        { "id": "403-phi-access-denied", "status": 403, "bodySchema": { "typeRef": "healthcare:ApiError" } },
        { "id": "404-medical-record-not-found", "status": 404, "bodySchema": { "typeRef": "healthcare:ApiError" } },
        { "id": "409-duplicate-prescription", "status": 409, "bodySchema": { "typeRef": "healthcare:ApiError" } },
        { "id": "422-prescriber-invalid", "status": 422, "bodySchema": { "typeRef": "healthcare:ApiError" } },
        { "id": "422-pharmacist-rejected", "status": 422, "bodySchema": { "typeRef": "healthcare:ApiError" } },
        { "id": "502-pharmacy-send-failed", "status": 502, "bodySchema": { "typeRef": "healthcare:ApiError" } },
        { "id": "500-prescription-update-conflict", "status": 500, "bodySchema": { "typeRef": "healthcare:ApiError" } }
      ],
      "steps": [
        { "id": "step-01", "kind": "validation", "description": "患者記録、処方医、薬剤、処方日数を検証する。", "rules": [
          { "field": "medicalRecordCode", "type": "regex", "pattern": "^MR[0-9]{8}[0-9]{6}$", "severity": "error", "message": "患者記録IDの形式が不正です" },
          { "field": "prescriberCode", "type": "regex", "pattern": "^PRV[0-9]{8}$", "severity": "error", "message": "処方医IDの形式が不正です" },
          { "field": "medicationCode", "type": "minLength", "length": 1, "severity": "error", "message": "薬剤コードは必須です" },
          { "field": "daysSupply", "type": "range", "min": 1, "max": 90, "severity": "error", "message": "処方日数は 1 から 90 日です" }
        ], "fieldErrorsVar": "fieldErrors", "inlineBranch": { "ok": [], "ng": [], "ngResponseId": "400-validation", "ngBodyExpression": "{ code: 'VALIDATION', message: '入力値が不正です', requestId: @requestId, fieldErrors: @fieldErrors }" } },
        { "id": "step-02", "kind": "dbAccess", "description": "患者記録を取得する。", "tableId": "4bffe509-cd06-42de-a814-43c51d2ee5ed", "operation": "SELECT", "sql": "SELECT id, record_code, patient_id, appointment_id, provider_id, encounter_at, diagnosis_code, retained_until FROM medical_records WHERE record_code = @inputs.medicalRecordCode", "outputBinding": { "name": "record" }, "lineage": { "reads": [{ "tableId": "4bffe509-cd06-42de-a814-43c51d2ee5ed", "purpose": "lookup" }] } },
        { "id": "step-03", "kind": "branch", "description": "患者記録が存在しない場合は 404 を返す。", "branches": [{ "id": "br-03-a", "code": "A", "label": "記録なし", "condition": { "kind": "expression", "expression": "@record == null" }, "steps": [{ "id": "step-03-a-01", "kind": "return", "description": "記録なし", "responseId": "404-medical-record-not-found", "bodyExpression": "{ code: 'MEDICAL_RECORD_NOT_FOUND', message: '患者記録が見つかりません', requestId: @requestId }" }] }], "elseBranch": { "id": "br-03-else", "code": "B", "label": "記録あり", "steps": [] } },
        { "id": "step-04", "kind": "dbAccess", "description": "患者を取得する。", "tableId": "6b5ec66a-08bb-4df6-b908-1684b9c744c2", "operation": "SELECT", "sql": "SELECT id, patient_code, full_name, phi_consent_status, allergy_summary FROM patients WHERE id = @record.patient_id", "outputBinding": { "name": "patient" }, "lineage": { "reads": [{ "tableId": "6b5ec66a-08bb-4df6-b908-1684b9c744c2", "purpose": "phi-read" }] } },
        { "id": "step-05", "kind": "healthcare:PhiAccessCheckStep", "description": "処方箋発行に必要な PHI アクセスを確認する。", "config": { "purpose": "prescription-issue", "patientRef": "@patient.patient_code", "minimumNecessary": true }, "lineage": { "reads": [{ "tableId": "6b5ec66a-08bb-4df6-b908-1684b9c744c2", "purpose": "phi-access-check" }] } },
        { "id": "step-06", "kind": "branch", "description": "PHI 同意が制限されている場合は停止する。", "branches": [{ "id": "br-06-a", "code": "A", "label": "PHI 不可", "condition": { "kind": "expression", "expression": "@patient.phi_consent_status == 'revoked'" }, "steps": [{ "id": "step-06-a-01", "kind": "return", "description": "PHI アクセス不可", "responseId": "403-phi-access-denied", "bodyExpression": "{ code: 'PHI_ACCESS_DENIED', message: 'PHI へのアクセスが許可されていません', requestId: @requestId }" }] }], "elseBranch": { "id": "br-06-else", "code": "B", "label": "PHI 可", "steps": [] } },
        { "id": "step-07", "kind": "dbAccess", "description": "処方医を取得する。", "tableId": "3cd0df6d-9a55-423c-9f12-829c132871ae", "operation": "SELECT", "sql": "SELECT id, provider_code, role, credential_number, credential_status FROM providers WHERE provider_code = @inputs.prescriberCode", "outputBinding": { "name": "prescriber" }, "lineage": { "reads": [{ "tableId": "3cd0df6d-9a55-423c-9f12-829c132871ae", "purpose": "lookup" }] } },
        { "id": "step-08", "kind": "branch", "description": "処方医資格が有効でない場合は停止する。", "branches": [{ "id": "br-08-a", "code": "A", "label": "処方不可", "condition": { "kind": "expression", "expression": "@prescriber == null || @prescriber.role != 'physician' || @prescriber.credential_status != 'active'" }, "steps": [{ "id": "step-08-a-01", "kind": "return", "description": "処方医資格無効", "responseId": "422-prescriber-invalid", "bodyExpression": "{ code: 'PRESCRIBER_INVALID', message: '処方医の資格が有効ではありません', requestId: @requestId }" }] }], "elseBranch": { "id": "br-08-else", "code": "B", "label": "処方可", "steps": [] } },
        { "id": "step-09", "kind": "compute", "description": "薬剤コードを標準化する。", "expression": "fn.normalizeMedicationCode(@inputs.medicationCode)", "outputBinding": { "name": "normalizedMedicationCode" } },
        { "id": "step-10", "kind": "dbAccess", "description": "同一患者、同一薬剤の有効処方を検索する。", "tableId": "d628ce21-bacc-4f6c-952b-a4c07846e740", "operation": "SELECT", "sql": "SELECT id, prescription_code, medication_code, status FROM prescriptions WHERE patient_id = @patient.id AND medication_code = @normalizedMedicationCode AND status IN ('pending_verification', 'verified', 'sent')", "outputBinding": { "name": "duplicatePrescription" }, "lineage": { "reads": [{ "tableId": "d628ce21-bacc-4f6c-952b-a4c07846e740", "purpose": "duplicate-check" }] } },
        { "id": "step-11", "kind": "healthcare:ClinicalSafetyCheckStep", "description": "相互作用、禁忌、アレルギー、重複処方を確認する。", "config": { "patientRef": "@patient.patient_code", "medicationRef": "@normalizedMedicationCode", "checkKinds": ["duplicate", "allergy", "contraindication", "interaction"] }, "outputBinding": { "name": "clinicalSafety" } },
        { "id": "step-12", "kind": "externalSystem", "description": "薬剤安全性チェックサービスで重複処方と相互作用を確認する。", "systemRef": "drugInteractionService", "httpCall": { "method": "POST", "path": "/v1/checks", "body": "{ patientCode: @patient.patient_code, medicationCode: @normalizedMedicationCode, allergySummary: @patient.allergy_summary }" }, "outputBinding": { "name": "drugSafetyResult" }, "outcomes": { "success": { "action": "continue" }, "failure": { "action": "abort" }, "timeout": { "action": "abort" } } },
        { "id": "step-13", "kind": "branch", "description": "重複処方があれば処方を停止する。", "branches": [{ "id": "br-13-a", "code": "A", "label": "重複あり", "condition": { "kind": "expression", "expression": "@duplicatePrescription != null" }, "steps": [{ "id": "step-13-a-01", "kind": "eventPublish", "description": "処方停止イベントを発行する。", "topic": "healthcare.prescription_blocked", "payload": "{ prescriptionCode: 'not-created', reason: 'duplicate' }" }, { "id": "step-13-a-02", "kind": "return", "description": "重複処方", "responseId": "409-duplicate-prescription", "bodyExpression": "{ code: 'DUPLICATE_PRESCRIPTION', message: '重複処方の疑いがあります', requestId: @requestId }" }] }], "elseBranch": { "id": "br-13-else", "code": "B", "label": "重複なし", "steps": [] } },
        { "id": "step-14", "kind": "dbAccess", "description": "処方案を作成する。", "tableId": "d628ce21-bacc-4f6c-952b-a4c07846e740", "operation": "INSERT", "sql": "INSERT INTO prescriptions (prescription_code, patient_id, medical_record_id, prescriber_provider_id, medication_code, medication_name, dosage_instruction, days_supply, status, duplicate_check_result, pharmacy_routing_status) VALUES (fn.generatePrescriptionCode(@now), @patient.id, @record.id, @prescriber.id, @normalizedMedicationCode, @inputs.medicationName, @inputs.dosageInstruction, @inputs.daysSupply, 'pending_verification', 'passed', 'pending') RETURNING id, prescription_code, patient_id, medication_code, status, pharmacy_routing_status", "outputBinding": { "name": "draftPrescription" }, "lineage": { "writes": [{ "tableId": "d628ce21-bacc-4f6c-952b-a4c07846e740", "purpose": "create" }] } },
        { "id": "step-15", "kind": "eventPublish", "description": "処方案作成イベントを発行する。", "topic": "healthcare.prescription_drafted", "payload": "{ prescriptionCode: @draftPrescription.prescription_code, patientCode: @patient.patient_code }" },
        { "id": "step-stage-1", "kind": "workflow", "description": "Stage 1 医師署名。処方医本人または同等権限者が署名する。", "maturity": "committed", "pattern": "sign-off", "approvers": [{ "role": "@conv.healthcareRole.physician", "label": "処方医", "order": 1 }], "onApproved": [{ "id": "step-stage-1-app-01", "kind": "eventPublish", "description": "医師署名イベントを発行する。", "topic": "healthcare.prescriber_signed", "payload": "{ prescriptionCode: @draftPrescription.prescription_code, prescriberCode: @prescriber.provider_code }" }] },
        { "id": "step-stage-2", "kind": "workflow", "description": "Stage 2 薬剤師鑑査。薬剤師が相互作用、禁忌、重複処方、用量を確認する。", "maturity": "committed", "pattern": "review", "approvers": [{ "role": "@conv.healthcareRole.pharmacist", "label": "薬剤師", "order": 1 }], "onApproved": [{ "id": "step-stage-2-app-01", "kind": "dbAccess", "description": "薬剤師鑑査済みに更新する。", "tableId": "d628ce21-bacc-4f6c-952b-a4c07846e740", "operation": "UPDATE", "sql": "UPDATE prescriptions SET status = 'verified', pharmacist_verified_at = CURRENT_TIMESTAMP, updated_at = CURRENT_TIMESTAMP WHERE id = @draftPrescription.id", "affectedRowsCheck": { "operator": "=", "expected": 1, "onViolation": "throw", "errorCode": "PRESCRIPTION_UPDATE_CONFLICT" }, "lineage": { "writes": [{ "tableId": "d628ce21-bacc-4f6c-952b-a4c07846e740", "purpose": "verify" }] } }, { "id": "step-stage-2-app-02", "kind": "eventPublish", "description": "薬剤師鑑査完了イベントを発行する。", "topic": "healthcare.pharmacist_verified", "payload": "{ prescriptionCode: @draftPrescription.prescription_code, pharmacistCode: @sessionUserId }" }], "onRejected": [{ "id": "step-stage-2-rej-01", "kind": "dbAccess", "description": "処方を差し戻し状態に更新する。", "tableId": "d628ce21-bacc-4f6c-952b-a4c07846e740", "operation": "UPDATE", "sql": "UPDATE prescriptions SET status = 'blocked', updated_at = CURRENT_TIMESTAMP WHERE id = @draftPrescription.id" }, { "id": "step-stage-2-rej-02", "kind": "eventPublish", "description": "鑑査差し戻しイベントを発行する。", "topic": "healthcare.prescription_blocked", "payload": "{ prescriptionCode: @draftPrescription.prescription_code, reason: 'pharmacist review rejected' }" }, { "id": "step-stage-2-rej-03", "kind": "return", "description": "薬剤師鑑査差し戻し", "responseId": "422-pharmacist-rejected", "bodyExpression": "{ code: 'PHARMACIST_REJECTED', message: '薬剤師鑑査で差し戻されました', requestId: @requestId }" }] },
        { "id": "step-stage-3", "kind": "workflow", "description": "Stage 3 発行承認。医師と薬剤師の確認後、薬局送信前に最終承認する。", "maturity": "committed", "pattern": "approval-sequential", "approvers": [{ "role": "@conv.healthcareRole.physician", "label": "処方医", "order": 1 }, { "role": "@conv.healthcareRole.pharmacist", "label": "薬剤師", "order": 2 }], "onApproved": [{ "id": "step-stage-3-app-01", "kind": "dbAccess", "description": "最終承認済 (発行直前) 状態に更新する。Stage 2 verified との状態分離で薬局送信前の最終決裁を可視化。", "tableId": "d628ce21-bacc-4f6c-952b-a4c07846e740", "operation": "UPDATE", "sql": "UPDATE prescriptions SET status = 'final_approved', updated_at = CURRENT_TIMESTAMP WHERE id = @draftPrescription.id", "affectedRowsCheck": { "operator": "=", "expected": 1, "onViolation": "throw", "errorCode": "PRESCRIPTION_UPDATE_CONFLICT" } }], "onRejected": [{ "id": "step-stage-3-rej-01", "kind": "eventPublish", "description": "最終承認差し戻しイベントを発行する。", "topic": "healthcare.prescription_blocked", "payload": "{ prescriptionCode: @draftPrescription.prescription_code, reason: 'final approval rejected' }" }, { "id": "step-stage-3-rej-02", "kind": "return", "description": "最終承認差し戻し", "responseId": "422-pharmacist-rejected", "bodyExpression": "{ code: 'PHARMACIST_REJECTED', message: '最終承認で差し戻されました', requestId: @requestId }" }] },
        { "id": "step-16", "kind": "externalSystem", "description": "薬局連携システムへ電子処方箋を送信する。", "systemRef": "pharmacyNetwork", "httpCall": { "method": "POST", "path": "/v1/e-prescriptions", "body": "{ prescriptionCode: @draftPrescription.prescription_code, patientCode: @patient.patient_code, medicationCode: @normalizedMedicationCode, dosageInstruction: @inputs.dosageInstruction, daysSupply: @inputs.daysSupply }" }, "outputBinding": { "name": "pharmacyRouting" }, "outcomes": { "success": { "action": "continue" }, "failure": { "action": "abort" }, "timeout": { "action": "abort" } }, "idempotencyKey": "@draftPrescription.prescription_code" },
        { "id": "step-17", "kind": "dbAccess", "description": "薬局送信済みに更新する。", "tableId": "d628ce21-bacc-4f6c-952b-a4c07846e740", "operation": "UPDATE", "sql": "UPDATE prescriptions SET status = 'sent', pharmacy_routing_status = 'sent', updated_at = CURRENT_TIMESTAMP WHERE id = @draftPrescription.id AND status = 'final_approved'", "affectedRowsCheck": { "operator": "=", "expected": 1, "onViolation": "throw", "errorCode": "PRESCRIPTION_UPDATE_CONFLICT" }, "lineage": { "writes": [{ "tableId": "d628ce21-bacc-4f6c-952b-a4c07846e740", "purpose": "status-update" }] } },
        { "id": "step-18", "kind": "eventPublish", "description": "処方箋送信イベントを発行する。", "topic": "healthcare.prescription_sent", "payload": "{ prescriptionCode: @draftPrescription.prescription_code, routingStatus: 'sent' }" },
        { "id": "step-19", "kind": "audit", "description": "処方箋発行を PHI 監査ログに記録する。", "action": "healthcare.prescription.issue", "resource": { "type": "prescription", "id": "@draftPrescription.prescription_code" }, "result": "success", "sensitive": true },
        { "id": "step-20", "kind": "return", "description": "処方箋発行結果を返す。", "responseId": "201-created", "bodyExpression": "{ prescriptionId: @draftPrescription.prescription_code, patientId: @patient.patient_code, status: 'sent', pharmacyRoutingStatus: 'sent' }" }
      ]
    }
  ],
  "authoring": {
    "decisions": [
      { "id": "ADR-001", "title": "処方箋発行は多段 WorkflowStep で表現する", "status": "accepted", "context": "処方箋は医師署名、薬剤師鑑査、最終承認の分離が必要である。", "decision": "sign-off、review、approval-sequential の 3 段 WorkflowStep を 1 フロー内に配置する。", "consequences": "処方の責任分界と差し戻し理由が明確になるが、フローは長くなる。", "date": "2026-04-30" },
      { "id": "ADR-002", "title": "重複処方チェックを発行前ブロッカーにする", "status": "accepted", "context": "同一薬剤の有効処方が複数存在すると患者安全上のリスクが高い。", "decision": "既存処方検索と薬剤安全性サービスの両方を実行し、重複時は処方案作成前または送信前に停止する。", "consequences": "緊急時の例外処方は別フローまたは override 権限が必要になる。", "date": "2026-04-30" },
      { "id": "ADR-003", "title": "薬局連携は鑑査後に限定する", "status": "accepted", "context": "未鑑査の処方箋を薬局へ送ると調剤前確認の負荷と事故リスクが増える。", "decision": "薬剤師鑑査完了後、最終承認を経た処方のみ pharmacyNetwork へ送信する。", "consequences": "送信までのリードタイムは増えるが、患者安全と説明責任を優先できる。", "date": "2026-04-30" }
    ],
    "glossary": {
      "処方箋": { "definition": "医師が患者に対して薬剤、用法用量、処方日数を指示する文書または電子データ。", "aliases": ["Prescription"] },
      "薬剤師鑑査": { "definition": "薬剤師が処方内容の妥当性、相互作用、禁忌、重複を確認する業務。", "aliases": ["Pharmacist Verification"] },
      "重複処方": { "definition": "同一患者に同一または同効薬が重なって処方される状態。", "aliases": ["Duplicate Prescription"] },
      "相互作用": { "definition": "複数薬剤の併用により効果や副作用が変化すること。", "aliases": ["Drug Interaction"] },
      "禁忌": { "definition": "患者状態、疾患、アレルギーなどにより使用すべきでない薬剤条件。", "aliases": ["Contraindication"] },
      "医師署名": { "definition": "処方医が処方内容の責任を負うことを電子的に確認する行為。", "aliases": ["Prescriber Sign-off"] },
      "薬局連携": { "definition": "電子処方箋を保険薬局または薬局ネットワークへ送信すること。", "aliases": ["Pharmacy Routing"] },
      "カルテ保存期間": { "definition": "診療記録を法令または院内規程に従って保存する期間。", "aliases": ["Medical Record Retention"] }
    },
    "testScenarios": [
      { "id": "happy-path-prescription", "name": "医師署名と薬剤師鑑査を経て処方箋を送信", "given": [{ "kind": "sessionContext", "context": { "requestId": "req-rx-001", "sessionUserId": "PRV00000002", "sessionRole": "physician" } }, { "kind": "dbState", "tableId": "4bffe509-cd06-42de-a814-43c51d2ee5ed", "rows": [{ "id": 100, "record_code": "MR20260430000001", "patient_id": 1, "provider_id": 10, "encounter_at": "2026-04-30T09:00:00.000Z" }] }, { "kind": "dbState", "tableId": "6b5ec66a-08bb-4df6-b908-1684b9c744c2", "rows": [{ "id": 1, "patient_code": "PAT0000000001", "phi_consent_status": "active", "allergy_summary": "なし" }] }, { "kind": "dbState", "tableId": "3cd0df6d-9a55-423c-9f12-829c132871ae", "rows": [{ "id": 10, "provider_code": "PRV00000002", "role": "physician", "credential_status": "active" }] }, { "kind": "externalStub", "externalRef": "drugInteractionService", "responseMock": { "risk": "none" } }, { "kind": "externalStub", "externalRef": "pharmacyNetwork", "responseMock": { "routingStatus": "sent" } }], "when": { "actionId": "act-001", "input": { "medicalRecordCode": "MR20260430000001", "prescriberCode": "PRV00000002", "medicationCode": "AMOX500", "medicationName": "アモキシシリン 500mg", "dosageInstruction": "1 回 1 錠、1 日 3 回、食後", "daysSupply": 5 } }, "then": [{ "kind": "outcome", "expected": "201-created" }, { "kind": "dbRow", "tableId": "d628ce21-bacc-4f6c-952b-a4c07846e740", "match": { "status": "sent" }, "count": 1 }, { "kind": "auditLog", "action": "healthcare.prescription.issue", "result": "success" }], "tags": ["happy", "workflow"] },
      { "id": "validation-error-days-supply", "name": "処方日数が上限超過", "given": [{ "kind": "sessionContext", "context": { "requestId": "req-rx-002", "sessionUserId": "PRV00000002" } }], "when": { "actionId": "act-001", "input": { "medicalRecordCode": "MR20260430000001", "prescriberCode": "PRV00000002", "medicationCode": "AMOX500", "medicationName": "アモキシシリン 500mg", "dosageInstruction": "1 日 3 回", "daysSupply": 120 } }, "then": [{ "kind": "outcome", "expected": "400-validation" }], "tags": ["error", "validation"] },
      { "id": "edge-duplicate-prescription", "name": "同一薬剤の有効処方が存在する", "given": [{ "kind": "sessionContext", "context": { "requestId": "req-rx-003", "sessionUserId": "PRV00000002" } }, { "kind": "dbState", "tableId": "d628ce21-bacc-4f6c-952b-a4c07846e740", "rows": [{ "id": 200, "prescription_code": "RX20260430000001", "patient_id": 1, "medication_code": "AMOX500", "status": "sent" }] }], "when": { "actionId": "act-001", "input": { "medicalRecordCode": "MR20260430000001", "prescriberCode": "PRV00000002", "medicationCode": "AMOX500", "medicationName": "アモキシシリン 500mg", "dosageInstruction": "1 日 3 回", "daysSupply": 5 } }, "then": [{ "kind": "outcome", "expected": "409-duplicate-prescription" }], "tags": ["edge", "duplicate"] }
    ]
  }
}
