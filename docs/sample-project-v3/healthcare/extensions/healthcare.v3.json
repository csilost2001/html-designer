{
  "$schema": "../../../../schemas/v3/extensions.v3.schema.json",
  "namespace": "healthcare",
  "version": "1.0.0",
  "requiresCoreSchema": ">=3.0.0",
  "description": "医療業界 v3 dogfood 用拡張。PHI 保護、診察予約、患者記録、処方箋発行、薬剤師鑑査に関する型、ステップ、レスポンス、規約カテゴリを定義する。",
  "fieldTypes": [
    { "kind": "patientId", "label": "患者ID", "baseType": "string", "description": "PAT + 10 桁の医療機関内患者識別子。" },
    { "kind": "appointmentId", "label": "予約ID", "baseType": "string", "description": "APT + 日付 + 連番の診察予約識別子。" },
    { "kind": "prescriptionId", "label": "処方箋ID", "baseType": "string", "description": "RX + 日付 + 連番の電子処方箋識別子。" },
    { "kind": "npiNumber", "label": "医師資格番号", "baseType": "string", "description": "医師資格確認で用いる医療提供者番号。" }
  ],
  "actionTriggers": [
    { "value": "appointmentRequested", "label": "診察予約要求", "description": "患者または受付担当者が診察予約を要求した時に起動する。" },
    { "value": "prescriptionRequested", "label": "処方箋発行要求", "description": "医師が診察記録に基づき処方箋発行を要求した時に起動する。" }
  ],
  "stepKinds": {
    "PhiAccessCheckStep": {
      "label": "PHI アクセス確認",
      "icon": "ShieldCheck",
      "description": "保護対象医療情報へのアクセス目的、ロール、患者同意を確認する。",
      "schema": {
        "type": "object",
        "required": ["purpose", "patientRef"],
        "properties": {
          "purpose": { "type": "string" },
          "patientRef": { "type": "string" },
          "minimumNecessary": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "ClinicalSafetyCheckStep": {
      "label": "臨床安全性チェック",
      "icon": "Stethoscope",
      "description": "薬剤相互作用、重複処方、禁忌、アレルギーを確認する。",
      "schema": {
        "type": "object",
        "required": ["patientRef", "medicationRef"],
        "properties": {
          "patientRef": { "type": "string" },
          "medicationRef": { "type": "string" },
          "checkKinds": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    }
  },
  "responseTypes": {
    "AppointmentResponse": {
      "description": "診察予約 API の成功レスポンス。",
      "schema": {
        "type": "object",
        "required": ["appointmentId", "status"],
        "properties": {
          "appointmentId": { "type": "string" },
          "patientId": { "type": "string" },
          "scheduledStartAt": { "type": "string" },
          "providerId": { "type": "string" },
          "status": { "type": "string" }
        }
      }
    },
    "PrescriptionResponse": {
      "description": "処方箋発行 API の成功レスポンス。",
      "schema": {
        "type": "object",
        "required": ["prescriptionId", "status"],
        "properties": {
          "prescriptionId": { "type": "string" },
          "patientId": { "type": "string" },
          "status": { "type": "string" },
          "pharmacyRoutingStatus": { "type": "string" }
        }
      }
    },
    "ApiError": {
      "description": "医療 API 共通エラー。",
      "schema": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "requestId": { "type": "string" }
        }
      }
    }
  },
  "conventionCategories": [
    {
      "categoryName": "healthcareRetention",
      "label": "医療記録保存期間",
      "description": "カルテ、監査ログ、処方箋などの保存期間規約。",
      "entrySchema": {
        "type": "object",
        "required": ["years", "description"],
        "properties": {
          "years": { "type": "integer" },
          "description": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    {
      "categoryName": "healthcareRole",
      "label": "医療ロール",
      "description": "医師、薬剤師、看護師、受付担当者などの業務ロール。",
      "entrySchema": {
        "type": "object",
        "required": ["code", "description"],
        "properties": {
          "code": { "type": "string" },
          "description": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    {
      "categoryName": "healthcarePolicy",
      "label": "医療ポリシー",
      "description": "PHI 最小必要、処方鑑査、重複処方判定などの規約。",
      "entrySchema": {
        "type": "object",
        "required": ["value", "description"],
        "properties": {
          "value": { "type": "string" },
          "description": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  ]
}
