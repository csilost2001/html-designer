{
  "$schema": "../../../schemas/v3/process-flow.v3.schema.json",
  "meta": {
    "id": "e1f2a3b4-c5d6-4e7f-8a9b-0c1d2e3f4a5b",
    "name": "商品詳細表示 (小売)",
    "description": "商品コードで商品マスタと在庫情報を取得して詳細画面に表示する。カートへの追加ボタン押下で ScreenTransitionStep によりカート画面に遷移する。画面フロー × ScreenTransitionStep × URL ルーティング 三者整合のサンプル (#650)。",
    "version": "1.0.0",
    "maturity": "committed",
    "createdAt": "2026-04-30T00:00:00.000Z",
    "updatedAt": "2026-04-30T00:00:00.000Z",
    "kind": "screen",
    "screenId": "a2c4e6f8-1b3d-4a5e-9c7b-8d0f2e4a6c8e",
    "apiVersion": "v2",
    "mode": "upstream"
  },
  "context": {
    "catalogs": {
      "errors": {
        "PRODUCT_NOT_FOUND": {
          "httpStatus": 404,
          "defaultMessage": "商品が見つかりません",
          "responseId": "404-product-not-found"
        },
        "INTERNAL_ERROR": {
          "httpStatus": 500,
          "defaultMessage": "内部エラーが発生しました",
          "responseId": "500-internal-error"
        }
      }
    },
    "ambientVariables": [
      {
        "name": "requestId",
        "type": "string",
        "required": true,
        "description": "リクエスト追跡 ID"
      }
    ]
  },
  "actions": [
    {
      "id": "act-001",
      "name": "商品詳細取得",
      "trigger": "load",
      "description": "商品コードを path パラメータとして受け取り、products × inventory を JOIN して詳細を返す。",
      "maturity": "committed",
      "httpRoute": {
        "method": "GET",
        "path": "/api/retail/products/:productCode",
        "auth": "optional"
      },
      "inputs": [
        {
          "name": "productCode",
          "label": "商品コード",
          "type": "string",
          "required": true
        }
      ],
      "outputs": [
        {
          "name": "product",
          "label": "商品情報",
          "type": {
            "kind": "object",
            "fields": [
              { "name": "productCode", "label": "商品コード", "type": "string", "required": true },
              { "name": "name", "label": "商品名", "type": "string", "required": true },
              { "name": "unitPrice", "label": "単価", "type": "number", "required": true }
            ]
          }
        }
      ],
      "responses": [
        {
          "id": "200-ok",
          "status": 200,
          "when": "商品詳細の取得が成功した"
        },
        {
          "id": "404-product-not-found",
          "status": 404,
          "when": "商品コードが存在しない"
        },
        {
          "id": "500-internal-error",
          "status": 500,
          "when": "予期しないエラー"
        }
      ],
      "steps": [
        {
          "id": "step-01",
          "kind": "dbAccess",
          "description": "products テーブルから商品情報を取得する。",
          "maturity": "committed",
          "tableId": "eb574288-88f2-419f-ac5e-56a9948e8f46",
          "operation": "SELECT",
          "sql": "SELECT product_code, name, unit_price FROM products WHERE product_code = @inputs.productCode AND is_active = true",
          "outputBinding": { "name": "product" },
          "lineage": {
            "reads": [
              { "tableId": "eb574288-88f2-419f-ac5e-56a9948e8f46", "purpose": "lookup" }
            ]
          }
        },
        {
          "id": "step-02",
          "kind": "branch",
          "description": "商品が存在しない場合は 404 を返す。",
          "maturity": "committed",
          "branches": [
            {
              "id": "br-02-a",
              "code": "A",
              "label": "商品なし",
              "condition": {
                "kind": "expression",
                "expression": "@product == null"
              },
              "steps": [
                {
                  "id": "step-02-a-01",
                  "kind": "return",
                  "description": "404 商品なし",
                  "responseId": "404-product-not-found",
                  "bodyExpression": "{ code: 'PRODUCT_NOT_FOUND', message: '指定の商品が見つかりません' }"
                }
              ]
            }
          ],
          "elseBranch": {
            "id": "br-02-else",
            "code": "B",
            "label": "商品あり",
            "steps": []
          }
        },
        {
          "id": "step-03",
          "kind": "dbAccess",
          "description": "inventory テーブルから在庫情報を取得する。",
          "maturity": "committed",
          "tableId": "d6db2166-5634-404d-84e4-8a7a11c28233",
          "operation": "SELECT",
          "sql": "SELECT available_quantity, reserved_quantity FROM inventory WHERE product_code = @inputs.productCode AND store_code = 'DEFAULT'",
          "outputBinding": { "name": "inventory" },
          "lineage": {
            "reads": [
              { "tableId": "d6db2166-5634-404d-84e4-8a7a11c28233", "purpose": "lookup" }
            ]
          }
        },
        {
          "id": "step-04",
          "kind": "screenTransition",
          "description": "カートへ追加ボタン押下時にカート画面へ遷移する。画面フロー edge (st-retail-02) と対応。",
          "maturity": "committed",
          "targetScreenId": "b4e7a012-3c56-4d89-a123-456789abcdef"
        },
        {
          "id": "step-05",
          "kind": "return",
          "description": "200 OK で商品詳細を返す。",
          "maturity": "committed",
          "responseId": "200-ok",
          "bodyExpression": "{ product: @product, inventory: @inventory }"
        }
      ]
    }
  ],
  "authoring": {
    "decisions": [
      {
        "id": "ADR-001",
        "title": "ScreenTransitionStep を使って商品詳細→カート遷移を三者整合させる (#650)",
        "status": "accepted",
        "context": "画面フロー edge (st-retail-02: 商品詳細→カート) / ScreenTransitionStep (step-04) / URL ルーティング (/retail/products/:productCode → /retail/cart) の三者整合を #650 validator が検証する。",
        "decision": "step-04 の targetScreenId = b4e7a012-3c56-4d89-a123-456789abcdef (カート画面) と edge st-retail-02 を対応させることで MISSING_FLOW_EDGE / ORPHAN_FLOW_EDGE いずれも発生しない整合状態にする。PATH_PARAM_MISMATCH は /retail/cart がパラメータなしのため発生しない。",
        "consequences": "三者整合が取れた状態で #650 screenNavigationValidator の false positive ゼロを実証する。",
        "date": "2026-04-30"
      }
    ]
  }
}
