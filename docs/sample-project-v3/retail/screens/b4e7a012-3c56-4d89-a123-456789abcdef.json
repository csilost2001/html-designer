{
  "$schema": "../../../schemas/v3/screen.v3.schema.json",
  "id": "b4e7a012-3c56-4d89-a123-456789abcdef",
  "name": "カート",
  "description": "ショッピングカート画面。カート内の商品明細一覧と合計金額を表示し、注文確定に進む。",
  "version": "1.0.0",
  "maturity": "committed",
  "createdAt": "2026-04-30T00:00:00.000Z",
  "updatedAt": "2026-04-30T00:00:00.000Z",
  "kind": "form",
  "path": "/retail/cart",
  "auth": "required",
  "items": [
    {
      "id": "cartItems",
      "label": "カート明細",
      "type": {
        "kind": "array",
        "itemType": {
          "kind": "object",
          "fields": [
            { "name": "productCode", "label": "商品コード", "type": "string", "required": true },
            { "name": "productName", "label": "商品名", "type": "string", "required": true },
            { "name": "quantity", "label": "数量", "type": "integer", "required": true },
            { "name": "unitPrice", "label": "単価", "type": "number", "required": true }
          ]
        }
      },
      "direction": "output",
      "valueFrom": {
        "kind": "flowVariable",
        "variableName": "cartRows"
      }
    },
    {
      "id": "totalAmount",
      "label": "合計金額",
      "type": "number",
      "direction": "output",
      "valueFrom": {
        "kind": "expression",
        "expression": "@cartRows.reduce((s, r) => s + r.unit_price * r.quantity, 0)"
      },
      "displayFormat": "#,##0 円"
    },
    {
      "id": "cartId",
      "label": "カートID",
      "type": "string",
      "direction": "input",
      "description": "セッション管理されるカートID。フォーム送信時に処理フローへ引き渡す。"
    },
    {
      "id": "addProductCode",
      "label": "追加商品コード",
      "type": "string",
      "direction": "input",
      "required": true
    },
    {
      "id": "addQuantity",
      "label": "追加数量",
      "type": "integer",
      "direction": "input",
      "required": true,
      "min": 1
    },
    {
      "id": "addToCartForm",
      "label": "商品追加フォーム",
      "type": "string",
      "direction": "input",
      "events": [
        {
          "id": "submit",
          "handlerFlowId": "a3a129e5-55fe-4805-a411-833e8f6a7311",
          "argumentMapping": {
            "cartId": "@screen.cartId",
            "productCode": "@screen.addProductCode",
            "quantity": "@screen.addQuantity"
          }
        }
      ]
    }
  ],
  "authoring": {
    "notes": [
      {
        "id": "note-01",
        "kind": "assumption",
        "body": "カート画面は auth=required。ログインユーザーのカートを表示する。カート追加ボタン押下でカート追加フロー (a3a129e5) が呼ばれる。",
        "createdAt": "2026-04-30T00:00:00.000Z"
      }
    ]
  }
}
