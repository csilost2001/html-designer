{
  "$schema": "../../../schemas/v3/screen.v3.schema.json",
  "id": "a2c4e6f8-1b3d-4a5e-9c7b-8d0f2e4a6c8e",
  "name": "商品詳細",
  "description": "商品コードで商品マスタと在庫情報を表示する詳細画面。カートへの追加ボタンを持つ。",
  "version": "1.0.0",
  "maturity": "committed",
  "createdAt": "2026-04-30T00:00:00.000Z",
  "updatedAt": "2026-04-30T00:00:00.000Z",
  "kind": "detail",
  "path": "/retail/products/:productCode",
  "auth": "optional",
  "items": [
    {
      "id": "productCode",
      "label": "商品コード",
      "type": "string",
      "direction": "output",
      "valueFrom": {
        "kind": "expression",
        "expression": "@inputs.productCode"
      }
    },
    {
      "id": "productName",
      "label": "商品名",
      "type": "string",
      "direction": "output",
      "valueFrom": {
        "kind": "flowVariable",
        "variableName": "product.name"
      }
    },
    {
      "id": "unitPrice",
      "label": "単価",
      "type": "number",
      "direction": "output",
      "valueFrom": {
        "kind": "flowVariable",
        "variableName": "product.unit_price"
      },
      "displayFormat": "#,##0 円"
    },
    {
      "id": "availableQuantity",
      "label": "在庫可能数量",
      "type": "integer",
      "direction": "output",
      "valueFrom": {
        "kind": "flowVariable",
        "variableName": "inventory.available_quantity"
      }
    },
    {
      "id": "addToCartBtn",
      "label": "カートへ追加",
      "type": "string",
      "direction": "input",
      "events": [
        {
          "id": "click",
          "handlerFlowId": "e1f2a3b4-c5d6-4e7f-8a9b-0c1d2e3f4a5b",
          "argumentMapping": {
            "productCode": "@screen.productCode"
          }
        }
      ]
    }
  ],
  "authoring": {
    "notes": [
      {
        "id": "note-01",
        "kind": "assumption",
        "body": "商品詳細画面は auth=optional。在庫表示はゲストにも許可するが、カート追加ボタン押下時は認証を要求する設計にする。",
        "createdAt": "2026-04-30T00:00:00.000Z"
      }
    ]
  }
}
