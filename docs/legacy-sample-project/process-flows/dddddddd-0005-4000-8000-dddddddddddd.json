{
  "id": "dddddddd-0005-4000-8000-dddddddddddd",
  "name": "規制報告: 取引報告/KYC/AML 監視 (証券)",
  "type": "system",
  "description": "証券取引の月次規制報告、KYC 状態確認、AML リスク評価、疑わしい取引報告を扱う金融ドッグフードシナリオ。取引報告は当局指定公開鍵で暗号化し、AML は取引発生ごとに自動評価する。",
  "apiVersion": "v2",
  "mode": "downstream",
  "maturity": "committed",
  "eventsCatalog": {
    "regulatory.report.submitted": {
      "description": "規制当局への取引報告送信が完了した時点で発行するイベント。",
      "payload": {
        "type": "object",
        "required": [
          "submissionId",
          "reportingPeriod",
          "submittedCount"
        ],
        "properties": {
          "submissionId": {
            "type": "string"
          },
          "reportingPeriod": {
            "type": "string"
          },
          "submittedCount": {
            "type": "number"
          }
        },
        "additionalProperties": false
      }
    },
    "aml.alert.raised": {
      "description": "AML 評価で中リスク以上が検出された時点で発行するイベント。",
      "payload": {
        "type": "object",
        "required": [
          "tradeId",
          "accountId",
          "riskRating",
          "actionTaken"
        ],
        "properties": {
          "tradeId": {
            "type": "string"
          },
          "accountId": {
            "type": "string"
          },
          "riskRating": {
            "type": "string"
          },
          "actionTaken": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "kyc.verified": {
      "description": "顧客の KYC 確認結果が AML 評価に利用可能になった時点で発行するイベント。",
      "payload": {
        "type": "object",
        "required": [
          "accountId",
          "kycLevel",
          "verifiedAt"
        ],
        "properties": {
          "accountId": {
            "type": "string"
          },
          "kycLevel": {
            "type": "string"
          },
          "verifiedAt": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "suspicious.transaction.reported": {
      "description": "疑わしい取引報告 (STR) が起票された時点で発行するイベント。",
      "payload": {
        "type": "object",
        "required": [
          "tradeId",
          "accountId",
          "riskRating"
        ],
        "properties": {
          "tradeId": {
            "type": "string"
          },
          "accountId": {
            "type": "string"
          },
          "riskRating": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "glossary": {
    "取引報告": {
      "definition": "報告対象期間内の約定情報を規制当局指定形式に整形して提出する業務。",
      "aliases": [
        "Trade Report",
        "規制報告"
      ],
      "domainRef": "regulatory_submissions"
    },
    "KYC": {
      "definition": "顧客本人確認と属性確認を行い、取引許可や AML 評価の前提情報にする手続き。",
      "aliases": [
        "Know Your Customer",
        "本人確認"
      ],
      "domainRef": "customers.kyc_level"
    },
    "AML": {
      "definition": "マネーロンダリングやテロ資金供与につながる取引を検知・抑止する監視業務。",
      "aliases": [
        "Anti-Money Laundering",
        "マネロン対策"
      ],
      "domainRef": "aml_screening_log"
    },
    "STR": {
      "definition": "疑わしい取引を検出した際に当局または内部コンプライアンス部門へ提出する報告。",
      "aliases": [
        "Suspicious Transaction Report",
        "疑わしい取引報告"
      ],
      "domainRef": "suspicious_transaction_reports"
    },
    "PEP": {
      "definition": "政治的に影響力のある人物。通常顧客より高い AML リスクとして評価する。",
      "aliases": [
        "Politically Exposed Person"
      ],
      "domainRef": "customers.pep_status"
    },
    "制裁リスト": {
      "definition": "取引禁止または制限対象の個人・法人・国・地域を示す外部照合リスト。",
      "aliases": [
        "Sanctions List"
      ],
      "domainRef": "sanctions_screening"
    },
    "監査ログ": {
      "definition": "規制報告や AML 評価の証跡として、操作者・入力・結果・署名を改ざん検知可能に記録するログ。",
      "aliases": [
        "Audit Log"
      ],
      "domainRef": "audit_logs"
    },
    "暗号化": {
      "definition": "提出データを当局指定の公開鍵で保護し、送信経路や保管先で平文露出を防ぐ処理。",
      "aliases": [
        "Encryption"
      ],
      "domainRef": "secrets.regulatoryPublicKey"
    }
  },
  "decisions": [
    {
      "id": "ADR-001",
      "title": "取引報告は当局指定公開鍵で暗号化、監査ログに署名残す",
      "status": "accepted",
      "context": "取引報告には個人情報と取引情報が含まれるため、提出前に当局指定方式で秘匿し、後続監査で提出内容の完全性を検証できる必要がある。",
      "decision": "報告ペイロードは @secret.regulatoryPublicKey で暗号化し、送信前に @secret.auditLogSigningKey で監査ログ署名を生成する。",
      "consequences": "公開鍵の期限切れや署名鍵ローテーション失敗は提出停止要因になるため、鍵監視とリトライ設計が必要になる。",
      "date": "2026-04-26"
    },
    {
      "id": "ADR-002",
      "title": "AML監視は取引発生毎の自動評価+月次バッチ再スクリーニング",
      "status": "accepted",
      "context": "制裁リストや PEP 情報は日々更新されるため、取引時点の即時判定だけでは過去取引の再評価が不足する。",
      "decision": "取引発生ごとに自動評価し、報告期間単位で月次バッチ再スクリーニングを実施する。",
      "consequences": "月次再評価で追加アラートが発生するため、AML ログは再評価履歴を区別できる粒度で保持する。",
      "date": "2026-04-26"
    },
    {
      "id": "ADR-003",
      "title": "疑わしい取引は人手レビュー前に自動的にHold",
      "status": "accepted",
      "context": "高リスク取引をレビュー待ちのまま進行させると、資金流出や規制違反のリスクがある。",
      "decision": "AML 高リスク判定時は STR を起票し、コンプライアンス担当者の人手レビュー前に取引を自動 Hold にする。",
      "consequences": "誤検知時の顧客影響があるため、Hold 解除の監査手順と SLA を別途設計する。",
      "date": "2026-04-26"
    }
  ],
  "ambientVariables": [
    {
      "name": "requestId",
