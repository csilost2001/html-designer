  "functionsCatalog": {
    "encryptForRegulator": {
      "signature": "encryptForRegulator(payload: object, publicKey: string): string",
      "returnType": "string",
      "description": "規制当局指定公開鍵で提出ペイロードを暗号化し、送信用文字列を返す。",
      "examples": [
        "@fn.encryptForRegulator(@reportableTrades, @secret.regulatoryPublicKey)"
      ]
    },
    "screenAgainstSanctions": {
      "signature": "screenAgainstSanctions(customer: Customer): RiskRating",
      "returnType": "RiskRating",
      "description": "顧客情報を制裁リスト・PEP 情報と照合し、AML リスク評価を返す。",
      "examples": [
        "@fn.screenAgainstSanctions(@customer)"
      ]
    }
  },
  "actions": [
    {
      "id": "act-001",
      "name": "規制報告自動生成",
      "trigger": "regulatoryDeadline",
      "description": "報告期間の約定を抽出し、監査署名と当局公開鍵暗号化を行ったうえで金融庁 EDINET へ提出する。",
      "maturity": "committed",
      "httpRoute": {
        "method": "POST",
        "path": "/internal/regulatory/report/submit",
        "auth": "required"
      },
      "inputs": [
        {
          "name": "reportingPeriod",
          "label": "報告期間",
          "type": "string",
          "required": true,
          "description": "YYYY-MM 形式。例: 2026-04"
        }
      ],
      "outputs": [
        {
          "name": "submissionId",
          "label": "提出ID",
          "type": "string",
          "required": true
        },
        {
          "name": "submittedCount",
          "label": "提出件数",
          "type": "number",
          "required": true
        }
      ],
      "responses": [
        {
          "id": "200-ok",
          "status": 200,
          "bodySchema": {
            "schema": {
              "type": "object",
              "required": [
                "submissionId",
                "submittedCount"
              ],
              "properties": {
                "submissionId": {
                  "type": "string"
                },
                "submittedCount": {
                  "type": "number"
                }
              },
              "additionalProperties": false
            }
          },
          "description": "規制報告提出成功"
        },
        {
          "id": "500-encryption-failed",
          "status": 500,
          "bodySchema": {
            "typeRef": "ApiError"
          },
          "description": "暗号化失敗"
        },
        {
          "id": "502-regulatory-api-error",
          "status": 502,
          "bodySchema": {
            "typeRef": "ApiError"
          },
          "description": "規制当局 API エラー"
        },
        {
          "id": "400-validation",
          "status": 400,
          "bodySchema": {
            "typeRef": "ApiError"
          }
        },
        {
          "id": "422-kyc-not-found",
          "status": 404,
          "bodySchema": {
            "typeRef": "ApiError"
          }
        },
        {
          "id": "422-aml-high-risk",
          "status": 422,
          "bodySchema": {
            "typeRef": "ApiError"
          }
        }
      ],
      "steps": [
        {
          "id": "step-01",
          "type": "validation",
          "description": "reportingPeriod が YYYY-MM 形式で指定されていることを検証する。",
          "maturity": "committed",
          "conditions": "reportingPeriod は必須、YYYY-MM 形式。",
          "rules": [
            {
              "field": "reportingPeriod",
              "type": "required",
              "message": "報告期間は必須です"
            },
            {
              "field": "reportingPeriod",
              "type": "regex",
              "pattern": "^\\d{4}-\\d{2}$",
              "message": "報告期間は YYYY-MM 形式で入力してください"
            }
          ]
        },
        {
          "id": "step-02",
          "type": "dbAccess",
          "description": "RegulatoryReportStep: 報告期間の trades から tradeId/accountId/quantity/price/executedAt を抽出し @reportableTrades に束ねる。",
          "note": "extensionStep=securities:RegulatoryReportStep; reportingPeriod=@inputs.reportingPeriod; regulatoryAuthority=regulatoryAuthority; encryptionKeyRef=@secret.regulatoryPublicKey",
          "maturity": "committed",
          "tableName": "trades",
          "operation": "SELECT",
          "sql": "SELECT trade_id AS tradeId, account_id AS accountId, quantity, price, executed_at AS executedAt FROM trades WHERE reporting_period = @inputs.reportingPeriod ORDER BY trade_id",
          "outputBinding": "reportableTrades",
          "lineage": {
            "reads": [
              "trades"
            ]
          }
        },
        {
          "id": "step-02b-empty-check",
          "type": "branch",
          "description": "報告対象取引が 0 件の場合は提出処理を行わず 200 OK を返す。",
          "maturity": "committed",
          "branches": [
            {
              "id": "br-empty",
              "code": "EMPTY",
              "label": "報告対象なし",
              "condition": "@reportableTrades.length == 0",
              "steps": [
                {
                  "id": "step-02b-empty-return",
                  "type": "return",
                  "description": "報告対象 0 件として 200 OK を返す。",
                  "responseRef": "200-ok",
                  "bodyExpression": "{ submittedCount: 0 }"
                }
              ]
            }
          ],
          "elseBranch": {
            "id": "br-non-empty",
            "code": "NON_EMPTY",
            "label": "報告対象あり",
            "steps": []
          }
        },
        {
          "id": "step-03",
          "type": "compute",
          "description": "監査ログ署名を生成する。",
          "maturity": "committed",
          "expression": "sign({ requestId: @requestId, reportingPeriod: @inputs.reportingPeriod, count: @reportableTrades.length }, @secret.auditLogSigningKey)",
          "outputBinding": "auditSignature"
        },
        {
          "id": "step-04",
          "type": "compute",
          "description": "@fn.encryptForRegulator(@reportableTrades, @secret.regulatoryPublicKey) を実行して提出ペイロードを暗号化する。",
          "maturity": "committed",
          "expression": "@fn.encryptForRegulator(@reportableTrades, @secret.regulatoryPublicKey)",
          "outputBinding": "encryptedPayload"
        },
        {
          "id": "step-05",
          "type": "branch",
          "description": "暗号化結果が空の場合は 500 ENCRYPTION_FAILED を返す。",
          "maturity": "committed",
          "branches": [
            {
              "id": "br-05-a",
              "code": "ENCRYPTION_FAILED",
              "label": "暗号化失敗",
              "condition": "@encryptedPayload == null || @encryptedPayload == ''",
              "steps": [
                {
                  "id": "step-05-a-01",
                  "type": "audit",
                  "description": "暗号化失敗を監査ログに残す。",
                  "action": "regulatory.report.encrypt",
                  "result": "failure",
                  "reason": "ENCRYPTION_FAILED",
                  "sensitive": true
                },
                {
                  "id": "step-05-a-02",
                  "type": "return",
                  "description": "500 ENCRYPTION_FAILED を返す。",
                  "responseRef": "500-encryption-failed",
                  "bodyExpression": "{ code: 'ENCRYPTION_FAILED', message: '規制報告ペイロードの暗号化に失敗しました' }"
                }
              ]
            }
          ],
          "elseBranch": {
            "id": "br-05-else",
            "code": "OK",
            "label": "暗号化成功",
            "steps": []
          }
        },
        {
          "id": "step-06",
          "type": "externalSystem",
          "description": "regulatoryAuthority へ暗号化済み取引報告を POST する。failure は abort とし 502 として扱う。",
          "maturity": "committed",
          "systemName": "金融庁EDINET",
          "systemRef": "regulatoryAuthority",
          "httpCall": {
            "method": "POST",
            "path": "/api/v2/trade-reports",
            "body": "{ reportingPeriod: @inputs.reportingPeriod, encryptedPayload: @encryptedPayload, auditSignature: @auditSignature }"
          },
          "outcomes": {
            "success": {
              "action": "continue"
            },
            "failure": {
              "action": "abort",
              "description": "502 REGULATORY_API_ERROR"
            },
            "timeout": {
              "action": "abort",
              "sameAs": "failure"
            }
          },
          "outputBinding": "regulatorySubmission"
        },
        {
          "id": "step-07",
          "type": "dbAccess",
          "description": "regulatory_submissions に提出監査レコードを登録する。",
          "maturity": "committed",
          "tableName": "regulatory_submissions",
          "operation": "INSERT",
          "sql": "INSERT INTO regulatory_submissions (submission_id, reporting_period, submitted_count, audit_signature, idempotency_key, created_at) VALUES (@regulatorySubmission.body.submissionId, @inputs.reportingPeriod, @reportableTrades.length, @auditSignature, @requestId, NOW()) ON CONFLICT (idempotency_key) DO NOTHING RETURNING submission_id AS submissionId, submitted_count AS submittedCount",
          "outputBinding": "submissionRecord",
          "lineage": {
            "writes": [
              "regulatory_submissions"
            ]
          }
        },
        {
          "id": "step-08",
          "type": "audit",
          "description": "全提出を監査ログに残す。",
          "maturity": "committed",
          "action": "regulatory.report.submit",
          "resource": {
            "type": "RegulatorySubmission",
            "id": "@submissionRecord.submissionId"
          },
          "result": "success",
          "sensitive": true
        },
        {
          "id": "step-09",
          "type": "eventPublish",
          "description": "regulatory.report.submitted イベントを発行する。",
          "maturity": "committed",
          "topic": "regulatory.report.submitted",
          "eventRef": "regulatory.report.submitted",
          "payload": "{ submissionId: @submissionRecord.submissionId, reportingPeriod: @inputs.reportingPeriod, submittedCount: @submissionRecord.submittedCount ?? @reportableTrades.length }"
        },
        {
          "id": "step-10",
          "type": "return",
          "description": "200 OK と submissionId/submittedCount を返す。",
          "maturity": "committed",
          "responseRef": "200-ok",
          "bodyExpression": "{ submissionId: @submissionRecord.submissionId, submittedCount: @submissionRecord.submittedCount ?? @reportableTrades.length }"
        }
      ],
      "requiredPermissions": [
        "system",
        "compliance"
      ]
    },
    {
      "id": "act-002",
      "name": "AML監視+疑わしい取引報告",
      "trigger": "auto",
      "description": "取引発生ごとに KYC 情報、制裁リスト、PEP、金額・頻度・相手国の異常を評価し、高リスク時は Hold と STR 起票を行う。",
      "maturity": "committed",
      "httpRoute": {
        "method": "POST",
        "path": "/internal/aml/screen-trade",
        "auth": "required"
      },
      "inputs": [
        {
          "name": "tradeId",
          "label": "取引ID",
          "type": "string",
          "required": true,
          "domainRef": "TradeId"
        },
        {
          "name": "accountId",
          "label": "口座ID",
          "type": "string",
          "required": true,
          "domainRef": "AccountId"
        },
        {
          "name": "amount",
          "label": "取引金額",
          "type": "number",
          "required": true
        }
      ],
      "outputs": [
        {
          "name": "riskRating",
          "label": "リスク評価",
          "type": "string",
          "required": true,
          "domainRef": "RiskRating"
        },
        {
          "name": "actionTaken",
          "label": "対応",
          "type": "string",
          "required": true,
          "description": "NORMAL/WATCH/HOLD"
        }
      ],
      "responses": [
        {
          "id": "200-ok",
          "status": 200,
          "bodySchema": {
            "schema": {
              "type": "object",
              "required": [
                "riskRating",
                "actionTaken"
              ],
              "properties": {
                "riskRating": {
                  "type": "string"
                },
                "actionTaken": {
                  "type": "string",
                  "enum": [
                    "NORMAL",
                    "WATCH",
                    "HOLD"
                  ]
                }
              },
              "additionalProperties": false
            }
          },
          "description": "AML 評価完了"
        },
        {
          "id": "422-kyc-not-found",
          "status": 422,
          "bodySchema": {
            "typeRef": "ApiError"
          },
          "description": "KYC レベル不足"
        },
        {
          "id": "422-aml-high-risk",
          "status": 422,
          "bodySchema": {
            "typeRef": "ApiError"
          },
          "description": "AML 高リスク検出"
        },
        {
          "id": "400-validation",
          "status": 400,
          "bodySchema": {
            "typeRef": "ApiError"
          }
        },
        {
          "id": "502-regulatory-api-error",
          "status": 502,
          "bodySchema": {
            "typeRef": "ApiError"
          }
        },
        {
          "id": "500-encryption-failed",
          "status": 500,
          "bodySchema": {
            "typeRef": "ApiError"
          }
        }
      ],
      "steps": [
        {
          "id": "step-01",
          "type": "validation",
          "description": "tradeId/accountId/amount を検証する。",
          "maturity": "committed",
          "conditions": "tradeId/accountId は必須、amount は 0 より大きい。",
          "rules": [
            {
              "field": "tradeId",
              "type": "required",
              "message": "取引IDは必須です"
            },
            {
              "field": "accountId",
              "type": "required",
              "message": "口座IDは必須です"
            },
            {
              "field": "amount",
              "type": "range",
              "min": 1,
              "message": "取引金額は 1 以上です"
            }
          ]
        },
        {
          "id": "step-02",
          "type": "dbAccess",
          "description": "customers から KYC 情報を取得し @customer に格納する。",
          "maturity": "committed",
          "tableName": "customers",
          "operation": "SELECT",
          "sql": "SELECT account_id AS accountId, customer_id, name, kyc_level AS kycLevel, pep_status AS pepStatus, country_code AS countryCode FROM customers WHERE account_id = @inputs.accountId",
          "outputBinding": "customer",
          "lineage": {
            "reads": [
              "customers"
            ]
          }
        },
        {
          "id": "step-03",
          "type": "branch",
          "description": "KYC レベルが不足している場合は 422 KYC_NOT_FOUND を返す。",
          "maturity": "committed",
          "branches": [
            {
              "id": "br-03-a",
              "code": "KYC_NOT_FOUND",
              "label": "KYC 不足",
              "condition": "@customer == null || @customer.kycLevel == null || @customer.kycLevel == 'none'",
              "steps": [
                {
                  "id": "step-03-a-01",
                  "type": "return",
                  "description": "422 KYC_NOT_FOUND を返す。",
                  "responseRef": "422-kyc-not-found",
                  "bodyExpression": "{ code: 'KYC_NOT_FOUND', message: 'AML 評価に必要な KYC 情報が見つかりません' }"
                }
              ]
            }
          ],
          "elseBranch": {
            "id": "br-03-else",
            "code": "KYC_OK",
            "label": "KYC 評価可能",
            "steps": []
          }
        },
        {
          "id": "step-04",
          "type": "externalSystem",
          "description": "sanctionsListService で制裁リストと PEP 照合を行う。",
          "maturity": "committed",
          "systemName": "Sanctions List Service",
          "systemRef": "sanctionsListService",
          "httpCall": {
            "method": "POST",
            "path": "/screenings/sanctions",
            "body": "{ customer: @customer, tradeId: @inputs.tradeId, accountId: @inputs.accountId }"
          },
          "outcomes": {
            "success": {
              "action": "continue"
            },
            "failure": {
              "action": "continue",
              "description": "照合失敗時は内部異常検知スコアのみで評価を継続する"
            },
            "timeout": {
              "action": "continue",
              "sameAs": "failure"
            }
          },
          "outputBinding": "sanctionsResult"
        },
        {
          "id": "step-05",
          "type": "compute",
          "description": "金額・頻度・相手国に基づく取引パターン異常検知を行う。",
          "maturity": "committed",
          "expression": "detectTradeAnomaly({ tradeId: @inputs.tradeId, accountId: @inputs.accountId, amount: @inputs.amount, customer: @customer, sanctions: @sanctionsResult ?? null })",
          "outputBinding": "anomalyScore"
        },
        {
          "id": "step-06",
          "type": "branch",
          "description": "高リスクは 422 AML_HIGH_RISK と STR 起票と Hold、中リスクは WATCH、低リスクは NORMAL に分岐する。",
          "maturity": "committed",
          "branches": [
            {
              "id": "br-06-a",
              "code": "HIGH",
              "label": "高リスク",
              "condition": "@sanctionsResult?.riskRating == 'HIGH' || @anomalyScore >= 90",
              "steps": [
                {
                  "id": "step-06-a-01",
                  "type": "dbAccess",
                  "description": "高リスク取引を Hold に更新する。",
                  "tableName": "trades",
                  "operation": "UPDATE",
                  "sql": "UPDATE trades SET aml_status = 'HOLD', updated_at = NOW() WHERE trade_id = @inputs.tradeId AND account_id = @inputs.accountId",
                  "outputBinding": "holdResult",
                  "lineage": {
                    "writes": [
                      "trades"
                    ]
                  }
                },
                {
                  "id": "step-06-a-02",
                  "type": "dbAccess",
                  "description": "STR を起票する。",
                  "tableName": "suspicious_transaction_reports",
                  "operation": "INSERT",
                  "sql": "INSERT INTO suspicious_transaction_reports (trade_id, account_id, risk_rating, reason, created_at) VALUES (@inputs.tradeId, @inputs.accountId, 'HIGH', 'AML_HIGH_RISK', NOW())",
                  "outputBinding": "strRecord",
                  "lineage": {
                    "writes": [
                      "suspicious_transaction_reports"
                    ]
                  }
                },
                {
                  "id": "step-06-a-03",
                  "type": "eventPublish",
                  "description": "suspicious.transaction.reported イベントを発行する。",
                  "topic": "suspicious.transaction.reported",
                  "eventRef": "suspicious.transaction.reported",
                  "payload": "{ tradeId: @inputs.tradeId, accountId: @inputs.accountId, riskRating: 'HIGH' }"
                },
                {
                  "id": "step-06-a-aml-log",
                  "type": "audit",
                  "description": "HIGH リスク検知を AML 監査ログに記録する。",
                  "action": "aml.high_risk_detected",
                  "resource": {
                    "type": "Trade",
                    "id": "@inputs.tradeId"
                  },
                  "result": "success",
                  "sensitive": true
                },
                {
                  "id": "step-06-a-aml-screening-log-insert",
                  "type": "dbAccess",
                  "description": "HIGH リスクの AML 評価履歴を登録する。",
                  "tableName": "aml_screening_log",
                  "operation": "INSERT",
                  "sql": "INSERT INTO aml_screening_log (trade_id, account_id, amount, risk_rating, action_taken, created_at) VALUES (@inputs.tradeId, @inputs.accountId, @inputs.amount, 'HIGH', 'HOLD', NOW())",
                  "lineage": {
                    "writes": [
                      "aml_screening_log"
                    ]
                  }
                },
                {
                  "id": "step-06-a-aml-event",
                  "type": "eventPublish",
                  "description": "HIGH リスクの AML alert イベントを発行する。",
                  "topic": "aml.alert.raised",
                  "eventRef": "aml.alert.raised",
                  "payload": "{ tradeId: @inputs.tradeId, accountId: @inputs.accountId, riskRating: 'HIGH', actionTaken: 'HOLD' }"
                },
                {
                  "id": "step-06-a-04",
                  "type": "return",
                  "description": "422 AML_HIGH_RISK を返す。",
                  "responseRef": "422-aml-high-risk",
                  "bodyExpression": "{ code: 'AML_HIGH_RISK', riskRating: 'HIGH', actionTaken: 'HOLD' }"
                }
              ]
            },
            {
              "id": "br-06-b",
              "code": "MEDIUM",
              "label": "中リスク",
              "condition": "@sanctionsResult?.riskRating == 'MEDIUM' || @anomalyScore >= 50",
              "steps": [
                {
                  "id": "step-06-b-01",
                  "type": "audit",
                  "description": "中リスク評価を監査ログに残す。",
                  "action": "aml.screen.watch",
                  "resource": {
                    "type": "Trade",
                    "id": "@inputs.tradeId"
                  },
                  "result": "success",
                  "sensitive": true
                },
                {
                  "id": "step-06-b-02",
                  "type": "compute",
                  "description": "中リスク時の出力値を設定する。",
                  "expression": "{ riskRating: 'MEDIUM', actionTaken: 'WATCH' }",
                  "outputBinding": "amlDecision"
                }
              ]
            }
          ],
          "elseBranch": {
            "id": "br-06-else",
            "code": "LOW",
            "label": "低リスク",
            "steps": [
              {
                "id": "step-06-c-01",
                "type": "compute",
                "description": "低リスク時の出力値を設定する。",
                "expression": "{ riskRating: 'LOW', actionTaken: 'NORMAL' }",
                "outputBinding": "amlDecision"
              }
            ]
          }
        },
        {
          "id": "step-07",
          "type": "audit",
          "description": "全 AML 評価結果を監査ログに残す。",
          "maturity": "committed",
          "action": "aml.screen.evaluate",
          "resource": {
            "type": "Trade",
            "id": "@inputs.tradeId"
          },
          "result": "success",
          "sensitive": true,
          "runIf": "@amlDecision != null"
        },
        {
          "id": "step-08",
          "type": "dbAccess",
          "description": "aml_screening_log に評価履歴を登録する。",
          "maturity": "committed",
          "tableName": "aml_screening_log",
          "operation": "INSERT",
          "runIf": "@amlDecision != null",
          "sql": "INSERT INTO aml_screening_log (trade_id, account_id, amount, risk_rating, action_taken, created_at) VALUES (@inputs.tradeId, @inputs.accountId, @inputs.amount, @amlDecision.riskRating, @amlDecision.actionTaken, NOW())",
          "lineage": {
            "writes": [
              "aml_screening_log"
            ]
          }
        },
        {
          "id": "step-09",
          "type": "eventPublish",
          "description": "高/中リスクのみ aml.alert.raised イベントを発行する。",
          "maturity": "committed",
          "topic": "aml.alert.raised",
          "eventRef": "aml.alert.raised",
          "payload": "{ tradeId: @inputs.tradeId, accountId: @inputs.accountId, riskRating: @amlDecision.riskRating, actionTaken: @amlDecision.actionTaken }",
          "runIf": "@amlDecision != null"
        },
        {
          "id": "step-10",
          "type": "return",
          "description": "200 OK と riskRating/actionTaken を返す。",
          "maturity": "committed",
          "responseRef": "200-ok",
          "bodyExpression": "{ riskRating: @amlDecision.riskRating, actionTaken: @amlDecision.actionTaken }"
        }
      ],
      "requiredPermissions": [
        "system",
        "compliance"
      ]
    }
  ],
  "testScenarios": [
