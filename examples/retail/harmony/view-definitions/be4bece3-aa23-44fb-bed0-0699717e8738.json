{
  "$schema": "../../../schemas/v3/view-definition.v3.schema.json",
  "id": "be4bece3-aa23-44fb-bed0-0699717e8738",
  "name": "在庫一覧 (商品検索結果)",
  "description": "商品検索画面 (e6147dc0) の viewer 項目 (inventoryRows) が参照する列定義。店舗在庫照会フロー (efa7ac6e) の出力変数 'rows' (isLowStock フラグ付き在庫行配列) を表示する。列は inventory × products × stores JOIN 結果のフィールドに対応 (#771)。",
  "maturity": "provisional",
  "createdAt": "2026-05-03T00:00:00.000Z",
  "updatedAt": "2026-05-03T00:00:00.000Z",
  "kind": "list",
  "query": {
    "from": { "tableId": "834ede22-3cb0-4dcf-aa8a-7c046664774a", "alias": "inv" },
    "joins": [
      {
        "kind": "INNER",
        "tableId": "652cbbfe-17e2-4f23-a0c9-4403e6b23bb0",
        "alias": "p",
        "on": ["inv.product_id = p.id"]
      },
      {
        "kind": "INNER",
        "tableId": "fdf00088-87d1-40e8-9eba-65ef58a9bfe5",
        "alias": "s",
        "on": ["inv.store_id = s.id"]
      }
    ]
  },
  "columns": [
