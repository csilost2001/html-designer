  "name": "カート明細",
  "description": "カート確認画面 (cff4a398) の viewer 項目 (cartSummary) が参照する列定義。カート集計フロー (267e94bf) の出力変数 'rows' (cart_items × products × stores JOIN 行配列: productCode / productName / storeCode / storeName / quantity / unitPrice / subtotal) を表示する (#771)。multi-store inventory 整合のため店舗情報を含む。",
  "maturity": "provisional",
  "createdAt": "2026-05-03T00:00:00.000Z",
  "updatedAt": "2026-05-03T00:00:00.000Z",
  "kind": "list",
  "query": {
    "from": { "tableId": "57110336-a984-4d39-bb21-1e5d5bb4390b", "alias": "ci" },
    "joins": [
      {
        "kind": "INNER",
        "tableId": "652cbbfe-17e2-4f23-a0c9-4403e6b23bb0",
        "alias": "p",
        "on": ["ci.product_id = p.id"]
      },
      {
        "kind": "INNER",
        "tableId": "fdf00088-87d1-40e8-9eba-65ef58a9bfe5",
        "alias": "s",
        "on": ["ci.store_id = s.id"]
      }
    ]
  },
