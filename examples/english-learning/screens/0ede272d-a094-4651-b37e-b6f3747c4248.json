{
  "$schema": "../../../schemas/v3/screen.v3.schema.json",
  "id": "0ede272d-a094-4651-b37e-b6f3747c4248",
  "name": "プロフィール/設定",
  "description": "プロフィール確認・学習設定変更画面 (補助)。ユーザー情報 (表示名 / メール) と学習設定 (目標 CEFR レベル) を表示・編集できる。",
  "kind": "form",
  "path": "/profile",
  "auth": "required",
  "groupId": "1c90d535-ffd5-4991-a5d2-28c918c1f5f3",
  "maturity": "draft",
  "createdAt": "2026-05-04T00:00:00.000Z",
  "updatedAt": "2026-05-04T00:00:00.000Z",
  "items": [
    {
      "id": "displayName",
      "label": "表示名",
      "type": "string",
      "direction": "input",
      "required": true,
      "maxLength": 50,
      "valueFrom": {
        "kind": "tableColumn",
        "ref": { "tableId": "c7e50462-bbc4-498f-a280-2ec40bda30b1", "columnId": "col-display-name" }
      },
      "description": "users.display_name の編集フィールド。"
    },
    {
      "id": "email",
      "label": "メールアドレス",
      "type": "string",
      "direction": "output",
      "valueFrom": {
        "kind": "tableColumn",
        "ref": { "tableId": "c7e50462-bbc4-498f-a280-2ec40bda30b1", "columnId": "col-email" }
      },
      "description": "users.email の読み取り専用表示。変更は別途メール確認フローが必要なため読み取り専用とする。"
    },
    {
      "id": "cefrLevelDisplay",
      "label": "現在の CEFR レベル",
      "type": "string",
      "direction": "output",
      "valueFrom": {
        "kind": "tableColumn",
        "ref": { "tableId": "c7e50462-bbc4-498f-a280-2ec40bda30b1", "columnId": "col-cefr-level" }
      },
      "description": "users.cefr_level の読み取り専用表示。自動昇格のため手動変更不可。"
    },
    {
      "id": "targetCefrLevel",
      "label": "目標 CEFR レベル",
      "type": "string",
      "direction": "input",
      "required": false,
      "options": [
        { "value": "A1", "label": "A1 入門" },
        { "value": "A2", "label": "A2 初級" },
        { "value": "B1", "label": "B1 中級" },
        { "value": "B2", "label": "B2 中上級" },
        { "value": "C1", "label": "C1 上級" },
        { "value": "C2", "label": "C2 最上級" }
      ],
      "valueFrom": {
        "kind": "tableColumn",
        "ref": { "tableId": "c7e50462-bbc4-498f-a280-2ec40bda30b1", "columnId": "col-target-cefr-level" }
      },
      "description": "users.target_cefr_level の編集フィールド。プロフィール設定画面で変更可能。"
    },
    {
      "id": "interests",
      "label": "興味分野",
      "type": "json",
      "direction": "input",
      "valueFrom": {
        "kind": "tableColumn",
        "ref": { "tableId": "c7e50462-bbc4-498f-a280-2ec40bda30b1", "columnId": "col-interests" }
      },
      "description": "users.interests の編集フィールド (JSON 配列)。IT / ビジネス / 旅行等の興味分野を複数選択。コンテンツパック選択のレコメンドに使用する。"
    },
    {
      "id": "saveProfile",
      "label": "設定を保存する",
      "type": "string",
      "direction": "input",
      "description": "送信ボタン。users テーブルの display_name / target_cefr_level / interests を更新する処理フローを実行する。"
    }
  ],
  "design": {
    "designFileRef": "0ede272d-a094-4651-b37e-b6f3747c4248.design.json"
  }
}
