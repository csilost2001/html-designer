          "component": {
            "type": "wrapper",
            "components": "\n<div class=\"el-app\">\n  <nav class=\"navbar navbar-dark bg-primary px-3 py-2\">\n    <a href=\"/\" class=\"btn btn-sm btn-outline-light me-2\" aria-label=\"ダッシュボードへ戻る\"><i class=\"bi bi-arrow-left\"></i></a>\n    <span class=\"navbar-brand fw-bold flex-grow-1\">プロフィール / 設定</span>\n  </nav>\n\n  <div class=\"container-fluid px-3 py-3\" style=\"max-width:600px;margin:0 auto;\">\n\n    <form>\n      <!-- プロフィール情報 -->\n      <div class=\"card border-0 shadow-sm mb-4\">\n        <div class=\"card-header bg-white\">\n          <h2 class=\"h6 mb-0\"><i class=\"bi bi-person me-2\"></i>プロフィール</h2>\n        </div>\n        <div class=\"card-body\">\n          <div class=\"mb-3\">\n            <label class=\"form-label\" for=\"displayName\">表示名</label>\n            <input type=\"text\" class=\"form-control\" id=\"displayName\" name=\"displayName\" data-item-id=\"displayName\"\n                   value=\"田中 英語太郎\" maxlength=\"50\" required aria-label=\"表示名\">\n          </div>\n          <div class=\"mb-3\">\n            <label class=\"form-label\">メールアドレス</label>\n            <p class=\"form-control-plaintext\" id=\"email\" data-item-id=\"email\">tanaka@example.com</p>\n          </div>\n          <div class=\"mb-0\">\n            <label class=\"form-label\">現在の CEFR レベル</label>\n            <p class=\"form-control-plaintext\">\n              <span class=\"badge bg-info text-dark fs-6\" id=\"cefrLevelDisplay\" data-item-id=\"cefrLevelDisplay\">B1</span>\n              <span class=\"small text-muted ms-2\">※ 自動昇格のため手動変更不可</span>\n            </p>\n          </div>\n        </div>\n      </div>\n\n      <!-- 学習設定 -->\n      <div class=\"card border-0 shadow-sm mb-4\">\n        <div class=\"card-header bg-white\">\n          <h2 class=\"h6 mb-0\"><i class=\"bi bi-gear me-2\"></i>学習設定</h2>\n        </div>\n        <div class=\"card-body\">\n          <div class=\"mb-3\">\n            <label class=\"form-label\" for=\"dailyGoalSessions\">1 日の目標セッション数</label>\n            <div class=\"d-flex align-items-center gap-3\">\n              <input type=\"number\" class=\"form-control\" id=\"dailyGoalSessions\" name=\"dailyGoalSessions\"\n                     data-item-id=\"dailyGoalSessions\" value=\"5\" min=\"1\" max=\"20\" required\n                     style=\"width:100px;\" aria-label=\"1 日の目標セッション数\">\n              <span class=\"text-muted small\">セッション / 日</span>\n            </div>\n          </div>\n          <div class=\"form-check form-switch mb-0\">\n            <input class=\"form-check-input\" type=\"checkbox\" id=\"notificationsEnabled\" name=\"notificationsEnabled\"\n                   data-item-id=\"notificationsEnabled\" role=\"switch\" checked\n                   aria-label=\"学習リマインダー通知を有効にする\">\n            <label class=\"form-check-label\" for=\"notificationsEnabled\">学習リマインダー通知</label>\n          </div>\n        </div>\n      </div>\n\n      <!-- 保存ボタン -->\n      <button type=\"submit\" class=\"btn btn-primary w-100 py-3\"\n              id=\"saveProfile\" data-item-id=\"saveProfile\" aria-label=\"設定を保存する\">\n        <i class=\"bi bi-floppy-fill me-2\"></i>設定を保存する\n      </button>\n    </form>\n\n  </div>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js\"></script>\n"
          }
