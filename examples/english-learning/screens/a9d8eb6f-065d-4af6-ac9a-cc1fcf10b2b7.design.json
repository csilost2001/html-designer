            "type": "wrapper",
            "components": "\n<div class=\"el-app d-flex flex-column\" style=\"height:100vh;\">\n\n  <!-- ヘッダー -->\n  <nav class=\"navbar navbar-dark bg-dark px-3 py-2\">\n    <span class=\"navbar-brand fw-bold flex-grow-1\">\n      <i class=\"bi bi-chat-square-text-fill me-2\"></i>会話プレイ\n    </span>\n    <span class=\"badge bg-secondary\" id=\"sessionId\" data-item-id=\"sessionId\">セッション: #001</span>\n  </nav>\n\n  <!-- 字幕エリア -->\n  <div class=\"bg-primary text-white px-4 py-4 text-center\">\n    <p class=\"fs-4 fw-semibold mb-1\" id=\"currentDialogueLine\" data-item-id=\"currentDialogueLine\">\n      Hello! I'm excited to talk with you today.\n    </p>\n    <p class=\"small opacity-75 mb-0\" id=\"currentDialogueTranslation\" data-item-id=\"currentDialogueTranslation\">\n      こんにちは！今日はあなたとお話できて嬉しいです。\n    </p>\n  </div>\n\n  <!-- 発音スコア -->\n  <div class=\"bg-light border-bottom px-3 py-2 d-flex align-items-center gap-3\">\n    <span class=\"small text-muted\">発音スコア:</span>\n    <div class=\"progress flex-grow-1\" style=\"height:8px;\" role=\"progressbar\" aria-label=\"発音スコア\">\n      <div class=\"progress-bar bg-success\" id=\"pronunciationScore\" data-item-id=\"pronunciationScore\" style=\"width:78%\"></div>\n    </div>\n    <span class=\"small fw-bold text-success\">78 点</span>\n  </div>\n\n  <!-- AI 応答 -->\n  <div class=\"px-3 py-2 bg-white border-bottom\">\n    <div class=\"d-flex align-items-start gap-2\">\n      <span class=\"badge bg-primary rounded-circle p-2\"><i class=\"bi bi-robot\"></i></span>\n      <div class=\"bg-light rounded p-2 flex-grow-1\">\n        <p class=\"small mb-0\" id=\"aiResponseText\" data-item-id=\"aiResponseText\">\n          That's a great self-introduction! Could you tell me more about your experience?\n        </p>\n      </div>\n    </div>\n  </div>\n\n  <!-- 会話履歴 -->\n  <div class=\"flex-grow-1 overflow-auto px-3 py-2\" id=\"turnHistory\" data-item-id=\"turnHistory\">\n    <div class=\"d-flex align-items-start gap-2 mb-3\">\n      <span class=\"badge bg-secondary rounded-circle p-2\"><i class=\"bi bi-person\"></i></span>\n      <div class=\"bg-primary bg-opacity-10 rounded p-2\">\n        <p class=\"small mb-0\">Hi, my name is Tanaka. Nice to meet you.</p>\n      </div>\n    </div>\n    <div class=\"d-flex align-items-start gap-2 mb-3 flex-row-reverse\">\n      <span class=\"badge bg-primary rounded-circle p-2\"><i class=\"bi bi-robot\"></i></span>\n      <div class=\"bg-light rounded p-2\">\n        <p class=\"small mb-0\">Nice to meet you too, Tanaka! Tell me about yourself.</p>\n      </div>\n    </div>\n  </div>\n\n  <!-- 入力エリア -->\n  <div class=\"border-top bg-white px-3 py-3\">\n    <!-- テキスト入力代替 -->\n    <div class=\"mb-3\">\n      <input type=\"text\" class=\"form-control form-control-sm\"\n             id=\"userTextInput\" name=\"userTextInput\" data-item-id=\"userTextInput\"\n             placeholder=\"テキストで入力する場合はこちら\"\n             maxlength=\"500\">\n    </div>\n\n    <div class=\"d-flex gap-2 align-items-center\">\n      <!-- 録音ボタン -->\n      <button type=\"button\" class=\"btn btn-danger flex-grow-1 py-3\"\n              id=\"recordButton\" data-item-id=\"recordButton\"\n              aria-label=\"音声を録音して送信する\">\n        <i class=\"bi bi-mic-fill me-2\"></i>録音して送信\n      </button>\n\n      <!-- セッション終了 -->\n      <button type=\"button\" class=\"btn btn-outline-secondary px-3 py-3\"\n              id=\"finishSession\" data-item-id=\"finishSession\"\n              aria-label=\"セッションを終了して結果を確認する\">\n        <i class=\"bi bi-flag-fill\"></i>\n      </button>\n    </div>\n  </div>\n\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js\"></script>\n"
