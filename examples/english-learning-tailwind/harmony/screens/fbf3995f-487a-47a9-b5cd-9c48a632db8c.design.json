"flex gap-3 mb-3\">\n          <div class=\"flex-1\">\n            <input type=\"text\"\n                   class=\"form-control rounded-2xl border-slate-200 shadow-sm text-sm\"\n                   id=\"wordSearch\" name=\"wordSearch\" data-item-id=\"wordSearch\"\n                   placeholder=\"英単語を入力\" maxlength=\"100\" />\n          </div>\n        </div>\n        <div class=\"flex gap-2\">\n          <select class=\"form-select flex-1 rounded-2xl border-slate-200 shadow-sm text-sm\"\n                  id=\"masteryFilter\" name=\"masteryFilter\" data-item-id=\"masteryFilter\">\n            <option value=\"\">すべて</option>\n            <option value=\"new\">未学習</option>\n            <option value=\"learning\">学習中</option>\n            <option value=\"mastered\">習得済み</option>\n          </select>\n        </div>\n      </div>\n    </div>\n\n    <!-- 単語一覧 -->\n    <div id=\"wordList\" data-item-id=\"wordList\" class=\"flex flex-col gap-3\">\n\n      <!-- 習得済みカード -->\n      <a href=\"/vocabulary/word-001\" class=\"card border-0 shadow-lg rounded-3xl hover:shadow-xl hover:-translate-y-0.5 transition-all duration-200 no-underline border-l-4\" style=\"border-left-color:#10b981;\">\n        <div class=\"card-body flex items-center gap-4 p-4\">\n          <div class=\"w-10 h-10 bg-emerald-100 rounded-2xl flex items-center justify-center flex-shrink-0\">\n            <i class=\"bi bi-check-circle-fill text-emerald-500\"></i>\n          </div>\n          <div class=\"flex-1 min-w-0\">\n            <div class=\"font-bold text-slate-800 text-base\">latte</div>\n            <div class=\"text-slate-500 text-xs\">ラテ (名詞)</div>\n          </div>\n          <div class=\"flex flex-col items-end gap-1\">\n            <span class=\"badge bg-emerald-100 text-emerald-700 rounded-xl text-xs px-2 py-0.5 font-medium\">習得済み</span>\n            <span class=\"text-slate-400 text-xs\">A2</span>\n          </div>\n        </div>\n      </a>\n\n      <!-- 学習中カード -->\n      <a href=\"/vocabulary/word-002\" class=\"card border-0 shadow-lg rounded-3xl hover:shadow-xl hover:-translate-y-0.5 transition-all duration-200 no-underline border-l-4\" style=\"border-left-color:#f59e0b;\">\n        <div class=\"card-body flex items-center gap-4 p-4\">\n          <div class=\"w-10 h-10 bg-amber-100 rounded-2xl flex items-center justify-center flex-shrink-0\">\n            <i class=\"bi bi-arrow-repeat text-amber-500 text-lg\"></i>\n          </div>\n          <div class=\"flex-1 min-w-0\">\n            <div class=\"font-bold text-slate-800 text-base\">concise</div>\n            <div class=\"text-slate-500 text-xs\">簡潔な (形容詞)</div>\n          </div>\n          <div class=\"flex flex-col items-end gap-1\">\n            <span class=\"badge bg-amber-100 text-amber-700 rounded-xl text-xs px-2 py-0.5 font-medium\">学習中</span>\n            <span class=\"text-slate-400 text-xs\">B1</span>\n          </div>\n        </div>\n      </a>\n\n      <!-- 未学習カード -->\n      <a href=\"/vocabulary/word-003\" class=\"card border-0 shadow-lg rounded-3xl hover:shadow-xl hover:-translate-y-0.5 transition-all duration-200 no-underline border-l-4\" style=\"border-left-color:#94a3b8;\">\n        <div class=\"card-body flex items-center gap-4 p-4\">\n          <div class=\"w-10 h-10 bg-slate-100 rounded-2xl flex items-center justify-center flex-shrink-0\">\n            <i class=\"bi bi-circle text-slate-400 text-lg\"></i>\n          </div>\n          <div class=\"flex-1 min-w-0\">\n            <div class=\"font-bold text-slate-800 text-base\">elaborate</div>\n            <div class=\"text-slate-500 text-xs\">詳述する (動詞)</div>\n          </div>\n          <div class=\"flex flex-col items-end gap-1\">\n            <span class=\"badge bg-slate-100 text-slate-500 rounded-xl text-xs px-2 py-0.5 font-medium\">未学習</span>\n            <span class=\"text-slate-400 text-xs\">B2</span>\n          </div>\n        </div>\n      </a>\n\n    </div>\n  </div>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js\"></script>\n"
