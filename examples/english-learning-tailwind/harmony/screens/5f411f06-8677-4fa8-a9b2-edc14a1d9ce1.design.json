            "type": "wrapper",
            "components": "\n<div class=\"el-app min-h-screen bg-gradient-to-br from-slate-50 via-white to-sky-50\">\n  <nav class=\"navbar bg-white/80 backdrop-blur-sm border-b border-slate-100 shadow-sm px-6 py-3 flex items-center gap-4\">\n    <a href=\"/\" class=\"text-slate-400 hover:text-slate-600 transition-colors\" aria-label=\"ダッシュボードへ戻る\">\n      <i class=\"bi bi-arrow-left text-lg\"></i>\n    </a>\n    <span class=\"navbar-brand text-slate-800 font-bold text-base flex-1\">ストーリー一覧</span>\n    <a href=\"/profile\" class=\"btn btn-sm bg-slate-100 text-slate-600 hover:bg-indigo-50 hover:text-indigo-700 rounded-xl border-0 transition-all\" aria-label=\"プロフィール\">\n      <i class=\"bi bi-person-circle text-lg\"></i>\n    </a>\n  </nav>\n\n  <div style=\"max-width:560px;margin:0 auto;padding:1.5rem 1rem 5rem;\">\n\n    <!-- 検索・フィルタ -->\n    <div class=\"card border-0 shadow-xl rounded-3xl mb-6\">\n      <div class=\"card-body p-5\">\n        <h2 class=\"text-sm font-bold text-slate-500 uppercase tracking-wider mb-4\">\n          <i class=\"bi bi-funnel me-2 text-indigo-400\"></i>フィルター\n        </h2>\n        <div class=\"flex flex-col gap-3\">\n          <div>\n            <label class=\"form-label text-slate-600\" for=\"cefrFilter\">CEFR レベル</label>\n            <select class=\"form-select rounded-2xl border-slate-200 shadow-sm\" id=\"cefrFilter\" name=\"cefrFilter\" data-item-id=\"cefrFilter\">\n              <option value=\"\">すべて</option>\n              <option value=\"A1\">A1 入門</option>\n              <option value=\"A2\">A2 初級</option>\n              <option value=\"B1\">B1 中級</option>\n              <option value=\"B2\">B2 中上級</option>\n              <option value=\"C1\">C1 上級</option>\n              <option value=\"C2\">C2 最上級</option>\n            </select>\n          </div>\n          <div>\n            <label class=\"form-label text-slate-600\" for=\"packFilter\">コンテンツパック</label>\n            <select class=\"form-select rounded-2xl border-slate-200 shadow-sm\" id=\"packFilter\" name=\"packFilter\" data-item-id=\"packFilter\">\n              <option value=\"\">すべてのパック</option>\n            </select>\n          </div>\n          <div>\n            <label class=\"form-label text-slate-600\" for=\"keywordFilter\">キーワード</label>\n            <input type=\"text\" class=\"form-control rounded-2xl border-slate-200 shadow-sm\"\n                   id=\"keywordFilter\" name=\"keywordFilter\" data-item-id=\"keywordFilter\"\n                   placeholder=\"ストーリー名を入力\" maxlength=\"100\" />\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- ストーリー一覧 -->\n    <div id=\"storyList\" data-item-id=\"storyList\" class=\"flex flex-col gap-4\">\n\n      <div class=\"card border-0 shadow-lg rounded-3xl hover:shadow-2xl hover:-translate-y-1 transition-all duration-200\">\n        <div class=\"card-body p-5\">\n          <div class=\"flex items-start gap-4\">\n            <div class=\"w-12 h-12 bg-gradient-to-br from-amber-400 to-orange-400 rounded-2xl flex items-center justify-center flex-shrink-0 shadow-lg\">\n              <i class=\"bi bi-cup-hot-fill text-white text-lg\"></i>\n            </div>\n            <div class=\"flex-1 min-w-0\">\n              <div class=\"flex items-center gap-2 mb-1\">\n                <span class=\"badge bg-amber-100 text-amber-700 rounded-xl px-3 py-1 font-bold text-xs\">A2</span>\n                <span class=\"text-slate-400 text-xs\">12 シーン</span>\n              </div>\n              <div class=\"font-bold text-slate-800 text-base mb-1\">At the Coffee Shop</div>\n              <div class=\"text-slate-500 text-sm leading-relaxed\">カフェでの日常会話を通じて注文・雑談表現を習得する</div>\n            </div>\n          </div>\n          <div class=\"mt-4 flex items-center justify-between\">\n            <div class=\"flex items-center gap-2\">\n              <div class=\"bg-slate-100 rounded-full\" style=\"width:80px;height:4px;\">\n                <div class=\"bg-amber-400 rounded-full\" style=\"width:65%;height:4px;\"></div>\n              </div>\n              <span class=\"text-xs text-slate-400\">65%</span>\n            </div>\n            <a href=\"/stories/story-001\"\n               class=\"btn btn-sm bg-gradient-to-r from-indigo-600 to-violet-600 text-white rounded-xl border-0 shadow-md hover:shadow-lg hover:scale-[1.03] transition-all duration-200 font-semibold\">\n              続ける <i class=\"bi bi-arrow-right\"></i>\n            </a>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"card border-0 shadow-lg rounded-3xl hover:shadow-2xl hover:-translate-y-1 transition-all duration-200\">\n        <div class=\"card-body p-5\">\n          <div class=\"flex items-start gap-4\">\n            <div class=\"w-12 h-12 bg-gradient-to-br from-sky-400 to-blue-500 rounded-2xl flex items-center justify-center flex-shrink-0 shadow-lg\">\n              <i class=\"bi bi-briefcase-fill text-white text-lg\"></i>\n            </div>\n            <div class=\"flex-1 min-w-0\">\n              <div class=\"flex items-center gap-2 mb-1\">\n                <span class=\"badge bg-sky-100 text-sky-700 rounded-xl px-3 py-1 font-bold text-xs\">B1</span>\n                <span class=\"text-slate-400 text-xs\">18 シーン</span>\n              </div>\n              <div class=\"font-bold text-slate-800 text-base mb-1\">Job Interview Prep</div>\n              <div class=\"text-slate-500 text-sm leading-relaxed\">英語での面接対策に特化した実践的な会話練習</div>\n            </div>\n          </div>\n          <div class=\"mt-4 flex items-center justify-between\">\n            <div class=\"flex items-center gap-2\">\n              <div class=\"bg-slate-100 rounded-full\" style=\"width:80px;height:4px;\">\n                <div class=\"bg-sky-400 rounded-full\" style=\"width:30%;height:4px;\"></div>\n              </div>\n              <span class=\"text-xs text-slate-400\">30%</span>\n            </div>\n            <a href=\"/stories/story-002\"\n               class=\"btn btn-sm bg-gradient-to-r from-indigo-600 to-violet-600 text-white rounded-xl border-0 shadow-md hover:shadow-lg hover:scale-[1.03] transition-all duration-200 font-semibold\">\n              始める <i class=\"bi bi-arrow-right\"></i>\n            </a>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"card border-0 shadow-lg rounded-3xl hover:shadow-2xl hover:-translate-y-1 transition-all duration-200\">\n        <div class=\"card-body p-5\">\n          <div class=\"flex items-start gap-4\">\n            <div class=\"w-12 h-12 bg-gradient-to-br from-emerald-400 to-teal-500 rounded-2xl flex items-center justify-center flex-shrink-0 shadow-lg\">\n              <i class=\"bi bi-laptop-fill text-white text-lg\"></i>\n            </div>\n            <div class=\"flex-1 min-w-0\">\n              <div class=\"flex items-center gap-2 mb-1\">\n                <span class=\"badge bg-emerald-100 text-emerald-700 rounded-xl px-3 py-1 font-bold text-xs\">B2</span>\n                <span class=\"text-slate-400 text-xs\">24 シーン</span>\n              </div>\n              <div class=\"font-bold text-slate-800 text-base mb-1\">Tech Startup Meeting</div>\n              <div class=\"text-slate-500 text-sm leading-relaxed\">IT スタートアップの英語ミーティングで使える表現集</div>\n            </div>\n          </div>\n          <div class=\"mt-4 flex items-center justify-between\">\n            <div class=\"flex items-center gap-2\">\n              <span class=\"text-xs text-slate-400\">未開始</span>\n            </div>\n            <a href=\"/stories/story-003\"\n               class=\"btn btn-sm bg-gradient-to-r from-indigo-600 to-violet-600 text-white rounded-xl border-0 shadow-md hover:shadow-lg hover:scale-[1.03] transition-all duration-200 font-semibold\">\n              始める <i class=\"bi bi-arrow-right\"></i>\n            </a>\n          </div>\n        </div>\n      </div>\n\n    </div>\n  </div>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js\"></script>\n"
