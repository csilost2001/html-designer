            "type": "wrapper",
            "components": "\n<div class=\"el-app min-h-screen bg-gradient-to-br from-slate-50 via-white to-emerald-50\">\n\n  <div style=\"max-width:480px;margin:0 auto;padding:2rem 1rem 5rem;\">\n\n    <!-- ヘッダー -->\n    <div class=\"text-center mb-8\">\n      <div class=\"inline-flex items-center justify-center w-16 h-16 bg-gradient-to-br from-emerald-400 to-teal-500 rounded-3xl shadow-2xl mb-4\">\n        <i class=\"bi bi-trophy-fill text-white text-2xl\"></i>\n      </div>\n      <h1 class=\"text-2xl font-bold text-slate-800 mb-1\">セッション完了！</h1>\n      <p class=\"text-slate-500 text-sm\">お疲れ様でした。今日もよく頑張りました</p>\n    </div>\n\n    <!-- 総合スコア -->\n    <div class=\"card border-0 shadow-2xl rounded-3xl mb-6 overflow-hidden\">\n      <div class=\"card-body p-6 text-center\" style=\"background:linear-gradient(135deg,#059669,#10b981,#34d399);\">\n        <div class=\"text-emerald-100 text-xs font-bold uppercase tracking-wider mb-2\">\n          総合発音スコア\n        </div>\n        <div class=\"text-white font-bold mb-1\" style=\"font-size:5rem;line-height:1;\" id=\"totalScore\" data-item-id=\"totalScore\">85</div>\n        <div class=\"text-emerald-200 text-base\">/100</div>\n        <!-- 円形プログレス風の装飾 -->\n        <div class=\"mt-4 flex justify-center gap-1\">\n          <span class=\"inline-block w-2 h-2 bg-white/60 rounded-full\"></span>\n          <span class=\"inline-block w-2 h-2 bg-white/60 rounded-full\"></span>\n          <span class=\"inline-block w-8 h-2 bg-white rounded-full\"></span>\n          <span class=\"inline-block w-2 h-2 bg-white/60 rounded-full\"></span>\n          <span class=\"inline-block w-2 h-2 bg-white/60 rounded-full\"></span>\n        </div>\n      </div>\n    </div>\n\n    <!-- 統計サマリー -->\n    <div class=\"flex gap-4 mb-6\">\n      <div class=\"card flex-1 border-0 shadow-xl rounded-2xl\">\n        <div class=\"card-body text-center py-5\">\n          <div class=\"text-3xl font-bold text-indigo-600 mb-1\" id=\"turnCount\" data-item-id=\"turnCount\">12</div>\n          <div class=\"text-slate-500 text-xs font-medium\">完了ターン数</div>\n        </div>\n      </div>\n      <div class=\"card flex-1 border-0 shadow-xl rounded-2xl\">\n        <div class=\"card-body text-center py-5\">\n          <div class=\"text-3xl font-bold text-amber-500 mb-1\" id=\"newWordsCount\" data-item-id=\"newWordsCount\">7</div>\n          <div class=\"text-slate-500 text-xs font-medium\">新規習得単語</div>\n        </div>\n      </div>\n    </div>\n\n    <!-- 次の推奨ストーリー -->\n    <div class=\"card border-0 shadow-xl rounded-3xl mb-6\">\n      <div class=\"card-body p-5\">\n        <div class=\"text-xs font-bold text-slate-500 uppercase tracking-wider mb-3\">\n          <i class=\"bi bi-stars me-1 text-amber-400\"></i>次のおすすめ\n        </div>\n        <div class=\"flex items-center gap-4\">\n          <div class=\"w-10 h-10 bg-gradient-to-br from-sky-400 to-blue-500 rounded-2xl flex items-center justify-center flex-shrink-0 shadow-md\">\n            <i class=\"bi bi-briefcase-fill text-white\"></i>\n          </div>\n          <div class=\"flex-1\">\n            <div class=\"font-bold text-slate-800 text-sm\" id=\"recommendedStory\" data-item-id=\"recommendedStory\">Job Interview Prep</div>\n            <div class=\"text-slate-400 text-xs mt-0.5\">B1 中級 • 18 シーン</div>\n          </div>\n          <a href=\"/stories/story-002\"\n             class=\"btn btn-sm bg-gradient-to-r from-indigo-600 to-violet-600 text-white rounded-xl border-0 font-semibold\">\n            挑戦する\n          </a>\n        </div>\n      </div>\n    </div>\n\n    <!-- 発音フィードバック -->\n    <div class=\"card border-0 shadow-xl rounded-3xl mb-6\">\n      <div class=\"card-body p-5\">\n        <div class=\"text-xs font-bold text-slate-500 uppercase tracking-wider mb-3\">\n          <i class=\"bi bi-soundwave me-1 text-indigo-400\"></i>発音フィードバック\n        </div>\n        <div id=\"pronunciationFeedback\" data-item-id=\"pronunciationFeedback\" class=\"flex flex-col gap-2\">\n          <div class=\"flex items-center justify-between p-3 bg-emerald-50 rounded-2xl\">\n            <span class=\"text-slate-600 text-sm\">\"Could I get a latte?\"</span>\n            <span class=\"badge bg-emerald-100 text-emerald-700 rounded-xl font-bold\">82</span>\n          </div>\n          <div class=\"flex items-center justify-between p-3 bg-sky-50 rounded-2xl\">\n            <span class=\"text-slate-600 text-sm\">\"Here you go\"</span>\n            <span class=\"badge bg-sky-100 text-sky-700 rounded-xl font-bold\">90</span>\n          </div>\n          <div class=\"flex items-center justify-between p-3 bg-amber-50 rounded-2xl\">\n            <span class=\"text-slate-600 text-sm\">\"Thank you so much\"</span>\n            <span class=\"badge bg-amber-100 text-amber-700 rounded-xl font-bold\">78</span>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- アクションボタン -->\n    <div class=\"flex flex-col gap-3\">\n      <a href=\"/stories\"\n         class=\"btn btn-primary w-full py-4 rounded-2xl font-bold border-0 shadow-xl hover:shadow-2xl hover:scale-[1.02] transition-all duration-200\"\n         style=\"background:linear-gradient(135deg,#4f46e5,#7c3aed);\">\n        <i class=\"bi bi-arrow-repeat me-2\"></i>別のストーリーへ\n      </a>\n      <a href=\"/\"\n         class=\"btn w-full py-3 rounded-2xl font-semibold bg-slate-100 text-slate-600 hover:bg-slate-200 border-0 transition-all\">\n        <i class=\"bi bi-house me-2\"></i>ダッシュボードへ戻る\n      </a>\n    </div>\n\n  </div>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js\"></script>\n"
