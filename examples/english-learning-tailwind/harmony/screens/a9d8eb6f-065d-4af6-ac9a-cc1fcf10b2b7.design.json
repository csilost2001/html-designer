          "component": {
            "type": "wrapper",
            "components": "\n<div class=\"el-app min-h-screen bg-gradient-to-br from-slate-900 via-indigo-950 to-slate-900\" style=\"color:#e2e8f0;\">\n\n  <!-- ナビゲーション -->\n  <nav class=\"flex items-center justify-between px-6 py-3 border-b border-white/10\">\n    <div class=\"flex items-center gap-3\">\n      <span class=\"text-slate-400 text-xs font-mono\" id=\"sessionId\" data-item-id=\"sessionId\">Session #42</span>\n    </div>\n    <button\n      id=\"finishSession\"\n      name=\"finishSession\"\n      data-item-id=\"finishSession\"\n      class=\"btn btn-sm bg-white/10 text-slate-300 hover:bg-white/20 rounded-xl border-0 transition-all font-medium\"\n      aria-label=\"セッションを終了する\">\n      終了 <i class=\"bi bi-x-circle ms-1\"></i>\n    </button>\n  </nav>\n\n  <div style=\"max-width:540px;margin:0 auto;padding:1.5rem 1rem 8rem;\">\n\n    <!-- 現在のセリフ (字幕エリア) -->\n    <div class=\"card border-0 rounded-3xl mb-6 overflow-hidden shadow-2xl\"\n         style=\"background:linear-gradient(135deg,rgba(99,102,241,0.3) 0%,rgba(139,92,246,0.2) 100%);border:1px solid rgba(255,255,255,0.1);\">\n      <div class=\"card-body p-6\">\n        <div class=\"text-xs font-bold text-indigo-300 uppercase tracking-wider mb-3\">\n          <i class=\"bi bi-chat-quote me-1\"></i>現在のセリフ\n        </div>\n        <p class=\"text-xl font-bold text-white leading-relaxed mb-2\" id=\"currentDialogueLine\" data-item-id=\"currentDialogueLine\">\n          \"Could I get a latte, please?\"\n        </p>\n        <p class=\"text-slate-400 text-sm italic\" id=\"currentDialogueTranslation\" data-item-id=\"currentDialogueTranslation\">\n          ラテをいただけますか？\n        </p>\n      </div>\n    </div>\n\n    <!-- AI 応答 -->\n    <div class=\"mb-6\">\n      <div class=\"text-xs font-bold text-slate-500 uppercase tracking-wider mb-2 px-1\">\n        <i class=\"bi bi-robot me-1\"></i>AI アシスタント\n      </div>\n      <div class=\"rounded-3xl p-4 shadow-xl\"\n           style=\"background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.08);backdrop-filter:blur(10px);\">\n        <p class=\"text-slate-200 text-sm leading-relaxed\" id=\"aiResponseText\" data-item-id=\"aiResponseText\">\n          Great effort! Your pronunciation was mostly clear. Try to soften the \"t\" in \"latte\" — it's closer to a soft \"d\" sound in American English.\n        </p>\n      </div>\n    </div>\n\n    <!-- 発音スコア -->\n    <div class=\"card border-0 rounded-2xl mb-6 shadow-lg\"\n         style=\"background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.08);\">\n      <div class=\"card-body flex items-center gap-4 p-4\">\n        <div class=\"text-xs font-bold text-slate-500 uppercase tracking-wider\">発音スコア</div>\n        <div class=\"flex-1\">\n          <div class=\"w-full rounded-full\" style=\"height:6px;background:rgba(255,255,255,0.1);\">\n            <div class=\"rounded-full\" style=\"width:82%;height:6px;background:linear-gradient(90deg,#10b981,#34d399);\"></div>\n          </div>\n        </div>\n        <div class=\"text-2xl font-bold text-emerald-400\" id=\"pronunciationScore\" data-item-id=\"pronunciationScore\">82</div>\n        <div class=\"text-slate-500 text-sm\">/100</div>\n      </div>\n    </div>\n\n    <!-- 会話履歴 -->\n    <div class=\"mb-6\">\n      <div class=\"text-xs font-bold text-slate-500 uppercase tracking-wider mb-3 px-1\">\n        <i class=\"bi bi-chat-dots me-1\"></i>会話履歴\n      </div>\n      <div id=\"turnHistory\" data-item-id=\"turnHistory\" class=\"flex flex-col gap-3\" style=\"max-height:240px;overflow-y:auto;\">\n        <!-- ユーザー発話 -->\n        <div class=\"flex justify-end\">\n          <div class=\"rounded-3xl rounded-br-sm px-4 py-3 max-w-xs shadow-lg\"\n               style=\"background:linear-gradient(135deg,#4f46e5,#7c3aed);\">\n            <p class=\"text-white text-sm\">\"Hi, could I get a menu please?\"</p>\n            <div class=\"text-indigo-300 text-xs mt-1 text-right\">スコア: 88</div>\n          </div>\n        </div>\n        <!-- AI 応答 -->\n        <div class=\"flex justify-start\">\n          <div class=\"rounded-3xl rounded-bl-sm px-4 py-3 max-w-xs shadow-lg\"\n               style=\"background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.1);\">\n            <p class=\"text-slate-200 text-sm\">Sure! Here you go. Our special today is the caramel macchiato.</p>\n          </div>\n        </div>\n        <!-- ユーザー発話 2 -->\n        <div class=\"flex justify-end\">\n          <div class=\"rounded-3xl rounded-br-sm px-4 py-3 max-w-xs shadow-lg\"\n               style=\"background:linear-gradient(135deg,#4f46e5,#7c3aed);\">\n            <p class=\"text-white text-sm\">\"Could I get a latte, please?\"</p>\n            <div class=\"text-indigo-300 text-xs mt-1 text-right\">スコア: 82</div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- テキスト入力代替 -->\n    <div class=\"mb-4\">\n      <input type=\"text\"\n             id=\"userTextInput\"\n             name=\"userTextInput\"\n             data-item-id=\"userTextInput\"\n             class=\"form-control rounded-2xl text-sm\"\n             style=\"background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.1);color:#e2e8f0;\"\n             placeholder=\"テキストで入力する場合はこちら\"\n             maxlength=\"500\" />\n    </div>\n\n  </div>\n\n  <!-- 録音ボタン (フローティング固定) -->\n  <div class=\"fixed bottom-0 left-0 right-0 px-6 pb-8 pt-4\" style=\"background:linear-gradient(to top,rgba(15,23,42,0.95),transparent);\">\n    <div style=\"max-width:540px;margin:0 auto;\">\n      <button\n        id=\"recordButton\"\n        name=\"recordButton\"\n        data-item-id=\"recordButton\"\n        class=\"btn btn-danger w-full py-5 rounded-3xl font-bold text-base border-0 shadow-2xl hover:shadow-2xl hover:scale-[1.02] transition-all duration-200\"\n        style=\"background:linear-gradient(135deg,#e11d48,#be123c);\"\n        aria-label=\"録音して送信する\">\n        <i class=\"bi bi-mic-fill me-2 text-xl\"></i>録音して送信\n      </button>\n    </div>\n  </div>\n\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js\"></script>\n"
          }
