            "type": "wrapper",
            "components": "\n<div class=\"el-app min-h-screen bg-gradient-to-br from-slate-50 via-white to-indigo-50\">\n  <nav class=\"navbar bg-white/80 backdrop-blur-sm border-b border-slate-100 shadow-sm px-6 py-3 flex items-center gap-4\">\n    <a href=\"/vocabulary\" class=\"text-slate-400 hover:text-slate-600 transition-colors\" aria-label=\"単語帳へ戻る\">\n      <i class=\"bi bi-arrow-left text-lg\"></i>\n    </a>\n    <span class=\"navbar-brand text-slate-800 font-bold text-base flex-1\">単語詳細</span>\n  </nav>\n\n  <div style=\"max-width:480px;margin:0 auto;padding:2rem 1rem 5rem;\">\n\n    <!-- メイン単語 表示 -->\n    <div class=\"card border-0 shadow-2xl rounded-3xl mb-6 overflow-hidden\">\n      <div class=\"card-body text-center py-10 px-6\" style=\"background:linear-gradient(135deg,#1e1b4b 0%,#312e81 50%,#3730a3 100%);\">\n        <!-- 習熟度バッジ -->\n        <div class=\"mb-4\">\n          <span class=\"badge bg-emerald-400/90 text-white rounded-2xl px-4 py-1.5 text-sm font-bold shadow-lg\"\n                id=\"masteryStatus\" data-item-id=\"masteryStatus\">習得済み</span>\n        </div>\n        <!-- 英単語 大見出し -->\n        <h1 class=\"text-5xl font-bold text-white mb-2\" id=\"wordText\" data-item-id=\"wordText\">latte</h1>\n        <!-- 品詞 -->\n        <div class=\"text-indigo-300 text-sm font-medium mb-3\"\n             id=\"wordPartOfSpeech\" data-item-id=\"wordPartOfSpeech\">noun</div>\n        <!-- IPA -->\n        <div class=\"inline-block bg-white/10 rounded-2xl px-5 py-2 backdrop-blur-sm\">\n          <span class=\"font-mono text-xl text-indigo-200 tracking-wider\"\n                id=\"wordIpa\" data-item-id=\"wordIpa\">/ˈlɑːteɪ/</span>\n        </div>\n        <!-- CEFR バッジ -->\n        <div class=\"mt-4\">\n          <span class=\"badge bg-amber-400/80 text-white rounded-xl px-3 py-1 text-xs font-bold\"\n                id=\"wordCefrLevel\" data-item-id=\"wordCefrLevel\">A2</span>\n        </div>\n      </div>\n    </div>\n\n    <!-- 日本語訳 -->\n    <div class=\"card border-0 shadow-xl rounded-3xl mb-4\">\n      <div class=\"card-body p-5\">\n        <div class=\"text-xs font-bold text-slate-500 uppercase tracking-wider mb-2\">\n          <i class=\"bi bi-translate me-1 text-indigo-400\"></i>日本語訳\n        </div>\n        <div class=\"text-slate-800 font-semibold text-lg\" id=\"wordTranslation\" data-item-id=\"wordTranslation\">\n          ラテ、ラテコーヒー\n        </div>\n      </div>\n    </div>\n\n    <!-- 例文 -->\n    <div class=\"card border-0 shadow-xl rounded-3xl mb-6\">\n      <div class=\"card-body p-5\">\n        <div class=\"text-xs font-bold text-slate-500 uppercase tracking-wider mb-3\">\n          <i class=\"bi bi-chat-quote me-1 text-indigo-400\"></i>例文\n        </div>\n        <p class=\"text-slate-700 italic leading-relaxed text-sm\"\n           id=\"wordExampleSentence\" data-item-id=\"wordExampleSentence\">\n          \"Could I get a latte with oat milk, please? Make it a large.\"\n        </p>\n        <p class=\"text-slate-400 text-xs mt-2\">\n          オートミルクのラテをいただけますか？ラージサイズでお願いします。\n        </p>\n      </div>\n    </div>\n\n    <!-- アクション -->\n    <div class=\"flex gap-3\">\n      <button class=\"card flex-1 border-0 shadow-lg rounded-2xl hover:shadow-xl hover:-translate-y-0.5 transition-all duration-200 cursor-pointer\"\n              aria-label=\"発音を聞く\">\n        <div class=\"card-body text-center py-4 px-2\">\n          <i class=\"bi bi-volume-up-fill text-indigo-500 text-xl mb-1 block\"></i>\n          <span class=\"text-slate-600 text-xs font-medium\">発音を聞く</span>\n        </div>\n      </button>\n      <button class=\"card flex-1 border-0 shadow-lg rounded-2xl hover:shadow-xl hover:-translate-y-0.5 transition-all duration-200 cursor-pointer\"\n              aria-label=\"フラッシュカード練習\">\n        <div class=\"card-body text-center py-4 px-2\">\n          <i class=\"bi bi-card-text text-amber-500 text-xl mb-1 block\"></i>\n          <span class=\"text-slate-600 text-xs font-medium\">カード練習</span>\n        </div>\n      </button>\n      <a href=\"/stories\" class=\"card flex-1 border-0 shadow-lg rounded-2xl hover:shadow-xl hover:-translate-y-0.5 transition-all duration-200\">\n        <div class=\"card-body text-center py-4 px-2\">\n          <i class=\"bi bi-play-circle-fill text-emerald-500 text-xl mb-1 block\"></i>\n          <span class=\"text-slate-600 text-xs font-medium\">会話練習</span>\n        </div>\n      </a>\n    </div>\n\n  </div>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js\"></script>\n"
