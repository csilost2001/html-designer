{
  "name": "english-learning-tailwind-generated-tests",
  "version": "0.0.1",
  "description": "Generated test fixtures for english-learning-tailwind (ISSUE #1038 dogfood)",
  "private": true,
  "scripts": {
    "test:p3": "vitest run src/test/p3/",
    "test:p4": "playwright test --config=src/test/e2e/playwright.config.ts",
    "test:step3": "DATABASE_URL=file:./prisma/dev.db jest --config test/jest-e2e.json --runInBand test/cc173367.e2e-spec.ts",
    "test:p5": "jest --config test/jest-e2e.json --runInBand test/96118ae1-ai-mock.e2e-spec.ts",
    "test:p5:live": "RUN_AI_INTEGRATION=1 jest --config test/jest-e2e.json --runInBand test/96118ae1-ai-mock.e2e-spec.ts",
    "db:push": "prisma db push --skip-generate --accept-data-loss",
    "db:seed": "prisma generate && ts-node prisma/seed.ts",
    "db:reset": "rm -f prisma/dev.db && npm run db:push && npm run db:seed",
    "build": "tsc"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/passport": "^10.0.0",
    "@prisma/client": "^5.0.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.0.0",
    "@playwright/test": "^1.44.0",
    "@testing-library/react": "^16.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/react": "^18.0.0",
    "@types/supertest": "^6.0.0",
    "jest": "^29.0.0",
    "msw": "^2.0.0",
    "prisma": "^5.0.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0",
    "vitest": "^4.0.0"
  },
  "notes": "このパッケージは /generate-tests skill の dogfood 出力 fixture。NestJS app 本体は別途スキャフォールドが必要。structure 検証のみは npm install 後 vitest run で実行可能。"
}
