          "component": {
            "type": "wrapper",
            "components": "\n<div class=\"el-app min-h-screen bg-gradient-to-br from-slate-50 via-white to-violet-50\">\n  <nav class=\"navbar bg-white/80 backdrop-blur-sm border-b border-slate-100 shadow-sm px-6 py-3 flex items-center gap-4\">\n    <a href=\"/\" class=\"text-slate-400 hover:text-slate-600 transition-colors\" aria-label=\"ダッシュボードへ戻る\">\n      <i class=\"bi bi-arrow-left text-lg\"></i>\n    </a>\n    <span class=\"navbar-brand text-slate-800 font-bold text-base flex-1\">コンテンツパック</span>\n  </nav>\n\n  <div style=\"max-width:560px;margin:0 auto;padding:1.5rem 1rem 5rem;\">\n\n    <!-- ヘッダー -->\n    <div class=\"mb-6\">\n      <h1 class=\"text-2xl font-bold text-slate-800 mb-1\">パックを選んで学ぼう</h1>\n      <p class=\"text-slate-500 text-sm\">興味のある分野のパックを適用して、専門的な英語を習得できます</p>\n    </div>\n\n    <!-- パック一覧 -->\n    <div id=\"packList\" data-item-id=\"packList\" class=\"flex flex-col gap-5\">\n\n      <!-- アクティブ済みパック -->\n      <div class=\"card border-0 shadow-xl rounded-3xl overflow-hidden hover:shadow-2xl hover:-translate-y-0.5 transition-all duration-200\">\n        <div class=\"card-body p-0\">\n          <div class=\"p-6\" style=\"background:linear-gradient(135deg,#4f46e5,#7c3aed);\">\n            <div class=\"flex items-start justify-between mb-3\">\n              <div class=\"w-12 h-12 bg-white/20 rounded-2xl flex items-center justify-center shadow-lg\">\n                <i class=\"bi bi-cup-hot-fill text-white text-xl\"></i>\n              </div>\n              <span class=\"badge bg-white/25 text-white rounded-2xl px-3 py-1.5 text-xs font-bold\">\n                <i class=\"bi bi-check-circle-fill me-1\"></i>適用中\n              </span>\n            </div>\n            <h3 class=\"text-white font-bold text-lg mb-1\">日常会話パック</h3>\n            <p class=\"text-indigo-200 text-sm\">カフェ・ショッピング・旅行シーンの日常英語</p>\n          </div>\n          <div class=\"flex items-center justify-between px-6 py-4 bg-white\">\n            <div class=\"text-slate-500 text-sm\">\n              <i class=\"bi bi-book me-1 text-indigo-400\"></i>24 ストーリー\n            </div>\n            <button class=\"btn btn-sm bg-slate-100 text-slate-500 rounded-xl border-0 font-medium\">\n              解除する\n            </button>\n          </div>\n        </div>\n      </div>\n\n      <!-- 未適用パック 1 -->\n      <div class=\"card border-0 shadow-xl rounded-3xl overflow-hidden hover:shadow-2xl hover:-translate-y-0.5 transition-all duration-200\">\n        <div class=\"card-body p-0\">\n          <div class=\"p-6\" style=\"background:linear-gradient(135deg,#0ea5e9,#2563eb);\">\n            <div class=\"flex items-start justify-between mb-3\">\n              <div class=\"w-12 h-12 bg-white/20 rounded-2xl flex items-center justify-center shadow-lg\">\n                <i class=\"bi bi-briefcase-fill text-white text-xl\"></i>\n              </div>\n              <span class=\"badge bg-white/20 text-white rounded-2xl px-3 py-1.5 text-xs font-bold\">\n                <i class=\"bi bi-circle me-1\"></i>未適用\n              </span>\n            </div>\n            <h3 class=\"text-white font-bold text-lg mb-1\">ビジネス英語パック</h3>\n            <p class=\"text-sky-200 text-sm\">会議・プレゼン・メール対応のビジネス英語</p>\n          </div>\n          <div class=\"flex items-center justify-between px-6 py-4 bg-white\">\n            <div class=\"text-slate-500 text-sm\">\n              <i class=\"bi bi-book me-1 text-sky-400\"></i>18 ストーリー\n            </div>\n            <div class=\"flex items-center gap-2\">\n              <input type=\"hidden\"\n                     id=\"activatePackId\"\n                     name=\"activatePackId\"\n                     data-item-id=\"activatePackId\"\n                     value=\"business-pack\" />\n              <button class=\"btn btn-sm bg-gradient-to-r from-sky-500 to-blue-600 text-white rounded-xl border-0 font-semibold shadow-md hover:shadow-lg hover:scale-[1.03] transition-all\">\n                <i class=\"bi bi-plus-circle me-1\"></i>適用する\n              </button>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <!-- 未適用パック 2 -->\n      <div class=\"card border-0 shadow-xl rounded-3xl overflow-hidden hover:shadow-2xl hover:-translate-y-0.5 transition-all duration-200\">\n        <div class=\"card-body p-0\">\n          <div class=\"p-6\" style=\"background:linear-gradient(135deg,#059669,#0d9488);\">\n            <div class=\"flex items-start justify-between mb-3\">\n              <div class=\"w-12 h-12 bg-white/20 rounded-2xl flex items-center justify-center shadow-lg\">\n                <i class=\"bi bi-laptop-fill text-white text-xl\"></i>\n              </div>\n              <span class=\"badge bg-white/20 text-white rounded-2xl px-3 py-1.5 text-xs font-bold\">\n                <i class=\"bi bi-circle me-1\"></i>未適用\n              </span>\n            </div>\n            <h3 class=\"text-white font-bold text-lg mb-1\">IT エンジニアパック</h3>\n            <p class=\"text-emerald-200 text-sm\">エンジニアリング・コードレビュー・スタンドアップ英語</p>\n          </div>\n          <div class=\"flex items-center justify-between px-6 py-4 bg-white\">\n            <div class=\"text-slate-500 text-sm\">\n              <i class=\"bi bi-book me-1 text-emerald-400\"></i>32 ストーリー\n            </div>\n            <button class=\"btn btn-sm bg-gradient-to-r from-emerald-500 to-teal-600 text-white rounded-xl border-0 font-semibold shadow-md hover:shadow-lg hover:scale-[1.03] transition-all\">\n              <i class=\"bi bi-plus-circle me-1\"></i>適用する\n            </button>\n          </div>\n        </div>\n      </div>\n\n    </div>\n  </div>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js\"></script>\n"
