          "component": {
            "type": "wrapper",
            "components": "\n<div class=\"el-app min-h-screen bg-gradient-to-br from-slate-50 via-white to-indigo-50\">\n  <nav class=\"navbar bg-white/80 backdrop-blur-sm border-b border-slate-100 shadow-sm px-6 py-3 flex items-center gap-4\">\n    <a href=\"/\" class=\"text-slate-400 hover:text-slate-600 transition-colors\" aria-label=\"ダッシュボードへ戻る\">\n      <i class=\"bi bi-arrow-left text-lg\"></i>\n    </a>\n    <span class=\"navbar-brand text-slate-800 font-bold text-base flex-1\">プロフィール / 設定</span>\n  </nav>\n\n  <div style=\"max-width:480px;margin:0 auto;padding:1.5rem 1rem 7rem;\">\n\n    <!-- アバター -->\n    <div class=\"flex flex-col items-center mb-8\">\n      <div class=\"w-20 h-20 bg-gradient-to-br from-indigo-400 to-violet-500 rounded-3xl flex items-center justify-center shadow-2xl mb-3\">\n        <i class=\"bi bi-person-fill text-white text-3xl\"></i>\n      </div>\n      <div class=\"text-xs font-bold text-slate-500 uppercase tracking-wider\">\n        <span id=\"cefrLevelDisplay\" data-item-id=\"cefrLevelDisplay\">B1</span>\n        <span class=\"mx-1 text-slate-300\">|</span>\n        <span>現在のレベル</span>\n      </div>\n    </div>\n\n    <!-- プロフィール編集フォーム -->\n    <div class=\"card border-0 shadow-xl rounded-3xl mb-4\">\n      <div class=\"card-body p-6\">\n        <h2 class=\"text-sm font-bold text-slate-500 uppercase tracking-wider mb-5\">\n          <i class=\"bi bi-person me-2 text-indigo-400\"></i>プロフィール情報\n        </h2>\n        <div class=\"flex flex-col gap-4\">\n          <div>\n            <label class=\"form-label text-slate-600\" for=\"displayName\">\n              表示名 <span class=\"text-rose-500 font-bold\">*</span>\n            </label>\n            <input type=\"text\"\n                   class=\"form-control rounded-2xl border-slate-200 shadow-sm\"\n                   id=\"displayName\" name=\"displayName\" data-item-id=\"displayName\"\n                   placeholder=\"表示名を入力してください\"\n                   maxlength=\"50\"\n                   required />\n          </div>\n          <div>\n            <label class=\"form-label text-slate-500\" for=\"email\">メールアドレス</label>\n            <input type=\"email\"\n                   class=\"form-control rounded-2xl border-slate-200 shadow-sm bg-slate-50 text-slate-500\"\n                   id=\"email\" name=\"email\" data-item-id=\"email\"\n                   value=\"user@example.com\"\n                   readonly />\n            <div class=\"text-slate-400 text-xs mt-1 px-1\">メールアドレスは変更できません</div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- 学習設定 -->\n    <div class=\"card border-0 shadow-xl rounded-3xl mb-4\">\n      <div class=\"card-body p-6\">\n        <h2 class=\"text-sm font-bold text-slate-500 uppercase tracking-wider mb-5\">\n          <i class=\"bi bi-gear me-2 text-indigo-400\"></i>学習設定\n        </h2>\n        <div class=\"flex flex-col gap-4\">\n          <div>\n            <label class=\"form-label text-slate-600\" for=\"targetCefrLevel\">目標 CEFR レベル</label>\n            <select class=\"form-select rounded-2xl border-slate-200 shadow-sm\"\n                    id=\"targetCefrLevel\" name=\"targetCefrLevel\" data-item-id=\"targetCefrLevel\">\n              <option value=\"A1\">A1 入門</option>\n              <option value=\"A2\">A2 初級</option>\n              <option value=\"B1\">B1 中級</option>\n              <option value=\"B2\" selected>B2 中上級</option>\n              <option value=\"C1\">C1 上級</option>\n              <option value=\"C2\">C2 最上級</option>\n            </select>\n          </div>\n          <div>\n            <label class=\"form-label text-slate-600\" for=\"interests\">興味分野</label>\n            <div class=\"flex flex-wrap gap-2 mt-1\" id=\"interests\" name=\"interests\" data-item-id=\"interests\">\n              <label class=\"flex items-center gap-1.5 cursor-pointer px-3 py-2 rounded-2xl border border-slate-200 bg-white hover:border-indigo-300 hover:bg-indigo-50 transition-all text-sm\">\n                <input type=\"checkbox\" class=\"form-check-input\" value=\"it\" /> IT・テック\n              </label>\n              <label class=\"flex items-center gap-1.5 cursor-pointer px-3 py-2 rounded-2xl border border-indigo-300 bg-indigo-50 text-indigo-700 transition-all text-sm font-medium\">\n                <input type=\"checkbox\" class=\"form-check-input\" value=\"business\" checked /> ビジネス\n              </label>\n              <label class=\"flex items-center gap-1.5 cursor-pointer px-3 py-2 rounded-2xl border border-slate-200 bg-white hover:border-indigo-300 hover:bg-indigo-50 transition-all text-sm\">\n                <input type=\"checkbox\" class=\"form-check-input\" value=\"travel\" /> 旅行\n              </label>\n              <label class=\"flex items-center gap-1.5 cursor-pointer px-3 py-2 rounded-2xl border border-slate-200 bg-white hover:border-indigo-300 hover:bg-indigo-50 transition-all text-sm\">\n                <input type=\"checkbox\" class=\"form-check-input\" value=\"science\" /> 科学\n              </label>\n              <label class=\"flex items-center gap-1.5 cursor-pointer px-3 py-2 rounded-2xl border border-slate-200 bg-white hover:border-indigo-300 hover:bg-indigo-50 transition-all text-sm\">\n                <input type=\"checkbox\" class=\"form-check-input\" value=\"culture\" /> 文化・芸術\n              </label>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n  </div>\n\n  <!-- 固定保存ボタン (フローティング風) -->\n  <div class=\"fixed bottom-0 left-0 right-0 px-5 pb-6 pt-3\"\n       style=\"background:linear-gradient(to top,rgba(248,250,252,0.98),transparent);\">\n    <div style=\"max-width:480px;margin:0 auto;\">\n      <button\n        id=\"saveProfile\"\n        name=\"saveProfile\"\n        data-item-id=\"saveProfile\"\n        type=\"submit\"\n        class=\"btn btn-primary w-full py-4 rounded-2xl font-bold text-base border-0 shadow-2xl hover:shadow-2xl hover:scale-[1.02] transition-all duration-200\"\n        style=\"background:linear-gradient(135deg,#4f46e5,#7c3aed);\"\n        aria-label=\"設定を保存する\">\n        <i class=\"bi bi-check-lg me-2\"></i>設定を保存する\n      </button>\n    </div>\n  </div>\n\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js\"></script>\n"
          }
