            "type": "wrapper",
            "components": "\n<div class=\"el-app min-h-screen bg-gradient-to-br from-slate-50 via-white to-indigo-50\">\n  <nav class=\"navbar bg-white/80 backdrop-blur-sm border-b border-slate-100 shadow-sm px-6 py-3 flex items-center gap-4\">\n    <a href=\"/stories\" class=\"text-slate-400 hover:text-slate-600 transition-colors\" aria-label=\"ストーリー一覧へ戻る\">\n      <i class=\"bi bi-arrow-left text-lg\"></i>\n    </a>\n    <span class=\"navbar-brand text-slate-800 font-bold text-base flex-1\">ストーリー詳細</span>\n  </nav>\n\n  <div style=\"max-width:540px;margin:0 auto;padding:0 0 5rem;\">\n\n    <!-- ヒーロービジュアル -->\n    <div class=\"relative overflow-hidden\" style=\"height:200px;background:linear-gradient(135deg,#4f46e5 0%,#7c3aed 50%,#2563eb 100%);\">\n      <div class=\"absolute inset-0 flex flex-col items-center justify-center text-white px-6 text-center\">\n        <div class=\"w-16 h-16 bg-white/20 rounded-3xl flex items-center justify-center mb-3 shadow-2xl backdrop-blur-sm\">\n          <i class=\"bi bi-book-half text-3xl\"></i>\n        </div>\n        <h1 class=\"text-2xl font-bold mb-1\" id=\"storyTitle\" data-item-id=\"storyTitle\">At the Coffee Shop</h1>\n        <span class=\"badge bg-white/30 text-white rounded-2xl px-4 py-1.5 text-sm font-semibold\" id=\"storyCefrLevel\" data-item-id=\"storyCefrLevel\">A2</span>\n      </div>\n    </div>\n\n    <div class=\"px-5 pt-6\">\n\n      <!-- 概要 -->\n      <div class=\"card border-0 shadow-xl rounded-3xl mb-5\">\n        <div class=\"card-body p-5\">\n          <h2 class=\"text-xs font-bold text-slate-500 uppercase tracking-wider mb-2\">\n            <i class=\"bi bi-info-circle me-1 text-indigo-400\"></i>概要\n          </h2>\n          <p class=\"text-slate-600 text-sm leading-relaxed\" id=\"storyDescription\" data-item-id=\"storyDescription\">\n            カフェでの日常会話を通じて、注文・雑談・丁寧な断り方などの実用英語を習得します。\n          </p>\n        </div>\n      </div>\n\n      <!-- シーン一覧 -->\n      <div class=\"mb-5\">\n        <h2 class=\"text-base font-bold text-slate-700 mb-3\">\n          <i class=\"bi bi-list-ol me-2 text-indigo-400\"></i>シーン一覧\n        </h2>\n        <div id=\"sceneList\" data-item-id=\"sceneList\" class=\"flex flex-col gap-2\">\n          <div class=\"card border-0 shadow-md rounded-2xl\">\n            <div class=\"card-body flex items-center gap-4 p-4\">\n              <div class=\"w-8 h-8 bg-emerald-100 rounded-xl flex items-center justify-center flex-shrink-0\">\n                <i class=\"bi bi-check-lg text-emerald-600 font-bold\"></i>\n              </div>\n              <div class=\"flex-1\">\n                <div class=\"text-sm font-semibold text-slate-700\">Scene 1: 席について注文する</div>\n              </div>\n              <span class=\"badge bg-emerald-100 text-emerald-700 rounded-xl text-xs px-2 py-1\">完了</span>\n            </div>\n          </div>\n          <div class=\"card border-0 shadow-md rounded-2xl\">\n            <div class=\"card-body flex items-center gap-4 p-4\">\n              <div class=\"w-8 h-8 bg-indigo-100 rounded-xl flex items-center justify-center flex-shrink-0\">\n                <span class=\"text-indigo-600 font-bold text-sm\">2</span>\n              </div>\n              <div class=\"flex-1\">\n                <div class=\"text-sm font-semibold text-slate-700\">Scene 2: 店員との雑談</div>\n              </div>\n              <span class=\"badge bg-indigo-50 text-indigo-500 rounded-xl text-xs px-2 py-1\">進行中</span>\n            </div>\n          </div>\n          <div class=\"card border-0 shadow-md rounded-2xl opacity-60\">\n            <div class=\"card-body flex items-center gap-4 p-4\">\n              <div class=\"w-8 h-8 bg-slate-100 rounded-xl flex items-center justify-center flex-shrink-0\">\n                <span class=\"text-slate-400 font-bold text-sm\">3</span>\n              </div>\n              <div class=\"flex-1\">\n                <div class=\"text-sm font-semibold text-slate-500\">Scene 3: お勘定と別れの挨拶</div>\n              </div>\n              <span class=\"badge bg-slate-100 text-slate-400 rounded-xl text-xs px-2 py-1\">未着手</span>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <!-- 学習開始 CTA -->\n      <button\n        id=\"startSession\"\n        name=\"startSession\"\n        data-item-id=\"startSession\"\n        class=\"btn btn-primary w-full py-4 px-8 rounded-2xl font-bold text-base border-0 shadow-2xl hover:shadow-2xl hover:scale-[1.02] transition-all duration-200\"\n        style=\"background:linear-gradient(135deg,#4f46e5,#7c3aed);\"\n        aria-label=\"学習セッションを開始する\">\n        <i class=\"bi bi-play-circle-fill me-2 text-lg\"></i>学習を開始する\n      </button>\n\n    </div>\n  </div>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js\"></script>\n"
