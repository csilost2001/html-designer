{
  "$schema": "../../../../schemas/v3/process-flow.v3.schema.json",
  "meta": {
    "id": "a9b0c1d2-e3f4-4a5b-8c6d-7e8f9a0b1c2d",
    "name": "AIタグ提案",
    "description": "投稿のタイトル + 本文を Claude AI へ送信し、信頼度付きタグ候補を取得する処理フロー。信頼度 0.6 未満のものは除外する。UI 側でユーザー選択後、確定は投稿作成/更新フロー経由で post_tags に INSERT。 / 注: AI モデル名 (claude-opus-4-7) は本 PR 時点でリテラル文字列としてハードコード。",
    "kind": "common",
    "maturity": "draft",
    "createdAt": "2026-05-06T14:00:00.000Z",
    "updatedAt": "2026-05-06T14:00:00.000Z"
  },
  "context": {
    "catalogs": {
      "errors": {
        "VALIDATION_ERROR": {
          "httpStatus": 400,
          "defaultMessage": "入力値が不正です。",
          "responseId": "400-validation",
          "description": "title / body が未入力の場合。"
        },
        "AI_API_ERROR": {
          "httpStatus": 502,
          "defaultMessage": "AI API の呼び出しに失敗しました。",
          "responseId": "502-ai-error",
          "description": "Claude API へのリクエストが失敗した場合。"
        }
      },
      "externalSystems": {
        "claudeApi": {
          "name": "Claude AI API",
          "baseUrl": "@env.CLAUDE_API_BASE_URL",
          "auth": {
            "kind": "bearer",
            "tokenRef": "@secret.claudeApiKey"
          },
          "timeoutMs": 30000,
          "retryPolicy": {
            "maxAttempts": 2,
            "backoff": "exponential",
            "initialDelayMs": 1000
          }
        }
      },
      "secrets": {
        "claudeApiKey": {
          "source": "env",
          "name": "CLAUDE_API_KEY",
          "description": "Claude API の認証キー。"
        }
      }
    },
    "ambientVariables": [
      {
        "name": "sessionUserId",
        "type": "integer",
        "required": false,
        "description": "ログインユーザー ID (JWT から抽出)。"
      }
    ]
  },
  "actions": [
    {
      "id": "act-001",
      "name": "AIタグ提案",
      "trigger": "submit",
      "description": "title + body + existingTags[] を受け取り、Claude API でタグ候補を生成し、信頼度フィルタ後に返す。",
      "maturity": "draft",
      "httpRoute": {
        "method": "POST",
        "path": "/api/ai/tag-suggest",
        "auth": "required"
      },
      "inputs": [
        {
          "name": "title",
          "label": "タイトル",
          "type": "string",
          "required": true,
          "description": "投稿タイトル。"
        },
        {
          "name": "body",
          "label": "本文",
          "type": "string",
          "required": true,
          "description": "投稿本文。"
        },
        {
          "name": "existingTags",
          "label": "既存タグ",
          "type": { "kind": "array", "itemType": "string" },
          "required": false,
          "description": "既に付いているタグのスラッグ一覧 (除外用)。"
        }
      ],
      "outputs": [
        {
          "name": "candidates",
          "label": "タグ候補",
          "type": {
            "kind": "array",
            "itemType": {
              "kind": "object",
              "fields": [
                { "name": "slug", "type": "string", "required": true },
                { "name": "name", "type": "string", "required": true },
                { "name": "confidence", "type": "number", "required": true },
                { "name": "isNew", "type": "boolean", "required": true }
              ]
            }
          },
          "description": "信頼度付きタグ候補の配列 (slug, name, confidence, isNew)。"
        }
      ],
      "responses": [
        {
          "id": "200-ok",
          "status": 200,
          "description": "タグ提案成功。",
          "when": "Claude API の呼び出しが正常完了した場合。"
        },
        {
          "id": "400-validation",
          "status": 400,
          "description": "バリデーションエラー。",
          "when": "title / body が未入力の場合。"
        },
        {
          "id": "502-ai-error",
          "status": 502,
          "description": "AI API エラー。",
          "when": "Claude API の呼び出しが失敗した場合。"
        }
      ],
      "steps": [
        {
          "id": "step-01",
          "kind": "validation",
          "description": "title / body 必須チェック。",
          "rules": [
            {
              "field": "title",
              "type": "required",
              "severity": "error",
              "message": "タイトルは必須です。"
            },
            {
              "field": "body",
              "type": "required",
              "severity": "error",
              "message": "本文は必須です。"
            }
          ],
          "inlineBranch": {
            "ok": [],
            "ng": [
              {
                "id": "step-01-ng-01",
                "kind": "return",
                "description": "400 バリデーションエラーを返す。",
                "responseId": "400-validation",
                "bodyExpression": "{ code: 'VALIDATION_ERROR', message: '入力値が不正です。', details: @fieldErrors }"
              }
            ]
          }
        },
        {
          "id": "step-02",
          "kind": "dbAccess",
          "description": "既存タグの全 slug 一覧を取得し、isNew 判定に使用する。",
          "tableId": "07439e21-0743-48ca-af9e-763e4be2d094",
          "operation": "SELECT",
          "sql": "SELECT slug FROM tags",
          "outputBinding": {
            "name": "allTagSlugs"
          },
          "lineage": {
            "reads": [
              {
                "tableId": "07439e21-0743-48ca-af9e-763e4be2d094",
                "purpose": "lookup"
              }
            ]
          }
        },
        {
          "id": "step-03",
          "kind": "externalSystem",
          "description": "Claude API にタグ抽出プロンプトを送信し、JSON 形式のタグ候補を取得する。",
          "systemRef": "claudeApi",
          "httpCall": {
            "method": "POST",
            "path": "/v1/messages",
            "body": "{ model: 'claude-opus-4-7', max_tokens: 512, messages: [{ role: 'user', content: '以下の記事から関連するタグを抽出してください。除外するタグ: ' + JSON.stringify(@inputs.existingTags) + '\\n\\n# タイトル\\n' + @inputs.title + '\\n\\n# 本文\\n' + @inputs.body + '\\n\\n各タグの slug (英小文字ハイフン区切り), name (日本語), confidence (0.0〜1.0) を JSON 配列で返してください。形式: [{\"slug\": \"...\", \"name\": \"...\", \"confidence\": 0.9}]' }] }"
          },
          "outputBinding": {
            "name": "aiResponse"
          },
          "outcomes": {
            "failure": {
              "action": "abort",
              "description": "Claude API 呼び出し失敗時は 502 を返す。"
            }
          }
        },
        {
          "id": "step-04",
          "kind": "compute",
          "description": "AI レスポンスから候補配列を JSON パースし、信頼度フィルタ (0.6 以上) と isNew フラグを付与する。",
          "expression": "JSON.parse(@aiResponse.content[0].text).filter(t => t.confidence >= 0.6).map(t => ({ ...t, isNew: !@allTagSlugs.some(s => s.slug === t.slug) }))",
          "outputBinding": {
            "name": "candidates"
          }
        },
        {
          "id": "step-05",
          "kind": "return",
          "description": "200 タグ候補を返す。",
          "responseId": "200-ok",
          "bodyExpression": "{ candidates: @candidates }"
        }
      ]
    }
  ]
}
