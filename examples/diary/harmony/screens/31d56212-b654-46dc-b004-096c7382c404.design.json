            "type": "wrapper",
            "components": "\n<div class=\"min-h-screen bg-gradient-to-br from-slate-50 via-white to-indigo-50\">\n  <!-- CDN Scripts -->\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n  <script src=\"https://unpkg.com/lucide@latest/dist/umd/lucide.min.js\"></script>\n\n  <!-- Top Navigation -->\n  <nav class=\"sticky top-0 z-40 bg-white/80 backdrop-blur-md border-b border-slate-100 shadow-[0_2px_20px_rgb(0,0,0,0.04)]\">\n    <div class=\"max-w-6xl mx-auto px-6 py-4 flex items-center gap-4\">\n      <div class=\"flex items-center gap-3 flex-1\">\n        <div class=\"w-9 h-9 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-xl flex items-center justify-center shadow-md\">\n          <i data-lucide=\"book-open\" class=\"w-5 h-5 text-white\"></i>\n        </div>\n        <span class=\"font-bold text-xl text-slate-800 tracking-tight\">My Diary</span>\n      </div>\n      <div class=\"flex items-center gap-2\">\n        <a href=\"/tags\" class=\"flex items-center gap-2 px-4 py-2 text-sm font-medium text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 rounded-xl transition-all duration-200\">\n          <i data-lucide=\"tag\" class=\"w-4 h-4\"></i>\n          タグ管理\n        </a>\n        <div class=\"w-9 h-9 bg-slate-100 rounded-full overflow-hidden flex items-center justify-center\">\n          <i data-lucide=\"user\" class=\"w-5 h-5 text-slate-500\"></i>\n        </div>\n      </div>\n    </div>\n  </nav>\n\n  <!-- Hero Header -->\n  <div class=\"max-w-6xl mx-auto px-6 pt-10 pb-6\">\n    <div class=\"mb-2\">\n      <span class=\"text-sm font-semibold text-indigo-500 tracking-widest uppercase\">2026年5月</span>\n    </div>\n    <h1 class=\"text-4xl font-bold text-slate-900 tracking-tight mb-1\">My Journal</h1>\n    <p class=\"text-slate-500 text-base\">あなたの毎日を記録しましょう</p>\n  </div>\n\n  <!-- Filter Bar -->\n  <div class=\"max-w-6xl mx-auto px-6 mb-8\">\n    <div class=\"bg-white rounded-2xl shadow-[0_4px_20px_rgb(0,0,0,0.06)] border border-slate-100 p-4\">\n\n      <!-- Search -->\n      <div class=\"relative mb-4\">\n        <div class=\"absolute inset-y-0 left-4 flex items-center pointer-events-none\">\n          <i data-lucide=\"search\" class=\"w-4 h-4 text-slate-400\"></i>\n        </div>\n        <input\n          id=\"searchQuery\"\n          name=\"searchQuery\"\n          data-item-id=\"searchQuery\"\n          type=\"text\"\n          placeholder=\"投稿を検索…\"\n          class=\"w-full pl-11 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm text-slate-700 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-300 focus:border-transparent transition-all duration-200\"\n        />\n      </div>\n\n      <!-- Status Toggle + Tag Chips Row -->\n      <div class=\"flex items-center gap-3 flex-wrap\">\n        <!-- Status Toggle -->\n        <div id=\"statusFilter\" data-item-id=\"statusFilter\" class=\"flex items-center bg-slate-100 rounded-full p-1 gap-1\">\n          <button class=\"px-4 py-1.5 text-xs font-semibold bg-white text-slate-700 rounded-full shadow-sm transition-all duration-200\">全部</button>\n          <button class=\"px-4 py-1.5 text-xs font-semibold text-slate-500 hover:text-slate-700 rounded-full transition-all duration-200\">公開</button>\n          <button class=\"px-4 py-1.5 text-xs font-semibold text-slate-500 hover:text-slate-700 rounded-full transition-all duration-200\">下書き</button>\n        </div>\n\n        <div class=\"w-px h-5 bg-slate-200\"></div>\n\n        <!-- Tag Chips -->\n        <div id=\"selectedTagSlugs\" data-item-id=\"selectedTagSlugs\" class=\"flex items-center gap-2 flex-wrap\">\n          <span class=\"inline-flex items-center gap-1 px-3 py-1.5 bg-indigo-100 text-indigo-700 text-xs font-semibold rounded-full cursor-pointer hover:bg-indigo-200 transition-all duration-200\">\n            <i data-lucide=\"hash\" class=\"w-3 h-3\"></i>旅行\n          </span>\n          <span class=\"inline-flex items-center gap-1 px-3 py-1.5 bg-rose-100 text-rose-700 text-xs font-semibold rounded-full cursor-pointer hover:bg-rose-200 transition-all duration-200\">\n            <i data-lucide=\"hash\" class=\"w-3 h-3\"></i>グルメ\n          </span>\n          <span class=\"inline-flex items-center gap-1 px-3 py-1.5 bg-amber-100 text-amber-700 text-xs font-semibold rounded-full cursor-pointer hover:bg-amber-200 transition-all duration-200\">\n            <i data-lucide=\"hash\" class=\"w-3 h-3\"></i>日常\n          </span>\n          <span class=\"inline-flex items-center gap-1 px-3 py-1.5 bg-emerald-100 text-emerald-700 text-xs font-semibold rounded-full cursor-pointer hover:bg-emerald-200 transition-all duration-200\">\n            <i data-lucide=\"hash\" class=\"w-3 h-3\"></i>仕事\n          </span>\n          <span class=\"inline-flex items-center gap-1 px-3 py-1.5 bg-slate-100 text-slate-600 text-xs font-medium rounded-full cursor-pointer hover:bg-slate-200 transition-all duration-200\">\n            <i data-lucide=\"plus\" class=\"w-3 h-3\"></i>もっと\n          </span>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <!-- Masonry Grid -->\n  <div id=\"posts\" data-item-id=\"posts\" class=\"max-w-6xl mx-auto px-6 pb-32\">\n    <div class=\"columns-1 md:columns-2 lg:columns-3 gap-6 space-y-0\">\n\n      <!-- Card 1: With Hero Image -->\n      <div class=\"break-inside-avoid mb-6 bg-white rounded-3xl overflow-hidden shadow-[0_4px_20px_rgb(0,0,0,0.08)] hover:shadow-[0_8px_40px_rgb(0,0,0,0.12)] hover:scale-[1.02] transition-all duration-300 cursor-pointer group\">\n        <div class=\"relative overflow-hidden\">\n          <div class=\"h-48 bg-gradient-to-br from-indigo-400 via-purple-500 to-pink-400\"></div>\n          <div class=\"absolute top-3 right-3\">\n            <span class=\"bg-white/20 backdrop-blur-md text-white text-xs font-semibold px-2.5 py-1 rounded-full\">公開</span>\n          </div>\n          <div class=\"absolute bottom-3 left-3 flex items-center gap-1.5\">\n            <span class=\"text-xl\">😊</span>\n            <span class=\"text-xl\">☀️</span>\n          </div>\n        </div>\n        <div class=\"p-5\">\n          <div class=\"flex items-center gap-2 mb-2\">\n            <i data-lucide=\"map-pin\" class=\"w-3.5 h-3.5 text-slate-400\"></i>\n            <span class=\"text-xs text-slate-400\">東京・渋谷</span>\n            <span class=\"text-xs text-slate-300\">•</span>\n            <span class=\"text-xs text-slate-400\">2026/05/05</span>\n          </div>\n          <h2 class=\"text-base font-bold text-slate-800 tracking-tight mb-2 group-hover:text-indigo-600 transition-colors\">春の渋谷散歩</h2>\n          <p class=\"text-sm text-slate-500 leading-relaxed mb-3 line-clamp-3\">桜の花びらが舞い散る中、渋谷の街をぶらりと歩いた。新しいカフェを発見して思わず立ち寄り…</p>\n          <div class=\"flex flex-wrap gap-1.5\">\n            <span class=\"px-2 py-0.5 bg-indigo-50 text-indigo-600 text-xs font-medium rounded-full\">旅行</span>\n            <span class=\"px-2 py-0.5 bg-amber-50 text-amber-600 text-xs font-medium rounded-full\">日常</span>\n          </div>\n        </div>\n      </div>\n\n      <!-- Card 2: Longer Text -->\n      <div class=\"break-inside-avoid mb-6 bg-white rounded-3xl overflow-hidden shadow-[0_4px_20px_rgb(0,0,0,0.08)] hover:shadow-[0_8px_40px_rgb(0,0,0,0.12)] hover:scale-[1.02] transition-all duration-300 cursor-pointer group\">\n        <div class=\"p-5\">\n          <div class=\"flex items-center justify-between mb-3\">\n            <div class=\"flex items-center gap-2\">\n              <span class=\"text-lg\">🌧️</span>\n              <span class=\"text-xs text-slate-400\">2026/05/03</span>\n            </div>\n            <span class=\"bg-amber-100 text-amber-700 text-xs font-semibold px-2.5 py-1 rounded-full\">下書き</span>\n          </div>\n          <h2 class=\"text-base font-bold text-slate-800 tracking-tight mb-2 group-hover:text-indigo-600 transition-colors\">雨の日の読書記録</h2>\n          <p class=\"text-sm text-slate-500 leading-relaxed mb-4 line-clamp-5\">梅雨入りを思わせるような長雨の一日。コーヒーを片手に積読を崩し始めた。村上春樹の新作は相変わらず文章が美しく、気づけば3時間が経過していた。窓の外の雨音が心地よいBGMになっている。夕方には雨が小降りになったので近所のパン屋へ。</p>\n          <div class=\"flex items-center gap-2 mb-3\">\n            <i data-lucide=\"book-open\" class=\"w-3.5 h-3.5 text-slate-400\"></i>\n            <span class=\"text-xs text-slate-400\">自宅</span>\n          </div>\n          <div class=\"flex flex-wrap gap-1.5\">\n            <span class=\"px-2 py-0.5 bg-slate-100 text-slate-600 text-xs font-medium rounded-full\">読書</span>\n            <span class=\"px-2 py-0.5 bg-amber-50 text-amber-600 text-xs font-medium rounded-full\">日常</span>\n          </div>\n        </div>\n      </div>\n\n      <!-- Card 3: With Image + AI summary badge -->\n      <div class=\"break-inside-avoid mb-6 bg-white rounded-3xl overflow-hidden shadow-[0_4px_20px_rgb(0,0,0,0.08)] hover:shadow-[0_8px_40px_rgb(0,0,0,0.12)] hover:scale-[1.02] transition-all duration-300 cursor-pointer group\">\n        <div class=\"relative overflow-hidden\">\n          <div class=\"h-36 bg-gradient-to-br from-emerald-400 to-teal-500\"></div>\n          <div class=\"absolute top-3 right-3\">\n            <span class=\"bg-white/20 backdrop-blur-md text-white text-xs font-semibold px-2.5 py-1 rounded-full\">公開</span>\n          </div>\n        </div>\n        <div class=\"p-5\">\n          <div class=\"flex items-center gap-2 mb-2\">\n            <span class=\"text-lg\">😄</span>\n            <span class=\"text-lg\">🌤️</span>\n            <span class=\"text-xs text-slate-400 ml-1\">2026/05/01</span>\n          </div>\n          <h2 class=\"text-base font-bold text-slate-800 tracking-tight mb-2 group-hover:text-indigo-600 transition-colors\">新しい趣味を始めた</h2>\n          <!-- AI Summary Badge -->\n          <div class=\"flex items-start gap-2 bg-indigo-50 rounded-xl px-3 py-2 mb-3\">\n            <i data-lucide=\"sparkles\" class=\"w-3.5 h-3.5 text-indigo-400 flex-shrink-0 mt-0.5\"></i>\n            <p class=\"text-xs text-indigo-600 leading-relaxed\">ガーデニングを始め、初めての収穫に喜ぶ充実した一日の記録。</p>\n          </div>\n          <div class=\"flex flex-wrap gap-1.5\">\n            <span class=\"px-2 py-0.5 bg-emerald-50 text-emerald-600 text-xs font-medium rounded-full\">趣味</span>\n            <span class=\"px-2 py-0.5 bg-amber-50 text-amber-600 text-xs font-medium rounded-full\">日常</span>\n          </div>\n        </div>\n      </div>\n\n      <!-- Card 4: Short entry -->\n      <div class=\"break-inside-avoid mb-6 bg-gradient-to-br from-rose-50 to-pink-50 rounded-3xl overflow-hidden shadow-[0_4px_20px_rgb(0,0,0,0.06)] hover:shadow-[0_8px_40px_rgb(0,0,0,0.10)] hover:scale-[1.02] transition-all duration-300 cursor-pointer group border border-rose-100\">\n        <div class=\"p-5\">\n          <div class=\"text-4xl mb-3\">🍣</div>\n          <div class=\"flex items-center gap-2 mb-2\">\n            <i data-lucide=\"map-pin\" class=\"w-3.5 h-3.5 text-rose-400\"></i>\n            <span class=\"text-xs text-rose-400\">銀座</span>\n            <span class=\"text-xs text-slate-300\">•</span>\n            <span class=\"text-xs text-slate-400\">2026/04/28</span>\n          </div>\n          <h2 class=\"text-base font-bold text-slate-800 tracking-tight mb-2 group-hover:text-rose-600 transition-colors\">記念日ディナー🥂</h2>\n          <p class=\"text-sm text-slate-500 leading-relaxed\">最高のお鮨で最高の夜を。</p>\n          <div class=\"mt-3 flex flex-wrap gap-1.5\">\n            <span class=\"px-2 py-0.5 bg-rose-100 text-rose-600 text-xs font-medium rounded-full\">グルメ</span>\n          </div>\n        </div>\n      </div>\n\n      <!-- Card 5: Long with gallery hint -->\n      <div class=\"break-inside-avoid mb-6 bg-white rounded-3xl overflow-hidden shadow-[0_4px_20px_rgb(0,0,0,0.08)] hover:shadow-[0_8px_40px_rgb(0,0,0,0.12)] hover:scale-[1.02] transition-all duration-300 cursor-pointer group\">\n        <div class=\"relative overflow-hidden\">\n          <div class=\"h-56 bg-gradient-to-br from-amber-400 via-orange-400 to-rose-400\"></div>\n          <div class=\"absolute bottom-3 right-3 bg-black/50 backdrop-blur-sm text-white text-xs px-2 py-1 rounded-full flex items-center gap-1\">\n            <i data-lucide=\"image\" class=\"w-3 h-3\"></i>\n            <span>8枚</span>\n          </div>\n          <div class=\"absolute top-3 right-3\">\n            <span class=\"bg-white/20 backdrop-blur-md text-white text-xs font-semibold px-2.5 py-1 rounded-full\">公開</span>\n          </div>\n          <div class=\"absolute bottom-3 left-3 flex items-center gap-1.5\">\n            <span class=\"text-xl\">🤩</span>\n            <span class=\"text-xl\">⛅</span>\n          </div>\n        </div>\n        <div class=\"p-5\">\n          <div class=\"flex items-center gap-2 mb-2\">\n            <i data-lucide=\"map-pin\" class=\"w-3.5 h-3.5 text-slate-400\"></i>\n            <span class=\"text-xs text-slate-400\">京都・嵐山</span>\n            <span class=\"text-xs text-slate-300\">•</span>\n            <span class=\"text-xs text-slate-400\">2026/04/25</span>\n          </div>\n          <h2 class=\"text-base font-bold text-slate-800 tracking-tight mb-2 group-hover:text-indigo-600 transition-colors\">嵐山一人旅</h2>\n          <p class=\"text-sm text-slate-500 leading-relaxed mb-3 line-clamp-3\">日帰りで嵐山へ。竹林を抜けてから渡月橋まで歩いた。思ったより人が多かったけれど、早朝だったおかげで幻想的な空気感を体感できた。</p>\n          <div class=\"flex flex-wrap gap-1.5\">\n            <span class=\"px-2 py-0.5 bg-indigo-50 text-indigo-600 text-xs font-medium rounded-full\">旅行</span>\n            <span class=\"px-2 py-0.5 bg-amber-50 text-amber-600 text-xs font-medium rounded-full\">写真</span>\n          </div>\n        </div>\n      </div>\n\n      <!-- Card 6: Work entry -->\n      <div class=\"break-inside-avoid mb-6 bg-white rounded-3xl overflow-hidden shadow-[0_4px_20px_rgb(0,0,0,0.08)] hover:shadow-[0_8px_40px_rgb(0,0,0,0.12)] hover:scale-[1.02] transition-all duration-300 cursor-pointer group\">\n        <div class=\"p-5\">\n          <div class=\"flex items-center justify-between mb-3\">\n            <div class=\"flex items-center gap-2\">\n              <span class=\"text-lg\">💪</span>\n              <span class=\"text-lg\">🌥️</span>\n            </div>\n            <span class=\"text-xs text-slate-400\">2026/04/22</span>\n          </div>\n          <h2 class=\"text-base font-bold text-slate-800 tracking-tight mb-2 group-hover:text-indigo-600 transition-colors\">プロジェクト完成 🎉</h2>\n          <!-- AI Summary Badge -->\n          <div class=\"flex items-start gap-2 bg-indigo-50 rounded-xl px-3 py-2 mb-3\">\n            <i data-lucide=\"sparkles\" class=\"w-3.5 h-3.5 text-indigo-400 flex-shrink-0 mt-0.5\"></i>\n            <p class=\"text-xs text-indigo-600 leading-relaxed\">半年かけたプロジェクトが無事リリース。チームとの達成感を振り返った記録。</p>\n          </div>\n          <p class=\"text-sm text-slate-500 leading-relaxed line-clamp-3\">半年越しのプロジェクトがついにリリース。深夜まで粘ったデプロイも無事成功。チームみんなに感謝しかない。</p>\n          <div class=\"mt-3 flex flex-wrap gap-1.5\">\n            <span class=\"px-2 py-0.5 bg-indigo-50 text-indigo-600 text-xs font-medium rounded-full\">仕事</span>\n          </div>\n        </div>\n      </div>\n\n    </div>\n\n    <!-- Total Count -->\n    <div id=\"totalCount\" data-item-id=\"totalCount\" class=\"text-center py-6\">\n      <p class=\"text-sm text-slate-400\">6件の投稿を表示中</p>\n    </div>\n  </div>\n\n  <!-- Floating FAB -->\n  <div class=\"fixed bottom-8 right-8 z-50\">\n    <a href=\"/post/edit\" class=\"flex items-center gap-2.5 bg-gradient-to-r from-indigo-500 to-purple-600 text-white px-6 py-4 rounded-full shadow-[0_8px_30px_rgb(99,102,241,0.4)] hover:shadow-[0_12px_40px_rgb(99,102,241,0.5)] hover:scale-[1.05] transition-all duration-300 font-semibold text-sm\">\n      <i data-lucide=\"pen-line\" class=\"w-5 h-5\"></i>\n      新しい投稿\n    </a>\n  </div>\n\n  <script>if (typeof lucide !== 'undefined') lucide.createIcons();</script>\n</div>\n"
          }
        }
