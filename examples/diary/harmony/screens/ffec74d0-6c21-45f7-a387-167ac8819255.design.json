            "type": "wrapper",
            "components": "\n<div class=\"min-h-screen bg-white\">\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n  <script src=\"https://unpkg.com/lucide@latest/dist/umd/lucide.min.js\"></script>\n\n  <!-- Top Nav -->\n  <nav class=\"sticky top-0 z-40 bg-white/80 backdrop-blur-md border-b border-slate-100 shadow-[0_2px_20px_rgb(0,0,0,0.04)]\">\n    <div class=\"max-w-4xl mx-auto px-6 py-4 flex items-center justify-between\">\n      <a href=\"/\" class=\"flex items-center gap-2 text-slate-500 hover:text-indigo-600 transition-colors\">\n        <i data-lucide=\"arrow-left\" class=\"w-5 h-5\"></i>\n        <span class=\"text-sm font-medium\">一覧に戻る</span>\n      </a>\n      <!-- Owner Actions -->\n      <div class=\"flex items-center gap-2\">\n        <a href=\"/post/edit/123\" class=\"flex items-center gap-2 px-4 py-2 text-sm font-medium text-indigo-600 hover:bg-indigo-50 rounded-xl transition-all duration-200\">\n          <i data-lucide=\"edit-3\" class=\"w-4 h-4\"></i>\n          編集\n        </a>\n        <button id=\"deleteConfirm\" data-item-id=\"deleteConfirm\" class=\"flex items-center gap-2 px-4 py-2 text-sm font-medium text-rose-500 hover:bg-rose-50 rounded-xl transition-all duration-200\">\n          <i data-lucide=\"trash-2\" class=\"w-4 h-4\"></i>\n          削除\n        </button>\n      </div>\n    </div>\n  </nav>\n\n  <!-- Hero Image -->\n  <div id=\"heroImageUrl\" data-item-id=\"heroImageUrl\" class=\"relative overflow-hidden\" style=\"height: 480px;\">\n    <div class=\"absolute inset-0 bg-gradient-to-br from-indigo-500 via-purple-600 to-rose-500\"></div>\n    <!-- Overlay gradient for text readability -->\n    <div class=\"absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent\"></div>\n    <!-- Meta overlay on hero -->\n    <div class=\"absolute bottom-8 left-0 right-0 max-w-4xl mx-auto px-8\">\n      <div class=\"flex flex-wrap items-center gap-3 mb-4\">\n        <span class=\"text-2xl\" id=\"mood\" data-item-id=\"mood\">😊</span>\n        <span class=\"text-2xl\" id=\"weather\" data-item-id=\"weather\">☀️</span>\n        <span class=\"flex items-center gap-1.5 bg-white/20 backdrop-blur-sm text-white text-sm px-3 py-1.5 rounded-full\">\n          <i data-lucide=\"map-pin\" class=\"w-3.5 h-3.5\"></i>\n          <span id=\"location\" data-item-id=\"location\">東京・渋谷</span>\n        </span>\n        <span class=\"bg-white/20 backdrop-blur-sm text-white text-xs font-semibold px-3 py-1.5 rounded-full\">公開</span>\n      </div>\n      <h1 id=\"postTitle\" data-item-id=\"postTitle\" class=\"text-4xl md:text-5xl font-bold text-white tracking-tight leading-tight\">春の渋谷散歩</h1>\n    </div>\n  </div>\n\n  <!-- Article -->\n  <div class=\"max-w-4xl mx-auto px-6 md:px-8\">\n\n    <!-- Author + Date Meta -->\n    <div class=\"flex items-center gap-4 py-6 border-b border-slate-100\">\n      <div class=\"w-10 h-10 bg-gradient-to-br from-indigo-400 to-purple-500 rounded-full flex items-center justify-center flex-shrink-0\">\n        <i data-lucide=\"user\" class=\"w-5 h-5 text-white\"></i>\n      </div>\n      <div>\n        <p id=\"authorName\" data-item-id=\"authorName\" class=\"text-sm font-semibold text-slate-800\">Hidekatsu M.</p>\n        <p id=\"publishedAt\" data-item-id=\"publishedAt\" class=\"text-xs text-slate-400\">2026年5月5日</p>\n      </div>\n      <div class=\"ml-auto flex items-center gap-4 text-slate-400\">\n        <button class=\"flex items-center gap-1.5 hover:text-indigo-500 transition-colors\">\n          <i data-lucide=\"share-2\" class=\"w-4 h-4\"></i>\n          <span class=\"text-xs\">共有</span>\n        </button>\n        <button class=\"flex items-center gap-1.5 hover:text-rose-500 transition-colors\">\n          <i data-lucide=\"heart\" class=\"w-4 h-4\"></i>\n          <span class=\"text-xs\">12</span>\n        </button>\n      </div>\n    </div>\n\n    <!-- Body (Markdown rendered prose) -->\n    <div id=\"postBody\" data-item-id=\"postBody\" class=\"py-10 prose prose-slate prose-lg max-w-none prose-headings:font-bold prose-headings:tracking-tight prose-p:leading-relaxed prose-p:text-slate-600 prose-a:text-indigo-600 prose-a:no-underline hover:prose-a:underline\">\n      <p>桜の花びらが舞い散る中、渋谷の街をぶらりと歩いた日のことを記録しておく。</p>\n      <p>朝10時に代官山を出発して、散歩がてら渋谷方向へ。途中で見つけた小さなコーヒースタンドに思わず立ち寄り、テイクアウトのラテを片手に歩き続けた。</p>\n      <h2>代官山アドレス裏の隠れ家カフェ</h2>\n      <p>路地裏に佇む小さなカフェは、木の温もりと緑が調和した素敵な空間だった。カウンターに座ってのんびり過ごす時間は格別で、マスターとの会話も楽しかった。</p>\n      <p>渋谷のスクランブル交差点の喧騒を抜けると、道玄坂の静かな路地へ。夕方の柔らかな光の中、街の表情がまた違って見えた。</p>\n      <h2>まとめ</h2>\n      <p>何気ない散歩だったけれど、普段気づかないものをたくさん発見できた一日だった。また季節が変わったら同じコースを歩いてみたい。</p>\n    </div>\n\n    <!-- Photo Gallery -->\n    <div id=\"photos\" data-item-id=\"photos\" class=\"mb-10\">\n      <h3 class=\"text-sm font-bold text-slate-500 uppercase tracking-widest mb-4 flex items-center gap-2\">\n        <i data-lucide=\"images\" class=\"w-4 h-4\"></i>\n        フォトギャラリー\n      </h3>\n      <div class=\"grid grid-cols-2 md:grid-cols-3 gap-3\">\n        <div class=\"relative overflow-hidden rounded-2xl aspect-square bg-gradient-to-br from-indigo-300 to-purple-400 cursor-pointer hover:opacity-90 transition-opacity shadow-md hover:shadow-xl\">\n          <div class=\"absolute inset-0 flex items-center justify-center text-white/50\">\n            <i data-lucide=\"image\" class=\"w-8 h-8\"></i>\n          </div>\n        </div>\n        <div class=\"relative overflow-hidden rounded-2xl aspect-square bg-gradient-to-br from-emerald-300 to-teal-400 cursor-pointer hover:opacity-90 transition-opacity shadow-md hover:shadow-xl\">\n          <div class=\"absolute inset-0 flex items-center justify-center text-white/50\">\n            <i data-lucide=\"image\" class=\"w-8 h-8\"></i>\n          </div>\n        </div>\n        <div class=\"relative overflow-hidden rounded-2xl aspect-square bg-gradient-to-br from-amber-300 to-orange-400 cursor-pointer hover:opacity-90 transition-opacity shadow-md hover:shadow-xl\">\n          <div class=\"absolute inset-0 flex items-center justify-center text-white/50\">\n            <i data-lucide=\"image\" class=\"w-8 h-8\"></i>\n          </div>\n          <div class=\"absolute inset-0 bg-black/40 flex items-center justify-center\">\n            <span class=\"text-white font-bold text-lg\">+5</span>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- Tags -->\n    <div id=\"tags\" data-item-id=\"tags\" class=\"pb-12 border-t border-slate-100 pt-6\">\n      <h3 class=\"text-sm font-bold text-slate-500 uppercase tracking-widest mb-3 flex items-center gap-2\">\n        <i data-lucide=\"tag\" class=\"w-4 h-4\"></i>\n        タグ\n      </h3>\n      <div class=\"flex flex-wrap gap-2\">\n        <span class=\"inline-flex items-center gap-1.5 px-4 py-2 bg-indigo-50 text-indigo-700 text-sm font-semibold rounded-full hover:bg-indigo-100 cursor-pointer transition-all duration-200\">\n          <i data-lucide=\"hash\" class=\"w-3.5 h-3.5\"></i>旅行\n        </span>\n        <span class=\"inline-flex items-center gap-1.5 px-4 py-2 bg-amber-50 text-amber-700 text-sm font-semibold rounded-full hover:bg-amber-100 cursor-pointer transition-all duration-200\">\n          <i data-lucide=\"hash\" class=\"w-3.5 h-3.5\"></i>日常\n        </span>\n        <span class=\"inline-flex items-center gap-1.5 px-4 py-2 bg-slate-100 text-slate-600 text-sm font-semibold rounded-full hover:bg-slate-200 cursor-pointer transition-all duration-200\">\n          <i data-lucide=\"hash\" class=\"w-3.5 h-3.5\"></i>散歩\n        </span>\n      </div>\n    </div>\n  </div>\n\n  <script>if (typeof lucide !== 'undefined') lucide.createIcons();</script>\n</div>\n"
          }
