        {
          "component": {
            "type": "wrapper",
            "components": "\n<div class=\"min-h-screen bg-slate-50\">\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n  <script src=\"https://unpkg.com/lucide@latest/dist/umd/lucide.min.js\"></script>\n\n  <!-- Top Nav -->\n  <nav class=\"sticky top-0 z-40 bg-white/80 backdrop-blur-md border-b border-slate-100 shadow-[0_2px_20px_rgb(0,0,0,0.04)]\">\n    <div class=\"max-w-7xl mx-auto px-6 py-4 flex items-center justify-between\">\n      <div class=\"flex items-center gap-3\">\n        <a href=\"/\" class=\"flex items-center gap-2 text-slate-500 hover:text-indigo-600 transition-colors\">\n          <i data-lucide=\"arrow-left\" class=\"w-5 h-5\"></i>\n        </a>\n        <span class=\"text-sm font-medium text-slate-400\">新しい投稿</span>\n      </div>\n      <div class=\"flex items-center gap-2 text-xs text-slate-400\">\n        <i data-lucide=\"cloud\" class=\"w-3.5 h-3.5\"></i>\n        <span>下書き保存済み</span>\n      </div>\n    </div>\n  </nav>\n\n  <!-- Two-column Layout -->\n  <div class=\"max-w-7xl mx-auto px-6 py-8\">\n    <div class=\"flex gap-8 items-start\">\n\n      <!-- Main Editor Column -->\n      <div class=\"flex-1 min-w-0\">\n\n        <!-- Title Input -->\n        <div class=\"bg-white rounded-3xl shadow-[0_4px_20px_rgb(0,0,0,0.06)] border border-slate-100 p-8 mb-6\">\n          <input\n            id=\"postTitle\"\n            name=\"postTitle\"\n            data-item-id=\"postTitle\"\n            type=\"text\"\n            placeholder=\"タイトルを入力…\"\n            class=\"w-full text-3xl font-bold text-slate-900 placeholder-slate-300 bg-transparent border-none outline-none tracking-tight\"\n          />\n\n          <!-- Mood / Weather / Location Row -->\n          <div class=\"flex items-center gap-3 mt-6 pt-6 border-t border-slate-100 flex-wrap\">\n            <!-- Mood Selector -->\n            <div class=\"relative\">\n              <select id=\"mood\" name=\"mood\" data-item-id=\"mood\" class=\"appearance-none flex items-center gap-2 pl-3 pr-8 py-2 bg-slate-50 border border-slate-200 rounded-xl text-sm text-slate-700 cursor-pointer hover:bg-indigo-50 hover:border-indigo-200 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-indigo-300\">\n                <option value=\"\">😊 気分</option>\n                <option value=\"happy\">😊 嬉しい</option>\n                <option value=\"excited\">🤩 興奮</option>\n                <option value=\"calm\">😌 穏やか</option>\n                <option value=\"sad\">😢 悲しい</option>\n                <option value=\"tired\">😴 疲れた</option>\n                <option value=\"angry\">😤 怒り</option>\n                <option value=\"anxious\">😰 不安</option>\n                <option value=\"grateful\">🙏 感謝</option>\n              </select>\n            </div>\n\n            <!-- Weather Selector -->\n            <div class=\"relative\">\n              <select id=\"weather\" name=\"weather\" data-item-id=\"weather\" class=\"appearance-none pl-3 pr-8 py-2 bg-slate-50 border border-slate-200 rounded-xl text-sm text-slate-700 cursor-pointer hover:bg-amber-50 hover:border-amber-200 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-amber-300\">\n                <option value=\"\">☀️ 天気</option>\n                <option value=\"sunny\">☀️ 晴れ</option>\n                <option value=\"partly_cloudy\">⛅ 晴れのち曇り</option>\n                <option value=\"cloudy\">☁️ 曇り</option>\n                <option value=\"rainy\">🌧️ 雨</option>\n                <option value=\"stormy\">⛈️ 嵐</option>\n                <option value=\"snowy\">❄️ 雪</option>\n              </select>\n            </div>\n\n            <!-- Location Input -->\n            <div class=\"flex items-center gap-2 flex-1 min-w-40\">\n              <i data-lucide=\"map-pin\" class=\"w-4 h-4 text-slate-400 flex-shrink-0\"></i>\n              <input\n                id=\"location\"\n                name=\"location\"\n                data-item-id=\"location\"\n                type=\"text\"\n                placeholder=\"場所を入力 (例: 東京・渋谷)\"\n                class=\"w-full bg-transparent text-sm text-slate-700 placeholder-slate-400 border-none outline-none\"\n              />\n            </div>\n          </div>\n        </div>\n\n        <!-- Markdown Editor -->\n        <div class=\"bg-white rounded-3xl shadow-[0_4px_20px_rgb(0,0,0,0.06)] border border-slate-100 mb-6 overflow-hidden\">\n          <!-- Editor Toolbar -->\n          <div class=\"flex items-center gap-1 px-6 py-3 border-b border-slate-100 bg-slate-50/50\">\n            <button class=\"p-2 text-slate-500 hover:text-slate-900 hover:bg-slate-100 rounded-lg transition-all duration-200\" title=\"太字\">\n              <i data-lucide=\"bold\" class=\"w-4 h-4\"></i>\n            </button>\n            <button class=\"p-2 text-slate-500 hover:text-slate-900 hover:bg-slate-100 rounded-lg transition-all duration-200\" title=\"斜体\">\n              <i data-lucide=\"italic\" class=\"w-4 h-4\"></i>\n            </button>\n            <button class=\"p-2 text-slate-500 hover:text-slate-900 hover:bg-slate-100 rounded-lg transition-all duration-200\" title=\"見出し\">\n              <i data-lucide=\"heading\" class=\"w-4 h-4\"></i>\n            </button>\n            <button class=\"p-2 text-slate-500 hover:text-slate-900 hover:bg-slate-100 rounded-lg transition-all duration-200\" title=\"リスト\">\n              <i data-lucide=\"list\" class=\"w-4 h-4\"></i>\n            </button>\n            <button class=\"p-2 text-slate-500 hover:text-slate-900 hover:bg-slate-100 rounded-lg transition-all duration-200\" title=\"引用\">\n              <i data-lucide=\"quote\" class=\"w-4 h-4\"></i>\n            </button>\n            <button class=\"p-2 text-slate-500 hover:text-slate-900 hover:bg-slate-100 rounded-lg transition-all duration-200\" title=\"リンク\">\n              <i data-lucide=\"link\" class=\"w-4 h-4\"></i>\n            </button>\n            <div class=\"ml-auto\">\n              <button class=\"flex items-center gap-2 px-3 py-1.5 text-xs font-medium text-slate-500 hover:text-indigo-600 hover:bg-indigo-50 rounded-lg transition-all duration-200\">\n                <i data-lucide=\"eye\" class=\"w-3.5 h-3.5\"></i>\n                プレビュー\n              </button>\n            </div>\n          </div>\n          <!-- Textarea -->\n          <textarea\n            id=\"postBody\"\n            name=\"postBody\"\n            data-item-id=\"postBody\"\n            placeholder=\"今日のことを書いてみましょう…\"\n            rows=\"20\"\n            class=\"w-full px-8 py-6 text-slate-700 text-base leading-relaxed bg-transparent resize-none outline-none placeholder-slate-300 font-mono\"\n          ></textarea>\n        </div>\n\n        <!-- Photo Upload Zone -->\n        <div id=\"photos\" data-item-id=\"photos\" class=\"bg-white rounded-3xl shadow-[0_4px_20px_rgb(0,0,0,0.06)] border-2 border-dashed border-indigo-200 hover:border-indigo-400 transition-all duration-300 p-8 mb-6 text-center cursor-pointer group hover:bg-indigo-50/30\">\n          <div class=\"flex flex-col items-center gap-3\">\n            <div class=\"w-16 h-16 bg-indigo-100 group-hover:bg-indigo-200 rounded-2xl flex items-center justify-center transition-all duration-300\">\n              <i data-lucide=\"image-plus\" class=\"w-8 h-8 text-indigo-500\"></i>\n            </div>\n            <div>\n              <p class=\"text-sm font-semibold text-slate-700\">写真をドラッグ&ドロップ</p>\n              <p class=\"text-xs text-slate-400 mt-1\">またはクリックして選択 (JPG, PNG, HEIC / 最大10MB)</p>\n            </div>\n            <!-- Uploaded Previews -->\n            <div class=\"flex items-center gap-3 mt-2 flex-wrap justify-center\">\n              <div class=\"relative w-16 h-16 rounded-xl overflow-hidden bg-gradient-to-br from-indigo-200 to-purple-300 flex-shrink-0 shadow-md\">\n                <button class=\"absolute top-0.5 right-0.5 w-5 h-5 bg-black/50 rounded-full flex items-center justify-center hover:bg-black/70 transition-colors\">\n                  <i data-lucide=\"x\" class=\"w-3 h-3 text-white\"></i>\n                </button>\n              </div>\n              <div class=\"relative w-16 h-16 rounded-xl overflow-hidden bg-gradient-to-br from-emerald-200 to-teal-300 flex-shrink-0 shadow-md\">\n                <button class=\"absolute top-0.5 right-0.5 w-5 h-5 bg-black/50 rounded-full flex items-center justify-center hover:bg-black/70 transition-colors\">\n                  <i data-lucide=\"x\" class=\"w-3 h-3 text-white\"></i>\n                </button>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <!-- Tag Input -->\n        <div class=\"bg-white rounded-3xl shadow-[0_4px_20px_rgb(0,0,0,0.06)] border border-slate-100 p-6 mb-6\">\n          <h3 class=\"text-sm font-bold text-slate-700 mb-3 flex items-center gap-2\">\n            <i data-lucide=\"tag\" class=\"w-4 h-4 text-indigo-400\"></i>\n            タグ\n          </h3>\n          <div id=\"tagIds\" data-item-id=\"tagIds\" class=\"flex flex-wrap gap-2\">\n            <span class=\"inline-flex items-center gap-1.5 px-3 py-1.5 bg-indigo-100 text-indigo-700 text-xs font-semibold rounded-full\">\n              旅行\n              <button class=\"ml-0.5 hover:text-indigo-900\"><i data-lucide=\"x\" class=\"w-3 h-3\"></i></button>\n            </span>\n            <span class=\"inline-flex items-center gap-1.5 px-3 py-1.5 bg-amber-100 text-amber-700 text-xs font-semibold rounded-full\">\n              日常\n              <button class=\"ml-0.5 hover:text-amber-900\"><i data-lucide=\"x\" class=\"w-3 h-3\"></i></button>\n            </span>\n            <button class=\"inline-flex items-center gap-1 px-3 py-1.5 bg-slate-100 text-slate-600 text-xs font-medium rounded-full hover:bg-slate-200 transition-all duration-200\">\n              <i data-lucide=\"plus\" class=\"w-3 h-3\"></i>\n              タグを追加\n            </button>\n          </div>\n        </div>\n      </div>\n\n      <!-- AI Assist Sidebar -->\n      <div class=\"w-80 flex-shrink-0 sticky top-20\">\n        <div class=\"bg-white rounded-3xl shadow-[0_4px_24px_rgb(0,0,0,0.08)] border border-slate-100 overflow-hidden\">\n          <!-- Sidebar Header -->\n          <div class=\"px-6 py-5 border-b border-slate-100 bg-gradient-to-r from-indigo-50 to-purple-50\">\n            <div class=\"flex items-center gap-2.5\">\n              <div class=\"w-8 h-8 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-xl flex items-center justify-center\">\n                <i data-lucide=\"sparkles\" class=\"w-4 h-4 text-white\"></i>\n              </div>\n              <div>\n                <p class=\"text-sm font-bold text-slate-800\">AI アシスト</p>\n                <p class=\"text-xs text-slate-500\">4つの機能で執筆をサポート</p>\n              </div>\n            </div>\n          </div>\n\n          <div class=\"p-4 space-y-3\">\n\n            <!-- AI Summary -->\n            <div class=\"border border-slate-100 rounded-2xl overflow-hidden\">\n              <button class=\"w-full flex items-center gap-3 px-4 py-3 text-left hover:bg-indigo-50 transition-all duration-200\">\n                <div class=\"w-8 h-8 bg-indigo-100 rounded-xl flex items-center justify-center flex-shrink-0\">\n                  <i data-lucide=\"file-text\" class=\"w-4 h-4 text-indigo-600\"></i>\n                </div>\n                <div class=\"flex-1\">\n                  <p class=\"text-xs font-bold text-slate-700\">要約を生成</p>\n                  <p class=\"text-xs text-slate-400\">本文から自動要約</p>\n                </div>\n                <i data-lucide=\"chevron-right\" class=\"w-4 h-4 text-slate-400\"></i>\n              </button>\n              <!-- Result Area -->\n              <div id=\"aiSummary\" data-item-id=\"aiSummary\" class=\"px-4 pb-4\">\n                <div class=\"bg-indigo-50 rounded-xl p-3\">\n                  <p class=\"text-xs text-indigo-700 leading-relaxed\">春の渋谷を散歩し、隠れ家カフェを発見。季節の移ろいを感じながら街の新しい魅力を再発見した一日の記録。</p>\n                </div>\n              </div>\n            </div>\n\n            <!-- AI Tag Suggestion -->\n            <div class=\"border border-slate-100 rounded-2xl overflow-hidden\">\n              <button class=\"w-full flex items-center gap-3 px-4 py-3 text-left hover:bg-emerald-50 transition-all duration-200\">\n                <div class=\"w-8 h-8 bg-emerald-100 rounded-xl flex items-center justify-center flex-shrink-0\">\n                  <i data-lucide=\"tag\" class=\"w-4 h-4 text-emerald-600\"></i>\n                </div>\n                <div class=\"flex-1\">\n                  <p class=\"text-xs font-bold text-slate-700\">タグ提案</p>\n                  <p class=\"text-xs text-slate-400\">内容から自動提案</p>\n                </div>\n                <i data-lucide=\"chevron-right\" class=\"w-4 h-4 text-slate-400\"></i>\n              </button>\n              <!-- Result Area -->\n              <div id=\"aiSuggestedTags\" data-item-id=\"aiSuggestedTags\" class=\"px-4 pb-4\">\n                <div class=\"flex flex-wrap gap-1.5\">\n                  <button class=\"px-2.5 py-1 bg-emerald-100 text-emerald-700 text-xs font-semibold rounded-full hover:bg-emerald-200 transition-all duration-200 flex items-center gap-1\">\n                    <i data-lucide=\"plus\" class=\"w-3 h-3\"></i>散歩\n                  </button>\n                  <button class=\"px-2.5 py-1 bg-emerald-100 text-emerald-700 text-xs font-semibold rounded-full hover:bg-emerald-200 transition-all duration-200 flex items-center gap-1\">\n                    <i data-lucide=\"plus\" class=\"w-3 h-3\"></i>カフェ\n                  </button>\n                  <button class=\"px-2.5 py-1 bg-emerald-100 text-emerald-700 text-xs font-semibold rounded-full hover:bg-emerald-200 transition-all duration-200 flex items-center gap-1\">\n                    <i data-lucide=\"plus\" class=\"w-3 h-3\"></i>東京\n                  </button>\n                </div>\n              </div>\n            </div>\n\n            <!-- AI Proofread -->\n            <div class=\"border border-slate-100 rounded-2xl overflow-hidden\">\n              <button class=\"w-full flex items-center gap-3 px-4 py-3 text-left hover:bg-amber-50 transition-all duration-200\">\n                <div class=\"w-8 h-8 bg-amber-100 rounded-xl flex items-center justify-center flex-shrink-0\">\n                  <i data-lucide=\"check-circle\" class=\"w-4 h-4 text-amber-600\"></i>\n                </div>\n                <div class=\"flex-1\">\n                  <p class=\"text-xs font-bold text-slate-700\">文章校正</p>\n                  <p class=\"text-xs text-slate-400\">誤字脱字・表現チェック</p>\n                </div>\n                <i data-lucide=\"chevron-right\" class=\"w-4 h-4 text-slate-400\"></i>\n              </button>\n              <!-- Result -->\n              <div id=\"aiProofreadResult\" data-item-id=\"aiProofreadResult\" class=\"px-4 pb-4\">\n                <div class=\"bg-amber-50 rounded-xl p-3\">\n                  <p class=\"text-xs text-amber-700 leading-relaxed\">3箇所の改善提案があります。「ぶらりと」→「ふらりと」(より自然)、句読点の調整など。</p>\n                </div>\n              </div>\n            </div>\n\n            <!-- AI Image Alt -->\n            <div class=\"border border-slate-100 rounded-2xl overflow-hidden\">\n              <button class=\"w-full flex items-center gap-3 px-4 py-3 text-left hover:bg-rose-50 transition-all duration-200\">\n                <div class=\"w-8 h-8 bg-rose-100 rounded-xl flex items-center justify-center flex-shrink-0\">\n                  <i data-lucide=\"image\" class=\"w-4 h-4 text-rose-500\"></i>\n                </div>\n                <div class=\"flex-1\">\n                  <p class=\"text-xs font-bold text-slate-700\">画像 alt 生成</p>\n                  <p class=\"text-xs text-slate-400\">アクセシビリティ対応</p>\n                </div>\n                <i data-lucide=\"chevron-right\" class=\"w-4 h-4 text-slate-400\"></i>\n              </button>\n              <!-- Result -->\n              <div id=\"aiImageAlt\" data-item-id=\"aiImageAlt\" class=\"px-4 pb-4\">\n                <p class=\"text-xs text-slate-400 italic\">写真をアップロード後に実行できます</p>\n              </div>\n            </div>\n\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <!-- Sticky Bottom Action Bar -->\n  <div class=\"fixed bottom-0 left-0 right-0 z-40 bg-white/90 backdrop-blur-md border-t border-slate-200 shadow-[0_-4px_20px_rgb(0,0,0,0.06)]\">\n    <div class=\"max-w-7xl mx-auto px-6 py-4 flex items-center justify-between\">\n      <div class=\"flex items-center gap-3\">\n        <select id=\"status\" name=\"status\" data-item-id=\"status\" class=\"pl-3 pr-8 py-2.5 bg-slate-100 border border-slate-200 rounded-xl text-sm font-medium text-slate-700 focus:outline-none focus:ring-2 focus:ring-indigo-300 transition-all duration-200 appearance-none cursor-pointer\">\n          <option value=\"draft\">下書き</option>\n          <option value=\"published\">公開</option>\n        </select>\n      </div>\n      <div class=\"flex items-center gap-3\">\n        <button class=\"px-6 py-2.5 text-sm font-semibold text-slate-600 hover:text-slate-900 hover:bg-slate-100 rounded-xl transition-all duration-200\">\n          <i data-lucide=\"save\" class=\"w-4 h-4 inline mr-1.5\"></i>\n          下書き保存\n        </button>\n        <button class=\"px-8 py-2.5 bg-gradient-to-r from-indigo-500 to-purple-600 text-white text-sm font-bold rounded-xl shadow-[0_4px_15px_rgb(99,102,241,0.35)] hover:shadow-[0_6px_25px_rgb(99,102,241,0.45)] hover:scale-[1.02] transition-all duration-200\">\n          <i data-lucide=\"send\" class=\"w-4 h-4 inline mr-1.5\"></i>\n          公開する\n        </button>\n      </div>\n    </div>\n  </div>\n\n  <script>if (typeof lucide !== 'undefined') lucide.createIcons();</script>\n</div>\n"
          }
        }
      ]
    }
  ]
}
