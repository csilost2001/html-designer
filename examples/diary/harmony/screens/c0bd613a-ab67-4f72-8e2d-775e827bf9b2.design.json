          "component": {
            "type": "wrapper",
            "components": "\n<div class=\"min-h-screen bg-gradient-to-br from-slate-50 via-white to-indigo-50\">\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n  <script src=\"https://unpkg.com/lucide@latest/dist/umd/lucide.min.js\"></script>\n\n  <!-- Top Nav -->\n  <nav class=\"sticky top-0 z-40 bg-white/80 backdrop-blur-md border-b border-slate-100 shadow-[0_2px_20px_rgb(0,0,0,0.04)]\">\n    <div class=\"max-w-4xl mx-auto px-6 py-4 flex items-center gap-4\">\n      <a href=\"/\" class=\"flex items-center gap-2 text-slate-500 hover:text-indigo-600 transition-colors\">\n        <i data-lucide=\"arrow-left\" class=\"w-5 h-5\"></i>\n      </a>\n      <h1 class=\"text-lg font-bold text-slate-800 flex-1\">タグ管理</h1>\n      <button onclick=\"document.getElementById('newTagModal').classList.remove('hidden')\" class=\"flex items-center gap-2 px-4 py-2 bg-gradient-to-r from-indigo-500 to-purple-600 text-white text-sm font-semibold rounded-xl shadow-md hover:shadow-lg hover:scale-[1.02] transition-all duration-200\">\n        <i data-lucide=\"plus\" class=\"w-4 h-4\"></i>\n        新規タグ\n      </button>\n    </div>\n  </nav>\n\n  <div class=\"max-w-4xl mx-auto px-6 py-8\">\n\n    <!-- Search -->\n    <div class=\"relative mb-6\">\n      <div class=\"absolute inset-y-0 left-4 flex items-center pointer-events-none\">\n        <i data-lucide=\"search\" class=\"w-4 h-4 text-slate-400\"></i>\n      </div>\n      <input\n        id=\"searchQuery\"\n        name=\"searchQuery\"\n        data-item-id=\"searchQuery\"\n        type=\"text\"\n        placeholder=\"タグを検索…\"\n        class=\"w-full pl-11 pr-4 py-3 bg-white border border-slate-200 rounded-2xl text-sm text-slate-700 placeholder-slate-400 shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-300 focus:border-transparent transition-all duration-200\"\n      />\n    </div>\n\n    <!-- Stats Row -->\n    <div class=\"grid grid-cols-3 gap-4 mb-8\">\n      <div class=\"bg-white rounded-2xl border border-slate-100 shadow-sm p-5 text-center\">\n        <p class=\"text-3xl font-bold text-indigo-600\">12</p>\n        <p class=\"text-xs text-slate-500 mt-1\">タグ総数</p>\n      </div>\n      <div class=\"bg-white rounded-2xl border border-slate-100 shadow-sm p-5 text-center\">\n        <p class=\"text-3xl font-bold text-emerald-500\">48</p>\n        <p class=\"text-xs text-slate-500 mt-1\">タグ付き投稿</p>\n      </div>\n      <div class=\"bg-white rounded-2xl border border-slate-100 shadow-sm p-5 text-center\">\n        <p class=\"text-3xl font-bold text-amber-500\">4.0</p>\n        <p class=\"text-xs text-slate-500 mt-1\">平均タグ/投稿</p>\n      </div>\n    </div>\n\n    <!-- Tag Grid -->\n    <div id=\"tags\" data-item-id=\"tags\">\n      <h2 class=\"text-sm font-bold text-slate-500 uppercase tracking-widest mb-4\">すべてのタグ</h2>\n      <div class=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n\n        <!-- Tag Card: 旅行 -->\n        <div class=\"bg-white rounded-2xl border border-slate-100 shadow-sm hover:shadow-md p-5 flex items-center gap-4 group transition-all duration-200\">\n          <div class=\"w-12 h-12 bg-indigo-100 rounded-2xl flex items-center justify-center flex-shrink-0\">\n            <i data-lucide=\"map\" class=\"w-6 h-6 text-indigo-600\"></i>\n          </div>\n          <div class=\"flex-1 min-w-0\">\n            <div class=\"flex items-center gap-2 mb-1\">\n              <span class=\"font-bold text-slate-800\">旅行</span>\n              <span class=\"px-2 py-0.5 bg-indigo-100 text-indigo-600 text-xs font-medium rounded-full\">travel</span>\n            </div>\n            <div class=\"flex items-center gap-2\">\n              <div class=\"w-3 h-3 rounded-full bg-indigo-500\"></div>\n              <span class=\"text-xs text-slate-400\">15件の投稿</span>\n            </div>\n          </div>\n          <div class=\"flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity\">\n            <button class=\"p-2 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-xl transition-all duration-200\">\n              <i data-lucide=\"edit-3\" class=\"w-4 h-4\"></i>\n            </button>\n            <button id=\"deleteTagId\" data-item-id=\"deleteTagId\" class=\"p-2 text-slate-400 hover:text-rose-500 hover:bg-rose-50 rounded-xl transition-all duration-200\">\n              <i data-lucide=\"trash-2\" class=\"w-4 h-4\"></i>\n            </button>\n          </div>\n        </div>\n\n        <!-- Tag Card: グルメ -->\n        <div class=\"bg-white rounded-2xl border border-slate-100 shadow-sm hover:shadow-md p-5 flex items-center gap-4 group transition-all duration-200\">\n          <div class=\"w-12 h-12 bg-rose-100 rounded-2xl flex items-center justify-center flex-shrink-0\">\n            <i data-lucide=\"utensils\" class=\"w-6 h-6 text-rose-500\"></i>\n          </div>\n          <div class=\"flex-1 min-w-0\">\n            <div class=\"flex items-center gap-2 mb-1\">\n              <span class=\"font-bold text-slate-800\">グルメ</span>\n              <span class=\"px-2 py-0.5 bg-rose-100 text-rose-600 text-xs font-medium rounded-full\">gourmet</span>\n            </div>\n            <div class=\"flex items-center gap-2\">\n              <div class=\"w-3 h-3 rounded-full bg-rose-500\"></div>\n              <span class=\"text-xs text-slate-400\">10件の投稿</span>\n            </div>\n          </div>\n          <div class=\"flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity\">\n            <button class=\"p-2 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-xl transition-all duration-200\">\n              <i data-lucide=\"edit-3\" class=\"w-4 h-4\"></i>\n            </button>\n            <button class=\"p-2 text-slate-400 hover:text-rose-500 hover:bg-rose-50 rounded-xl transition-all duration-200\">\n              <i data-lucide=\"trash-2\" class=\"w-4 h-4\"></i>\n            </button>\n          </div>\n        </div>\n\n        <!-- Tag Card: 日常 -->\n        <div class=\"bg-white rounded-2xl border border-slate-100 shadow-sm hover:shadow-md p-5 flex items-center gap-4 group transition-all duration-200\">\n          <div class=\"w-12 h-12 bg-amber-100 rounded-2xl flex items-center justify-center flex-shrink-0\">\n            <i data-lucide=\"sun\" class=\"w-6 h-6 text-amber-500\"></i>\n          </div>\n          <div class=\"flex-1 min-w-0\">\n            <div class=\"flex items-center gap-2 mb-1\">\n              <span class=\"font-bold text-slate-800\">日常</span>\n              <span class=\"px-2 py-0.5 bg-amber-100 text-amber-600 text-xs font-medium rounded-full\">daily</span>\n            </div>\n            <div class=\"flex items-center gap-2\">\n              <div class=\"w-3 h-3 rounded-full bg-amber-400\"></div>\n              <span class=\"text-xs text-slate-400\">24件の投稿</span>\n            </div>\n          </div>\n          <div class=\"flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity\">\n            <button class=\"p-2 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-xl transition-all duration-200\">\n              <i data-lucide=\"edit-3\" class=\"w-4 h-4\"></i>\n            </button>\n            <button class=\"p-2 text-slate-400 hover:text-rose-500 hover:bg-rose-50 rounded-xl transition-all duration-200\">\n              <i data-lucide=\"trash-2\" class=\"w-4 h-4\"></i>\n            </button>\n          </div>\n        </div>\n\n        <!-- Tag Card: 仕事 -->\n        <div class=\"bg-white rounded-2xl border border-slate-100 shadow-sm hover:shadow-md p-5 flex items-center gap-4 group transition-all duration-200\">\n          <div class=\"w-12 h-12 bg-emerald-100 rounded-2xl flex items-center justify-center flex-shrink-0\">\n            <i data-lucide=\"briefcase\" class=\"w-6 h-6 text-emerald-600\"></i>\n          </div>\n          <div class=\"flex-1 min-w-0\">\n            <div class=\"flex items-center gap-2 mb-1\">\n              <span class=\"font-bold text-slate-800\">仕事</span>\n              <span class=\"px-2 py-0.5 bg-emerald-100 text-emerald-600 text-xs font-medium rounded-full\">work</span>\n            </div>\n            <div class=\"flex items-center gap-2\">\n              <div class=\"w-3 h-3 rounded-full bg-emerald-500\"></div>\n              <span class=\"text-xs text-slate-400\">8件の投稿</span>\n            </div>\n          </div>\n          <div class=\"flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity\">\n            <button class=\"p-2 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-xl transition-all duration-200\">\n              <i data-lucide=\"edit-3\" class=\"w-4 h-4\"></i>\n            </button>\n            <button class=\"p-2 text-slate-400 hover:text-rose-500 hover:bg-rose-50 rounded-xl transition-all duration-200\">\n              <i data-lucide=\"trash-2\" class=\"w-4 h-4\"></i>\n            </button>\n          </div>\n        </div>\n\n      </div>\n    </div>\n  </div>\n\n  <!-- New Tag Modal -->\n  <div id=\"newTagModal\" class=\"hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm\">\n    <div class=\"bg-white rounded-3xl shadow-2xl w-full max-w-md mx-4 overflow-hidden\">\n      <div class=\"px-6 py-5 border-b border-slate-100 flex items-center justify-between\">\n        <h2 class=\"text-lg font-bold text-slate-800\">新規タグを作成</h2>\n        <button onclick=\"document.getElementById('newTagModal').classList.add('hidden')\" class=\"p-2 text-slate-400 hover:text-slate-600 hover:bg-slate-100 rounded-xl transition-all duration-200\">\n          <i data-lucide=\"x\" class=\"w-5 h-5\"></i>\n        </button>\n      </div>\n      <div class=\"px-6 py-6 space-y-5\">\n        <!-- Tag Name -->\n        <div>\n          <label class=\"block text-xs font-bold text-slate-600 mb-2\">タグ名 *</label>\n          <input\n            id=\"newTagName\"\n            name=\"newTagName\"\n            data-item-id=\"newTagName\"\n            type=\"text\"\n            placeholder=\"タグ名を入力\"\n            class=\"w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm text-slate-700 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-300 focus:border-transparent transition-all duration-200\"\n          />\n        </div>\n        <!-- Slug -->\n        <div>\n          <label class=\"block text-xs font-bold text-slate-600 mb-2\">スラッグ *</label>\n          <input\n            id=\"newTagSlug\"\n            name=\"newTagSlug\"\n            data-item-id=\"newTagSlug\"\n            type=\"text\"\n            placeholder=\"tag-slug\"\n            class=\"w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm text-slate-700 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-300 focus:border-transparent font-mono transition-all duration-200\"\n          />\n        </div>\n        <!-- Color Picker -->\n        <div>\n          <label class=\"block text-xs font-bold text-slate-600 mb-2\">カラー</label>\n          <div class=\"flex items-center gap-3\">\n            <input\n              id=\"newTagColor\"\n              name=\"newTagColor\"\n              data-item-id=\"newTagColor\"\n              type=\"color\"\n              value=\"#6366f1\"\n              class=\"w-12 h-10 rounded-xl border-2 border-slate-200 cursor-pointer\"\n            />\n            <div class=\"flex items-center gap-2 flex-wrap\">\n              <button class=\"w-7 h-7 rounded-full bg-indigo-500 hover:scale-110 transition-transform shadow-sm\"></button>\n              <button class=\"w-7 h-7 rounded-full bg-rose-500 hover:scale-110 transition-transform shadow-sm\"></button>\n              <button class=\"w-7 h-7 rounded-full bg-amber-400 hover:scale-110 transition-transform shadow-sm\"></button>\n              <button class=\"w-7 h-7 rounded-full bg-emerald-500 hover:scale-110 transition-transform shadow-sm\"></button>\n              <button class=\"w-7 h-7 rounded-full bg-purple-500 hover:scale-110 transition-transform shadow-sm\"></button>\n              <button class=\"w-7 h-7 rounded-full bg-slate-400 hover:scale-110 transition-transform shadow-sm\"></button>\n            </div>\n          </div>\n        </div>\n        <!-- Icon Picker -->\n        <div>\n          <label class=\"block text-xs font-bold text-slate-600 mb-2\">アイコン</label>\n          <div id=\"newTagIcon\" data-item-id=\"newTagIcon\" class=\"flex items-center gap-2 flex-wrap\">\n            <button class=\"p-2.5 bg-indigo-50 border-2 border-indigo-300 rounded-xl hover:bg-indigo-100 transition-all\">\n              <i data-lucide=\"map\" class=\"w-5 h-5 text-indigo-600\"></i>\n            </button>\n            <button class=\"p-2.5 bg-slate-50 border-2 border-slate-200 rounded-xl hover:bg-slate-100 transition-all\">\n              <i data-lucide=\"utensils\" class=\"w-5 h-5 text-slate-500\"></i>\n            </button>\n            <button class=\"p-2.5 bg-slate-50 border-2 border-slate-200 rounded-xl hover:bg-slate-100 transition-all\">\n              <i data-lucide=\"sun\" class=\"w-5 h-5 text-slate-500\"></i>\n            </button>\n            <button class=\"p-2.5 bg-slate-50 border-2 border-slate-200 rounded-xl hover:bg-slate-100 transition-all\">\n              <i data-lucide=\"briefcase\" class=\"w-5 h-5 text-slate-500\"></i>\n            </button>\n            <button class=\"p-2.5 bg-slate-50 border-2 border-slate-200 rounded-xl hover:bg-slate-100 transition-all\">\n              <i data-lucide=\"book-open\" class=\"w-5 h-5 text-slate-500\"></i>\n            </button>\n            <button class=\"p-2.5 bg-slate-50 border-2 border-slate-200 rounded-xl hover:bg-slate-100 transition-all\">\n              <i data-lucide=\"camera\" class=\"w-5 h-5 text-slate-500\"></i>\n            </button>\n            <button class=\"p-2.5 bg-slate-50 border-2 border-slate-200 rounded-xl hover:bg-slate-100 transition-all\">\n              <i data-lucide=\"music\" class=\"w-5 h-5 text-slate-500\"></i>\n            </button>\n            <button class=\"p-2.5 bg-slate-50 border-2 border-slate-200 rounded-xl hover:bg-slate-100 transition-all\">\n              <i data-lucide=\"heart\" class=\"w-5 h-5 text-slate-500\"></i>\n            </button>\n          </div>\n        </div>\n      </div>\n      <div class=\"px-6 py-5 border-t border-slate-100 flex items-center justify-end gap-3\">\n        <button onclick=\"document.getElementById('newTagModal').classList.add('hidden')\" class=\"px-5 py-2.5 text-sm font-semibold text-slate-600 hover:bg-slate-100 rounded-xl transition-all duration-200\">\n          キャンセル\n        </button>\n        <button class=\"px-6 py-2.5 bg-gradient-to-r from-indigo-500 to-purple-600 text-white text-sm font-bold rounded-xl shadow-md hover:shadow-lg hover:scale-[1.02] transition-all duration-200\">\n          作成する\n        </button>\n      </div>\n    </div>\n  </div>\n\n  <script>if (typeof lucide !== 'undefined') lucide.createIcons();</script>\n</div>\n"
          }
        }
      ]
    }
