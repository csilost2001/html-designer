            "type": "wrapper",
            "components": "\n<div class=\"min-h-screen bg-gradient-to-br from-slate-900 via-indigo-950 to-purple-950 flex items-center justify-center p-6\">\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n  <script src=\"https://unpkg.com/lucide@latest/dist/umd/lucide.min.js\"></script>\n\n  <!-- Background decorations -->\n  <div class=\"absolute inset-0 overflow-hidden pointer-events-none\">\n    <div class=\"absolute top-1/4 left-1/4 w-96 h-96 bg-indigo-500/10 rounded-full blur-3xl\"></div>\n    <div class=\"absolute bottom-1/4 right-1/4 w-96 h-96 bg-purple-500/10 rounded-full blur-3xl\"></div>\n  </div>\n\n  <!-- Login Card -->\n  <div class=\"relative w-full max-w-md\">\n    <div class=\"bg-white/10 backdrop-blur-xl border border-white/20 rounded-3xl shadow-[0_25px_60px_rgb(0,0,0,0.4)] p-8\">\n\n      <!-- Logo -->\n      <div class=\"text-center mb-8\">\n        <div class=\"inline-flex items-center justify-center w-16 h-16 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-3xl shadow-2xl mb-4\">\n          <i data-lucide=\"book-open\" class=\"w-8 h-8 text-white\"></i>\n        </div>\n        <h1 class=\"text-2xl font-bold text-white tracking-tight\">My Diary</h1>\n        <p class=\"text-sm text-indigo-300 mt-1\">あなたの毎日を記録しましょう</p>\n      </div>\n\n      <!-- Form -->\n      <div class=\"space-y-4\">\n        <!-- Username -->\n        <div>\n          <label for=\"username\" class=\"block text-xs font-semibold text-indigo-200 mb-2\">ユーザー名</label>\n          <div class=\"relative\">\n            <div class=\"absolute inset-y-0 left-4 flex items-center pointer-events-none\">\n              <i data-lucide=\"user\" class=\"w-4 h-4 text-indigo-400\"></i>\n            </div>\n            <input\n              id=\"username\"\n              name=\"username\"\n              data-item-id=\"username\"\n              type=\"text\"\n              placeholder=\"ユーザー名またはメールアドレス\"\n              autocomplete=\"username\"\n              class=\"w-full pl-11 pr-4 py-3.5 bg-white/10 border border-white/20 rounded-2xl text-white placeholder-indigo-300/70 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-transparent transition-all duration-200 backdrop-blur-sm\"\n            />\n          </div>\n        </div>\n\n        <!-- Password -->\n        <div>\n          <label for=\"password\" class=\"block text-xs font-semibold text-indigo-200 mb-2\">パスワード</label>\n          <div class=\"relative\">\n            <div class=\"absolute inset-y-0 left-4 flex items-center pointer-events-none\">\n              <i data-lucide=\"lock\" class=\"w-4 h-4 text-indigo-400\"></i>\n            </div>\n            <input\n              id=\"password\"\n              name=\"password\"\n              data-item-id=\"password\"\n              type=\"password\"\n              placeholder=\"パスワードを入力\"\n              autocomplete=\"current-password\"\n              class=\"w-full pl-11 pr-12 py-3.5 bg-white/10 border border-white/20 rounded-2xl text-white placeholder-indigo-300/70 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-transparent transition-all duration-200 backdrop-blur-sm\"\n            />\n            <button class=\"absolute inset-y-0 right-4 flex items-center text-indigo-400 hover:text-indigo-200 transition-colors\">\n              <i data-lucide=\"eye\" class=\"w-4 h-4\"></i>\n            </button>\n          </div>\n        </div>\n\n        <!-- Remember Me -->\n        <div class=\"flex items-center gap-3\">\n          <input\n            id=\"rememberMe\"\n            name=\"rememberMe\"\n            data-item-id=\"rememberMe\"\n            type=\"checkbox\"\n            class=\"w-4 h-4 rounded border-white/30 bg-white/10 text-indigo-500 focus:ring-indigo-400 focus:ring-offset-0 cursor-pointer\"\n          />\n          <label for=\"rememberMe\" class=\"text-xs text-indigo-200 cursor-pointer select-none\">\n            ログイン状態を保持する\n          </label>\n        </div>\n\n        <!-- Login Button -->\n        <button\n          type=\"submit\"\n          class=\"w-full py-4 bg-gradient-to-r from-indigo-500 to-purple-600 text-white text-sm font-bold rounded-2xl shadow-[0_8px_30px_rgb(99,102,241,0.4)] hover:shadow-[0_12px_40px_rgb(99,102,241,0.5)] hover:scale-[1.02] active:scale-[0.98] transition-all duration-200 mt-2\"\n        >\n          <i data-lucide=\"log-in\" class=\"w-4 h-4 inline mr-2\"></i>\n          ログイン\n        </button>\n      </div>\n\n      <!-- Hint -->\n      <div class=\"mt-8 pt-6 border-t border-white/10\">\n        <div class=\"flex items-start gap-3 bg-white/5 border border-white/10 rounded-2xl px-4 py-3\">\n          <i data-lucide=\"info\" class=\"w-4 h-4 text-indigo-400 flex-shrink-0 mt-0.5\"></i>\n          <p class=\"text-xs text-indigo-300 leading-relaxed\">\n            アカウントをお持ちでない方は、管理者にアカウント作成を依頼してください。\n          </p>\n        </div>\n      </div>\n    </div>\n\n    <!-- Version -->\n    <p class=\"text-center text-xs text-indigo-600 mt-6\">My Diary v1.0.0</p>\n  </div>\n\n  <script>if (typeof lucide !== 'undefined') lucide.createIcons();</script>\n</div>\n"
