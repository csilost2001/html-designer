{
  "$schema": "../../../schemas/v3/extensions.v3.schema.json",
  "namespace": "realestate",
  "version": "1.0.0",
  "requiresCoreSchema": ">=3.0.0",
  "description": "不動産仲介 (realestate) namespace の v3 拡張定義。ボタン拡張 FieldType と API レスポンス型を提供する。",
  "fieldTypes": [
    {
      "kind": "button",
      "label": "ボタン",
      "baseType": "string",
      "description": "画面内のボタン要素を表す FieldType。events[] と組み合わせて使用する。"
    }
  ],
  "responseTypes": {
    "PropertySearchResponse": {
      "description": "物件検索 API のレスポンス body。rows 配列 + totalCount。",
      "schema": {
        "type": "object",
        "required": ["rows", "totalCount"],
        "properties": {
          "rows": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["propertyCode", "name", "propertyType"],
              "properties": {
                "id": { "type": "integer" },
                "propertyCode": { "type": "string" },
                "name": { "type": "string" },
                "propertyType": { "type": "string" },
                "areaSqm": { "type": "number" },
                "price10kYen": { "type": "integer" },
                "listedAt": { "type": "string", "format": "date" }
              }
            }
          },
          "totalCount": { "type": "integer" }
        }
      }
    },
    "ApiError": {
      "description": "汎用 API エラーレスポンス。",
      "schema": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" }
        }
      }
    }
  }
}
