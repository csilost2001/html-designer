{
  "$schema": "../../../schemas/v3/screen.v3.schema.json",
  "id": "b2f3a4c5-d6e7-4f80-9a1b-2c3d4e5f6a7b",
  "name": "物件検索",
  "description": "物件種別・上限価格・最小面積を条件に物件を検索する。検索ボタン押下で物件検索フロー (d4b5c6e7) を起動し、結果を viewer screen-item (propertyRows) に表示する (#762 direction=viewer デモ)。",
  "kind": "search",
  "path": "/properties/search",
  "auth": "required",
  "maturity": "committed",
  "createdAt": "2026-05-03T00:00:00.000Z",
  "updatedAt": "2026-05-03T00:00:00.000Z",
  "items": [
    {
      "id": "propertyType",
      "label": "物件種別",
      "type": "string",
      "direction": "input",
      "required": false,
      "options": [
        { "value": "apartment", "label": "マンション" },
        { "value": "house", "label": "一戸建て" },
        { "value": "land", "label": "土地" },
        { "value": "office", "label": "事務所" }
      ],
      "description": "検索条件: 物件種別。未指定時は全種別が対象。"
    },
    {
      "id": "maxPrice10kYen",
      "label": "上限価格 (万円)",
      "type": "integer",
      "direction": "input",
      "required": false,
      "min": 0,
      "placeholder": "例: 5000",
      "helperText": "万円単位で入力してください。",
      "description": "検索条件: 価格上限 (万円)。未指定時は上限なし。"
    },
    {
      "id": "minAreaSqm",
      "label": "最小面積 (m2)",
      "type": "number",
      "direction": "input",
      "required": false,
      "min": 0,
      "placeholder": "例: 50",
      "description": "検索条件: 最小面積 (平方メートル)。未指定時は下限なし。"
    },
    {
      "id": "searchButton",
      "label": "物件を検索",
      "type": { "kind": "extension", "extensionRef": "realestate:button" },
      "direction": "output",
      "readonly": true,
      "events": [
        {
          "id": "click",
          "label": "物件検索実行",
          "handlerFlowId": "d4b5c6e7-f809-4112-bc3d-4e5f6a7b8c9d",
          "argumentMapping": {
            "propertyType": "@screen.propertyType",
            "maxPrice10kYen": "@screen.maxPrice10kYen",
            "minAreaSqm": "@screen.minAreaSqm"
          }
        }
      ],
      "description": "物件検索ボタン。クリック時に物件検索フロー (d4b5c6e7) を起動する。"
    },
    {
      "id": "propertyRows",
      "label": "物件一覧",
      "type": { "kind": "array", "itemType": "json" },
      "direction": "viewer",
      "viewDefinitionId": "e5c6d7f8-0912-4223-cd4e-5f6a7b8c9d0e",
      "valueFrom": {
        "kind": "flowVariable",
        "processFlowId": "d4b5c6e7-f809-4112-bc3d-4e5f6a7b8c9d",
        "variableName": "rows"
      },
      "description": "物件検索結果の一覧表示。direction=viewer (#762): 物件一覧 ViewDefinition (e5c6d7f8) の列定義を使い、物件検索フロー (d4b5c6e7) の出力変数 'rows' を binding して表示する。"
    }
  ]
}
